<?xml version="1.0" encoding="windows-1251" ?>
<pda_private>
    <private_pda x="0" y="0" width="819" height="768">
        <state x="0" y="0" width="819" height="768"/>
        
        <!-- Main content area positioned to match PDA tabs -->
        <info x="60" y="90" width="700" height="640">
            <!-- Background for the entire info area -->
            <background x="0" y="0" width="700" height="640" stretch="1">
                <texture r="14" g="17" b="18" a="225">panda_private_panel</texture>
            </background>
            
            <!-- Border lines to frame the info area -->
            <auto_frameline x="0" y="0" width="700" height="1" vertical="0">
                <texture>ui_inGame2_pda_line_horizontal</texture>
            </auto_frameline>
            <auto_frameline x="0" y="639" width="700" height="1" vertical="0">
                <texture>ui_inGame2_pda_line_horizontal</texture>
            </auto_frameline>
            <auto_frameline x="0" y="0" width="1" height="640" vertical="1">
                <texture>ui_inGame2_pda_line_vertical</texture>
            </auto_frameline>
            <auto_frameline x="699" y="0" width="1" height="640" vertical="1">
                <texture>ui_inGame2_pda_line_vertical</texture>
            </auto_frameline>
            
            <!-- Vertical divider between left list and chat area -->
            <auto_frameline x="230" y="1" width="1" height="638" vertical="1">
                <texture>ui_inGame2_pda_line_vertical</texture>
            </auto_frameline>
            
            <!-- LEFT PANE: Contact list (210px wide) -->
            <list_bg x="5" y="5" width="220" height="630" stretch="1">
                <texture r="18" g="22" b="24" a="235">panda_private_rail</texture>
            </list_bg>
            
            <!-- Contact list header -->
            <list_header x="12" y="10" width="206" height="24">
                <text font="letterica18" r="184" g="204" b="196" a="255" align="l" vert_align="c">PRIVATE NET</text>
            </list_header>

            <player_presence_container x="10" y="40" width="210" height="42" stretch="1">
                <texture r="28" g="36" b="35" a="235">panda_private_contact</texture>
            </player_presence_container>

            <player_presence_portrait x="4" y="4" width="32" height="32" stretch="1">
                <texture>ui\ui_noise</texture>
            </player_presence_portrait>

            <player_presence_state_icon x="188" y="15" width="12" height="12" stretch="1">
                <texture>ui_panda_on_icon</texture>
            </player_presence_state_icon>

            <player_presence_label x="46" y="8" width="130" height="24">
                <text font="letterica16" r="220" g="230" b="220" a="255" align="l" vert_align="c">Actor uplink</text>
            </player_presence_label>

            <player_presence_toggle_btn x="0" y="0" width="210" height="40" can_focus="1" stretch="1">
                <texture_e a="0">ui_inGame2_hint_wnd_main_window</texture_e>
                <texture_h a="0">ui_inGame2_hint_wnd_main_window</texture_h>
                <texture_t a="0">ui_inGame2_hint_wnd_main_window</texture_t>
                <texture_d a="0">ui_inGame2_hint_wnd_main_window</texture_d>
            </player_presence_toggle_btn>

            <player_presence_menu_bg x="10" y="86" width="210" height="54" stretch="1">
                <texture r="18" g="26" b="28" a="240">panda_private_panel</texture>
            </player_presence_menu_bg>

            <player_presence_online_btn x="14" y="90" width="202" height="22" can_focus="1" stretch="1">
                <texture_e a="0">ui_inGame2_hint_wnd_main_window</texture_e>
                <texture_h a="0">ui_inGame2_hint_wnd_main_window</texture_h>
                <texture_t a="0">ui_inGame2_hint_wnd_main_window</texture_t>
                <texture_d a="0">ui_inGame2_hint_wnd_main_window</texture_d>
                <text font="letterica16" align="l" vert_align="c" x="8" y="0">Online</text>
            </player_presence_online_btn>

            <player_presence_offline_btn x="14" y="114" width="202" height="22" can_focus="1" stretch="1">
                <texture_e a="0">ui_inGame2_hint_wnd_main_window</texture_e>
                <texture_h a="0">ui_inGame2_hint_wnd_main_window</texture_h>
                <texture_t a="0">ui_inGame2_hint_wnd_main_window</texture_t>
                <texture_d a="0">ui_inGame2_hint_wnd_main_window</texture_d>
                <text font="letterica16" align="l" vert_align="c" x="8" y="0">Offline</text>
            </player_presence_offline_btn>
            
            <message_list x="10" y="146" width="210" height="482" item_height="60" can_select="1"/>
            
            <!-- RIGHT PANE: Chat area remapped to vanilla 407px pane -->
            <description x="230" y="0" width="470" height="640">
                <!-- Background for the chat area -->
                <background x="0" y="0" width="470" height="640" stretch="1">
                    <texture r="19" g="21" b="22" a="218">panda_private_thread</texture>
                </background>
                
                <!-- Empty state message -->
                <empty_state x="0" y="286" width="470" height="30">
                    <text font="letterica25" r="106" g="122" b="118" a="255" align="c" vert_align="c">NO THREAD SELECTED</text>
                </empty_state>

                <!-- EXPANDED HEADER with integrated stats (120px tall) -->
                <header_bg x="0" y="0" width="470" height="126" stretch="1">
                    <texture r="25" g="31" b="33" a="240">panda_private_header</texture>
                </header_bg>
                
                <!-- Separator line under header -->
                <auto_frameline x="0" y="126" width="470" height="1" vertical="0">
                    <texture>ui_inGame2_pda_line_horizontal</texture>
                </auto_frameline>

                <!-- NPC Portrait -->
                <image_container x="8" y="8" width="66" height="66">
                    <image x="0" y="0" width="64" height="64" stretch="1">
                        <texture>ui_inGame2_neutral_1</texture>
                    </image>
                </image_container>
                
                <!-- Status indicator dot -->
                <status_indicator x="31" y="84" width="18" height="18" stretch="1">
                    <texture>ui_panda_off_icon</texture>
                </status_indicator>

                <!-- NPC Name -->
                <chat_header_name x="82" y="9" width="210" height="25">
                    <text font="letterica25" r="238" g="202" b="94" a="255" align="l" vert_align="c"/>
                </chat_header_name>
                
                <!-- Faction patch icon -->
                <faction_patch_icon x="82" y="36" width="22" height="22" stretch="1">
                    <texture>ui_inGame2_neutral_1</texture>
                </faction_patch_icon>

                <!-- Faction badge -->
                <faction_badge x="108" y="36" width="155" height="18">
                    <text font="letterica16" r="200" g="200" b="200" a="255" align="l" vert_align="c"/>
                </faction_badge>
                
                <!-- Message count -->
                <message_count x="326" y="10" width="136" height="20">
                    <text font="letterica16" r="150" g="166" b="160" a="255" align="r" vert_align="c"/>
                </message_count>
                
                <!-- Last contact time -->
                <last_seen x="326" y="31" width="136" height="18">
                    <text font="letterica16" r="124" g="139" b="136" a="255" align="r" vert_align="c"/>
                </last_seen>
                
                <!-- Divider between header and stats -->
                <auto_frameline x="82" y="62" width="380" height="1" vertical="0">
                    <texture>ui_inGame2_pda_line_horizontal</texture>
                </auto_frameline>
                
                <!-- Left column - SUPER TIGHT spacing -->
                <stat_relation_label x="82" y="70" width="55" height="16">
                    <text font="letterica16" r="140" g="140" b="140" a="255" align="l" vert_align="c">Relation:</text>
                </stat_relation_label>
                <stat_relation_value x="150" y="70" width="112" height="16">
                    <text font="letterica16" r="255" g="255" b="255" a="255" align="l" vert_align="c"/>
                </stat_relation_value>
                
                <stat_goodwill_label x="82" y="88" width="55" height="16">
                    <text font="letterica16" r="140" g="140" b="140" a="255" align="l" vert_align="c">Goodwill:</text>
                </stat_goodwill_label>
                <stat_goodwill_value x="150" y="88" width="112" height="16">
                    <text font="letterica16" r="255" g="255" b="255" a="255" align="l" vert_align="c"/>
                </stat_goodwill_value>
                
                <stat_rank_label x="82" y="106" width="55" height="16">
                    <text font="letterica16" r="140" g="140" b="140" a="255" align="l" vert_align="c">Rank:</text>
                </stat_rank_label>
                <stat_rank_value x="150" y="106" width="112" height="16">
                    <text font="letterica16" r="255" g="255" b="255" a="255" align="l" vert_align="c"/>
                </stat_rank_value>

                <!-- Player dialogue stats panel -->
                <player_stats_panel x="274" y="64" width="188" height="60">
                    <panel_bg x="0" y="0" width="188" height="60" stretch="1">
                        <texture r="18" g="24" b="26" a="220">panda_private_panel</texture>
                    </panel_bg>
                    <player_name x="8" y="3" width="172" height="13">
                        <text font="letterica16" r="160" g="185" b="178" a="255" align="r" vert_align="c">Player</text>
                    </player_name>
                    <stat_charisma x="8" y="17" width="172" height="10">
                        <text font="letterica16" r="205" g="202" b="154" a="255" align="r" vert_align="c">Charisma: 0</text>
                    </stat_charisma>
                    <stat_luck x="8" y="28" width="172" height="10">
                        <text font="letterica16" r="205" g="202" b="154" a="255" align="r" vert_align="c">Luck: 0</text>
                    </stat_luck>
                    <stat_intimidation x="8" y="39" width="172" height="10">
                        <text font="letterica16" r="205" g="202" b="154" a="255" align="r" vert_align="c">Intimidation: 0</text>
                    </stat_intimidation>
                    <stat_perception x="8" y="50" width="172" height="10">
                        <text font="letterica16" r="205" g="202" b="154" a="255" align="r" vert_align="c">Perception: 0</text>
                    </stat_perception>
                </player_stats_panel>

                <!-- Scrollbar for messages -->
                <scrollbar x="0" y="136" width="470" height="456" right_ident="0" left_ident="0" top_indent="0" bottom_indent="0" vert_interval="10" always_show_scroll="1">
                    <texture>ui_inGame2_scroll_background</texture>
                </scrollbar>

                <!-- Bottom composer: quick actions + disabled input look + send/expand -->
                <composer_container x="0" y="596" width="468" height="44">
                    <composer_bg x="0" y="0" width="468" height="44" stretch="1">
                        <texture r="24" g="30" b="33" a="240">panda_private_composer</texture>
                    </composer_bg>

                    <!-- Backgrounds support dynamic tinting, Buttons handle pure text/interactions -->
                    <composer_quick_1_bg x="2" y="2" width="30" height="30" stretch="1">
                        <texture>ui_panda_box</texture>
                    </composer_quick_1_bg>
                    <composer_quick_1_btn x="2" y="2" width="30" height="30" can_focus="1" stretch="1">
                        <texture_e a="0">ui_panda_box</texture_e>
                        <texture_h a="0">ui_panda_box</texture_h>
                        <texture_t a="0">ui_panda_box</texture_t>
                        <texture_d a="0">ui_panda_box</texture_d>
                        <text font="letterica16" align="c" vert_align="c" x="0" y="0">+</text>
                        <text_color>
                            <e r="210" g="220" b="230" a="255"/>
                            <h r="255" g="50" b="50" a="255"/>
                            <t r="255" g="50" b="50" a="255"/>
                        </text_color>
                    </composer_quick_1_btn>

                    <composer_quick_2_bg x="36" y="2" width="30" height="30" stretch="1">
                        <texture>ui_panda_box</texture>
                    </composer_quick_2_bg>
                    <composer_quick_2_btn x="36" y="2" width="30" height="30" can_focus="1" stretch="1">
                        <texture_e a="0">ui_panda_box</texture_e>
                        <texture_h a="0">ui_panda_box</texture_h>
                        <texture_t a="0">ui_panda_box</texture_t>
                        <texture_d a="0">ui_panda_box</texture_d>
                        <text font="letterica16" align="c" vert_align="c" x="0" y="0">...</text>
                        <text_color>
                            <e r="210" g="220" b="230" a="255"/>
                            <h r="50" g="140" b="255" a="255"/>
                            <t r="50" g="140" b="255" a="255"/>
                        </text_color>
                    </composer_quick_2_btn>

                    <composer_input_shell x="70" y="7" width="356" height="30" stretch="1">
                        <texture r="14" g="18" b="20" a="235">panda_private_reply</texture>
                    </composer_input_shell>
                    <composer_input_field x="82" y="7" width="336" height="30">
                        <text font="letterica16" r="132" g="150" b="147" a="255" align="l" vert_align="c">Choose reply...</text>
                    </composer_input_field>

                    <composer_send_bg x="432" y="2" width="36" height="30" stretch="1">
                        <texture>ui_panda_box</texture>
                    </composer_send_bg>
                    <composer_send_btn x="432" y="2" width="36" height="30" can_focus="1" stretch="1">
                        <texture_e a="0">ui_panda_box</texture_e>
                        <texture_h a="0">ui_panda_box</texture_h>
                        <texture_t a="0">ui_panda_box</texture_t>
                        <texture_d a="0">ui_panda_box</texture_d>
                        <text font="letterica18" align="c" vert_align="c" x="0" y="0">&gt;</text>
                        <text_color>
                            <e r="210" g="220" b="230" a="255"/>
                            <h r="50" g="140" b="255" a="255"/>
                            <t r="50" g="140" b="255" a="255"/>
                        </text_color>
                    </composer_send_btn>
                </composer_container>
                
                <message_lane_npc x="0" y="0" width="470" height="50" stretch="1">
                    <notification_icon x="12" y="14" width="18" height="18" stretch="1">
                        <texture>ui\ui_noise</texture>
                    </notification_icon>
                    <bubble_bg x="12" y="0" width="340" height="50" stretch="1">
                        <texture r="42" g="47" b="48" a="215">panda_private_bubble_npc</texture>
                    </bubble_bg>
                    <text_box x="24" y="6" width="316" height="20" complex_mode="1">
                         <text font="letterica16" r="220" g="220" b="220" a="255"/>
                    </text_box>
                </message_lane_npc>

                <message_lane_player x="0" y="0" width="470" height="50" stretch="1">
                    <bubble_bg x="170" y="0" width="288" height="50" stretch="1">
                        <texture r="38" g="62" b="50" a="210">panda_private_bubble_actor</texture>
                    </bubble_bg>
                    <text_box x="182" y="6" width="264" height="20" complex_mode="1">
                         <text font="letterica16" r="200" g="255" b="200" a="255"/>
                    </text_box>
                    <delivery_status x="182" y="28" width="264" height="16" complex_mode="1">
                         <text font="letterica16" align="r" vert_align="c" r="170" g="170" b="170" a="255"/>
                    </delivery_status>
                </message_lane_player>
                
                <!-- Background supports dynamic tinting, Button handles pure text/interactions -->
                <choice_chip_bg x="0" y="0" width="220" height="26" stretch="1">
                    <texture>panda_private_reply</texture>
                </choice_chip_bg>
                <choice_chip_btn x="0" y="0" width="220" height="26" can_focus="1" stretch="1">
                    <texture a="0">ui_panda_box</texture>
                    <texture_e a="0">ui_panda_box</texture_e>
                    <texture_h a="0">ui_panda_box</texture_h>
                    <texture_t a="0">ui_panda_box</texture_t>
                    <texture_d a="0">ui_panda_box</texture_d>
                    <text_color>
                        <e r="225" g="232" b="238" a="255"/>
                        <h r="50" g="140" b="255" a="255"/>
                        <t r="50" g="140" b="255" a="255"/>
                    </text_color>
                </choice_chip_btn>
                <choice_chip_label x="0" y="0" width="220" height="26" complex_mode="1">
                    <text font="letterica16" align="l" vert_align="c" x="10" y="0" r="255" g="220" b="80" a="255" />
                </choice_chip_label>
                <block_chip_btn x="0" y="0" width="220" height="26" can_focus="1" stretch="1">
                    <texture a="0">ui_panda_box</texture>
                    <texture_e a="0">ui_panda_box</texture_e>
                    <texture_h a="0">ui_panda_box</texture_h>
                    <texture_t a="0">ui_panda_box</texture_t>
                    <texture_d a="0">ui_panda_box</texture_d>
                    <text font="letterica16" align="l" vert_align="c" x="10" y="0" complex_mode="1" />
                    <text_color>
                        <e r="225" g="232" b="238" a="255"/>
                        <h r="255" g="50" b="50" a="255"/>
                        <t r="255" g="50" b="50" a="255"/>
                    </text_color>
                </block_chip_btn>
                <ignore_chip_btn x="0" y="0" width="220" height="26" can_focus="1" stretch="1">
                    <texture a="0">ui_panda_box</texture>
                    <texture_e a="0">ui_panda_box</texture_e>
                    <texture_h a="0">ui_panda_box</texture_h>
                    <texture_t a="0">ui_panda_box</texture_t>
                    <texture_d a="0">ui_panda_box</texture_d>
                    <text font="letterica16" align="l" vert_align="c" x="10" y="0" complex_mode="1" />
                    <text_color>
                        <e r="225" g="232" b="238" a="255"/>
                        <h r="255" g="140" b="0" a="255"/>
                        <t r="255" g="140" b="0" a="255"/>
                    </text_color>
                </ignore_chip_btn>
            </description>
        </info>
    </private_pda>
</pda_private>
