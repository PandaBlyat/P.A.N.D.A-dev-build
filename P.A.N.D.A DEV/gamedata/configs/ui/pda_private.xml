<?xml version="1.0" encoding="windows-1251" ?>
<pda_private>
    <private_pda x="0" y="0" width="1024" height="768">
        <state x="0" y="0" width="1024" height="768"/>
        
        <!-- Main content area positioned to match PDA tabs -->
        <info x="15" y="90" width="970" height="618">
            <!-- Background for the entire info area -->
            <background x="0" y="0" width="970" height="618" stretch="1">
                <texture r="20" g="20" b="20" a="200">ui_inGame2_hint_wnd_main_window</texture>
            </background>
            
            <!-- Border lines to frame the info area -->
            <auto_frameline x="0" y="0" width="970" height="1" vertical="0">
                <texture>ui_inGame2_pda_line_horizontal</texture>
            </auto_frameline>
            <auto_frameline x="0" y="618" width="970" height="1" vertical="0">
                <texture>ui_inGame2_pda_line_horizontal</texture>
            </auto_frameline>
            <auto_frameline x="0" y="0" width="1" height="618" vertical="1">
                <texture>ui_inGame2_pda_line_vertical</texture>
            </auto_frameline>
            <auto_frameline x="970" y="0" width="1" height="618" vertical="1">
                <texture>ui_inGame2_pda_line_vertical</texture>
            </auto_frameline>
            
            <!-- Vertical divider between left list and chat area -->
            <auto_frameline x="240" y="5" width="1" height="608" vertical="1">
                <texture>ui_inGame2_pda_line_vertical</texture>
            </auto_frameline>
            
            <!-- LEFT PANE: Contact list (240px wide) -->
            <list_bg x="5" y="5" width="230" height="608" stretch="1">
                <texture r="25" g="25" b="25" a="220">ui_inGame2_hint_wnd_main_window</texture>
            </list_bg>
            
            <!-- Contact list header -->
            <list_header x="10" y="10" width="220" height="25">
                <text font="letterica18" r="200" g="200" b="200" a="255" align="l" vert_align="c">CONTACTS</text>
            </list_header>

            <player_presence_container x="10" y="38" width="220" height="40" stretch="1">
                <texture r="36" g="36" b="36" a="220">ui_inGame2_hint_wnd_main_window</texture>
            </player_presence_container>

            <player_presence_portrait x="4" y="4" width="32" height="32" stretch="1">
                <texture>ui_inGame2_neutral_1</texture>
            </player_presence_portrait>

            <player_presence_state_icon x="38" y="24" width="12" height="12" stretch="1">
                <texture>ui_panda_on_icon</texture>
            </player_presence_state_icon>

            <player_presence_label x="46" y="7" width="150" height="24">
                <text font="letterica16" r="215" g="225" b="235" a="255" align="l" vert_align="c">Player</text>
            </player_presence_label>

            <player_presence_toggle_btn x="0" y="0" width="220" height="40" can_focus="1" stretch="1">
                <texture_e a="0">ui_inGame2_hint_wnd_main_window</texture_e>
                <texture_h a="0">ui_inGame2_hint_wnd_main_window</texture_h>
                <texture_t a="0">ui_inGame2_hint_wnd_main_window</texture_t>
                <texture_d a="0">ui_inGame2_hint_wnd_main_window</texture_d>
            </player_presence_toggle_btn>

            <player_presence_menu_bg x="10" y="80" width="220" height="54" stretch="1">
                <texture r="24" g="24" b="24" a="235">ui_inGame2_hint_wnd_main_window</texture>
            </player_presence_menu_bg>

            <player_presence_online_btn x="14" y="84" width="212" height="22" can_focus="1" stretch="1">
                <texture_e a="0">ui_inGame2_hint_wnd_main_window</texture_e>
                <texture_h a="0">ui_inGame2_hint_wnd_main_window</texture_h>
                <texture_t a="0">ui_inGame2_hint_wnd_main_window</texture_t>
                <texture_d a="0">ui_inGame2_hint_wnd_main_window</texture_d>
                <text font="letterica16" align="l" vert_align="c" x="8" y="0">Online</text>
            </player_presence_online_btn>

            <player_presence_offline_btn x="14" y="108" width="212" height="22" can_focus="1" stretch="1">
                <texture_e a="0">ui_inGame2_hint_wnd_main_window</texture_e>
                <texture_h a="0">ui_inGame2_hint_wnd_main_window</texture_h>
                <texture_t a="0">ui_inGame2_hint_wnd_main_window</texture_t>
                <texture_d a="0">ui_inGame2_hint_wnd_main_window</texture_d>
                <text font="letterica16" align="l" vert_align="c" x="8" y="0">Offline</text>
            </player_presence_offline_btn>
            
            <message_list x="10" y="138" width="220" height="462" item_height="55" can_select="1"/>
            
            <!-- RIGHT PANE: Chat area (720px wide - full remaining space) -->
            <description x="245" y="5" width="720" height="608">
                <!-- Background for the chat area -->
                <background x="0" y="0" width="720" height="608" stretch="1">
                    <texture r="30" g="30" b="30" a="200">ui_inGame2_hint_wnd_main_window</texture>
                </background>
                
                <!-- Empty state message -->
                <empty_state x="0" y="270" width="720" height="30">
                    <text font="letterica25" r="100" g="100" b="100" a="255" align="c" vert_align="c">SELECT A CONTACT</text>
                </empty_state>

                <!-- EXPANDED HEADER with integrated stats (120px tall) -->
                <header_bg x="0" y="0" width="460" height="120" stretch="1">
                    <texture r="40" g="40" b="40" a="220">ui_inGame2_hint_wnd_main_window</texture>
                </header_bg>
                
                <!-- Separator line under header -->
                <auto_frameline x="0" y="120" width="720" height="1" vertical="0">
                    <texture>ui_inGame2_pda_line_horizontal</texture>
                </auto_frameline>

                <!-- NPC Portrait -->
                <image_container x="5" y="3" width="64" height="64">
                    <image x="0" y="0" width="64" height="64" stretch="1">
                        <texture>ui_inGame2_neutral_1</texture>
                    </image>
                </image_container>
                
                <!-- Status indicator dot -->
                <status_indicator x="30" y="95" width="20" height="20" stretch="1">
                    <texture>ui_panda_off_icon</texture>
                </status_indicator>

                <!-- NPC Name -->
                <chat_header_name x="75" y="8" width="400" height="25">
                    <text font="letterica25" r="255" g="200" b="50" a="255" align="l" vert_align="c"/>
                </chat_header_name>
                
                <!-- Faction patch icon -->
                <faction_patch_icon x="75" y="30" width="22" height="22" stretch="1">
                    <texture>ui_inGame2_neutral_1</texture>
                </faction_patch_icon>

                <!-- Faction badge -->
                <faction_badge x="100" y="32" width="275" height="18">
                    <text font="letterica16" r="200" g="200" b="200" a="255" align="l" vert_align="c"/>
                </faction_badge>
                
                <!-- Message count -->
                <message_count x="480" y="8" width="230" height="20">
                    <text font="letterica16" r="150" g="150" b="150" a="255" align="r" vert_align="c"/>
                </message_count>
                
                <!-- Last contact time -->
                <last_seen x="480" y="28" width="230" height="18">
                    <text font="letterica16" r="130" g="130" b="130" a="255" align="r" vert_align="c"/>
                </last_seen>
                
                <!-- Divider between header and stats -->
                <auto_frameline x="75" y="55" width="635" height="1" vertical="0">
                    <texture>ui_inGame2_pda_line_horizontal</texture>
                </auto_frameline>
                
                <!-- Left column - SUPER TIGHT spacing -->
                <stat_relation_label x="75" y="63" width="55" height="16">
                    <text font="letterica16" r="140" g="140" b="140" a="255" align="l" vert_align="c">Relation:</text>
                </stat_relation_label>
                <stat_relation_value x="110" y="63" width="100" height="16">
                    <text font="letterica16" r="255" g="255" b="255" a="255" align="l" vert_align="c"/>
                </stat_relation_value>
                
                <stat_goodwill_label x="75" y="82" width="55" height="16">
                    <text font="letterica16" r="140" g="140" b="140" a="255" align="l" vert_align="c">Goodwill:</text>
                </stat_goodwill_label>
                <stat_goodwill_value x="110" y="82" width="100" height="16">
                    <text font="letterica16" r="255" g="255" b="255" a="255" align="l" vert_align="c"/>
                </stat_goodwill_value>
                
                <stat_rank_label x="75" y="101" width="55" height="16">
                    <text font="letterica16" r="140" g="140" b="140" a="255" align="l" vert_align="c">Rank:</text>
                </stat_rank_label>
                <stat_rank_value x="110" y="101" width="100" height="16">
                    <text font="letterica16" r="255" g="255" b="255" a="255" align="l" vert_align="c"/>
                </stat_rank_value>
                
                <!-- Scrollbar for messages -->
                <scrollbar x="0" y="130" width="720" height="432" right_ident="0" left_ident="0" top_indent="0" bottom_indent="0" vert_interval="10" always_show_scroll="1">
                    <texture>ui_inGame2_scroll_background</texture>
                </scrollbar>

                <!-- Bottom composer: quick actions + disabled input look + send/expand -->
                <composer_container x="0" y="564" width="720" height="34">
                    <composer_bg x="0" y="0" width="720" height="34" stretch="1">
                        <texture r="32" g="36" b="40" a="220">ui_inGame2_hint_wnd_main_window</texture>
                    </composer_bg>

                    <!-- Backgrounds support dynamic tinting, Buttons handle pure text/interactions -->
                    <composer_quick_1_bg x="2" y="2" width="30" height="30" stretch="1">
                        <texture>ui_panda_box</texture>
                    </composer_quick_1_bg>
                    <composer_quick_1_btn x="2" y="2" width="30" height="30" can_focus="1" stretch="1">
                        <texture_e a="0">ui_panda_box</texture_e>
                        <texture_h a="0">ui_panda_box</texture_h>
                        <texture_t a="0">ui_panda_box</texture_t>
                        <texture_d a="0">ui_panda_box</texture_d>
                        <text font="letterica16" align="c" vert_align="c" x="0" y="0">+</text>
                        <text_color>
                            <e r="210" g="220" b="230" a="255"/>
                            <h r="255" g="50" b="50" a="255"/>
                            <t r="255" g="50" b="50" a="255"/>
                        </text_color>
                    </composer_quick_1_btn>

                    <composer_quick_2_bg x="36" y="2" width="30" height="30" stretch="1">
                        <texture>ui_panda_box</texture>
                    </composer_quick_2_bg>
                    <composer_quick_2_btn x="36" y="2" width="30" height="30" can_focus="1" stretch="1">
                        <texture_e a="0">ui_panda_box</texture_e>
                        <texture_h a="0">ui_panda_box</texture_h>
                        <texture_t a="0">ui_panda_box</texture_t>
                        <texture_d a="0">ui_panda_box</texture_d>
                        <text font="letterica16" align="c" vert_align="c" x="0" y="0">...</text>
                        <text_color>
                            <e r="210" g="220" b="230" a="255"/>
                            <h r="50" g="140" b="255" a="255"/>
                            <t r="50" g="140" b="255" a="255"/>
                        </text_color>
                    </composer_quick_2_btn>

                    <composer_input_shell x="70" y="4" width="586" height="26" stretch="1">
                        <texture r="20" g="22" b="25" a="230">ui_inGame2_hint_wnd_main_window</texture>
                    </composer_input_shell>
                    <composer_input_field x="82" y="4" width="566" height="26">
                        <text font="letterica16" r="120" g="132" b="145" a="255" align="l" vert_align="c">Choose a reply...</text>
                    </composer_input_field>

                    <composer_send_bg x="662" y="2" width="36" height="30" stretch="1">
                        <texture>ui_panda_box</texture>
                    </composer_send_bg>
                    <composer_send_btn x="662" y="2" width="36" height="30" can_focus="1" stretch="1">
                        <texture_e a="0">ui_panda_box</texture_e>
                        <texture_h a="0">ui_panda_box</texture_h>
                        <texture_t a="0">ui_panda_box</texture_t>
                        <texture_d a="0">ui_panda_box</texture_d>
                        <text font="letterica18" align="c" vert_align="c" x="0" y="0">&gt;</text>
                        <text_color>
                            <e r="210" g="220" b="230" a="255"/>
                            <h r="50" g="140" b="255" a="255"/>
                            <t r="50" g="140" b="255" a="255"/>
                        </text_color>
                    </composer_send_btn>
                </composer_container>
                
                <message_lane_npc x="0" y="0" width="720" height="50" stretch="1">
                    <bubble_bg x="16" y="0" width="520" height="50" stretch="1">
                        <texture r="52" g="52" b="52" a="190">ui_inGame2_hint_wnd_main_window</texture>
                    </bubble_bg>
                    <text_box x="30" y="6" width="496" height="20" complex_mode="1">
                         <text font="letterica16" r="220" g="220" b="220" a="255"/>
                    </text_box>
                </message_lane_npc>

                <message_lane_player x="0" y="0" width="720" height="50" stretch="1">
                    <bubble_bg x="250" y="0" width="460" height="50" stretch="1">
                        <texture r="45" g="70" b="45" a="180">ui_inGame2_hint_wnd_main_window</texture>
                    </bubble_bg>
                    <text_box x="262" y="6" width="436" height="20" complex_mode="1">
                         <text font="letterica16" r="200" g="255" b="200" a="255"/>
                    </text_box>
                    <delivery_status x="262" y="28" width="436" height="16" complex_mode="1">
                         <text font="letterica16" align="r" vert_align="c" r="170" g="170" b="170" a="255"/>
                    </delivery_status>
                </message_lane_player>
                
                <!-- Background supports dynamic tinting, Button handles pure text/interactions -->
                <choice_chip_bg x="0" y="0" width="220" height="26" stretch="1">
                    <texture>ui_inGame2_hint_wnd_main_window</texture>
                </choice_chip_bg>
                <choice_chip_btn x="0" y="0" width="220" height="26" can_focus="1" stretch="1">
                    <texture a="0">ui_panda_box</texture>
                    <texture_e a="0">ui_panda_box</texture_e>
                    <texture_h a="0">ui_panda_box</texture_h>
                    <texture_t a="0">ui_panda_box</texture_t>
                    <texture_d a="0">ui_panda_box</texture_d>
                    <text font="letterica16" align="l" vert_align="c" x="10" y="0" complex_mode="1" />
                    <text_color>
                        <e r="225" g="232" b="238" a="255"/>
                        <h r="50" g="140" b="255" a="255"/>
                        <t r="50" g="140" b="255" a="255"/>
                    </text_color>
                </choice_chip_btn>
                <block_chip_btn x="0" y="0" width="220" height="26" can_focus="1" stretch="1">
                    <texture a="0">ui_panda_box</texture>
                    <texture_e a="0">ui_panda_box</texture_e>
                    <texture_h a="0">ui_panda_box</texture_h>
                    <texture_t a="0">ui_panda_box</texture_t>
                    <texture_d a="0">ui_panda_box</texture_d>
                    <text font="letterica16" align="l" vert_align="c" x="10" y="0" complex_mode="1" />
                    <text_color>
                        <e r="225" g="232" b="238" a="255"/>
                        <h r="255" g="50" b="50" a="255"/>
                        <t r="255" g="50" b="50" a="255"/>
                    </text_color>
                </block_chip_btn>
                <ignore_chip_btn x="0" y="0" width="220" height="26" can_focus="1" stretch="1">
                    <texture a="0">ui_panda_box</texture>
                    <texture_e a="0">ui_panda_box</texture_e>
                    <texture_h a="0">ui_panda_box</texture_h>
                    <texture_t a="0">ui_panda_box</texture_t>
                    <texture_d a="0">ui_panda_box</texture_d>
                    <text font="letterica16" align="l" vert_align="c" x="10" y="0" complex_mode="1" />
                    <text_color>
                        <e r="225" g="232" b="238" a="255"/>
                        <h r="255" g="140" b="0" a="255"/>
                        <t r="255" g="140" b="0" a="255"/>
                    </text_color>
                </ignore_chip_btn>
            </description>
        </info>
    </private_pda>
</pda_private>
