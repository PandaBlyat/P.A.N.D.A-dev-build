	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_mutant_spawn_max_desc">
		<text>Maximum distance from the player where mutant squads will be spawned.</text>
	</string>

	<string id="ui_mcm_pda_interactive_conv_interactive_smart_spawn_min">
		<text>Smart terrain search (min distance, meters)</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_smart_spawn_min_desc">
		<text>When spawning mutants via smart terrain, only consider smarts at least this far from the player.</text>
	</string>

	<string id="ui_mcm_pda_interactive_conv_interactive_smart_spawn_max">
