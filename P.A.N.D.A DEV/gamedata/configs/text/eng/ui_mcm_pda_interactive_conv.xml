	<string id="ui_mcm_pda_interactive_conv_background_npc_conv_strict_cooldown_desc">
		<text>If enabled, topics on cooldown are completely blocked. If disabled, they have reduced weight.</text>
	</string>
	<string id="background_strict_cooldown_hint">
