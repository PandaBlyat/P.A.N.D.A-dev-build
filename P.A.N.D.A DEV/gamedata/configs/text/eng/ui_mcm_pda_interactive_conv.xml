	<!-- Cooldown Behaviour -->
	<string id="ui_mcm_pda_interactive_conv_interactive_cooldown_mode">
		<text>Cooldown Mode</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_cooldown_mode_desc">
		<text>Strict: Conversations on cooldown are completely blocked (original behavior). Flexible: Conversations on cooldown can still be picked, but at reduced probability. Prevents conversations from stopping entirely when the pool is small.</text>
	</string>
	<string id="interactive_cooldown_mode_hint">
		<text>Strict: Conversations on cooldown are completely blocked. Flexible: Conversations on cooldown can still be picked, but at reduced probability.</text>
	</string>
	<string id="pda_interactive_conv_cooldown_mode_lst_strict">
		<text>Strict (hard block)</text>
	</string>
	<string id="pda_interactive_conv_cooldown_mode_lst_flexible">
		<text>Flexible (reduced chance)</text>
	</string>

	<string id="ui_mcm_pda_interactive_conv_interactive_cooldown_penalty">
		<text>Cooldown Weight Penalty (%)</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_cooldown_penalty_desc">
		<text>In Flexible mode, conversations on cooldown keep this percentage of their normal selection weight. 25% means a cooldown conversation is 4x less likely to be picked than a fresh one. Only applies in Flexible cooldown mode.</text>
	</string>
	<string id="interactive_cooldown_penalty_hint">
		<text>In Flexible mode, conversations on cooldown keep this percentage of their normal selection weight. Only applies in Flexible cooldown mode.</text>
	</string>

	<string id="ui_mcm_pda_interactive_conv_interactive_cooldown_hard_min">
		<text>Hard Minimum Cooldown (minutes)</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_cooldown_hard_min_desc">
		<text>In Flexible mode, conversations within this many minutes of being played are still completely blocked. Prevents the same conversation from repeating back-to-back. Set to 0 to allow any repeat. Only applies in Flexible cooldown mode.</text>
	</string>
	<string id="interactive_cooldown_hard_min_hint">
		<text>In Flexible mode, conversations within this many minutes are still completely blocked. Only applies in Flexible cooldown mode.</text>
	</string>

	<string id="ui_mcm_pda_interactive_conv_interactive_allow_cross_faction">
		<text>Allow Cross-Faction Fallback</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_allow_cross_faction_desc">
		<text>When enabled, if no conversations are available for your faction, the system will try the Loner (general) conversation pool as a fallback. Useful for factions with few or no dedicated conversations.</text>
	</string>

	<!-- Gameplay -->
	<string id="ui_mcm_pda_interactive_conv_interactive_spawn_chance_mult">
		<text>Spawn Chance Multiplier (%)</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_spawn_chance_mult_desc">
		<text>Scales all spawn probability outcomes. 100 = normal, 200 = double chance, 0 = no spawns from conversations.</text>
	</string>
	<string id="interactive_spawn_chance_mult_hint">
		<text>Scales all spawn probability outcomes. 100 = normal, 200 = double chance, 0 = no spawns from conversations.</text>
	</string>

	<string id="ui_mcm_pda_interactive_conv_interactive_require_pda_equipped">
		<text>Require PDA Equipped</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_require_pda_equipped_desc">
		<text>When enabled, you must have a PDA equipped (slot 8) to respond to conversation choices.</text>
	</string>

	<string id="ui_mcm_pda_interactive_conv_interactive_companion_limit">
		<text>PDA Companion Limit</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_companion_limit_desc">
		<text>Maximum companion squad size allowed when spawning companions from PDA conversations. Overrides the base game limit if higher.</text>
	</string>

	<string id="ui_mcm_pda_interactive_conv_interactive_max_npcs_per_trigger">
		<text>Max NPCs per trigger</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_max_npcs_per_trigger_desc">
		<text>Maximum number of eligible NPCs to check each time a conversation trigger occurs. Higher values increase chance but may impact performance.</text>
	</string>

	<string id="ui_mcm_pda_interactive_conv_interactive_npc_cooldown">
		<text>NPC Cooldown (minutes)</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_npc_cooldown_desc">
		<text>Minimum in-game minutes before the same NPC can be used again for a PDA conversation. Helps avoid repetition.</text>
	</string>
	
		<string id="interactive_choice_tip_duration_hint">
