	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_smart_spawn_max_desc">
		<text>When spawning mutants via smart terrain, only consider smarts at most this far from the player.</text>
	</string>

	<!-- Technical -->
	<string id="ui_mcm_pda_interactive_conv_interactive_poll_retries">
