	<string id="ui_mcm_pda_interactive_conv_interactive_show_hunt_notifications_desc">
		<text>Enable or disable warning and arrival messages for hostile/mutant hunting squads spawned via PDA conversations.</text>
	</string>

	<string id="ui_mcm_pda_interactive_conv_interactive_show_companion_notifications">
		<text>Show Companion Notifications</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_show_companion_notifications_desc">
		<text>Enable or disable messages about companions arriving via PDA calls.</text>
	</string>

	<string id="ui_mcm_pda_interactive_conv_interactive_show_courier_notifications">
		<text>Show Courier Notifications</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_show_courier_notifications_desc">
		<text>Enable or disable all courier-related messages (warning, arrival, delivery, timeout).</text>
	</string>

	<!-- Conversation Types -->
	<string id="ui_mcm_pda_interactive_conv_interactive_non_task_chance">
		<text>Non-Task Chance (%)</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_non_task_chance_desc">
		<text>Percentage chance that a conversation will be non-task (friendly or hostile) instead of task-based. 0 = only task conversations, 100 = never task conversations.</text>
	</string>

	<string id="ui_mcm_pda_interactive_conv_interactive_friendly_hostile_ratio">
		<text>Friendly / Hostile Ratio (%)</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_friendly_hostile_ratio_desc">
		<text>When a non-task conversation occurs, this is the chance it will be friendly (vs hostile). 0 = all non-task are hostile, 100 = all non-task are friendly.</text>
	</string>

	<string id="ui_mcm_pda_interactive_conv_interactive_min_distance_for_call">
		<text>Min Distance for Non-Task Calls (m)</text>
	</string>
	<string id="ui_mcm_pda_interactive_conv_interactive_min_distance_for_call_desc">
		<text>Minimum distance an NPC must be from the player to initiate a non-task call. Simulates long-range PDA communication.</text>
	</string>

	<!-- Spawn Distances -->
	<string id="ui_mcm_pda_interactive_conv_interactive_spawn_distance_min">
