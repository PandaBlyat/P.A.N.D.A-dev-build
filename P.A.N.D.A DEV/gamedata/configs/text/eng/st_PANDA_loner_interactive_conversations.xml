    <!-- PANDA NPC CREATOR — TEMPLATE EXAMPLES                        -->
    <!-- Usage: spawn_custom_npc:<template_id>  or                    -->
    <!--        spawn_custom_npc_at:<template_id>:<smart_ref>         -->
    <!-- Format: pipe-separated key=value pairs                       -->
    <!--   name        = display name shown on NPC                    -->
    <!--   faction     = stalker|loner|freedom|duty|bandit|military   -->
    <!--                 ecolog|merc|monolith|renegade                 -->
    <!--   rank        = novice|stalker|veteran|master|legend         -->
    <!--   primary     = section[:attachment[:ammo_idx]]              -->
    <!--                 attachment: 0=none r=random                  -->
    <!--                 ammo_idx:   0=first r=random 1+=specific     -->
    <!--   secondary   = same format as primary                       -->
    <!--   outfit      = item section name                            -->
    <!--   items       = section:count,section:count,...              -->
    <!--   trade       = section:count,section:count,...  (for sale)  -->
    <!--   relation    = friendly|hostile|neutral|companion|default   -->
    <!--   spawn_dist  = distance from player to spawn (default 30)   -->
    <!--   count       = number of NPCs in squad (default 1)          -->
    <!-- ============================================================ -->

