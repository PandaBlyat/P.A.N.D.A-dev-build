    <string id="st_pda_ic_loner_1_precond">
        <text>req_npc_friendly:stalker</text>
    </string>
    <string id="st_pda_ic_loner_1_open">
        <text>yo we need to talk in person ASAP.</text>
    </string>
    <string id="st_pda_ic_loner_1_choice_1">
        <text>everything okay?</text>
    </string>
    <string id="st_pda_ic_loner_1_reply_1">
        <text>Dont want to talk over PDA, come over.</text>
    </string>
    <string id="st_pda_ic_loner_1_outcome_1">
        <text>none</text>
    </string>
    <string id="st_pda_ic_loner_1_cont_1">
        <text>2</text>
    </string>
    <string id="st_pda_ic_loner_1_cont_channel_1">
        <text>f2f</text>
    </string>
    <string id="st_pda_ic_loner_1_choice_2">
        <text>Nah im good</text>
    </string>
    <string id="st_pda_ic_loner_1_reply_2">
        <text>Your loss.</text>
    </string>
    <string id="st_pda_ic_loner_1_outcome_2">
        <text>none</text>
    </string>
    <string id="st_pda_ic_loner_1_t2_open">
        <text>About time!</text>
    </string>
    <string id="st_pda_ic_loner_1_t2_choice_1">
        <text>I was as quick as i could , so why did u call me over?</text>
    </string>
    <string id="st_pda_ic_loner_1_t2_reply_1">
        <text>There's been some weird activity up in garbage and i want to go check it out but not alone and you seem like you need some work.</text>
    </string>
    <string id="st_pda_ic_loner_1_t2_outcome_1">
        <text>none</text>
    </string>
    <string id="st_pda_ic_loner_1_t2_cont_1">
        <text>3</text>
    </string>
    <string id="st_pda_ic_loner_1_t2_cont_channel_1">
        <text>f2f</text>
    </string>
    <string id="st_pda_ic_loner_1_t2_choice_2">
        <text>Ehh you sound kinda dickish, imma go</text>
    </string>
    <string id="st_pda_ic_loner_1_t2_reply_2">
        <text>Fair enough.</text>
    </string>
    <string id="st_pda_ic_loner_1_t2_outcome_2">
        <text>none</text>
    </string>
    <string id="st_pda_ic_loner_1_t3_choice_1">
        <text>Yea sounds good im up for it!</text>
    </string>
    <string id="st_pda_ic_loner_1_t3_reply_1">
        <text>Alright  let's team up </text>
    </string>
    <string id="st_pda_ic_loner_1_t3_outcome_1">
        <text>none</text>
    </string>
    <string id="st_pda_ic_loner_1_t3_choice_2">
        <text>Actually, sounds like too much hassle, im good. </text>
    </string>
    <string id="st_pda_ic_loner_1_t3_reply_2">
        <text>Seriously? okay. Cya.</text>
    </string>
    <string id="st_pda_ic_loner_1_t3_outcome_2">
        <text>none</text>
    </string>
