handlers["spawn_mutant"] = function(parts, cmd_str, cmd)
    -- spawn_mutant:<mutant>:<distance>:<delay>[:<count>]
    local distance = tonumber(parts[3])
    local delay = tonumber(parts[4]) or 90
    local count = math.max(1, tonumber(parts[5]) or 1)
    for _ = 1, count do
        spawn_hunting_squad(parts[2] or "random", distance, true, delay)
    end
end

handlers["spawn_npc_squad"] = function(parts, cmd_str, cmd)
    -- spawn_npc_squad:<squad>:<distance>:<delay>[:<count>][:<state>]
    local squad_section = parts[2]
    local distance = tonumber(parts[3])
    local delay = tonumber(parts[4]) or 0
    local count = math.max(1, tonumber(parts[5]) or 1)
    local state = parts[6]
    if state == nil or state == "" then state = "default" end
    if not squad_section or squad_section == "" then
        printf("PANDA_IC: spawn_npc_squad missing squad section in '%s'", tostring(cmd_str))
    else
        for _ = 1, count do
            spawn_npc_squad_near_player(squad_section, distance, delay, state, sender_contact_id)
        end
    end
end

