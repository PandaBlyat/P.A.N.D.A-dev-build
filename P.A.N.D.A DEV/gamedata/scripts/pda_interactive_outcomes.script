                push_task_start_message("st_pda_ic_task_dead_drop_start")
            end
        end
    end

            -- Dead Drop (specific stash box): player must physically put the item inside the named stash box.
            -- The item is deleted from the box immediately and the success branch fires.
            -- Syntax: panda_task_dead_drop_stash:<stash_name>:<item_section>:<timeout>:<success_turn>:<fail_turn>
end

handlers["panda_task_dead_drop_stash"] = function(parts, cmd_str, cmd)
    local stash_name = parts[2]
    local item_sec = parts[3]
    local timeout = tonumber(parts[4]) or 600
    local s_turn = tonumber(parts[5])
    local f_turn = tonumber(parts[6])
    if not stash_name or not item_sec or not s_turn then
        printf("PANDA_IC: panda_task_dead_drop_stash missing params in '%s'", tostring(cmd_str))
    else
        local stash_box_id = find_stash_id_by_name(stash_name)
        local bridge = ensure_panda_task_bridge()
        if not stash_box_id then
            printf("PANDA_IC: panda_task_dead_drop_stash stash '%s' not found in caches", tostring(stash_name))
        elseif not bridge then
            printf("PANDA_IC: panda_task_dead_drop_stash ignored (bridge unavailable)")
        else
            local label_key = "st_" .. stash_name .. "_name"
            local stash_label = game.translate_string(label_key)
            if not stash_label or stash_label == "" or stash_label == label_key then
                stash_label = stash_name
            end
            local slot_id, err = bridge.create_task(build_bridge_task_params("dead_drop_stash", {
                item_section = item_sec,
                item_count = 1,
                stash_box_id = stash_box_id,
                stash_name = stash_name,
                destination_label = stash_label,
                location_label = stash_label,
                timeout_seconds = timeout,
                success_turn = s_turn,
                fail_turn = f_turn,
            }))
            if not slot_id then
                printf("PANDA_IC: panda_task_dead_drop_stash failed (%s)", tostring(err))
            else
                task_given = true
                push_task_start_message("st_pda_ic_task_dead_drop_start")
            end
        end
    end

            -- Fetch from Stash: item pre-spawned inside named stash box; player retrieves it (keeps it).
            -- Syntax: panda_task_fetch_from_stash:<stash_name>:<item_section>:<timeout>:<success_turn>:<fail_turn>
end

handlers["panda_task_fetch_from_stash"] = function(parts, cmd_str, cmd)
    local stash_name = parts[2]
    local item_sec = parts[3]
    local timeout = tonumber(parts[4]) or 600
    local s_turn = tonumber(parts[5])
    local f_turn = tonumber(parts[6])
    if not stash_name or not item_sec or not s_turn then
        printf("PANDA_IC: panda_task_fetch_from_stash missing params in '%s'", tostring(cmd_str))
    else
        local stash_box_id = find_stash_id_by_name(stash_name)
        local bridge = ensure_panda_task_bridge()
        if not stash_box_id then
            printf("PANDA_IC: panda_task_fetch_from_stash stash '%s' not found in caches", tostring(stash_name))
        elseif not bridge then
            printf("PANDA_IC: panda_task_fetch_from_stash ignored (bridge unavailable)")
        else
            local label_key = "st_" .. stash_name .. "_name"
            local stash_label = game.translate_string(label_key)
            if not stash_label or stash_label == "" or stash_label == label_key then
                stash_label = stash_name
            end
            -- Pre-spawn item inside the stash box so the player can loot it.
            local stash_se = alife() and alife():object(stash_box_id) or nil
            if stash_se and alife_create_item then
                alife_create_item(item_sec, stash_se)
            else
                printf("PANDA_IC: panda_task_fetch_from_stash could not spawn '%s' in stash '%s'", tostring(item_sec), tostring(stash_name))
            end
            local slot_id, err = bridge.create_task(build_bridge_task_params("fetch_stash", {
                item_section = item_sec,
                item_count = 1,
                stash_box_id = stash_box_id,
                stash_name = stash_name,
                destination_label = stash_label,
                location_label = stash_label,
                timeout_seconds = timeout,
                success_turn = s_turn,
                fail_turn = f_turn,
            }))
            if not slot_id then
                printf("PANDA_IC: panda_task_fetch_from_stash failed (%s)", tostring(err))
            else
                task_given = true
                push_task_start_message("st_pda_ic_task_fetch_start")
            end
        end
    end

            -- Escort: NPC becomes companion, escort to destination
            -- Syntax: panda_task_escort:<destination_smart>:<timeout>:<success_turn>:<fail_turn>
            -- Optional target: ...:<target_kind>:<target_id>[:<spawn_distance>]
            -- target_kind: sender|story_npc|custom_npc|spawn_faction|new_npc
            -- spawn_distance: meters from player; story_npc gets teleported in,
            -- custom_npc / spawn_faction spawn at this distance.
end

handlers["panda_task_escort"] = function(parts, cmd_str, cmd)
    local dest_smart = parts[2]
    local timeout = tonumber(parts[3]) or 900
    local s_turn = tonumber(parts[4])
    local f_turn = tonumber(parts[5])
    if not dest_smart or not s_turn then
        printf("PANDA_IC: panda_task_escort missing params in '%s'", tostring(cmd_str))
    else
        local target_kind = parts[6] or "sender"
        local target_value = parts[7]
        local target_spawn_distance = tonumber(parts[8])
        local escort_npc_id, escort_label, escort_squad_id = resolve_escort_target(
            target_kind,
            target_value,
            target_spawn_distance,
            sender_npc_id,
            sender_npc_name
        )
        local radius = PANDA.get_config("location_watch_radius") or 50
        local destination_map_id, destination_label = get_smart_task_target(dest_smart)
        if not escort_npc_id then
            printf("PANDA_IC: panda_task_escort missing escort npc id in '%s'", tostring(cmd_str))
        elseif not destination_map_id then
            printf("PANDA_IC: panda_task_escort destination resolve failed for '%s'", tostring(dest_smart))
        else
            local bridge = ensure_panda_task_bridge()
            if not bridge then
                printf("PANDA_IC: panda_task_escort ignored (bridge unavailable)")
            else
                local recruited, recruit_err, recruited_squad_id = recruit_escort_companion(escort_npc_id, escort_label, escort_squad_id)
                if not recruited then
                    printf("PANDA_IC: panda_task_escort companion recruit failed (%s)", tostring(recruit_err))
                end
                local slot_id, err = bridge.create_task(build_bridge_task_params("escort", {
                    target_npc_id = escort_npc_id,
                    target_squad_id = recruited_squad_id or escort_squad_id,
                    target_label = escort_label,
                    destination_ref = dest_smart,
                    destination_map_id = destination_map_id,
                    destination_label = destination_label,
                    location_label = destination_label,
                    target_radius = radius,
                    timeout_seconds = timeout,
                    success_turn = s_turn,
                    fail_turn = f_turn,
                }))
                if not slot_id then
                    printf("PANDA_IC: panda_task_escort failed (%s)", tostring(err))
                else
                    task_given = true
                    push_task_start_message("st_pda_ic_task_escort_start")
                end
            end
        end
    end

            -- Elimination: spawn enemies at location WHEN player approaches, player clears them
            -- Syntax: panda_task_eliminate:<target_type>:<smart_terrain>:<radius>:<timeout>:<success_turn>:<fail_turn>[:<squad_count>][:<state>]
            -- squad_count (optional, default 1) controls how many copies of the squad spawn.
            -- state (optional, default "hostile") sets relation: hostile|friendly|neutral|default.
            -- Squad spawn is deferred until the player enters the marker radius around the smart
            -- terrain. The PDA task creates its own map marker via the task system, so the
            -- watch zone skips its duplicate spot.
end

handlers["panda_task_eliminate"] = function(parts, cmd_str, cmd)
    local target_type = parts[2]
    local smart_ref = parts[3]
    local spawn_radius = tonumber(parts[4]) or 100
    local timeout = tonumber(parts[5]) or 900
    local s_turn = tonumber(parts[6])
    local f_turn = tonumber(parts[7])
    local squad_count = math.max(1, tonumber(parts[8]) or 1)
    local spawn_state = parts[9]
    if spawn_state == nil or spawn_state == "" then spawn_state = "hostile" end
    if not target_type or not smart_ref or not s_turn then
        printf("PANDA_IC: panda_task_eliminate missing params in '%s'", tostring(cmd_str))
    else
        local destination_map_id, destination_label = get_smart_task_target(smart_ref)
        local bridge = ensure_panda_task_bridge()
        if not destination_map_id then
            printf("PANDA_IC: panda_task_eliminate destination resolve failed for '%s'", tostring(smart_ref))
        elseif not bridge then
            printf("PANDA_IC: panda_task_eliminate ignored (bridge unavailable)")
        else
            local slot_id, err = bridge.create_task(build_bridge_task_params("eliminate", {
                destination_ref = smart_ref,
                destination_map_id = destination_map_id,
                destination_label = destination_label,
                location_label = destination_label,
                target_radius = spawn_radius,
                timeout_seconds = timeout,
                success_turn = s_turn,
                fail_turn = f_turn,
                target_squad_ids = {},
                spawn_pending = true,
            }))
            if not slot_id then
                printf("PANDA_IC: panda_task_eliminate failed (%s)", tostring(err))
            else
                task_given = true
                push_task_start_message("st_pda_ic_task_eliminate_start")

                -- Register a watch zone that fires the deferred squad spawn.
                -- skip_map_spot=true so the task system's destination marker isn't
                -- duplicated by a second primary_object spot at the same smart.
                local ref = register_location_reference(
                    smart_ref, sender_npc_name, sender_npc_id, spawn_radius, sender_contact_id,
                    { skip_map_spot = true }
                )
                if ref then
                    for _ = 1, squad_count do
                        table.insert(ref.trigger_cmds, table.concat({
                            "_panda_eliminate_spawn_internal",
                            tostring(target_type),
                            tostring(smart_ref),
                            tostring(slot_id),
                            tostring(spawn_state),
                        }, ":"))
                    end
                end
            end
        end
    end

            -- Artifact retrieval: player must find and return a specific artifact
            -- Syntax:          panda_task_artifact:<artifact_section>:<detector_tier>:<timeout>:<success_turn>:<fail_turn>
            -- Syntax (legacy): panda_task_artifact:<artifact_section>:<zone_name|any>:<detector_tier>:<timeout>:<success_turn>:<fail_turn>
            -- Syntax (v2):     panda_task_artifact:<artifact_section>:<zone_mode>:<zone_name>:<detector_tier>:<timeout>:<success_turn>:<fail_turn>
            -- zone_name supports deterministic level tokens like level:gar / level:esc.
end

handlers["panda_task_artifact"] = function(parts, cmd_str, cmd)
    local artifact_sec = parts[2]
    local zone_mode = "legacy"
    local zone_name = parts[3]
    local detector_tier_meta
    local timeout
    local s_turn
    local f_turn

    local detector_arg = parts[3]
    if (detector_arg == "basic" or detector_arg == "advanced" or detector_arg == "elite" or detector_arg == "scientific") and tonumber(parts[4]) then
        zone_mode = "natural"
        zone_name = nil
        detector_tier_meta = detector_arg
        timeout = tonumber(parts[4]) or 900
        s_turn = tonumber(parts[5])
        f_turn = tonumber(parts[6])
    elseif tonumber(parts[3]) then
        zone_mode = "natural"
        zone_name = nil
        detector_tier_meta = "basic"
        timeout = tonumber(parts[3]) or 900
        s_turn = tonumber(parts[4])
        f_turn = tonumber(parts[5])
    elseif parts[3] == "specific" or parts[3] == "any" or parts[3] == "random_level" then
        zone_mode = parts[3]
        zone_name = parts[4]
        local detector_index = 5
        local timeout_index = 6
        local success_index = 7
        local fail_index = 8

        if zone_name == "level" and parts[5] then
            zone_name = "level:" .. tostring(parts[5])
            detector_index = 6
            timeout_index = 7
            success_index = 8
            fail_index = 9
        end

        detector_tier_meta = parts[detector_index] or "basic"
        timeout = tonumber(parts[timeout_index]) or 900
        s_turn = tonumber(parts[success_index])
        f_turn = tonumber(parts[fail_index])
    else
        detector_tier_meta = parts[4] or "basic"
        timeout = tonumber(parts[5]) or 900
        s_turn = tonumber(parts[6])
        f_turn = tonumber(parts[7])
    end

    if not s_turn then
        printf("PANDA_IC: panda_task_artifact missing params in '%s'", tostring(cmd_str))
    else
        local bridge = ensure_panda_task_bridge()
        local task_runtime_id = make_artifact_runtime_task_id(conv_data)
        local resolved_zone = nil

        if zone_name and zone_name ~= "" and zone_name ~= "any" then
            local zone_err = nil
            resolved_zone, zone_err = resolve_artifact_zone_target(zone_name)
            if not resolved_zone then
                printf("PANDA_IC: panda_task_artifact zone resolve failed (%s), using natural-find mode", tostring(zone_err))
            end
        end

        if zone_name and zone_name ~= "" and zone_name ~= "any" and not resolved_zone then
            printf("PANDA_IC: panda_task_artifact no resolved zone, player must find naturally")
        end

        if not artifact_sec or artifact_sec == "" then
            if not resolved_zone then
                printf("PANDA_IC: panda_task_artifact requires explicit artifact_section when zone spawn is unavailable")
                return
            end
        end

        if not bridge then
            printf("PANDA_IC: panda_task_artifact ignored (bridge unavailable)")
            return
        end

        local slot_id, record_or_err = bridge.start_auto_artifact_task(build_bridge_task_params("artifact", {
            external_task_id = task_runtime_id,
            item_section = artifact_sec,
            zone_name = resolved_zone,
            zone_label = resolved_zone or zone_name,
            location_label = resolved_zone or zone_name,
            detector_tier = detector_tier_meta,
            timeout_seconds = timeout,
            success_turn = s_turn,
            fail_turn = f_turn,
            manual_turn_in = false,
            fail_if_artifact_lost = false,
        }))
        if not slot_id then
            printf("PANDA_IC: panda_task_artifact failed (%s)", tostring(record_or_err))
            return
        end

        local task_record = nil
        if type(record_or_err) == "table" then
            task_record = record_or_err
        elseif type(bridge.get_record) == "function" then
            task_record = bridge.get_record(task_runtime_id)
        end

        local spawned_artifact_section = task_record and task_record.item_section or artifact_sec
        if not spawned_artifact_section or spawned_artifact_section == "" then
            printf("PANDA_IC: panda_task_artifact requires explicit artifact_section when zone spawn is unavailable")
            return
        end

        task_given = true
        push_task_start_message("st_pda_ic_task_artifact_start")
    end
end

handlers["change_dialogue_stat"] = function(parts, cmd_str, cmd)
    local key = parts[2]
    local delta = tonumber(parts[3]) or 0
    apply_dialogue_stat_delta(key, delta)
end

handlers["give_skill_level"] = function(parts, cmd_str, cmd)
    local key = parts[2]
    local amount = math.abs(tonumber(parts[3]) or 0)
    apply_dialogue_stat_delta(key, amount)
end

handlers["take_skill_level"] = function(parts, cmd_str, cmd)
    local key = parts[2]
    local amount = math.abs(tonumber(parts[3]) or 0)
    apply_dialogue_stat_delta(key, -amount)
end

handlers["set_dialogue_stat"] = function(parts, cmd_str, cmd)
    local key = parts[2]
    local value = tonumber(parts[3]) or 0
    apply_dialogue_stat_set(key, value)
end

handlers["dialogue_skill_check"] = function(parts, cmd_str, cmd)
    -- Resolved inline before continuation; dispatcher entry kept so
    -- apply_outcome doesn't log "Unknown outcome command" warnings.
end

handlers["random_chance_check"] = function(parts, cmd_str, cmd)
    -- Resolved inline before continuation; dispatcher entry kept so
    -- apply_outcome doesn't log "Unknown outcome command" warnings.
end

function M.process_command(ctx, cmd_str)
    local chance_val, rest = string.match(cmd_str, "^chance:(%d+):(.+)$")
    if chance_val and rest then
        local spawn_mult = ctx.spawn_mult or 1
        local adjusted = math.floor(tonumber(chance_val) * spawn_mult)
        adjusted = math.max(0, math.min(100, adjusted))
        if math.random(100) <= adjusted then
            return M.process_command(ctx, rest) == true
        end
        return true
    end
    local parts = (ctx.str_explode or str_explode)(cmd_str, ":")
    local cmd = parts[1]
    if cmd and (cmd:sub(1, 11) == "panda_task_" or cmd == "start_anomaly_scan_task" or cmd == "start_artifact_retrieval_task") then
        ctx.task_author_meta = ctx.extract_trailing_task_meta(parts)
    else
        ctx.task_author_meta = {}
    end
    local handler = handlers[cmd]
    if not handler then
        printf("Unknown outcome command: %s", cmd_str)
        return false
    end
    local env = make_env(ctx, parts, cmd_str, cmd)
    setfenv(handler, env)
    handler(parts, cmd_str, cmd)
    return true
end

return M
