pda_interactive_outcomes = pda_interactive_outcomes or {}
local M = pda_interactive_outcomes

local handlers = {}

-- True while the game world is being torn down (quit-to-main-menu, mid-load).
-- Pending outcome time events keep firing for a frame or two after on_game_end,
-- and any reach into db.actor:* / level.object_by_id / alife() in that window
-- dereferences invalidated C++ objects and surfaces as the crash in
-- MainMenu::ReloadUI -> xrFactory_Create.
local function ic_is_shutting_down()
    local ic = rawget(_G, "pda_interactive_conv")
    if ic and type(ic.is_panda_ic_shutdown_in_progress) == "function" then
        local ok, val = pcall(ic.is_panda_ic_shutdown_in_progress)
        if ok and val == true then return true end
    end
    return db == nil or db.actor == nil
end

local function str_explode(str, sep)
    local t = {}
    for s in string.gmatch(str or "", "([^" .. sep .. "]+)") do table.insert(t, s) end
    return t
end

local function runtime_get(key)
    _panda_ic_runtime = _panda_ic_runtime or {}
    return _panda_ic_runtime[key]
end

local function runtime_set(key, value)
    _panda_ic_runtime = _panda_ic_runtime or {}
    _panda_ic_runtime[key] = value
end

local function apply_dialogue_stat_delta(key, delta)
    if pda_interactive_conv and type(pda_interactive_conv.change_dialogue_stat) == "function" then
        pda_interactive_conv.change_dialogue_stat(key, delta)
    elseif type(change_dialogue_stat) == "function" then
        change_dialogue_stat(key, delta)
    else
        printf(
            "PANDA_IC: pda_interactive_conv.change_dialogue_stat unavailable (key=%s delta=%s)",
            tostring(key),
            tostring(delta)
        )
    end
end

local function apply_dialogue_stat_set(key, value)
    if pda_interactive_conv and type(pda_interactive_conv.set_dialogue_stat) == "function" then
        pda_interactive_conv.set_dialogue_stat(key, value)
    elseif type(set_dialogue_stat) == "function" then
        set_dialogue_stat(key, value)
    else
        printf(
            "PANDA_IC: pda_interactive_conv.set_dialogue_stat unavailable (key=%s value=%s)",
            tostring(key),
            tostring(value)
        )
    end
end

local function make_env(ctx, parts, cmd_str, cmd)
    local env = { parts = parts, cmd_str = cmd_str, cmd = cmd, str_explode = ctx.str_explode or str_explode }
    return setmetatable(env, {
        __index = function(_, key)
            if key == "task_given" then return ctx.task_given end
            if key == "task_author_meta" then return ctx.task_author_meta end
            if key == "job_spawn_collector" then return runtime_get("job_spawn_collector") end
            if key == "pending_job_params" then return runtime_get("pending_job_params") end
            local value = ctx and ctx[key]
            if value ~= nil then return value end
            return _G[key]
        end,
        __newindex = function(t, key, value)
            if key == "task_given" then ctx.task_given = value; return end
            if key == "task_author_meta" then ctx.task_author_meta = value; return end
            if key == "job_spawn_collector" then runtime_set("job_spawn_collector", value); return end
            if key == "pending_job_params" then runtime_set("pending_job_params", value); return end
            rawset(t, key, value)
        end
    })
end

handlers["start_anomaly_scan_task"] = function(parts, cmd_str, cmd)
    local bridge = ensure_panda_task_bridge()
    if bridge then
        local slot_id, err = bridge.start_scan_task(
            parts[2],
            parts[3],
            parts[4] or "basic",
            tonumber(parts[5]) or 0,
            sender_npc_id,
            build_bridge_task_params("scan", {
                external_task_id = parts[2],
                zone_name = parts[3],
                zone_label = parts[3],
                location_label = parts[3],
            })
        )
        if not slot_id then
            printf("PANDA_IC: start_anomaly_scan_task failed (%s)", tostring(err))
        else
            task_given = true
        end
    else
        printf("PANDA_IC: start_anomaly_scan_task ignored (bridge unavailable)")
    end
end

handlers["start_artifact_retrieval_task"] = function(parts, cmd_str, cmd)
    local bridge = ensure_panda_task_bridge()
    if bridge then
        local slot_id, err = bridge.start_artifact_task(
            parts[2],
            parts[3],
            parts[4],
            parts[5] or "basic",
            tonumber(parts[6]) or 0,
            sender_npc_id,
            build_bridge_task_params("artifact", {
                external_task_id = parts[2],
                item_section = parts[3],
                zone_name = parts[4],
                zone_label = parts[4],
                location_label = parts[4],
                detector_tier = parts[5] or "basic",
                manual_turn_in = true,
                fail_if_artifact_lost = true,
            })
        )
        if not slot_id then
            printf("PANDA_IC: start_artifact_retrieval_task failed (%s)", tostring(err))
        else
            task_given = true
        end
    else
        printf("PANDA_IC: start_artifact_retrieval_task ignored (bridge unavailable)")
    end
end

handlers["spawn_artifact_on_npc"] = function(parts, cmd_str, cmd)
    -- Syntax: spawn_artifact_on_npc:<task_id>:<artifact_section>:<target_npc_id>
    local bridge = ensure_panda_task_bridge()
    if bridge then
        local artifact_sec = parts[3]
        local target_npc_id = tonumber(parts[4]) or sender_npc_id
        local ok, err = bridge.spawn_artifact_on_npc(parts[2], artifact_sec, target_npc_id)
        if not ok then
            printf("PANDA_IC: spawn_artifact_on_npc failed (%s)", tostring(err))
        end
    end
end

