            -- INTERNAL: deferred spawn for panda_task_eliminate. Not author-facing —
            -- emitted by the eliminate handler into a watch zone trigger so the squad
            -- is created only when the player approaches the marker.
end

handlers["_panda_eliminate_spawn_internal"] = function(parts, cmd_str, cmd)
    local target_type = parts[2]
    local smart_ref = parts[3]
    local task_slot_id = parts[4]
    local relation_mode = parts[5]
    if relation_mode == nil or relation_mode == "" then relation_mode = "hostile" end
    if not target_type or not smart_ref or not task_slot_id then
        printf("PANDA_IC: _panda_eliminate_spawn_internal malformed in '%s'", tostring(cmd_str))
    else
        local bridge = ensure_panda_task_bridge()
        local rec = bridge and bridge.get_record and bridge.get_record(task_slot_id) or nil
        if not bridge then
            printf("PANDA_IC: _panda_eliminate_spawn_internal bridge unavailable")
        elseif not rec then
            printf("PANDA_IC: _panda_eliminate_spawn_internal task %s missing", tostring(task_slot_id))
        elseif rec.active == false then
            -- Task already finished (player completed/failed before squad spawned). Skip.
        else
            -- NOTE: don't gate on rec.spawn_pending — rescue tasks register multiple
            -- trigger commands (one per squad_count) and only the first attach call
            -- clears spawn_pending. The watcher already removes its entry after the
            -- batch fires, so duplicate spawns across ticks aren't a concern.
            local is_mutant = is_mutant_squad_key(target_type)
            local collector_start = (job_spawn_collector and #job_spawn_collector) or 0
            local local_collector = false
            if not job_spawn_collector then
                job_spawn_collector = {}
                local_collector = true
                collector_start = 0
            end

            spawn_squad_at_smart_terrain(target_type, smart_ref, is_mutant, 0, sender_contact_id, relation_mode)

            local spawned_squad_ids = {}
            if job_spawn_collector then
                for i = collector_start + 1, #job_spawn_collector do
                    table.insert(spawned_squad_ids, job_spawn_collector[i])
                end
            end
            if local_collector then
                job_spawn_collector = nil
            end

            if #spawned_squad_ids == 0 then
                printf("PANDA_IC: _panda_eliminate_spawn_internal failed to spawn '%s'", tostring(target_type))
            elseif bridge.attach_target_squads then
                bridge.attach_target_squads(task_slot_id, spawned_squad_ids)
            end
        end
    end
end

handlers["watch_location"] = function(parts, cmd_str, cmd)
    local location_ref = parts[2]
    if location_ref and location_ref ~= "" then
        local radius = tonumber(parts[3]) or (PANDA.get_config("location_watch_radius") or 85)
        register_location_reference(location_ref, sender_npc_name, sender_npc_id, radius, sender_contact_id)
    else
        printf("PANDA_IC: watch_location missing location reference in '%s'", tostring(cmd_str))
    end
end

handlers["watch_location_trigger"] = function(parts, cmd_str, cmd)
    local location_ref = parts[2]
    local delayed_cmd = nil
    local radius = PANDA.get_config("location_watch_radius") or 85

    if #parts >= 3 then
        local maybe_radius = tonumber(parts[#parts])
        local cmd_end = #parts
        if maybe_radius then
            radius = maybe_radius
            cmd_end = #parts - 1
        end

        if cmd_end >= 3 then
            delayed_cmd = table.concat(parts, ":", 3, cmd_end)
        end
    end

    if location_ref and location_ref ~= "" then
        local ref = register_location_reference(location_ref, sender_npc_name, sender_npc_id, radius, sender_contact_id)
        if delayed_cmd and delayed_cmd ~= "" then
            -- Support multiple trigger commands separated by "+"
            -- Example: teleport_npc_to_smart:loc+spawn_mutant_at_smart:snork:loc
            for sub_cmd in string.gmatch(delayed_cmd, "([^+]+)") do
                sub_cmd = sub_cmd:match("^%s*(.-)%s*$")
                if sub_cmd ~= "" then
                    table.insert(ref.trigger_cmds, sub_cmd)
                end
            end
        else
            -- No trigger command supplied: behave like plain watch_location
            -- (map marker only). Authors who left the trigger blank in the editor
            -- still get a map spot instead of the malformed warning spam.
            printf("PANDA_IC: watch_location_trigger has no trigger command, registering as plain watch_location for '%s'", tostring(location_ref))
        end
    else
        printf("PANDA_IC: watch_location_trigger missing smart terrain in '%s'", tostring(cmd_str))
    end

            -- ========== TELEPORT NPC (to smart terrain) ==========
end

handlers["teleport_npc_to_smart"] = function(parts, cmd_str, cmd)
    local smart_ref = parts[2]
    local delay = tonumber(parts[3]) or 0
    if smart_ref and smart_ref ~= "" and sender_npc_id then
        teleport_npc_to_smart_terrain(sender_npc_id, smart_ref, sender_npc_name, delay)
    else
        printf("PANDA_IC: teleport_npc_to_smart missing smart reference or npc_id in '%s'", tostring(cmd_str))
    end

            -- ========== TELEPORT NPC (near player) ==========
end

handlers["teleport_npc_to_player"] = function(parts, cmd_str, cmd)
    local delay = tonumber(parts[2]) or 0
    if sender_npc_id then
        teleport_npc_near_player(sender_npc_id, sender_npc_name, delay)
    else
        printf("PANDA_IC: teleport_npc_to_player missing npc_id in '%s'", tostring(cmd_str))
    end

            -- ========== RECRUIT COMPANION (convert conversation NPC) ==========
end

handlers["recruit_companion"] = function(parts, cmd_str, cmd)
    local cannot_dismiss = parts[2] == "no_dismiss"
    if sender_npc_id then
        recruit_npc_as_companion(sender_npc_id, sender_npc_name, cannot_dismiss)
    else
        printf("PANDA_IC: recruit_companion missing npc_id in '%s'", tostring(cmd_str))
    end

            -- ========== PAUSE JOB (wait for spawned hostiles to die) ==========
            -- Syntax: pause_job:<timeout_seconds>:<success_turn>:<fail_turn>
            -- Must be in the same outcome string as spawn commands.
            -- Pauses the conversation until all squads spawned in this outcome batch are dead.
end

handlers["pause_job"] = function(parts, cmd_str, cmd)
    local timeout = tonumber(parts[2]) or 600
    local success_turn = tonumber(parts[3])
    local fail_turn = tonumber(parts[4])
    if not success_turn then
        printf("PANDA_IC: pause_job missing success_turn in '%s'", tostring(cmd_str))
    else
        -- Defer actual job creation to after all commands in this batch finish.
        -- Store params so the post-batch handler can create the job.
        pending_job_params = {
            timeout = timeout,
            success_turn = success_turn,
            fail_turn = fail_turn,
            sender_npc_id = sender_npc_id,
            sender_npc_name = sender_npc_name,
            sender_contact_id = sender_contact_id,
            sender_faction = sender_faction,
            conv_data = conv_data,
        }
    end

            -- ========== TAKE ITEM ==========
end

handlers["take_item"] = function(parts, cmd_str, cmd)
    local item_sec = parts[2]
    local count = math.max(1, tonumber(parts[3]) or 1)
    if item_sec then
        local to_remove = {}
        local removed = 0
        act:iterate_inventory(function(owner, item)
            if removed < count and item:section() == item_sec then
                table.insert(to_remove, item:id())
                removed = removed + 1
            end
        end, act)
        for _, item_id in ipairs(to_remove) do
            local se_obj = alife_object(item_id)
            if se_obj then alife_release(se_obj) end
        end
        if removed > 0 then
            local msg_key = removed == 1 and "st_pda_ic_outcome_item_taken" or "st_pda_ic_outcome_items_taken"
            local msg = utils_data.parse_string_keys(
                game.translate_string(msg_key),
                {["what"] = ui_item.get_sec_name(item_sec), ["count"] = tostring(removed)}
            )
            dynamic_news_helper.send_tip(msg, "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc")
        end
    end

            -- ========== GIVE ITEM COUNT ==========
end

handlers["give_item_count"] = function(parts, cmd_str, cmd)
    local item_sec = parts[2]
    local count = tonumber(parts[3]) or 1
    if item_sec and ini_sys:section_exist(item_sec) then
        for i = 1, count do
            alife_create_item(item_sec, db.actor)
        end
        local msg = string.format(
            game.translate_string("st_pda_ic_outcome_items_given"),
            count, ui_item.get_sec_name(item_sec)
        )
        dynamic_news_helper.send_tip(msg, "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc")
    end

            -- ========== REWARD STASH WITH SPECIFIC ITEMS ==========
end

handlers["reward_stash_items"] = function(parts, cmd_str, cmd)
    local items_str = parts[2]
    if items_str and items_str ~= "" then
        local bonus_items = {}
        for item_sec in string.gmatch(items_str, "([^+]+)") do
            item_sec = item_sec:match("^%s*(.-)%s*$")
            if item_sec ~= "" and ini_sys:section_exist(item_sec) then
                table.insert(bonus_items, item_sec)
            end
        end
        if #bonus_items > 0 then
            queue_stash_attachment_reward_custom(sender_npc_name, sender_npc_id, sender_contact_id, bonus_items)
        else
            queue_stash_attachment_reward(sender_npc_name, sender_npc_id, sender_contact_id)
        end
    else
        queue_stash_attachment_reward(sender_npc_name, sender_npc_id, sender_contact_id)
    end

            -- ========== REWARD SPECIFIC STASH (RANDOM LOOT) ==========
            -- Syntax: reward_stash_at:<stash_name>
            -- <stash_name> is the vanilla inventory box name from st_treasures.xml, e.g. dark_valley_treasure_1
end

handlers["reward_stash_at"] = function(parts, cmd_str, cmd)
    local stash_name = parts[2]
    if stash_name and stash_name ~= "" then
        queue_stash_attachment_at(stash_name, sender_npc_name, sender_npc_id, sender_contact_id)
    else
        printf("PANDA_IC: reward_stash_at missing stash_name in '%s'", tostring(cmd_str))
        queue_stash_attachment_reward(sender_npc_name, sender_npc_id, sender_contact_id)
    end

            -- ========== REWARD SPECIFIC STASH WITH CUSTOM ITEMS ==========
            -- Syntax: reward_stash_items_at:<stash_name>:<item1+item2+...>
end

handlers["reward_stash_items_at"] = function(parts, cmd_str, cmd)
    local stash_name = parts[2]
    local items_str = parts[3]
    local bonus_items = {}
    if items_str and items_str ~= "" then
        for item_sec in string.gmatch(items_str, "([^+]+)") do
            item_sec = item_sec:match("^%s*(.-)%s*$")
            if item_sec ~= "" and ini_sys:section_exist(item_sec) then
                table.insert(bonus_items, item_sec)
            end
        end
    end
    if stash_name and stash_name ~= "" then
        queue_stash_items_attachment_at(stash_name, #bonus_items > 0 and bonus_items or nil, sender_npc_name, sender_npc_id, sender_contact_id)
    else
        printf("PANDA_IC: reward_stash_items_at missing stash_name in '%s'", tostring(cmd_str))
        queue_stash_attachment_reward_custom(sender_npc_name, sender_npc_id, sender_contact_id, #bonus_items > 0 and bonus_items or nil)
    end

            -- ========== KNOWLEDGE / INFO PORTIONS ==========
end

handlers["give_info"] = function(parts, cmd_str, cmd)
    local info_id = parts[2]
    if info_id and info_id ~= "" then
        give_info(info_id)
        dynamic_news_helper.send_tip(
            game.translate_string("st_pda_ic_outcome_info_gained"),
            "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
        )
    end
end

handlers["disable_info"] = function(parts, cmd_str, cmd)
    local info_id = parts[2]
    if info_id and info_id ~= "" then
        disable_info(info_id)
        dynamic_news_helper.send_tip(
            game.translate_string("st_pda_ic_outcome_info_removed"),
            "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
        )
    end

            -- ========== PLAYER EFFECTS ==========
end

handlers["heal_player"] = function(parts, cmd_str, cmd)
    local amount = (tonumber(parts[2]) or 0) / 100
    amount = math.max(0, math.min(1, amount))
    db.actor.health = amount
end

handlers["damage_player"] = function(parts, cmd_str, cmd)
    local amount = (tonumber(parts[2]) or 0) / 100
    amount = math.max(0, math.min(0.99, amount))
    db.actor.health = -amount
end

handlers["give_radiation"] = function(parts, cmd_str, cmd)
    local amount = (tonumber(parts[2]) or 0) / 100
    amount = math.max(0, math.min(1, amount))
    db.actor:change_radiation(amount)
end

handlers["cure_radiation"] = function(parts, cmd_str, cmd)
    local cur_rad = db.actor:get_radiation()
    if cur_rad > 0 then
        db.actor:change_radiation(-cur_rad)
    end

            -- ========== NPC RELATION CHANGES ==========
end

handlers["dismiss_companion"] = function(parts, cmd_str, cmd)
    if sender_npc_id then
        local npc_obj = level.object_by_id(sender_npc_id)
        if npc_obj and axr_companions then
            axr_companions.dismiss_companion(npc_obj)
            dynamic_news_helper.send_tip(
                game.translate_string("st_pda_ic_outcome_npc_dismissed"),
                sender_npc_name or "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
            )
        end
    end
end

handlers["set_npc_hostile"] = function(parts, cmd_str, cmd)
    if sender_npc_id then
        local npc_obj = level.object_by_id(sender_npc_id)
        if npc_obj then
            npc_obj:set_relation(game_object.enemy, db.actor)
            npc_obj:force_set_goodwill(-5000, db.actor)
            dynamic_news_helper.send_tip(
                game.translate_string("st_pda_ic_outcome_npc_hostile"),
                sender_npc_name or "System", 0, 10, FALLBACK_NPC_ICON, "danger", "npc"
            )
        end
    end
end

handlers["set_npc_friendly"] = function(parts, cmd_str, cmd)
    if sender_npc_id then
        local npc_obj = level.object_by_id(sender_npc_id)
        if npc_obj then
            npc_obj:set_relation(game_object.friend, db.actor)
            npc_obj:force_set_goodwill(5000, db.actor)
            dynamic_news_helper.send_tip(
                game.translate_string("st_pda_ic_outcome_npc_friendly"),
                sender_npc_name or "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
            )
        end
    end
end

handlers["set_npc_state"] = function(parts, cmd_str, cmd)
    -- Unified replacement for set_npc_hostile/friendly/neutral.
    -- Syntax: set_npc_state:<state>     state = hostile|friendly|neutral
    local state = (parts[2] or "neutral"):lower()
    if sender_npc_id then
        local npc_obj = level.object_by_id(sender_npc_id)
        if npc_obj then
            if state == "hostile" or state == "enemy" or state == "aggressive" then
                npc_obj:set_relation(game_object.enemy, db.actor)
                npc_obj:force_set_goodwill(-5000, db.actor)
                dynamic_news_helper.send_tip(
                    game.translate_string("st_pda_ic_outcome_npc_hostile"),
                    sender_npc_name or "System", 0, 10, FALLBACK_NPC_ICON, "danger", "npc"
                )
            elseif state == "friendly" or state == "friend" then
                npc_obj:set_relation(game_object.friend, db.actor)
                npc_obj:force_set_goodwill(5000, db.actor)
                dynamic_news_helper.send_tip(
                    game.translate_string("st_pda_ic_outcome_npc_friendly"),
                    sender_npc_name or "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
                )
            else
                npc_obj:set_relation(game_object.neutral, db.actor)
                npc_obj:force_set_goodwill(0, db.actor)
                local notify_key = "st_pda_ic_outcome_npc_neutral"
                local notify = game.translate_string(notify_key)
                if notify == notify_key then
                    notify = "NPC is now neutral."
                end
                dynamic_news_helper.send_tip(
                    notify,
                    sender_npc_name or "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
                )
            end
        end
    end
end

handlers["kill_npc"] = function(parts, cmd_str, cmd)
    if sender_npc_id then
        local npc_obj = level.object_by_id(sender_npc_id)
        if npc_obj and npc_obj.alive and npc_obj:alive() then
            npc_obj:kill(npc_obj)
        else
            local se_obj = alife_object(sender_npc_id)
            if se_obj then
                alife_release(se_obj)
            end
        end
        dynamic_news_helper.send_tip(
            game.translate_string("st_pda_ic_outcome_npc_killed"),
            sender_npc_name or "System", 0, 10, FALLBACK_NPC_ICON, "danger", "npc"
        )
    end
end

handlers["change_npc_faction"] = function(parts, cmd_str, cmd)
    local new_faction = normalize_faction(parts[2] or "stalker")
    if sender_npc_id then
        local se_npc = alife_object(sender_npc_id)
        if se_npc then
            if SIMBOARD and SIMBOARD.change_faction then
                SIMBOARD:change_faction(se_npc, new_faction)
            elseif se_npc.community then
                se_npc:community(new_faction)
            end
            dynamic_news_helper.send_tip(
                game.translate_string("st_pda_ic_outcome_npc_faction_change"),
                sender_npc_name or "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
            )
        end
    end

            -- ─── NEW OUTCOME HANDLERS ────────────────────────────────────────────

            -- Player Effects: hunger
end

handlers["give_hunger"] = function(parts, cmd_str, cmd)
    local amount = (tonumber(parts[2]) or 10) / 100
    if act.cast_Actor and act:cast_Actor() and act:cast_Actor().conditions then
        local cond = act:cast_Actor():conditions()
        if cond and cond.ChangeSatiety then
            cond:ChangeSatiety(-amount)
        end
    end
end

handlers["cure_hunger"] = function(parts, cmd_str, cmd)
    local amount = (tonumber(parts[2]) or 50) / 100
    if act.cast_Actor and act:cast_Actor() and act:cast_Actor().conditions then
        local cond = act:cast_Actor():conditions()
        if cond and cond.ChangeSatiety then
            cond:ChangeSatiety(amount)
        end
    end

            -- Player Effects: speed
end

handlers["boost_speed"] = function(parts, cmd_str, cmd)
    local mult = tonumber(parts[2]) or 1.5
    local dur = tonumber(parts[3]) or 60
    act:set_actor_run_coef(mult)
    act:set_actor_sprint_koef(mult)
    CreateTimeEvent(0, "panda_speed_reset_" .. tostring(time_global()), dur, function()
        if ic_is_shutting_down() then return true end
        db.actor:set_actor_run_coef(0)
        db.actor:set_actor_sprint_koef(0)
        return true
    end)
end

handlers["slow_speed"] = function(parts, cmd_str, cmd)
    local mult = tonumber(parts[2]) or 0.5
    local dur = tonumber(parts[3]) or 60
    act:set_actor_run_coef(mult)
    act:set_actor_sprint_koef(mult)
    CreateTimeEvent(0, "panda_speed_reset_" .. tostring(time_global()), dur, function()
        if ic_is_shutting_down() then return true end
        db.actor:set_actor_run_coef(0)
        db.actor:set_actor_sprint_koef(0)
        return true
    end)

            -- Player Effects: rank
end

handlers["change_rank"] = function(parts, cmd_str, cmd)
    local amount = tonumber(parts[2]) or 0
    if game_statistics and game_statistics.increment_rank then
        game_statistics.increment_rank(amount)
    else
        local cur = act:character_rank()
        act:set_character_rank(cur + amount)
    end

            -- Player Effects: teleport player
end

handlers["teleport_player_to_smart"] = function(parts, cmd_str, cmd)
    local smart_ref = parts[2]
    local delay = tonumber(parts[3]) or 0
    if smart_ref and smart_ref ~= "" then
        local smart_pos = resolve_smart_position_from_reference(smart_ref)
        if smart_pos then
            if delay > 0 then
                CreateTimeEvent(0, "panda_tp_player_" .. tostring(time_global()), delay, function()
                    if ic_is_shutting_down() then return true end
                    db.actor:set_actor_position(smart_pos)
                    return true
                end)
            else
                act:set_actor_position(smart_pos)
            end
        end
    end

            -- NPC: change rank
end

handlers["change_npc_rank"] = function(parts, cmd_str, cmd)
    local amount = tonumber(parts[2]) or 0
    if sender_npc_id then
        local npc_obj = level.object_by_id(sender_npc_id)
        if npc_obj then
            local cur = npc_obj:character_rank()
            npc_obj:set_character_rank(cur + amount)
        end
    end

            -- NPC: give item
end

handlers["equip_npc_item"] = function(parts, cmd_str, cmd)
    local item_sec = parts[2]
    if item_sec and sender_npc_id then
        local se_npc = alife_object(sender_npc_id)
        if se_npc and ini_sys:section_exist(item_sec) then
            alife_create_item(item_sec, se_npc)
        end
    end

            -- NPC: companion behavior state
end

handlers["set_companion_state"] = function(parts, cmd_str, cmd)
    local state = parts[2] or "follow"
    if sender_npc_id and axr_companions then
        local npc_obj = level.object_by_id(sender_npc_id)
        if npc_obj then
            if state == "follow" and axr_companions.set_companion_to_follow_state then
                axr_companions.set_companion_to_follow_state(npc_obj)
            elseif state == "wait" and axr_companions.set_companion_to_wait_state then
                axr_companions.set_companion_to_wait_state(npc_obj)
            elseif state == "patrol" and axr_companions.set_companion_to_patrol_state then
                axr_companions.set_companion_to_patrol_state(npc_obj)
            elseif state == "attack" and axr_companions.set_companion_to_attack_state then
                axr_companions.set_companion_to_attack_state(npc_obj)
            elseif state == "stealth" and axr_companions.set_companion_to_stealth_substate then
                axr_companions.set_companion_to_stealth_substate(npc_obj)
            elseif state == "ignore_combat" and axr_companions.set_companion_to_ignore_combat_state then
                axr_companions.set_companion_to_ignore_combat_state(npc_obj)
            end
        end
    end

            -- NPC: set neutral
end

handlers["set_npc_neutral"] = function(parts, cmd_str, cmd)
    if sender_npc_id then
        local npc_obj = level.object_by_id(sender_npc_id)
        if npc_obj then
            npc_obj:set_relation(game_object.neutral, db.actor)
            npc_obj:force_set_goodwill(0, db.actor)
        end
    end

            -- NPC: invulnerability
end

handlers["make_npc_invulnerable"] = function(parts, cmd_str, cmd)
    local dur = tonumber(parts[2]) or 300
    if sender_npc_id then
        if not _panda_invulnerable_npcs then _panda_invulnerable_npcs = {} end
        _panda_invulnerable_npcs[sender_npc_id] = true
        CreateTimeEvent(0, "panda_invuln_" .. tostring(sender_npc_id), dur, function()
            if _panda_invulnerable_npcs then
                _panda_invulnerable_npcs[sender_npc_id] = nil
            end
            return true
        end)
    end
end

handlers["set_npc_animation"] = function(parts, cmd_str, cmd)
    if sender_npc_id then
        request_dialog_npc_animation(sender_npc_id, parts[2], parts[3], {
            channel = resolved_channel,
            source = "outcome:set_npc_animation",
            session_token = conv_data and (conv_data.f2f_session_token or conv_data.session_token) or nil,
        })
    else
        printf("PANDA_IC: set_npc_animation missing npc_id in '%s'", tostring(cmd_str))
    end
end

handlers["clear_npc_animation"] = function(parts, cmd_str, cmd)
    if sender_npc_id then
        request_dialog_npc_animation_clear(sender_npc_id, {
            channel = resolved_channel,
            source = "outcome:clear_npc_animation",
            session_token = conv_data and (conv_data.f2f_session_token or conv_data.session_token) or nil,
        })
    else
        printf("PANDA_IC: clear_npc_animation missing npc_id in '%s'", tostring(cmd_str))
    end

            -- Faction relations
end

handlers["change_faction_relations"] = function(parts, cmd_str, cmd)
    local f1 = normalize_faction(parts[2] or "stalker")
    local f2 = normalize_faction(parts[3] or "bandit")
    local amount = tonumber(parts[4]) or 0
    if game_relations and game_relations.change_faction_relations then
        game_relations.change_faction_relations(f1, f2, amount, false)
    end

            -- Change player faction
end

handlers["change_player_faction"] = function(parts, cmd_str, cmd)
    local new_fac = normalize_faction(parts[2] or "stalker")
    if act.set_character_community then
        act:set_character_community(new_fac, 0, 0)
    end

            -- Ceasefire
end

handlers["ceasefire"] = function(parts, cmd_str, cmd)
    local radius = tonumber(parts[2]) or 100
    local actor_pos = act:position()
    for id = 1, 65535 do
        local obj = level.object_by_id(id)
        if obj and obj:alive() and IsStalker(obj) and obj:id() ~= act:id() then
            local dist = obj:position():distance_to(actor_pos)
            if dist <= radius then
                obj:set_relation(game_object.neutral, db.actor)
                obj:force_set_goodwill(0, db.actor)
            end
        end
    end

            -- World: weather
end

handlers["set_weather"] = function(parts, cmd_str, cmd)
    local weather = parts[2] or "w_clear1"
    if level.set_weather then
        level.set_weather(weather, true)
    end

            -- World: game news
end

handlers["give_game_news"] = function(parts, cmd_str, cmd)
    local title = parts[2] or "News"
    local message = parts[3] or ""
    local dur = tonumber(parts[4]) or 5
    act:give_game_news(title, message, "ui_inGame2_PDA", 0, dur * 1000)

            -- Knowledge: tasks
end

handlers["give_task"] = function(parts, cmd_str, cmd)
    local task_id = parts[2]
    if task_id and task_manager and task_manager.get_task_manager then
        local tm = task_manager.get_task_manager()
        if tm and tm.give_task then
            tm:give_task(task_id)
        end
    end
end

handlers["complete_task"] = function(parts, cmd_str, cmd)
    local task_id = parts[2]
    if task_id and task_manager and task_manager.task_complete then
        task_manager.task_complete(task_id)
    end
end

handlers["fail_task"] = function(parts, cmd_str, cmd)
    local task_id = parts[2]
    if task_id and task_manager and task_manager.task_fail then
        task_manager.task_fail(task_id)
    end

            -- ========== CUSTOM TASKS ==========
            -- Each panda_task_* command creates real vanilla task-manager task slots.

            -- Delivery: player receives an auto package and delivers it to a randomly chosen NPC.
            -- Destination smart terrain is OPTIONAL — if omitted (or empty), engine picks any
            -- eligible online stalker anywhere as the recipient and tracks them on the map.
            -- Syntax: panda_task_delivery:<timeout>:<success_turn>:<fail_turn>
            -- Legacy: panda_task_delivery:<destination_smart>:<timeout>:<success_turn>:<fail_turn>
            -- Legacy: panda_task_delivery:<item_section>:<destination_smart>:<timeout>:<success_turn>:<fail_turn>
end

handlers["panda_task_delivery"] = function(parts, cmd_str, cmd)
    local item_sec = "quest_package_" .. tostring(math.random(1, 8))
    local dest_smart, timeout, s_turn, f_turn

    if tonumber(parts[2]) and tonumber(parts[3]) and tonumber(parts[4]) and not parts[5] then
        -- New no-destination form: panda_task_delivery:<timeout>:<s>:<f>
        dest_smart = nil
        timeout = tonumber(parts[2]) or 600
        s_turn = tonumber(parts[3])
        f_turn = tonumber(parts[4])
    elseif parts[3] and not tonumber(parts[3]) then
        -- Oldest legacy: panda_task_delivery:<item_section>:<destination_smart>:<timeout>:<s>:<f>
        item_sec = parts[2] or item_sec
        dest_smart = parts[3]
        timeout = tonumber(parts[4]) or 600
        s_turn = tonumber(parts[5])
        f_turn = tonumber(parts[6])
    else
        -- Legacy: panda_task_delivery:<destination_smart>:<timeout>:<s>:<f>
        dest_smart = parts[2]
        timeout = tonumber(parts[3]) or 600
        s_turn = tonumber(parts[4])
        f_turn = tonumber(parts[5])
    end

    if not item_sec or not s_turn then
        printf("PANDA_IC: panda_task_delivery missing params in '%s'", tostring(cmd_str))
    else
        local radius = PANDA.get_config("location_watch_radius") or 50
        local destination_map_id, destination_label
        if dest_smart and dest_smart ~= "" then
            destination_map_id, destination_label = get_smart_task_target(dest_smart)
        end

        local bridge = ensure_panda_task_bridge()
        if not bridge then
            printf("PANDA_IC: panda_task_delivery ignored (bridge unavailable)")
        else
            local delivery_target
            if dest_smart and dest_smart ~= "" then
                delivery_target = pick_delivery_target_near_smart(dest_smart, math.max(radius * 2, 150))
            end
            if not delivery_target then
                delivery_target = pick_random_delivery_target()
            end

            local delivery_target_id = delivery_target and delivery_target.se and delivery_target.se.id or nil
            local delivery_target_label = get_delivery_target_label(delivery_target)
            local task_map_id = delivery_target_id or destination_map_id
            local task_label = delivery_target_label or destination_label

            if not task_map_id then
                printf("PANDA_IC: panda_task_delivery could not pick a recipient NPC")
            else
                if type(spawn_native_courier) == "function" then
                    spawn_native_courier(item_sec)
                elseif db.actor and alife_create_item then
                    alife_create_item(item_sec, db.actor)
                end
                local slot_id, err = bridge.create_task(build_bridge_task_params("delivery", {
                    item_section = item_sec,
                    item_count = 1,
                    destination_ref = dest_smart,
                    destination_map_id = task_map_id,
                    destination_label = task_label,
                    location_label = destination_label or task_label,
                    target_npc_id = delivery_target_id,
                    target_label = delivery_target_label,
                    target_radius = radius,
                    timeout_seconds = timeout,
                    success_turn = s_turn,
                    fail_turn = f_turn,
                }))
                if not slot_id then
                    printf("PANDA_IC: panda_task_delivery failed (%s)", tostring(err))
                else
                    task_given = true
                    push_task_start_message("st_pda_ic_task_delivery_start")
                end
            end
        end
    end

            -- Fetch: player must find/collect items (periodic inventory check)
            -- Syntax: panda_task_fetch:<item_section>:<count>:<timeout>:<success_turn>:<fail_turn>
end

handlers["panda_task_fetch"] = function(parts, cmd_str, cmd)
