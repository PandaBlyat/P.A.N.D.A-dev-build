        else
            local slot_id, err = bridge.create_task(build_bridge_task_params("fetch", {
                item_section = item_sec,
                item_count = count,
                timeout_seconds = timeout,
                success_turn = s_turn,
                fail_turn = f_turn,
            }))
            if not slot_id then
                printf("PANDA_IC: panda_task_fetch failed (%s)", tostring(err))
            else
                task_given = true
                push_task_start_message("st_pda_ic_task_fetch_start")
            end
        end
    end

            -- Bounty: spawn target NPC at location, track kill
            -- Syntax: panda_task_bounty:<faction>:<smart_terrain>:<timeout>:<success_turn>:<fail_turn>
            -- Legacy: panda_task_bounty:<faction>:<rank>:<smart_terrain>:<timeout>:<success_turn>:<fail_turn>
end

handlers["panda_task_bounty"] = function(parts, cmd_str, cmd)
    local target_fac = parts[2]
    local target_rank = parts[3]
    local smart_ref = parts[4]
    local timeout = tonumber(parts[5]) or 900
    local s_turn = tonumber(parts[6])
    local f_turn = tonumber(parts[7])
    if parts[3] and (parts[3]:find("^st_") or parts[3]:find("^%%") or tonumber(parts[4])) then
        target_rank = nil
        smart_ref = parts[3]
        timeout = tonumber(parts[4]) or 900
        s_turn = tonumber(parts[5])
        f_turn = tonumber(parts[6])
    end
    if not target_fac or not smart_ref or not s_turn then
        printf("PANDA_IC: panda_task_bounty missing params in '%s'", tostring(cmd_str))
    else
        local target_id = nil
        local sec = find_squad_section(target_fac)
        if sec then
            local smart = resolve_smart_from_reference(smart_ref)
            if smart then
                local spos = get_position_from_object(smart)
                local slvid = smart.m_level_vertex_id
                local sgvid = smart.m_game_vertex_id
                if spos then
                    local sp, sl, sg = find_spawn_point_near_smart(10, 20, spos, slvid, sgvid)
                    local sq = create_squad_safely(sec, sp or spos, sl or slvid, sg or sgvid)
                    if sq then
                        -- Set hostile
                        sq.scripted_target = smart:name()
                        for k in sq:squad_members() do
                            if not target_id then target_id = k.id end
                        end
                    end
                end
            end
        end
        local radius = PANDA.get_config("location_watch_radius") or 85
        local destination_map_id, destination_label = get_smart_task_target(smart_ref)
        local target_label = nil
        if target_id then
            local target_obj = level.object_by_id(target_id)
            if target_obj and target_obj.character_name then
                local ok_name, resolved_name = pcall(function() return target_obj:character_name() end)
                if ok_name and resolved_name and resolved_name ~= "" then
                    target_label = resolved_name
                end
            end
            if (not target_label or target_label == "") and alife_object then
                local target_se = alife_object(target_id)
                if target_se and target_se.character_name then
                    local ok_name, resolved_name = pcall(function() return target_se:character_name() end)
                    if ok_name and resolved_name and resolved_name ~= "" then
                        target_label = resolved_name
                    end
                end
            end
        end

        if not target_id then
            printf("PANDA_IC: panda_task_bounty failed to spawn target in '%s'", tostring(cmd_str))
        else
            local bridge = ensure_panda_task_bridge()
            if not bridge then
                printf("PANDA_IC: panda_task_bounty ignored (bridge unavailable)")
            else
                local slot_id, err = bridge.create_task(build_bridge_task_params("bounty", {
                    target_npc_id = target_id,
                    target_label = target_label,
                    destination_ref = smart_ref,
                    destination_map_id = destination_map_id,
                    destination_label = destination_label,
                    location_label = destination_label,
                    target_radius = radius,
                    timeout_seconds = timeout,
                    success_turn = s_turn,
                    fail_turn = f_turn,
                }))
                if not slot_id then
                    printf("PANDA_IC: panda_task_bounty failed (%s)", tostring(err))
                else
                    task_given = true
                    push_task_start_message("st_pda_ic_task_bounty_start")
                end
            end
        end
    end

            -- Rescue: keep survivor alive while hostile squads are cleared.
            -- Survivor spawns immediately at the smart terrain (kneeling, hostage,
            -- invulnerable, ignores combat). Hostiles spawn ON ARRIVAL when the player
            -- enters the watch radius — they don't wander off and they don't kill the
            -- hostage while the player heads over.
            -- Syntax: panda_task_rescue:<enemy_squad>:<smart_terrain>:<squad_count>:<survivor_template|random>:<timeout>:<success_turn>:<fail_turn>[:<state>]
            --   state (optional, default "hostile") sets enemy squad relation: hostile|friendly|neutral|default.
end

handlers["panda_task_rescue"] = function(parts, cmd_str, cmd)
    local enemy_squad = parts[2]
    local smart_ref = parts[3]
    local squad_count = 1
    local survivor_template = "random"
    local timeout = 900
    local s_turn = nil
    local f_turn = nil
    local param_index = 4

    if parts[param_index] and tonumber(parts[param_index]) and tonumber(parts[param_index]) <= 10 then
        if parts[param_index + 1] and not tonumber(parts[param_index + 1]) then
            squad_count = math.max(1, tonumber(parts[param_index]) or 1)
            survivor_template = parts[param_index + 1]
            param_index = param_index + 2
        elseif parts[param_index + 3] then
            squad_count = math.max(1, tonumber(parts[param_index]) or 1)
            param_index = param_index + 1
        end
    elseif parts[param_index] and not tonumber(parts[param_index]) then
        survivor_template = parts[param_index]
        param_index = param_index + 1
    end

    timeout = tonumber(parts[param_index]) or timeout
    s_turn = tonumber(parts[param_index + 1])
    f_turn = tonumber(parts[param_index + 2])

    local enemy_state = parts[param_index + 3]
    if enemy_state == nil or enemy_state == "" then enemy_state = "hostile" end

    if not enemy_squad or not smart_ref or not s_turn then
        printf("PANDA_IC: panda_task_rescue missing params in '%s'", tostring(cmd_str))
    else
        -- Spawn the survivor IMMEDIATELY so they're at the location when the
        -- player arrives (matches vanilla rescue setpiece pacing).
        local survivor_id = nil
        local survivor_squad_obj = nil
        local survivor_label = game.translate_string("st_panda_task_rescue_survivor")
        if survivor_template and survivor_template ~= "" and survivor_template ~= "random" and panda_npc_creator and panda_npc_creator.spawn_custom_npc then
            panda_npc_creator.spawn_custom_npc(survivor_template, { smart_ref = smart_ref, conv_data = conv_data })
            if panda_npc_creator.get_active_npc_id then
                survivor_id = panda_npc_creator.get_active_npc_id(survivor_template)
            end
            survivor_label = survivor_template
        else
            local smart = resolve_smart_from_reference(smart_ref)
            if smart then
                local spos = get_position_from_object(smart)
                local slvid = smart.m_level_vertex_id
                local sgvid = smart.m_game_vertex_id
                local sec = find_squad_section("stalker")
                if spos and sec then
                    local sp, sl, sg = find_spawn_point_near_smart(2, 4, spos, slvid, sgvid)
                    local survivor_squad = create_squad_safely(sec, sp or spos, sl or slvid, sg or sgvid)
                    if survivor_squad and survivor_squad.clsid and survivor_squad:clsid() == clsid.online_offline_group_s then
                        survivor_squad_obj = survivor_squad
                        -- Pin the survivor squad to the smart terrain so they
                        -- don't wander while the player heads over.
                        survivor_squad.scripted_target = tostring(smart.id)
                        survivor_squad.rush_to_target = false
                        if type(survivor_squad.squad_members) == "function" then
                            for member in survivor_squad:squad_members() do
                                if not survivor_id then survivor_id = member.id end
                            end
                        end
                    end
                end
            end
        end

        -- Vanilla-style hostage: keep them out of combat with the captors.
        -- Friendly relation made the captors and survivor enemies of each
        -- other and they fought instead of holding. Apply hostage state
        -- (neutral, invulnerable, ignores combat) so they sit in prisoner
        -- pose until the player clears the area.
        if survivor_squad_obj then
            apply_spawned_faction_relation(survivor_squad_obj, "hostage")
        end
        apply_rescue_survivor_animation(survivor_id)
        mark_npc_as_hostage(survivor_id, smart_ref)

        local destination_map_id, destination_label = get_smart_task_target(smart_ref)
        local bridge = ensure_panda_task_bridge()
        if not destination_map_id then
            printf("PANDA_IC: panda_task_rescue destination resolve failed for '%s'", tostring(smart_ref))
        elseif not bridge then
            printf("PANDA_IC: panda_task_rescue ignored (bridge unavailable)")
        else
            local spawn_radius = PANDA.get_config("location_watch_radius") or 85
            local slot_id, err = bridge.create_task(build_bridge_task_params("rescue", {
                destination_ref = smart_ref,
                destination_map_id = destination_map_id,
                destination_label = destination_label,
                location_label = destination_label,
                target_radius = spawn_radius,
                timeout_seconds = timeout,
                success_turn = s_turn,
                fail_turn = f_turn,
                target_squad_ids = {},
                target_npc_id = survivor_id,
                target_label = survivor_label,
                spawn_pending = true,
            }))
            if not slot_id then
                printf("PANDA_IC: panda_task_rescue failed (%s)", tostring(err))
            else
                task_given = true
                push_task_start_message("st_pda_ic_task_rescue_start")

                -- Defer hostile spawn until the player enters the smart terrain
                -- watch radius. Mirrors panda_task_eliminate. The internal trigger
                -- spawns one squad per registered command, so we register `squad_count`
                -- copies. skip_map_spot=true so the rescue task's destination
                -- marker isn't duplicated by a primary_object spot.
                local ref = register_location_reference(
                    smart_ref, sender_npc_name, sender_npc_id, spawn_radius, sender_contact_id,
                    { skip_map_spot = true }
                )
                if ref then
                    for _ = 1, squad_count do
                        table.insert(ref.trigger_cmds, table.concat({
                            "_panda_eliminate_spawn_internal",
                            tostring(enemy_squad),
                            tostring(smart_ref),
                            tostring(slot_id),
                            tostring(enemy_state),
                        }, ":"))
                    end
                end
            end
        end
    end

            -- Dead Drop: deposit item at marked stash location
            -- Syntax: panda_task_dead_drop:<item_section>:<destination_smart>:<timeout>:<success_turn>:<fail_turn>
end

handlers["panda_task_dead_drop"] = function(parts, cmd_str, cmd)
    local item_sec = parts[2]
    local dest_smart = parts[3]
    local timeout = tonumber(parts[4]) or 600
    local s_turn = tonumber(parts[5])
    local f_turn = tonumber(parts[6])
    if not item_sec or not dest_smart or not s_turn then
        printf("PANDA_IC: panda_task_dead_drop missing params in '%s'", tostring(cmd_str))
    else
        local radius = PANDA.get_config("location_watch_radius") or 50
        local destination_map_id, destination_label = get_smart_task_target(dest_smart)
        local bridge = ensure_panda_task_bridge()
        if not destination_map_id then
            printf("PANDA_IC: panda_task_dead_drop destination resolve failed for '%s'", tostring(dest_smart))
        elseif not bridge then
