handlers["reward_money"] = function(parts, cmd_str, cmd)
    local reward = tonumber(parts[2]) or 0
    db.actor:give_money(reward)
    push_money_notification(reward)
end

handlers["punish_money"] = function(parts, cmd_str, cmd)
    local amt = tonumber(parts[2]) or 0
    local removed = 0
    if db.actor:money() >= amt then
        db.actor:give_money(-amt)
        removed = amt
    else
        removed = db.actor:money()
        db.actor:give_money(-removed)
    end
    push_money_notification(-removed)

            -- Custom NPC spawn (replaces spawn_hostile / spawn_friendly / spawn_npc / spawn_companion).
            -- Template defined in XML: st_panda_npc_template_<id>
            -- Examples:
            --   spawn_custom_npc:informant              (near player, immediate)
            --   spawn_custom_npc:hired_guns:5           (near player, 5s delay)
            --   spawn_custom_npc_at:dealer:bar_arena_base
            --   spawn_custom_npc_at:bouncer:esc_smart:3
            --   spawn_npc_squad:army_sim_squad_novice:50:10
            --   spawn_npc_squad_at_smart:army_sim_squad_novice:esc_smart
end

handlers["spawn_custom_npc"] = function(parts, cmd_str, cmd)
    local tpl_id = parts[2]
    local delay  = tonumber(parts[3]) or 0
    if not tpl_id or tpl_id == "" then
        printf("PANDA_IC: spawn_custom_npc missing template_id in '%s'", tostring(cmd_str))
    elseif delay > 0 then
        local ev_key = "panda_cnpc_" .. tostring(math.random(100000))
        CreateTimeEvent("panda_cnpc_spawn", ev_key, delay, function()
            if ic_is_shutting_down() then return true end
            panda_npc_creator.spawn_custom_npc(tpl_id, { use_player_pos = true, conv_data = conv_data })
            return true
        end)
    else
        panda_npc_creator.spawn_custom_npc(tpl_id, { use_player_pos = true, conv_data = conv_data })
    end
end

handlers["spawn_custom_npc_at"] = function(parts, cmd_str, cmd)
    local tpl_id    = parts[2]
    local smart_ref = parts[3]
    local delay     = tonumber(parts[4]) or 0
    if not tpl_id or tpl_id == "" then
        printf("PANDA_IC: spawn_custom_npc_at missing template_id in '%s'", tostring(cmd_str))
    elseif not smart_ref or smart_ref == "" then
        printf("PANDA_IC: spawn_custom_npc_at missing smart_ref in '%s'", tostring(cmd_str))
    elseif delay > 0 then
        local ev_key = "panda_cnpc_at_" .. tostring(math.random(100000))
        CreateTimeEvent("panda_cnpc_spawn", ev_key, delay, function()
            if ic_is_shutting_down() then return true end
            panda_npc_creator.spawn_custom_npc(tpl_id, { smart_ref = smart_ref, conv_data = conv_data })
            return true
        end)
    else
        panda_npc_creator.spawn_custom_npc(tpl_id, { smart_ref = smart_ref, conv_data = conv_data })
    end
end

handlers["spawn_dead_custom_npc"] = function(parts, cmd_str, cmd)
    -- spawn_dead_custom_npc:<template_id>:<distance>[:<items_plus_separated>][:<delay>]
    local tpl_id = parts[2]
    local distance = tonumber(parts[3])
    local items = parts[4]
    local delay = tonumber(parts[5]) or 0
    if tonumber(items) and not parts[5] then
        delay = tonumber(items) or 0
        items = nil
    end
    if not tpl_id or tpl_id == "" then
        printf("PANDA_IC: spawn_dead_custom_npc missing template_id in '%s'", tostring(cmd_str))
    else
        spawn_dead_custom_npc(tpl_id, nil, distance, items, delay, conv_data)
    end
end

