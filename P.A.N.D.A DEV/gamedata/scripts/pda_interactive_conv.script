            is_panda_ic_shutdown_in_progress = is_panda_ic_shutdown_in_progress,
        })
        return pda_interactive_dialog_anim
    end

    local ok = pcall(function()
        if require then
            require("pda_interactive_dialog_anim")
        end
    end)

    if not ok then
        pcall(function()
            dofile("gamedata\\scripts\\pda_interactive_dialog_anim.script")
        end)
    end

    if pda_interactive_dialog_anim and type(pda_interactive_dialog_anim.configure) == "function" then
