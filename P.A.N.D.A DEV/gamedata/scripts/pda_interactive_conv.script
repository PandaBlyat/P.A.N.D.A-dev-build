    precond_verbose_debug=false,
    -- Notification toggles (default true)
    show_hunt_notifications=true,
    show_companion_notifications=true,
    show_courier_notifications=true
}

function PANDA.get_config(key)
    if ui_mcm then
        -- Keys are stored under the "interactive" group inside the MCM tree
        local val = ui_mcm.get("pda_interactive_conv/interactive/" .. key)
        if val ~= nil then
            if key == "precond_unknown_policy" then
                if val == 1 or val == "1" then return "strict" end
                if val == 2 or val == "2" then return "warn-and-skip" end
                if val == "strict" or val == "warn-and-skip" then return val end
                return MCM_DEFAULTS.precond_unknown_policy
            end
            if key == "location_watch_spot_type" then
                if val == 1 or val == "1" then return "primary_object" end
                if val == 2 or val == "2" then return "secondary_task_location" end
                if val == 3 or val == "3" then return "quest_npc" end
                if val == "primary_object" or val == "secondary_task_location" or val == "quest_npc" then
                    return val
                end
                return MCM_DEFAULTS.location_watch_spot_type or "primary_object"
            end
            return val
        end
    end
    return MCM_DEFAULTS[key]
end

function set_player_chat_online(is_online)
    pda_player_chat_online = is_online ~= false
end

function is_player_chat_online()
    return pda_player_chat_online ~= false
end

