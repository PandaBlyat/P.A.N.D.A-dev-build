    friendly_hostile_ratio=50, min_distance_for_call=30, npc_cooldown=10,
    -- New timing configs
    npc_reply_delay_min=2, npc_reply_delay_max=4,
    outcome_delay_min=1, outcome_delay_max=2,
    branch_delay_min=2, branch_delay_max=4,
