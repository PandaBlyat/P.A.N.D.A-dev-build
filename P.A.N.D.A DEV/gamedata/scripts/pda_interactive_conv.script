-- Find a stash's alife ID by its display name (as stored in st_treasures.xml: e.g. "dark_valley_treasure_1").
-- Mirrors treasure_manager's own level_prefix substitution so both named and level_prefix boxes are matched.
local function find_stash_id_by_name(target_name)
    if not (treasure_manager and treasure_manager.caches) then return nil end
    local gg = game_graph()
    local sim = alife()
    for id, _ in pairs(treasure_manager.caches) do
        local se = sim:object(id)
        if se then
            local raw = se:name()
            local resolved = raw
            if string.find(raw, "level_prefix", 1, true) then
                local lvl = sim:level_name(gg:vertex(se.m_game_vertex_id):level_id())
                resolved = string.gsub(raw, "level_prefix", lvl, 1)
            end
            if resolved == target_name then
                return id
            end
        end
    end
    return nil
end

