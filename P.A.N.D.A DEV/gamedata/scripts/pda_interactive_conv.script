function process_map_attachment_action(entry)
    if type(entry) ~= "table" then
        return false
    end

    if entry.attachment_claimed then
        return false
    end

    if entry.attachment_action == "reward_stash" then
        reveal_random_stash()
        entry.attachment_claimed = true
        return true
    end

    if entry.attachment_action == "reward_stash_custom" then
        local bonus = entry.custom_items or {}
        if treasure_manager and treasure_manager.create_random_stash then
            treasure_manager.create_random_stash(nil, nil, bonus, true)
        end
        entry.attachment_claimed = true
        return true
    end

    if entry.attachment_action == "reward_stash_at" then
        local id = find_stash_id_by_name(entry.stash_name)
        if id then
            treasure_manager.set_random_stash(nil, nil, nil, id)
        else
            printf("PANDA_IC: reward_stash_at | stash '%s' not found, falling back to random", tostring(entry.stash_name))
            reveal_random_stash()
        end
        entry.attachment_claimed = true
        return true
    end

    if entry.attachment_action == "reward_stash_items_at" then
        local bonus = entry.custom_items or {}
        local id = find_stash_id_by_name(entry.stash_name)
        if id then
            treasure_manager.set_random_stash(nil, nil, #bonus > 0 and bonus or nil, id)
        else
            printf("PANDA_IC: reward_stash_items_at | stash '%s' not found, falling back to random", tostring(entry.stash_name))
            if treasure_manager and treasure_manager.create_random_stash then
                treasure_manager.create_random_stash(nil, nil, #bonus > 0 and bonus or nil, true)
            end
        end
        entry.attachment_claimed = true
        return true
    end

    return false
end


-- Helper to find NPC server object by character name
function get_npc_by_name(name)
    for i = 1, 65534 do
        local se_obj = alife_object(i)
        if se_obj and se_obj:character_name() == name then
            return se_obj
        end
    end
    return nil
end
-- ============================================================
-- ENGINE OVERRIDES
-- ============================================================
local _overrides_done = false
function setup_engine_overrides()
    if _overrides_done then return end
    if not db.actor then return end

    local o_get_npc = mob_trade.GetTalkingNpc
    mob_trade.GetTalkingNpc = function()
        if fake_talking_npc_id then
            return level.object_by_id(fake_talking_npc_id)
        end
        return o_get_npc()
    end

    local o_is_talk = db.actor.is_talking
    db.actor.is_talking = function(...)
        if fake_talking_npc_id then return true end
        return o_is_talk(...)
    end

    local o_get_spk = _G.get_speaker
    _G.get_speaker = function(...)
        if fake_talking_npc_id then
            return level.object_by_id(fake_talking_npc_id)
        end
        return o_get_spk(...)
    end

    local o_give_msg = db.actor.give_talk_message2
    db.actor.give_talk_message2 = function(...)
        if fake_talking_npc_id then
            return
        else
            return o_give_msg(...)
        end
    end

    _overrides_done = true
end

-- ============================================================
-- TASK DISCOVERY 
-- ============================================================
function discover_all_available_tasks()
    local player_comm = get_actor_true_community() or "stalker"
    local eligible_npcs = get_eligible_npcs_for_community(player_comm)
    if #eligible_npcs == 0 then return {} end

    for _, npc_se in ipairs(eligible_npcs) do
        local npc_obj = level.object_by_id(npc_se.id)
        if npc_obj then
            fake_talking_npc_id = npc_se.id
            local is_sim = string.find(npc_obj:section(), "sim_") ~= nil
            axr_task_manager.generate_available_tasks(npc_obj, is_sim)
            fake_talking_npc_id = nil
        end
    end

    local master_job_list = {}
    for _, npc_se in ipairs(eligible_npcs) do
        local task_list = axr_task_manager.available_tasks[npc_se.id]
        if task_list and #task_list > 0 then
            for _, task_id in ipairs(task_list) do
                local category = TASK_ID_TO_CAT[task_id]
                if category then
                    table.insert(master_job_list, {
                        npc_se = npc_se,
                        task_id = task_id,
                        category = category
                    })
                end
            end
        end
    end

    printf("Discovered %d total available jobs from %d NPCs.", #master_job_list, #eligible_npcs)
    return master_job_list
end

-- ============================================================
-- NPC COOLDOWN HELPERS
-- ============================================================
local function is_npc_on_cooldown(npc_id)
    local last = npc_last_used[npc_id]
    if not last then return false end
    local cd_min = PANDA.get_config("npc_cooldown") or 10
    return (game.get_game_time():diffSec(last) / 60) < cd_min
end

record_npc_use = function(npc_id)
    npc_last_used[npc_id] = game.get_game_time()
end

-- Vanilla patterns:
--   * Story/important NPCs have a story id (get_object_story_id(id) ~= nil)
--   * Simulated NPCs are spawned from sim_* sections (most commonly sim_default_*)
-- We only want simulated stalkers for random PDA conversations.
local function is_simulated_conversation_npc(npc_obj, npc_se, npc_id)
    if not npc_id then return false end

    if get_object_story_id(npc_id) then
        return false
    end

    local section = nil
    if npc_obj and type(npc_obj.section) == "function" then
        section = npc_obj:section()
    elseif npc_se and type(npc_se.section_name) == "function" then
        section = npc_se:section_name()
    end

    if not section or section == "" then
        return false
    end

    return string.find(section, "sim_default_") ~= nil or string.find(section, "sim_") ~= nil
end

-- ============================================================
-- NPC FILTERING (with cooldown check)
-- ============================================================
function get_friendly_npcs()
    local friendly = {}
    local online = db.OnlineStalkers or {}
    local min_dist = PANDA.get_config("min_distance_for_call") or 150
    local player_pos = db.actor:position()
    local player_comm = get_actor_true_community() or "stalker"

    for i = 1, #online do
        local id = online[i]
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive() and not obj:is_talking() 
           and not obj:best_enemy() and id ~= last_conv_npc_id and not is_npc_on_cooldown(id) then
            local comm = obj:character_community()
            if comm and comm ~= "trader" and comm ~= "actor" and comm ~= "zombied" and comm ~= "monolith" then
                if obj:relation(db.actor) ~= game_object.enemy or comm == player_comm then
                    local dist = player_pos:distance_to(obj:position())
                    if dist >= min_dist then
                        local se = alife_object(id)
                        if se and (not se.squad_id or se.squad_id ~= db.actor:squad_id()) and is_simulated_conversation_npc(obj, se, id) then
                            table.insert(friendly, se)
                        end
                    end
                end
            end
        end
    end

    local max = PANDA.get_config("max_npcs_per_trigger") or 10
    return limit_random_list(friendly, max)
end

function get_hostile_npcs()
    local hostile = {}
    local online = db.OnlineStalkers or {}
    local min_dist = PANDA.get_config("min_distance_for_call") or 100
    local player_pos = db.actor:position()
    local player_comm = get_actor_true_community() or "stalker"

    for i = 1, #online do
        local id = online[i]
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive() and not obj:is_talking()
           and not obj:best_enemy() and id ~= last_conv_npc_id and not is_npc_on_cooldown(id) then
            local comm = obj:character_community()
            if comm and comm ~= "trader" and comm ~= "actor" and comm ~= "zombied" and comm ~= "monolith" then
                if obj:relation(db.actor) == game_object.enemy and comm ~= player_comm then
                    local dist = player_pos:distance_to(obj:position())
                    if dist >= min_dist then
                        local se = alife_object(id)
                        if se and (not se.squad_id or se.squad_id ~= db.actor:squad_id()) and is_simulated_conversation_npc(obj, se, id) then
                            table.insert(hostile, se)
                        end
                    end
                end
            end
        end
    end

    local max = PANDA.get_config("max_npcs_per_trigger") or 10
    return limit_random_list(hostile, max)
end

-- Get ALL eligible NPCs regardless of relation (for merged conversation system).
-- Preconditions on each conversation handle friendly/hostile filtering via goodwill.
function get_all_eligible_npcs()
    local npcs = {}
    local online = db.OnlineStalkers or {}
    local min_dist = PANDA.get_config("min_distance_for_call") or 100
    local player_pos = db.actor:position()

    for i = 1, #online do
        local id = online[i]
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive() and not obj:is_talking()
           and not obj:best_enemy() and id ~= last_conv_npc_id and not is_npc_on_cooldown(id) then
            local comm = obj:character_community()
            if comm and comm ~= "trader" and comm ~= "actor" and comm ~= "zombied" and comm ~= "monolith" then
                local dist = player_pos:distance_to(obj:position())
                if dist >= min_dist then
                    local se = alife_object(id)
                    if se and (not se.squad_id or se.squad_id ~= db.actor:squad_id()) and is_simulated_conversation_npc(obj, se, id) then
                        table.insert(npcs, se)
                    end
                end
            end
        end
    end

    local max = PANDA.get_config("max_npcs_per_trigger") or 10
    return limit_random_list(npcs, max)
end

function get_eligible_npcs_for_community(player_comm)
    local eligible = {}
    local online = db.OnlineStalkers or {}
    for i = 1, #online do
        local id = online[i]
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive() and not obj:is_talking()
           and not obj:best_enemy() and id ~= last_conv_npc_id and not is_npc_on_cooldown(id) then
            local comm = obj:character_community()
            if comm and comm ~= "trader" and comm ~= "actor" and comm ~= "zombied" and comm ~= "monolith" then
                if comm == player_comm or PANDA.get_config("allow_cross_faction") then
                    local se = alife_object(id)
                    if se and (not se.squad_id or se.squad_id ~= db.actor:squad_id()) and is_simulated_conversation_npc(obj, se, id) then
                        table.insert(eligible, se)
                    end
                end
            end
        end
    end

    local max = PANDA.get_config("max_npcs_per_trigger") or 10
    return limit_random_list(eligible, max)
end

function pick_random_npc_from_list(list)
    if #list == 0 then return nil end
    return list[math.random(#list)]
end

function find_npc_with_task()
    local jobs = discover_all_available_tasks()
    if #jobs == 0 then
        printf("No available tasks found.")
        return nil
    end

    local valid_jobs = {}
    for _, job in ipairs(jobs) do
        local npc_obj = level.object_by_id(job.npc_se.id)
        if npc_obj and npc_obj:alive() and not npc_obj:is_talking() and not is_npc_on_cooldown(job.npc_se.id) then
            table.insert(valid_jobs, job)
        end
    end

    if #valid_jobs == 0 then
        printf("All task‑givers became invalid or on cooldown.")
        return nil
    end

    local chosen = valid_jobs[math.random(#valid_jobs)]
    return chosen.npc_se, chosen.task_id, chosen.category
end

function panda_give_task(task_id, npc_id)
    if not task_id or not npc_id then return false end
    local npc_obj = level.object_by_id(npc_id)
    if not npc_obj then return false end

    -- FIX: Prevent giving a task that is already active (avoids resetting/looping delivery tasks)
    if db.actor:get_task(task_id, true) then
        printf("Task %s is already active!", task_id)
        return false
    end

    local prev_fake_id = fake_talking_npc_id
    fake_talking_npc_id = npc_id

    local original_dist_le = xr_conditions.dist_to_actor_le
    xr_conditions.dist_to_actor_le = function() return true end

    local old_abort = _G.abort
    _G.abort = function(msg, ...)
        if PANDA.get_config("debug_logging") then
            _G.printf("PANDA_IC: Suppressed abort (non-critical): %s", msg or "unknown error")
        end
    end

    local ok, err = pcall(function()
        local on_job_descr = task_manager.task_ini:r_string_ex(task_id, "on_job_descr")
        if on_job_descr then
            local cond_ok, cond = pcall(xr_logic.parse_condlist, db.actor, "task_manager", "condlist", on_job_descr)
            if cond_ok and cond then
                -- FIX: Pass 'npc_obj' instead of 'db.actor' as the second argument.
                -- Many engine tasks (especially delivery) use the npc argument to generate the target correctly!
                pcall(xr_logic.pick_section_from_condlist, db.actor, npc_obj, cond)
            else
                printf("Warning: Failed to parse on_job_descr for task %s: %s", task_id, tostring(cond))
            end
        end

        local fetch = task_manager.task_ini:r_string_ex(task_id, "fetch_descr")
        if fetch then
            pcall(axr_task_manager.trigger_fetch_func, task_id)
        end

        task_manager.get_task_manager():give_task(task_id, npc_id)
    end)

    _G.abort = old_abort
    xr_conditions.dist_to_actor_le = original_dist_le
    fake_talking_npc_id = prev_fake_id

    if not ok then
        printf("Error giving task: %s", tostring(err))
        return false
    end

    if not db.actor:get_task(task_id, true) then
        printf("PANDA: Task [%s] failed to assign post-pcall (Precondition failure?)", task_id)
        return false
    end
    return true
end

-- ============================================================
-- PRECONDITIONS & CONVERSATION SELECTION
-- ============================================================
local RANK_ORDER = {
    novice=1, trainee=2, experienced=3, professional=4,
    veteran=5, expert=6, master=7, legend=8
}

-- ============================================================
-- SMART TERRAIN LEVEL TABLES
-- Live in pda_ic_smart_terrains.script (extracted from this file).
-- Wrappers below preserve the public function names so the local
-- sub_placeholders helper and any external callers keep working.
-- ============================================================
function resolve_level_smart_terrain(level_key)
    return pda_ic_smart_terrains.resolve_level_smart_terrain(level_key)
end

function resolve_level_smart_terrain_name(level_key)
    return pda_ic_smart_terrains.resolve_level_smart_terrain_name(level_key)
end

local function build_substitution_table(npc_name, npc_faction, npc_se, contact_id)
    local act = db.actor
    local player_name = act and act:character_name() or "Stalker"
    local player_comm = get_actor_true_community() or "stalker"
    if player_comm == "actor" then player_comm = "stalker" end

    local display_npc_fac = (npc_faction == "loner") and "stalker" or (npc_faction or "stalker")
    local cur_level = level and level.name and level.name() or "unknown"

    -- Player money
    local money = act and act:money() or 0
    -- Player rank
    local rank_name = (act and ranks and ranks.get_obj_rank_name) and ranks.get_obj_rank_name(act) or "unknown"
    -- Player reputation
    local reputation = act and act.character_reputation and act:character_reputation() or 0
    -- Companion count
    local comp_count = 0
    if axr_companions and axr_companions.companion_squads then
        for _ in pairs(axr_companions.companion_squads) do comp_count = comp_count + 1 end
    end
    -- Time of day
    local gt = game.get_game_time()
    local Y, M, D, h, mi = 0, 0, 0, 0, 0
    Y, M, D, h, mi = gt:get(Y, M, D, h, mi, 0, 0)
    local time_of_day = (h >= 6 and h < 12) and "morning" or (h >= 12 and h < 18) and "afternoon" or (h >= 18 and h < 22) and "evening" or "night"

    -- NPC rank
    local npc_rank_name = "unknown"
    if npc_se and ranks and ranks.get_obj_rank_name then
        local npc_obj = level.object_by_id(npc_se.id)
        if npc_obj then
            npc_rank_name = ranks.get_obj_rank_name(npc_obj) or "unknown"
        end
    end

    -- Player health percentage
    local player_health = act and math.floor((act.health or 0) * 100) or 0

    -- Kill statistics
    local stalker_kills = 0
    local mutant_kills = 0
    if act_statistic and act_statistic.get_stat then
        stalker_kills = act_statistic.get_stat("killed_stalkers") or 0
        mutant_kills = act_statistic.get_stat("killed_monsters") or 0
    elseif game_stats and game_stats.get_actor_stat then
        stalker_kills = game_stats.get_actor_stat("killed_stalkers") or 0
        mutant_kills = game_stats.get_actor_stat("killed_monsters") or 0
    end

    -- Relationship score
    local rel_score = 0
    if contact_id and relationship_scores then
        rel_score = relationship_scores[contact_id] or 0
    elseif npc_se and relationship_scores then
        rel_score = relationship_scores[npc_se.id] or 0
    end

    -- Game days survived
    local game_days = level.get_time_days and level.get_time_days() or 0

    -- Player satiety
    local player_satiety = 100
    if act and act.cast_Actor and act:cast_Actor() and act:cast_Actor().conditions then
        local cond = act:cast_Actor():conditions()
        if cond and cond.GetSatiety then
            player_satiety = math.floor(cond:GetSatiety() * 100)
        end
    end

    -- Player radiation
    local player_radiation = act and math.floor((act.radiation or 0) * 100) or 0

    -- Current weather
    local weather_name = level.get_weather and tostring(level.get_weather()) or "unknown"

    -- Total carry weight
    local total_weight = act and act.get_total_weight and string.format("%.1f", act:get_total_weight()) or "0"

    return {
        ["player_name"] = player_name,
        ["npc_name"] = npc_name or "Stalker",
        ["player_faction"] = game.translate_string("st_faction_"..player_comm),
        ["npc_faction"] = game.translate_string("st_faction_"..display_npc_fac),
        ["current_level"] = game.translate_string(cur_level),
        ["player_money"] = tostring(money),
        ["player_rank"] = rank_name,
        ["player_reputation"] = tostring(reputation),
        ["companion_count"] = tostring(comp_count),
        ["time_of_day"] = time_of_day,
        ["game_hour"] = string.format("%02d:%02d", h, mi),
        ["npc_rank"] = npc_rank_name,
        ["player_health"] = tostring(player_health),
        ["stalker_kills"] = tostring(stalker_kills),
        ["mutant_kills"] = tostring(mutant_kills),
        ["relationship_score"] = tostring(rel_score),
        ["game_days"] = tostring(game_days),
        ["player_satiety"] = tostring(player_satiety),
        ["player_radiation"] = tostring(player_radiation),
        ["player_rank_name"] = rank_name,
        ["npc_rank_name"] = npc_rank_name,
        ["weather"] = weather_name,
        ["total_weight"] = total_weight,
        ["game_day_number"] = tostring(D),
    }
end

-- Cache of resolved smart terrain placeholders per-conversation to keep
-- references consistent within a single conversation flow.
local _st_resolve_cache = {}

function clear_st_resolve_cache()
    _st_resolve_cache = {}
end

sub_placeholders = function(str, npc_name, npc_faction, npc_se, contact_id)
    if not str or str == "" then return str end

    -- First resolve any %<level>_panda_st% patterns.
    -- Each unique level key gets resolved once per conversation (cached)
    -- so that all turns referencing e.g. %cordon_panda_st% get the same location.
    str = string.gsub(str, "%%(%w+)_panda_st%%", function(level_key)
        if not _st_resolve_cache[level_key] then
            local translated, raw_key = resolve_level_smart_terrain_name(level_key)
            if translated then
                _st_resolve_cache[level_key] = { name = translated, key = raw_key }
            else
                printf("failed to resolve %%%s_panda_st%% placeholder", tostring(level_key))
                return "%"..level_key.."_panda_st%"
            end
        end
        return _st_resolve_cache[level_key].name
    end)

    -- Resolve %<level>_panda_st_key% placeholders for outcome commands.
    str = string.gsub(str, "%%(%w+)_panda_st_key%%", function(level_key)
        if not _st_resolve_cache[level_key] then
            local translated, raw_key = resolve_level_smart_terrain_name(level_key)
            if translated then
                _st_resolve_cache[level_key] = { name = translated, key = raw_key }
            else
                printf("failed to resolve %%%s_panda_st_key%% placeholder", tostring(level_key))
                return "%"..level_key.."_panda_st_key%"
            end
        end
        return _st_resolve_cache[level_key].key
    end)

    -- Then do normal $placeholder substitutions
    local subs = build_substitution_table(npc_name, npc_faction, npc_se, contact_id)
    return utils_data.parse_string_keys(str, subs)
end

-- Resolve %<level>_panda_st_key% to the raw smart terrain key (for use in outcomes).
-- Must be called AFTER sub_placeholders has resolved the cache for that level.
function get_cached_st_key(level_key)
    local cached = _st_resolve_cache[level_key]
    return cached and cached.key or nil
end

local function get_rank_order_value(rank_name)
    if not rank_name then return 1 end
    return RANK_ORDER[tostring(rank_name):lower()] or 1
end

get_npc_rank_name = function(npc_se)
    if not npc_se or not ranks or not ranks.get_obj_rank_name then
        return nil
    end

    local npc_obj = level.object_by_id(npc_se.id)
    if not npc_obj then
        return nil
    end

    return ranks.get_obj_rank_name(npc_obj)
end

local function get_npc_faction(npc_se)
    if not npc_se then
        return nil
    end

    local npc_obj = level.object_by_id(npc_se.id)
    if npc_obj and npc_obj.character_community then
        return normalize_faction(npc_obj:character_community())
    end

    -- Fallbacks for cases where only server entity data is available.
    if npc_se.community then
        return normalize_faction(npc_se.community)
    end

    if npc_se.m_community then
        return normalize_faction(npc_se.m_community)
    end

    return nil
end

local function get_manager_remaining_seconds(manager_module, getter_name, delta_key, last_time_key)
    if not manager_module or not manager_module[getter_name] then
        return nil
    end

    local manager = manager_module[getter_name]()
    if not manager then
        return nil
    end

    local delta = manager[delta_key]
    local last_time = manager[last_time_key]
    if not delta or not last_time then
        return nil
    end

    local now = game.get_game_time()
    if not now then
        return nil
    end

    return math.floor(delta - now:diffSec(last_time))
end

local function is_weather_fx_active_now()
    local active = false

    if level_weathers and level_weathers.get_weather_manager then
        local wm = level_weathers.get_weather_manager()
        if wm and wm.weather_fx then
            active = true
        end
    end

    if not active and level and level.get_wfx_time then
        active = (level.get_wfx_time() or 0) > 0
    end

    return active
end

function ensure_pda_interactive_preconditions()
    if pda_interactive_preconditions and type(pda_interactive_preconditions.check) == "function" then
        return pda_interactive_preconditions
    end

    local ok = pcall(function()
        if require then
            require("pda_interactive_preconditions")
        end
    end)

    if not ok then
        pcall(function()
            dofile("gamedata\\scripts\\pda_interactive_preconditions.script")
        end)
    end

    if pda_interactive_preconditions and type(pda_interactive_preconditions.check) == "function" then
        return pda_interactive_preconditions
    end

    printf("PANDA_IC: warning: pda_interactive_preconditions unavailable")
    return nil
end

function build_precondition_context()
    return {
        PANDA = PANDA,
        str_explode = str_explode,
        completed_storylines = completed_storylines,
        relationship_scores = relationship_scores,
        get_anomaly_artifact_adapter = get_anomaly_artifact_adapter,
        get_rank_order_value = get_rank_order_value,
        get_npc_rank_name = get_npc_rank_name,
        get_npc_faction = get_npc_faction,
        get_npc_position = get_npc_position,
        resolve_actor_id_for_goodwill = resolve_actor_id_for_goodwill,
        resolve_smart_position_from_reference = resolve_smart_position_from_reference,
        normalize_faction = normalize_faction,
        get_manager_remaining_seconds = get_manager_remaining_seconds,
        is_weather_fx_active_now = is_weather_fx_active_now,
    }
end

function check_preconditions_generic(precond_key, npc_se)
    local mod = ensure_pda_interactive_preconditions()
    if mod and type(mod.check) == "function" then
        return mod.check(precond_key, npc_se, build_precondition_context())
    end
    return false
end

function is_conv_on_cooldown_generic(key)
    local last = conv_last_played[key]
    if not last then return false end
    local cd_min = PANDA.get_config("default_cooldown")
    return (game.get_game_time():diffSec(last) / 60) < cd_min
end

-- Look up the author-defined storyline id (set in the editor's opener panel).
-- Returns nil if not set.
local function get_conversation_storyline_id(prefix, faction, conv_id)
    if not (faction and conv_id) then return nil end
    local base
    if prefix == "task" or not prefix then
        base = "st_pda_ic_" .. tostring(faction) .. "_" .. tostring(conv_id)
    else
        base = "st_pda_ic_" .. tostring(prefix) .. "_" .. tostring(faction) .. "_" .. tostring(conv_id)
    end
    local key = base .. "_storyline_id"
    local raw = game.translate_string(key)
    if not raw or raw == key then return nil end
    raw = tostring(raw):gsub("^%s+", ""):gsub("%s+$", "")
    if raw == "" then return nil end
    return raw
end

normalize_npc_ref = function(value)
    if value == nil then return nil end
    local ref = tostring(value):lower():gsub("^%s+", ""):gsub("%s+$", "")
    if ref == "" then return nil end
    local kind, id = ref:match("^(story):([^,%s]+)$")
    if not kind then
        kind, id = ref:match("^(custom):([^,%s]+)$")
    end
    if not kind or not id or id == "" then return nil end
    return kind .. ":" .. id
end

normalize_npc_refs = function(refs)
    local out = {}
    local seen = {}
    if type(refs) == "string" then
        for raw in tostring(refs):gmatch("([^,]+)") do
            local ref = normalize_npc_ref(raw)
            if ref and not seen[ref] then
                out[#out + 1] = ref
                seen[ref] = true
            end
        end
    elseif type(refs) == "table" then
        for _, raw in pairs(refs) do
            local ref = normalize_npc_ref(raw)
            if ref and not seen[ref] then
                out[#out + 1] = ref
                seen[ref] = true
            end
        end
    end
    return out
end

get_conversation_npc_refs = function(prefix, faction, conv_id)
    if not (faction and conv_id) then return {} end
    local base
    if prefix == "task" or not prefix then
        base = "st_pda_ic_" .. tostring(faction) .. "_" .. tostring(conv_id)
    else
        base = "st_pda_ic_" .. tostring(prefix) .. "_" .. tostring(faction) .. "_" .. tostring(conv_id)
    end
    return normalize_npc_refs(read_trimmed_string_key(base .. "_npc_refs"))
end

npc_refs_overlap = function(left_refs, right_refs)
    if type(left_refs) ~= "table" or type(right_refs) ~= "table" then
        return false, nil
    end
    local right = {}
    for _, raw in pairs(right_refs) do
        local ref = normalize_npc_ref(raw)
        if ref then right[ref] = true end
    end
    for _, raw in pairs(left_refs) do
        local ref = normalize_npc_ref(raw)
        if ref and right[ref] then
            return true, ref
        end
    end
    return false, nil
end

local function is_conversation_repeatable(prefix, faction, conv_id)
    local base
    if prefix == "task" or not prefix then
        base = "st_pda_ic_" .. tostring(faction) .. "_" .. tostring(conv_id)
    else
        base = "st_pda_ic_" .. tostring(prefix) .. "_" .. tostring(faction) .. "_" .. tostring(conv_id)
    end
    local key = base .. "_repeatable"
    local raw = game.translate_string(key)
    if raw == key then
        return true
    end
    raw = tostring(raw or ""):lower():match("^%s*(.-)%s*$")
    return not (raw == "0" or raw == "false" or raw == "no" or raw == "once")
end

local function get_panda_story_prefixes(faction)
    local prefixes = { "panda" }
    local seen = { panda = true }
    local key = "st_pda_ic_panda_" .. tostring(faction) .. "_prefixes"
    local raw = game.translate_string(key)
    if raw and raw ~= key then
        for prefix in tostring(raw):gmatch("[^,%s]+") do
            prefix = tostring(prefix):gsub("^%s+", ""):gsub("%s+$", "")
            if prefix ~= "" and not seen[prefix] then
                prefixes[#prefixes + 1] = prefix
                seen[prefix] = true
            end
        end
    end
    return prefixes
end

function pick_random_conv_id_generic(prefix, xml_fac, category, npc_se)
    local base
    if prefix == "task" or not prefix then
        base = "st_pda_ic_"
    else
        base = "st_pda_ic_" .. prefix .. "_"
    end

    local max_id = 0
    while true do
        local p = base .. xml_fac .. "_" .. tostring(max_id+1) .. "_open"
        if game.translate_string(p) == p then break end
        max_id = max_id + 1
    end
    if max_id == 0 then return nil end

    local candidates = {}  -- { id = cid, weight = number }
    local mode = PANDA.get_config("cooldown_mode")
    local penalty = PANDA.get_config("cooldown_penalty") / 100  -- as multiplier
    local hard_min = PANDA.get_config("cooldown_hard_min") * 60  -- convert to seconds

    for i = 1, max_id do
        local cid = i
        local skip = false

        -- Skip F2F-only conversations (they are triggered face-to-face, not via PDA)
        local start_mode_key = base .. xml_fac .. "_" .. tostring(cid) .. "_start_mode"
        local start_mode_val = game.translate_string(start_mode_key)
        if start_mode_val ~= start_mode_key and start_mode_val == "f2f" then skip = true end

        -- Preconditions
        if not skip then
            local precond_key = base .. xml_fac .. "_" .. tostring(cid) .. "_precond"
            if not check_preconditions_generic(precond_key, npc_se) then skip = true end
        end
        if not skip then
            local branch_precond_key = base .. xml_fac .. "_" .. tostring(cid) .. "_branch_precond"
            if not check_preconditions_generic(branch_precond_key, npc_se) then skip = true end
        end

        -- Category filtering for task conversations
        if not skip and prefix == "task" then
            local has_cat = false
            local target_cat = CATEGORY_ALIAS[category] or category
            for oi = 1, 4 do
                local outcome_key = base .. xml_fac .. "_" .. cid .. "_outcome_" .. oi
                local os = game.translate_string(outcome_key)
                if os and os ~= outcome_key then
                    local cat = string.match(os, "give_task_cat:([^,]+)")
                    if cat and (CATEGORY_ALIAS[cat] or cat) == target_cat then
                        has_cat = true
                        break
                    end
                    if not cat and (target_cat == "random" or target_cat == "any") then
                        has_cat = true
                        break
                    end
                end
            end
            if not has_cat then skip = true end
        end

        if skip then goto continue end

        -- Cooldown handling
        local cooldown_key = (prefix or "task") .. "_" .. xml_fac .. "_" .. cid
        local last = conv_last_played[cooldown_key]
        if last and not is_conversation_repeatable(prefix, xml_fac, cid) then
            skip = true
            goto continue
        end
        local on_cooldown = false
        local seconds_since = 0
        if last then
            seconds_since = game.get_game_time():diffSec(last)
            on_cooldown = seconds_since < (PANDA.get_config("default_cooldown") * 60)
        end

        if mode == 1 then  -- strict: block if on cooldown
            if on_cooldown then skip = true end
        else  -- flexible
            if on_cooldown then
                -- If within hard minimum, still block
                if seconds_since < hard_min then
                    skip = true
                else
                    -- Apply weight penalty
                    local weight = penalty * 100  -- base weight 100
                    table.insert(candidates, {id = cid, weight = weight})
                end
            else
                -- Not on cooldown, full weight
                table.insert(candidates, {id = cid, weight = 100})
            end
        end

        if not skip and mode == 1 then
            table.insert(candidates, {id = cid, weight = 100})
        end

        ::continue::
    end

    if #candidates == 0 then return nil end

    -- Weighted random selection
    local total_weight = 0
    for _, cand in ipairs(candidates) do
        total_weight = total_weight + cand.weight
    end
    local r = math.random(total_weight)
    local accum = 0
    for _, cand in ipairs(candidates) do
        accum = accum + cand.weight
        if r <= accum then
            return cand.id
        end
    end
    return candidates[1].id  -- fallback
end


-- ============================================================
-- OUTCOME HANDLERS
-- ============================================================

local spawn_squad_at_smart_terrain

function ensure_pda_interactive_outcomes()
    if pda_interactive_outcomes and type(pda_interactive_outcomes.process_command) == "function" then
        return pda_interactive_outcomes
    end

    local ok = pcall(function()
        if require then
            require("pda_interactive_outcomes")
        end
    end)

    if not ok then
        pcall(function()
            dofile("gamedata\\scripts\\pda_interactive_outcomes.script")
        end)
    end

    if pda_interactive_outcomes and type(pda_interactive_outcomes.process_command) == "function" then
        return pda_interactive_outcomes
    end

    printf("PANDA_IC: warning: pda_interactive_outcomes unavailable")
    return nil
end

function format_money_value(amount)
    local n = math.floor(math.abs(tonumber(amount) or 0))
    local grouped = tostring(n)
    while true do
        local next_grouped, replaced = string.gsub(grouped, "^(%-?%d+)(%d%d%d)", "%1 %2")
        grouped = next_grouped
        if replaced == 0 then break end
    end
    return grouped
end

local function apply_outcome_internal(outcome_str, sender_npc_name, sender_faction, sender_npc_id, pre_found_task_id, sender_contact_id, conv_data, channel)
    if is_panda_ic_shutdown_in_progress() then
        return false
    end
    if not outcome_str or outcome_str == "" or outcome_str == "none" then return false end
    local resolved_channel = channel or (conv_data and conv_data.channel) or "pda"
    if conv_data and conv_data.channel == nil then
        conv_data.channel = resolved_channel
    end

    local sender_se = sender_npc_id and alife_object(sender_npc_id) or nil
    outcome_str = sub_placeholders(outcome_str, sender_npc_name, sender_faction, sender_se, sender_contact_id)

    local ctx = {
        PANDA = PANDA,
        FALLBACK_NPC_ICON = FALLBACK_NPC_ICON,
        str_explode = str_explode,
        extract_trailing_task_meta = extract_trailing_task_meta,
        task_given = false,
        task_author_meta = {},
        spawn_mult = (PANDA.get_config("spawn_chance_mult") or 100) / 100,
        sender_npc_name = sender_npc_name,
        sender_faction = sender_faction,
        sender_npc_id = sender_npc_id,
        sender_contact_id = sender_contact_id,
        pre_found_task_id = pre_found_task_id,
        conv_data = conv_data,
        resolved_channel = resolved_channel,
        ensure_panda_task_bridge = ensure_panda_task_bridge,
        get_anomaly_artifact_adapter = get_anomaly_artifact_adapter,
        make_artifact_runtime_task_id = make_artifact_runtime_task_id,
        resolve_artifact_zone_target = resolve_artifact_zone_target,
        is_mutant_squad_key = is_mutant_squad_key,
        normalize_faction = normalize_faction,
        resolve_smart_from_reference = resolve_smart_from_reference,
        resolve_smart_position_from_reference = resolve_smart_position_from_reference,
        get_position_from_object = get_position_from_object,
        get_location_display_name = get_location_display_name,
        register_location_reference = register_location_reference,
        queue_stash_attachment_reward = queue_stash_attachment_reward,
        queue_stash_attachment_reward_custom = queue_stash_attachment_reward_custom,
        find_stash_id_by_name = find_stash_id_by_name,
        queue_stash_attachment_at = queue_stash_attachment_at,
        queue_stash_items_attachment_at = queue_stash_items_attachment_at,
        pick_delivery_target_near_smart = pick_delivery_target_near_smart,
        pick_random_delivery_target = pick_random_delivery_target,
        get_delivery_target_label = get_delivery_target_label,
        request_dialog_npc_animation = request_dialog_npc_animation,
        request_dialog_npc_animation_clear = request_dialog_npc_animation_clear,
        recruit_escort_companion = recruit_escort_companion,
        resolve_escort_target = resolve_escort_target,
        spawn_squad_at_smart_terrain = spawn_squad_at_smart_terrain,
    }

    ctx.build_bridge_task_params = function(family, extra)
        local params = {
            family = family,
            external_task_id = make_panda_runtime_task_id(family, conv_data),
            contact_id = sender_contact_id,
            npc_id = sender_npc_id,
            giver_id = sender_npc_id,
            npc_name = sender_npc_name,
            conv_icon = conv_data and conv_data.npc_icon or FALLBACK_NPC_ICON,
            faction = sender_faction,
            conv_prefix = conv_data and conv_data.prefix or nil,
            conv_id = conv_data and conv_data.conv_id or nil,
            channel = resolved_channel,
            applied_outcomes = conv_data and conv_data.applied_outcomes or {},
            resume_npc_id = conv_data and conv_data.pending_resume_npc_id or nil,
            resume_npc_faction_filters = (conv_data and conv_data.pending_resume_allow_generic_stalker == true and has_values(conv_data.pending_resume_npc_faction_filters)) and conv_data.pending_resume_npc_faction_filters or nil,
            resume_allow_generic_stalker = conv_data and conv_data.pending_resume_allow_generic_stalker == true and has_values(conv_data.pending_resume_npc_faction_filters),
        }
        if type(extra) == "table" then
            for key, value in pairs(extra) do params[key] = value end
        end
        if ctx.task_author_meta.title and params.custom_title == nil then params.custom_title = ctx.task_author_meta.title end
        if ctx.task_author_meta.description and params.custom_description == nil then params.custom_description = ctx.task_author_meta.description end
        return params
    end

    ctx.push_task_start_message = function(text_id)
        if not text_id or not sender_contact_id then return end
        pda_private_add_message(sender_contact_id, sender_npc_name, sender_npc_name, game.translate_string(text_id), conv_data and conv_data.npc_icon or FALLBACK_NPC_ICON, false)
    end

    ctx.get_smart_task_target = function(smart_ref)
        local smart, smart_name = resolve_smart_from_reference(smart_ref)
        local label = get_location_display_name(smart_ref) or smart_name or tostring(smart_ref or "")
        return smart and smart.id or nil, label
    end

    ctx.push_money_notification = function(amount_delta)
        if not sender_contact_id then return end
        local abs_amount = math.abs(tonumber(amount_delta) or 0)
        if abs_amount <= 0 then return end
        local is_gain = amount_delta > 0
        local prefix = is_gain and "+" or "-"
        local icon = is_gain and "ui\\green_ruble" or "ui\\red_ruble"
        local text = string.format("Account %s%s RU", prefix, format_money_value(abs_amount))
        pda_private_add_message(sender_contact_id, sender_npc_name, "System Notification", text, resolve_sender_icon(sender_npc_id), false, nil, nil, icon, { skip_personality = true })
    end

    local mod = ensure_pda_interactive_outcomes()
    if not mod then return false end

    local prev_collector = _panda_ic_runtime.job_spawn_collector
    _panda_ic_runtime.job_spawn_collector = {}
    _panda_ic_runtime.pending_job_params = nil

    local processed_any = false
    for entry in string.gmatch(outcome_str, "([^,]+)") do
        entry = entry:match("^%s*(.-)%s*$")
        if entry ~= "" then
            processed_any = mod.process_command(ctx, entry) == true or processed_any == true
        end
    end

    local collected_squads = _panda_ic_runtime.job_spawn_collector
    _panda_ic_runtime.job_spawn_collector = prev_collector

    if _panda_ic_runtime.pending_job_params and collected_squads then
        local jp = _panda_ic_runtime.pending_job_params
        _panda_ic_runtime.pending_job_params = nil
        local cid = jp.sender_contact_id
        if cid then
            create_pending_job(cid, jp.sender_npc_id, jp.sender_npc_name, jp.sender_faction,
                collected_squads, jp.timeout, jp.success_turn, jp.fail_turn, jp.conv_data, jp.extra)
        else
            printf("PANDA_IC: pause_job has no contact_id, cannot create job")
        end
    else
        _panda_ic_runtime.pending_job_params = nil
    end

    return ctx.task_given == true or processed_any == true
end

function apply_outcome(outcome_str, sender_npc_name, sender_faction, sender_npc_id, pre_found_task_id, sender_contact_id, conv_data, channel)
    return apply_outcome_internal(
        outcome_str,
        sender_npc_name,
        sender_faction,
        sender_npc_id,
        pre_found_task_id,
        sender_contact_id,
        conv_data,
        channel or "pda"
    )
end

function find_squad_section(faction)
    if faction and faction ~= "" and ini_sys:section_exist(faction) then
        return faction
    end
    local tiers = { "_advanced", "_novice", "_veteran", "_alpha" }
    for _, t in ipairs(tiers) do
        local s = faction .. "_sim_squad" .. t
        if ini_sys:section_exist(s) then return s end
    end
    return "merc_sim_squad_advanced" 
end

local MUTANT_SQUADS = {
    "simulation_lurker", "simulation_bloodsucker_1_2", "simulation_psysucker",
    "simulation_snork_2_3", "simulation_fracture", "simulation_mix_dogs",
    "simulation_pseudodog", "simulation_cat", "simulation_chimera",
    "simulation_controller", "simulation_burer", "simulation_boar"
}

function resolve_mutant_section(mutant_type)
    if mutant_type and mutant_type ~= "" and ini_sys:section_exist(mutant_type) then
        return mutant_type
    end
    if mutant_type == "random" then
        return MUTANT_SQUADS[math.random(#MUTANT_SQUADS)]
    end
    for _, s in ipairs(MUTANT_SQUADS) do
        if string.find(s, mutant_type, 1, true) then return s end
    end
    return "simulation_bloodsucker_1_2" 
end

is_mutant_squad_key = function(target)
    if not target or target == "" then
        return false
    end

    if target == "random" then
        return true
    end

    if ini_sys:section_exist(target) then
        local faction = ini_sys:r_string_ex(target, "faction") or ""
        return faction == "monster"
            or faction == "zombied"
            or string.find(faction, "monster_", 1, true) ~= nil
    end

    for _, s in ipairs(MUTANT_SQUADS) do
        if string.find(s, target, 1, true) then
            return true
        end
    end

    return false
end

local function normalize_spawn_relation_mode(relation_mode)
    local normalized = tostring(relation_mode or "default"):lower():gsub("^%s+", ""):gsub("%s+$", "")
    if normalized == "aggressive" or normalized == "agressive" or normalized == "enemy" then
        return "hostile"
    end
    if normalized == "ally" or normalized == "friend" then
        return "friendly"
    end
    if normalized == "" then
        return "default"
    end
    return normalized
end

apply_spawned_faction_relation = function(obj, relation_mode)
    if not obj or obj:clsid() ~= clsid.online_offline_group_s or not db.actor then
        return
    end

    relation_mode = normalize_spawn_relation_mode(relation_mode)
    if relation_mode == "hostile" then
        pcall(function() obj:set_squad_relation("enemy") end)
    elseif relation_mode == "friendly" then
        pcall(function() obj:set_squad_relation("friend") end)
    elseif relation_mode == "neutral" then
        pcall(function() obj:set_squad_relation("neutral") end)
    elseif relation_mode == "hostage" then
        -- Hostage squads stay neutral so the captor faction does not engage them.
        -- We disable combat AI per-member below so they don't shoot back either.
        if obj.set_squad_relation then
            local ok = pcall(obj.set_squad_relation, obj, "neutral")
            if not ok then
                pcall(obj.set_squad_relation, obj, "friend")
            end
        end
        for k in obj:squad_members() do
            local o = level.object_by_id(k.id)
            if o then
                pcall(function() o:set_relation(game_object.neutral, db.actor) end)
                pcall(function() o:force_set_goodwill(0, db.actor) end)
                pcall(function() o:invulnerable(true) end)
                pcall(function() o:give_info_portion("npcx_beh_ignore_combat") end)
                pcall(function() o:give_info_portion("npcx_beh_ignore_actor_enemies") end)
            end
        end
        return
    else
        return
    end

    local relation = relation_mode == "hostile" and game_object.enemy or game_object.friend
    local goodwill = relation_mode == "hostile" and -5000 or 5000

    local function apply_member_relation()
        local touched = 0
        for k in obj:squad_members() do
            local o = level.object_by_id(k.id)
            if o then
                pcall(function() o:set_relation(relation, db.actor) end)
                pcall(function() o:force_set_goodwill(goodwill, db.actor) end)
                if relation_mode == "hostile" then
                    pcall(function() o:set_enemy(db.actor) end)
                end
                touched = touched + 1
            end
        end
        return touched
    end

    local touched = apply_member_relation()
    if relation_mode == "hostile" and touched == 0 and CreateTimeEvent then
        local attempts = 0
        local ev_key = "panda_spawn_relation_" .. tostring(obj.id) .. "_" .. tostring(math.random(100000))
        CreateTimeEvent("pda_ic_spawn", ev_key, 1, function()
            if is_panda_ic_shutdown_in_progress() or not db.actor then
                return true
            end
            attempts = attempts + 1
            local retry_touched = apply_member_relation()
            return retry_touched > 0 or attempts >= 10
        end)
    end
end

-- Hook the NPC into vanilla's hostage table so combat AI and task systems
-- treat them as a captive — the engine refuses to spawn assault tasks on
-- hostage NPCs, and other faction members keep their distance.
function mark_npc_as_hostage(npc_id, smart_ref)
    if not npc_id then
        return
    end

    local function try_mark()
        if not db.actor then
            return true
        end
        local smart = resolve_smart_from_reference(smart_ref)
        local smart_id = smart and smart.id or nil
        if axr_task_manager and axr_task_manager.hostages_by_id then
            axr_task_manager.hostages_by_id[npc_id] = smart_id or true
        end
        local obj = level.object_by_id(npc_id)
        if obj then
            pcall(function() obj:invulnerable(true) end)
            pcall(function() obj:give_info_portion("npcx_beh_ignore_combat") end)
            pcall(function() obj:give_info_portion("npcx_beh_ignore_actor_enemies") end)
            return true
        end
        return false
    end

    if try_mark() then
        return
    end

    local key = "rescue_hostage_" .. tostring(npc_id) .. "_" .. tostring(math.random(100000))
    track_panda_ic_event("pda_ic_spawn", key)
    local attempts = 0
    CreateTimeEvent("pda_ic_spawn", key, 1, function()
        if is_panda_ic_shutdown_in_progress() or not db.actor then
            return true
        end
        attempts = attempts + 1
        if try_mark() or attempts >= 10 then
            return true
        end
        return false
    end)
end

-- Force survivor NPC into kneeling/hostage idle, matching vanilla rescue tasks.
-- Retries briefly because the NPC may not be online yet right after squad creation.
function apply_rescue_survivor_animation(npc_id)
    if not npc_id then
        return
    end

    local function try_set()
        if not db.actor then
            return true
        end
        local obj = level.object_by_id(npc_id)
        if not obj then
            return false
        end
        if state_mgr and state_mgr.set_state then
            -- Vanilla rescue uses `wait_anim = prisoner` (bound captive). Fall back to
            -- sit_knee if prisoner state is unavailable on this Anomaly build.
            local ok = pcall(state_mgr.set_state, obj, "prisoner")
            if not ok then
                ok = pcall(state_mgr.set_state, obj, "sit_knee")
            end
            if ok then
                if save_var then
                    save_var(obj, "task_target", "task_target_hostage")
                    save_var(obj, "panda_rescue_hostage", true)
                end
                return true
            end
        end
        return false
    end

    if try_set() then
        return
    end

    local key = "rescue_anim_" .. tostring(npc_id) .. "_" .. tostring(math.random(100000))
    track_panda_ic_event("pda_ic_spawn", key)
    local attempts = 0
    CreateTimeEvent("pda_ic_spawn", key, 1, function()
        if is_panda_ic_shutdown_in_progress() or not db.actor then
            return true
        end
        attempts = attempts + 1
        if try_set() or attempts >= 10 then
            return true
        end
        return false
    end)
end

-- Detach a freshly-spawned survivor squad from smart-terrain job assignment so
-- the captives don't get pulled into a regular gulag job and wander off. The
-- squad's scripted_target keeps it pinned at the rescue smart, but individual
-- members still need their smart_terrain_id cleared or xr_logic will drag them
-- onto a walker/camper job from the smart.
function detach_rescue_survivor_squad(squad_obj)
    if not squad_obj or squad_obj:clsid() ~= clsid.online_offline_group_s then
        return
    end

    local squad_id = squad_obj.id
    local old_smart_id = squad_obj.smart_id

    if SIMBOARD and old_smart_id and old_smart_id ~= 65535 then
        local smart_entry = SIMBOARD.smarts and SIMBOARD.smarts[old_smart_id]
        local smart = smart_entry and smart_entry.smrt or nil
        if smart and smart.unregister_squad then
            pcall(function() smart:unregister_squad(squad_obj) end)
        end
        if SIMBOARD.assign_squad_to_smart then
            pcall(function() SIMBOARD:assign_squad_to_smart(squad_obj, nil) end)
        end
    end

    pcall(function() squad_obj.smart_id = nil end)
    pcall(function() squad_obj.task_target_id = nil end)
    pcall(function() squad_obj.assigned_target_id = squad_id end)
    pcall(function() squad_obj.current_target_id = squad_id end)
    pcall(function() squad_obj.rush_to_target = false end)

    if type(squad_obj.squad_members) == "function" then
        for member in squad_obj:squad_members() do
            local se_member = alife_object(member.id)
            if se_member then
                if se_member.clear_smart_terrain then
                    pcall(function() se_member:clear_smart_terrain() end)
                end
                pcall(function() se_member.m_smart_terrain_id = 65535 end)
            end
        end
    end
end

-- Persistent re-anchor for rescue survivors: every few seconds, while the
-- survivor is alive and the task is still active, teleport them back to the
-- rescue smart if they've drifted and re-apply the prisoner state. This is
-- needed because vanilla xr_logic re-asserts the NPC's default walker/camper
-- behavior on each tick, overwriting our one-shot state_mgr.set_state.
local RESCUE_REANCHOR_PERIOD_SEC = 3
local RESCUE_REANCHOR_DRIFT_DIST = 6
function lock_rescue_survivor_at_smart(npc_id, smart_ref)
    if not npc_id or not smart_ref then
        return
    end

    local key = "rescue_lock_" .. tostring(npc_id) .. "_" .. tostring(math.random(100000))
    track_panda_ic_event("pda_ic_spawn", key)

    local anchor_pos = nil
    local function ensure_anchor()
        if anchor_pos then return anchor_pos end
        local smart = resolve_smart_from_reference(smart_ref)
        anchor_pos = get_position_from_object(smart)
        return anchor_pos
    end

    CreateTimeEvent("pda_ic_spawn", key, RESCUE_REANCHOR_PERIOD_SEC, function()
        if is_panda_ic_shutdown_in_progress() or not db.actor then
            return true
        end

        local se_npc = alife_object(npc_id)
        if not se_npc then
            return true
        end

        local bridge = panda_task_bridge
        if bridge and bridge.has_active_rescue_for_survivor
            and not bridge.has_active_rescue_for_survivor(npc_id)
        then
            return true
        end

        local obj = level.object_by_id(npc_id)
        if not obj then
            -- Survivor is offline (player far away). Re-schedule the same event
            -- by returning false; it will keep firing until the actor approaches.
            return false
        end

        if obj.alive and not obj:alive() then
            return true
        end

        if axr_task_manager and axr_task_manager.hostages_by_id and not axr_task_manager.hostages_by_id[npc_id] then
            local smart = resolve_smart_from_reference(smart_ref)
            axr_task_manager.hostages_by_id[npc_id] = (smart and smart.id) or true
        end

        pcall(function() obj:invulnerable(true) end)
        pcall(function() obj:give_info_portion("npcx_beh_ignore_combat") end)
        pcall(function() obj:give_info_portion("npcx_beh_ignore_actor_enemies") end)

        local desired_pos = ensure_anchor()
        if desired_pos and obj.position then
            local cur_pos = obj:position()
            local ok_dist, dist = pcall(function() return cur_pos:distance_to(desired_pos) end)
            if ok_dist and dist and dist > RESCUE_REANCHOR_DRIFT_DIST then
                pcall(function() obj:set_npc_position(desired_pos) end)
            end
        end

        if state_mgr and state_mgr.set_state then
            local ok = pcall(state_mgr.set_state, obj, "prisoner")
            if not ok then
                pcall(state_mgr.set_state, obj, "sit_knee")
            end
        end

        return false
    end)
end

pda_interactive_conv.apply_spawned_faction_relation = apply_spawned_faction_relation
pda_interactive_conv.mark_npc_as_hostage = mark_npc_as_hostage
pda_interactive_conv.apply_rescue_survivor_animation = apply_rescue_survivor_animation
pda_interactive_conv.detach_rescue_survivor_squad = detach_rescue_survivor_squad
pda_interactive_conv.lock_rescue_survivor_at_smart = lock_rescue_survivor_at_smart

-- Returns notification string key for spawned NPC squad based on relation to player.
-- Falls back to a generic key if the specific one is missing from the string table.
function get_faction_spawn_notification_keys(relation_mode)
    relation_mode = relation_mode or "default"
    local key
    if relation_mode == "hostile" then
        key = "st_pda_ic_outcome_squad_warn_hostile"
    elseif relation_mode == "friendly" then
        key = "st_pda_ic_outcome_squad_warn_friendly"
    elseif relation_mode == "companion" then
        key = "st_pda_ic_outcome_squad_warn_companion"
    else
        key = "st_pda_ic_outcome_squad_warn_default"
    end
    if game.translate_string(key) == key then
        local fallback = "st_pda_ic_outcome_squad_warn"
        if game.translate_string(fallback) ~= fallback then
            return fallback
        end
    end
    return key
end

function spawn_npc_squad_near_player(squad_key, distance, delay, relation_mode, job_contact_id)
    delay = tonumber(delay) or 0
    relation_mode = normalize_spawn_relation_mode(relation_mode)

    local function do_spawn()
        if not db.actor then
            return true
        end

        local sec = find_squad_section(squad_key)
        if not sec then
            printf("PANDA_IC: spawn near player failed â€” no NPC squad section for '%s'", tostring(squad_key))
            return true
        end

        local dist = tonumber(distance)
        local min, max
        if dist and dist > 0 then
            min, max = dist, dist
        else
            min, max = get_spawn_distance_range("npc_spawn_min", "npc_spawn_max", 40, 100)
        end

        local pos, lvid, gvid = find_spawn_point_near_player(min, max)
        local obj = create_squad_safely(sec, pos, lvid, gvid)
        if not obj or obj:clsid() ~= clsid.online_offline_group_s then
            printf("PANDA_IC: spawn near player failed â€” could not create NPC squad '%s'", tostring(sec))
            return true
        end

        obj.scripted_target = nil
        obj.rush_to_target = false
        apply_spawned_faction_relation(obj, relation_mode)
        if job_contact_id and pending_jobs[job_contact_id] then
            job_register_squads(job_contact_id, { obj.id })
        end
        return true
    end

    if delay > 0 then
        local ev_key = "panda_npc_squad_" .. tostring(math.random(100000))
        CreateTimeEvent("panda_npc_squad_spawn", ev_key, delay, do_spawn)
    else
        do_spawn()
    end
end

spawn_squad_at_smart_terrain = function(squad_key, smart_ref, is_mutant, delay, job_contact_id, relation_mode)
    delay = tonumber(delay) or 0
    relation_mode = normalize_spawn_relation_mode(relation_mode)
    local sender = game.translate_string("st_pda_ic_outcome_sender")

    local function do_spawn()
        if not db.actor then
            return true
        end

        local smart, smart_name = resolve_smart_from_reference(smart_ref)
        if not smart then
            printf("PANDA_IC: spawn at smart failed — smart terrain '%s' not found", tostring(smart_ref))
            return true
        end

        local smart_pos = get_position_from_object(smart)
        local smart_lvid = smart.m_level_vertex_id
        local smart_gvid = smart.m_game_vertex_id
        if not (smart_pos and smart_lvid and smart_gvid) then
            printf("PANDA_IC: spawn at smart failed — smart terrain '%s' missing position or vertex info", tostring(smart_ref))
            return true
        end

        local sec = is_mutant and resolve_mutant_section(squad_key) or find_squad_section(squad_key)
        if not sec then
            printf("PANDA_IC: spawn at smart failed — no section for '%s'", tostring(squad_key))
            return true
        end

        local spawn_pos, spawn_lvid, spawn_gvid = find_spawn_point_near_smart(10, 20, smart_pos, smart_lvid, smart_gvid)
        local obj = create_squad_safely(sec, spawn_pos, spawn_lvid, spawn_gvid)
        if not obj or obj:clsid() ~= clsid.online_offline_group_s then
            printf("PANDA_IC: spawn at smart failed — could not create squad '%s'", tostring(sec))
            return true
        end

        obj.scripted_target = nil
        obj.rush_to_target = false

        if SIMBOARD and SIMBOARD.assign_squad_to_smart then
            SIMBOARD:assign_squad_to_smart(obj, smart.id)
        end

        if is_mutant then
            for k in obj:squad_members() do
                local o = level.object_by_id(k.id)
                if o then
                    o:set_relation(game_object.enemy, db.actor)
                end
            end
        elseif relation_mode == "companion" then
            apply_spawned_faction_relation(obj, "friendly")
            -- Recruit the spawned squad into companion system
            if axr_companions and axr_companions.add_companion_squad then
                axr_companions.add_companion_squad(obj.id)
            elseif axr_companions and axr_companions.companion_squads then
                axr_companions.companion_squads[obj.id] = true
            end
        else
            apply_spawned_faction_relation(obj, relation_mode)
        end

        -- Register delayed spawn with the pending job so kill tracking works
        if job_contact_id and pending_jobs[job_contact_id] then
            job_register_squads(job_contact_id, { obj.id })
        end

        local loc_name = get_location_display_name(smart_ref)
        local warn_key = nil
        if is_mutant then
            warn_key = "st_pda_ic_outcome_mutant_warn"
        else
            warn_key = get_faction_spawn_notification_keys(relation_mode)
        end

        if warn_key and PANDA.get_config("show_hunt_notifications") then
            local notify_msg = utils_data.parse_string_keys(
                game.translate_string(warn_key),
                {
                    ["location"] = loc_name,
                    ["smart"] = smart_name or tostring(smart_ref),
                }
            )
            dynamic_news_helper.send_tip(
                notify_msg,
                sender,
                0,
                10,
                FALLBACK_NPC_ICON,
                (is_mutant or relation_mode == "hostile") and "danger" or "beep_1",
                "gr"
            )
        end

        return true
    end

    if delay > 0 then
        local event_name = "spawn_smart_" .. tostring(math.random(100000))
        track_panda_ic_event("pda_ic_spawn", event_name)
        CreateTimeEvent("pda_ic_spawn", event_name, delay, do_spawn)
    else
        do_spawn()
    end
end

function find_spawn_point_near_smart(min, max, smart_pos, smart_lvid, smart_gvid)
    for _ = 1, 20 do
        local d = math.random(min, max)
        local dir = vector():set(math.random(-100,100), 0, math.random(-100,100)):normalize()
        local n = level.vertex_in_direction(smart_lvid, dir, d)
        if n and n < 4294967295 then
            return level.vertex_position(n), n, smart_gvid
        end
    end
    return smart_pos, smart_lvid, smart_gvid
end

function find_spawn_point_near_player(min, max)
    local a = db.actor
    local p, l, g = a:position(), a:level_vertex_id(), a:game_vertex_id()

    min = tonumber(min) or 10
    max = tonumber(max) or min
    if min > max then
        min, max = max, min
    end

    for _ = 1, 20 do
        local d = math.random(min, max)
        local dir = vector():set(math.random(-100,100), 0, math.random(-100,100)):normalize()
        local n = level.vertex_in_direction(l, dir, d)
        if n and n < 4294967295 then
            return level.vertex_position(n), n, g
        end
    end
    return p, l, g 
end

local DEAD_NPC_FACTION_ALIASES = {
    army = "military",
    dolg = "duty",
    duty = "duty",
    freedom = "freedom",
    bandit = "bandit",
    stalker = "stalker",
    loner = "stalker",
    csky = "csky",
    clear_sky = "csky",
    ecolog = "ecolog",
    killer = "killer",
    merc = "killer",
    monolith = "monolith",
    renegade = "renegade",
    isg = "isg",
    greh = "greh",
    sin = "greh",
    zombied = "zombied",
    zombie = "zombied",
}

local function dead_npc_section_for_faction(faction)
    local key = faction and string.lower(tostring(faction)) or "stalker"
    key = string.gsub(key, "^actor_", "")
    key = DEAD_NPC_FACTION_ALIASES[key] or key

    for _, rank in ipairs({ 1, 0, 2, 3, 4, 5 }) do
        local sec = "sim_default_" .. key .. "_" .. tostring(rank)
        if ini_sys and ini_sys:section_exist(sec) then
            return sec
        end
    end

    if ini_sys and ini_sys:section_exist("sim_default_stalker_0") then
        return "sim_default_stalker_0"
    end

    return nil
end

local function parse_dead_body_items(items_str)
    local items = {}
    if not items_str or items_str == "" or items_str == "none" then
        return items
    end

    local normalized = string.gsub(tostring(items_str), ",", "+")
    for token in string.gmatch(normalized, "([^%+]+)") do
        local sec = tostring(token):match("^%s*(.-)%s*$")
        if sec ~= "" and ini_sys and ini_sys:section_exist(sec) then
            items[#items + 1] = sec
        elseif sec ~= "" then
            printf("PANDA_IC: dead body item section '%s' not found; skipped", tostring(sec))
        end
    end
    return items
end

local function kill_spawned_dead_npc(se_obj)
    if not se_obj then
        return
    end

    if se_save_var then
        se_save_var(se_obj.id, se_obj.name and se_obj:name() or nil, "death_dropped", true)
    end

    local online_obj = level and level.object_by_id and level.object_by_id(se_obj.id) or nil
    if online_obj and online_obj.alive and online_obj:alive() then
        online_obj:kill(online_obj)
        if panda_npc_creator and type(panda_npc_creator.mark_custom_npc_dead) == "function" then
            pcall(panda_npc_creator.mark_custom_npc_dead, se_obj.id)
        end
        return
    end

    if se_obj.kill then
        pcall(function() se_obj:kill() end)
    end

    if panda_npc_creator and type(panda_npc_creator.mark_custom_npc_dead) == "function" then
        pcall(panda_npc_creator.mark_custom_npc_dead, se_obj.id)
    end
end

local function spawn_dead_npc_at_position(faction, pos, lvid, gvid, items)
    local sec = dead_npc_section_for_faction(faction)
    if not sec then
        printf("PANDA_IC: spawn dead NPC failed - no corpse section for faction '%s'", tostring(faction))
        return nil
    end

    local se_obj = alife():create(sec, pos, lvid, gvid)
    if not se_obj then
        printf("PANDA_IC: spawn dead NPC failed - could not create '%s'", tostring(sec))
        return nil
    end

    kill_spawned_dead_npc(se_obj)

    for _, item_sec in ipairs(items or {}) do
        if alife_create_item then
            pcall(alife_create_item, item_sec, se_obj)
        end
    end

    return se_obj
end

local function collect_spawned_custom_npc_ids(spawn_result)
    local ids = {}
    if not spawn_result then
        return ids
    end

    if spawn_result.id and (not spawn_result.clsid or spawn_result:clsid() ~= clsid.online_offline_group_s) then
        ids[#ids + 1] = spawn_result.id
        return ids
    end

    if spawn_result.squad_members then
        local ok = pcall(function()
            for k in spawn_result:squad_members() do
                if k.id then
                    ids[#ids + 1] = k.id
                elseif k.object and k.object.id then
                    ids[#ids + 1] = k.object.id
                end
            end
        end)
        if not ok then
            printf("PANDA_IC: spawn_dead_custom_npc could not enumerate squad members")
        end
    end

    return ids
end

local function turn_custom_spawn_into_corpses(spawn_result, items_str)
    local items = parse_dead_body_items(items_str)
    local ids = collect_spawned_custom_npc_ids(spawn_result)
    local killed = 0

    for _, npc_id in ipairs(ids) do
        local se_obj = alife_object(npc_id)
        if se_obj then
            kill_spawned_dead_npc(se_obj)
            for _, item_sec in ipairs(items) do
                if alife_create_item then
                    pcall(alife_create_item, item_sec, se_obj)
                end
            end
            killed = killed + 1
        end
    end

    return killed
end

function spawn_dead_custom_npc(template_id, smart_ref, distance, items_str, delay, conv_data)
    delay = tonumber(delay) or 0

    local function do_spawn()
        if not panda_npc_creator or type(panda_npc_creator.spawn_custom_npc) ~= "function" then
            printf("PANDA_IC: spawn_dead_custom_npc ignored - panda_npc_creator unavailable")
            return true
        end

        local context = { conv_data = conv_data }
        if smart_ref and smart_ref ~= "" then
            context.smart_ref = smart_ref
        else
            context.use_player_pos = true
            if tonumber(distance) and tonumber(distance) > 0 then
                context.spawn_dist = tonumber(distance)
            end
        end

        local ok, spawn_result = pcall(panda_npc_creator.spawn_custom_npc, template_id, context)
        if not ok or not spawn_result then
            printf("PANDA_IC: spawn_dead_custom_npc failed for template '%s'", tostring(template_id))
            return true
        end

        local killed = turn_custom_spawn_into_corpses(spawn_result, items_str)
        if killed == 0 then
            printf("PANDA_IC: spawn_dead_custom_npc spawned template '%s' but found no NPC members to kill", tostring(template_id))
        end
        return true
    end

    if delay > 0 then
        local ev_key = "panda_dead_custom_" .. tostring(math.random(100000))
        track_panda_ic_event("pda_ic_spawn", ev_key)
        CreateTimeEvent("pda_ic_spawn", ev_key, delay, do_spawn)
    else
        do_spawn()
    end
end

function spawn_dead_npcs_near_player(faction, distance, count, items_str, delay)
    delay = tonumber(delay) or 0
    count = math.max(1, tonumber(count) or 1)

    local function do_spawn()
        if not db.actor then
            return true
        end

        local dist = tonumber(distance)
        local min, max
        if dist and dist > 0 then
            min, max = dist, dist
        else
            min = tonumber(PANDA.get_config("npc_spawn_min")) or 40
            max = tonumber(PANDA.get_config("npc_spawn_max")) or 100
            if min > max then
                min, max = max, min
            end
            min = math.max(1, min)
            max = math.max(min, max)
        end

        local items = parse_dead_body_items(items_str)
        for _ = 1, count do
            local pos, lvid, gvid = find_spawn_point_near_player(min, max)
            spawn_dead_npc_at_position(faction, pos, lvid, gvid, items)
        end
        return true
    end

    if delay > 0 then
        local ev_key = "panda_dead_npc_player_" .. tostring(math.random(100000))
        track_panda_ic_event("pda_ic_spawn", ev_key)
        CreateTimeEvent("pda_ic_spawn", ev_key, delay, do_spawn)
    else
        do_spawn()
    end
end

function spawn_dead_npcs_at_smart(faction, smart_ref, count, items_str, delay)
    delay = tonumber(delay) or 0
    count = math.max(1, tonumber(count) or 1)

    local function do_spawn()
        local smart, smart_name = resolve_smart_from_reference(smart_ref)
        if not smart then
            printf("PANDA_IC: spawn dead NPCs at smart failed - smart terrain '%s' not found", tostring(smart_ref))
            return true
        end

        local smart_pos = get_position_from_object(smart)
        local smart_lvid = smart.m_level_vertex_id
        local smart_gvid = smart.m_game_vertex_id
        if not (smart_pos and smart_lvid and smart_gvid) then
            printf("PANDA_IC: spawn dead NPCs at smart failed - smart terrain '%s' missing position or vertex info", tostring(smart_ref))
            return true
        end

        local items = parse_dead_body_items(items_str)
        for _ = 1, count do
            local pos, lvid, gvid = find_spawn_point_near_smart(5, 18, smart_pos, smart_lvid, smart_gvid)
            spawn_dead_npc_at_position(faction, pos, lvid, gvid, items)
        end

        printf("PANDA_IC: spawned %d dead %s NPC(s) near smart '%s'", count, tostring(faction), tostring(smart_name or smart_ref))
        return true
    end

    if delay > 0 then
        local ev_key = "panda_dead_npc_smart_" .. tostring(math.random(100000))
        track_panda_ic_event("pda_ic_spawn", ev_key)
        CreateTimeEvent("pda_ic_spawn", ev_key, delay, do_spawn)
    else
        do_spawn()
    end
end

local function get_spawn_distance_range(min_key, max_key, default_min, default_max)
    local min = tonumber(PANDA.get_config(min_key)) or default_min
    local max = tonumber(PANDA.get_config(max_key)) or default_max

    if min > max then
        min, max = max, min
    end

    min = math.max(1, min)
    max = math.max(min, max)

    return min, max
end

function create_squad_safely(sec, pos, lvid, gvid)
    local obj = alife():create(sec, pos, lvid, gvid)
    if obj and obj:clsid() == clsid.online_offline_group_s then
        if obj.create_npc then
            obj:create_npc(nil, pos, lvid, gvid)
        end
        for k in obj:squad_members() do
            local se = k.object or (k.id and alife():object(k.id))
            if se then
                SIMBOARD:setup_squad_and_group(se)
            end
        end
        -- If a job spawn collector is active, register this squad for tracking
        if _panda_ic_runtime.job_spawn_collector then
            table.insert(_panda_ic_runtime.job_spawn_collector, obj.id)
            dbg("PANDA_IC: Job collector captured squad ID %d (%s)", obj.id, tostring(sec))
        end
    end
    return obj
end

-- spawn_hunting_squad: mutant-only (NPC faction spawning moved to panda_npc_creator)
function spawn_hunting_squad(fac, distance, is_mutant, delay, relation_mode)
    if not is_mutant then
        printf("PANDA_IC: spawn_hunting_squad called for non-mutant '%s' — use spawn_custom_npc instead", tostring(fac))
        return
    end

    delay = tonumber(delay) or 90
    fac = normalize_faction(fac)
    local sec = resolve_mutant_section(fac)
    if not sec then
        printf("No squad section found for mutant")
        return
    end

    local key = "spawn_hunt_" .. tostring(math.random(100000))
    local sender = game.translate_string("st_pda_ic_outcome_sender")

    -- Stage 1: Initial warning
    if PANDA.get_config("show_hunt_notifications") then
        dynamic_news_helper.send_tip(
            game.translate_string("st_pda_ic_outcome_mutant_warn"),
            sender, 2, 10, FALLBACK_NPC_ICON, "danger", "gr"
        )
    end

    track_panda_ic_event("pda_ic_spawn", key)
    CreateTimeEvent("pda_ic_spawn", key, delay, function()
        if not db.actor then return true end

        local min, max
        local dist = tonumber(distance)
        if dist and dist > 0 then
            min, max = dist, dist
        else
            min, max = get_spawn_distance_range("mutant_spawn_min", "mutant_spawn_max", 40, 100)
        end

        local pos, l, g = find_spawn_point_near_player(min, max)
        local obj = create_squad_safely(sec, pos, l, g)

        if obj and obj:clsid() == clsid.online_offline_group_s then
            local squad_id = obj.id
            obj.scripted_target = "actor"
            obj.rush_to_target = true

            for k in obj:squad_members() do
                local o = level.object_by_id(k.id)
                if o then
                    o:set_relation(game_object.enemy, db.actor)
                end
            end

            -- Stage 2: Notify arrival
            local arrival_event = "arrival_"..squad_id
            track_panda_ic_event("pda_ic_spawn", arrival_event)
            CreateTimeEvent("pda_ic_spawn", arrival_event, math.random(5, 10), function()
                if not db.actor then return true end
                local s = alife_object(squad_id)
                if not s then return true end
                local commander = level.object_by_id(s:commander_id())
                if commander and commander:alive() then
                    local actor_dist = commander:position():distance_to(db.actor:position())
                    if actor_dist < 150 and PANDA.get_config("show_hunt_notifications") then
                        dynamic_news_helper.send_tip(
                            game.translate_string("st_pda_ic_outcome_mutant_arrive"),
                            sender, 0, 10, FALLBACK_NPC_ICON, "danger", "gr"
                        )
                    end
                end
                return true
            end)

            -- Stage 3: Monitor and timeout
            local start_time = game.get_game_time()
            local monitor_event = "monitor_"..squad_id
            track_panda_ic_event("pda_ic_spawn", monitor_event)
            CreateTimeEvent("pda_ic_spawn", monitor_event, 30, function()
                if not db.actor then return true end
                local s = alife_object(squad_id)
                if not s then return true end

                local any_alive = false
                for k in s:squad_members() do
                    local o = level.object_by_id(k.id)
                    if o and o:alive() then
                        any_alive = true
                        break
                    end
                end

                if not any_alive then
                    return true
                end

                local elapsed_min = game.get_game_time():diffSec(start_time) / 60
                if elapsed_min > 10 then
                    if PANDA.get_config("show_hunt_notifications") then
                        dynamic_news_helper.send_tip(
                            game.translate_string("st_pda_ic_hunt_timeout"),
                            sender, 0, 10, FALLBACK_NPC_ICON, "attention", "gr"
                        )
                    end
                    if alife() and alife().release then
                        alife():release(s, true)
                    end
                    return true
                end
                return false
            end)

        else
            printf("Failed to create hunting squad (squad creation returned nil or wrong class).")
        end
        return true
    end)
end

-- ============================================================
-- TELEPORT NPC TO SMART TERRAIN
-- ============================================================
function teleport_npc_to_smart_terrain(npc_id, smart_ref, npc_name, delay)
    delay = delay or 0
    local sender = game.translate_string("st_pda_ic_outcome_sender")

    local function do_teleport()
        if not db.actor then return true end

        local smart, smart_name = resolve_smart_from_reference(smart_ref)
        if not smart then
            printf("PANDA_IC: teleport_npc_to_smart failed — smart terrain '%s' not found", tostring(smart_ref))
            return true
        end

        local se_npc = alife_object(npc_id)
        if not se_npc then
            printf("PANDA_IC: teleport_npc_to_smart — NPC %d no longer exists", npc_id)
            return true
        end

        -- Get the smart terrain position and vertex data
        local smart_pos = smart.position
        local smart_gvid = smart.m_game_vertex_id
        local smart_lvid = smart.m_level_vertex_id

        -- Get the NPC's squad (if any) and teleport the whole squad
        local squad = get_object_squad(se_npc)
        if squad then
            -- Use the vanilla TeleportSquad approach
            local sim = alife()
            sim:teleport_object(squad.id, smart_gvid, smart_lvid, smart_pos)
            for k in squad:squad_members() do
                if db.offline_objects[k.id] then
                    db.offline_objects[k.id].level_vertex_id = nil
                end
                db.spawned_vertex_by_id[k.id] = nil
                sim:teleport_object(k.id, smart_gvid, smart_lvid, smart_pos)
            end

            -- Assign the squad to the target smart terrain
            if SIMBOARD and SIMBOARD.assign_squad_to_smart then
                SIMBOARD:assign_squad_to_smart(squad, smart.id)
            end
        else
            -- Solo NPC (no squad), teleport directly
            local npc_obj = level.object_by_id(npc_id)
            if npc_obj then
                npc_obj:set_npc_position(smart_pos)
            else
                se_npc.position = smart_pos
            end
        end

        local display_name = get_location_display_name(smart_ref)
        local name = npc_name or (se_npc:character_name()) or "Unknown"

        dynamic_news_helper.send_tip(
            utils_data.parse_string_keys(
                game.translate_string("st_pda_ic_outcome_npc_teleport_smart"),
                { ["name"] = name, ["location"] = display_name }
            ),
            sender, 0, 10, FALLBACK_NPC_ICON, "beep_2", "npc"
        )

        return true
    end

    if delay > 0 then
        local tp_smart_event = "tp_smart_" .. tostring(npc_id) .. "_" .. math.random(100000)
        track_panda_ic_event("pda_ic_tp", tp_smart_event)
        CreateTimeEvent("pda_ic_tp", tp_smart_event, delay, do_teleport)
    else
        do_teleport()
    end
end

-- ============================================================
-- TELEPORT NPC NEAR PLAYER
-- ============================================================
function teleport_npc_near_player(npc_id, npc_name, delay)
    delay = delay or 0
    local sender = game.translate_string("st_pda_ic_outcome_sender")

    local function do_teleport()
        if not db.actor then return true end

        local se_npc = alife_object(npc_id)
        if not se_npc then
            printf("PANDA_IC: teleport_npc_to_player — NPC %d no longer exists", npc_id)
            return true
        end

        -- Respect MCM companion/courier spawn range settings.
        local min_dist, max_dist = get_spawn_distance_range("companion_spawn_min", "companion_spawn_max", 20, 50)
        local pos, lvid, gvid = find_spawn_point_near_player(min_dist, max_dist)

        -- Get the NPC's squad (if any) and teleport the whole squad
        local squad = get_object_squad(se_npc)
        if squad then
            local sim = alife()
            sim:teleport_object(squad.id, gvid, lvid, pos)
            for k in squad:squad_members() do
                if db.offline_objects[k.id] then
                    db.offline_objects[k.id].level_vertex_id = nil
                end
                db.spawned_vertex_by_id[k.id] = nil
                sim:teleport_object(k.id, gvid, lvid, pos)
            end

            -- Clear any smart terrain assignment so they stay where teleported
            if SIMBOARD and SIMBOARD.assign_squad_to_smart then
                SIMBOARD:assign_squad_to_smart(squad, nil)
            end
        else
            -- Solo NPC
            local npc_obj = level.object_by_id(npc_id)
            if npc_obj then
                npc_obj:set_npc_position(pos)
            else
                se_npc.position = pos
            end
        end

        local name = npc_name or (se_npc:character_name()) or "Unknown"

        dynamic_news_helper.send_tip(
            utils_data.parse_string_keys(
                game.translate_string("st_pda_ic_outcome_npc_teleport_player"),
                { ["name"] = name }
            ),
            sender, 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
        )

        return true
    end

    if delay > 0 then
        local tp_player_event = "tp_player_" .. tostring(npc_id) .. "_" .. math.random(100000)
        track_panda_ic_event("pda_ic_tp", tp_player_event)
        CreateTimeEvent("pda_ic_tp", tp_player_event, delay, do_teleport)
    else
        do_teleport()
    end
end

-- ============================================================
-- RECRUIT NPC AS COMPANION
-- ============================================================
function recruit_npc_as_companion(npc_id, npc_name, cannot_dismiss)
    if not axr_companions then
        printf("PANDA_IC: recruit_companion failed — axr_companions not available")
        return
    end

    -- Check companion limit
    local comps = 0
    if axr_companions.companion_squads then
        for _ in pairs(axr_companions.companion_squads) do
            comps = comps + 1
        end
    end
    local max_comps = PANDA.get_config("companion_limit") or 4
    if comps >= max_comps then
        printf("PANDA_IC: recruit_companion — companion limit reached (%d/%d)", comps, max_comps)
        dynamic_news_helper.send_tip(
            game.translate_string("st_pda_ic_outcome_recruit_limit"),
            game.translate_string("st_pda_ic_outcome_sender"), 0, 8,
            FALLBACK_NPC_ICON, "beep_1", "npc"
        )
        return
    end

    local npc_obj = level.object_by_id(npc_id)
    if not npc_obj or not npc_obj:alive() then
        printf("PANDA_IC: recruit_companion — NPC %d not online or dead", npc_id)
        return
    end

    local se_npc = alife_object(npc_id)
    if not se_npc then
        printf("PANDA_IC: recruit_companion — server object for NPC %d not found", npc_id)
        return
    end

    -- Get the NPC's squad
    local squad = get_object_squad(npc_obj) or get_object_squad(se_npc)

    if squad then
        -- Register the squad as a companion squad (vanilla pattern from dialogs_axr_companion)
        axr_companions.companion_squads[squad.id] = squad

        -- Unassign from current smart terrain
        if SIMBOARD and SIMBOARD.assign_squad_to_smart then
            SIMBOARD:assign_squad_to_smart(squad, nil)
        end

        -- Set up each squad member as a companion
        for k in squad:squad_members() do
            local member = db.storage[k.id] and db.storage[k.id].object
            if member and member:alive() then
                se_save_var(k.id, member:name(), "companion", true)
                if cannot_dismiss then
                    se_save_var(k.id, member:name(), "companion_cannot_dismiss", true)
                end
                axr_companions.add_to_actor_squad(member)
            end
        end
    else
        -- Solo NPC without a squad — still mark and add as companion
        se_save_var(npc_id, npc_obj:name(), "companion", true)
        if cannot_dismiss then
            se_save_var(npc_id, npc_obj:name(), "companion_cannot_dismiss", true)
        end
        axr_companions.add_to_actor_squad(npc_obj)
    end

    local name = npc_name or npc_obj:character_name() or "Unknown"
    local icon = npc_obj:character_icon() or FALLBACK_NPC_ICON

    if PANDA.get_config("show_companion_notifications") then
        dynamic_news_helper.send_tip(
            utils_data.parse_string_keys(
                game.translate_string("st_pda_ic_outcome_recruit_success"),
                { ["name"] = name }
            ),
            game.translate_string("st_pda_ic_outcome_sender"), 0, 10,
            icon, "beep_2", "npc"
        )
    end
end

recruit_escort_companion = function(npc_id, npc_name, squad_id)
    npc_id = tonumber(npc_id)
    if not npc_id then
        return false, "missing_npc_id"
    end
    if not axr_companions then
        return false, "axr_companions_unavailable"
    end

    local se_npc = alife_object and alife_object(npc_id) or nil
    if not se_npc then
        return false, "missing_server_object"
    end

    local npc_obj = level and level.object_by_id and level.object_by_id(npc_id) or nil
    if npc_obj and npc_obj.alive and not npc_obj:alive() then
        return false, "npc_dead"
    end
    if not npc_obj and se_npc.alive then
        local ok_alive, alive = pcall(function() return se_npc:alive() end)
        if ok_alive and alive == false then
            return false, "npc_dead"
        end
    end

    local squad = (squad_id and alife_object and alife_object(squad_id))
        or (npc_obj and get_object_squad(npc_obj))
        or get_object_squad(se_npc)
    if squad and axr_companions.companion_squads then
        axr_companions.companion_squads[squad.id] = squad
        if SIMBOARD and SIMBOARD.assign_squad_to_smart then
            SIMBOARD:assign_squad_to_smart(squad, nil)
        end
        if type(squad.squad_members) == "function" then
            for member in squad:squad_members() do
                local member_id = tonumber(member.id)
                local live_member = member_id and level and level.object_by_id and level.object_by_id(member_id) or nil
                local member_se = member_id and alife_object and alife_object(member_id) or nil
                local member_name = (live_member and live_member.name and live_member:name())
                    or (member_se and member_se.name and member_se:name())
                    or tostring(member_id or "")
                if member_id and se_save_var then
                    se_save_var(member_id, member_name, "companion", true)
                    se_save_var(member_id, member_name, "companion_cannot_dismiss", true)
                    se_save_var(member_id, member_name, "companion_cannot_teleport", true)
                end
                if live_member and live_member.alive and live_member:alive() and axr_companions.add_to_actor_squad then
                    pcall(function() live_member:give_info_portion("npcx_beh_cannot_dismiss") end)
                    axr_companions.add_to_actor_squad(live_member)
                end
            end
        end
    else
        local save_name = (npc_obj and npc_obj.name and npc_obj:name()) or (se_npc.name and se_npc:name()) or tostring(npc_id)
        if se_save_var then
            se_save_var(npc_id, save_name, "companion", true)
            se_save_var(npc_id, save_name, "companion_cannot_dismiss", true)
            se_save_var(npc_id, save_name, "companion_cannot_teleport", true)
        end
        if npc_obj and axr_companions.add_to_actor_squad then
            pcall(function() npc_obj:give_info_portion("npcx_beh_cannot_dismiss") end)
            axr_companions.add_to_actor_squad(npc_obj)
        end
    end

    if PANDA.get_config("show_companion_notifications") then
        dynamic_news_helper.send_tip(
            utils_data.parse_string_keys(
                game.translate_string("st_pda_ic_outcome_recruit_success"),
                { ["name"] = npc_name or "Unknown" }
            ),
            game.translate_string("st_pda_ic_outcome_sender"), 0, 10,
            FALLBACK_NPC_ICON, "beep_2", "npc"
        )
    end

    return true, nil, squad and squad.id or squad_id
end

resolve_escort_target = function(target_kind, target_value, spawn_distance, fallback_npc_id, fallback_npc_name)
    target_kind = tostring(target_kind or "sender"):lower()
    if target_kind == "" or target_kind == "self" or target_kind == "sender" or target_kind == "talker" then
        local se = fallback_npc_id and alife_object and alife_object(fallback_npc_id) or nil
        local squad = se and get_object_squad(se) or nil
        return tonumber(fallback_npc_id), fallback_npc_name, squad and squad.id or nil
    end

    local se = nil
    local label = nil
    local explicit_dist = tonumber(spawn_distance)

    if (target_kind == "story" or target_kind == "story_npc") and target_value and target_value ~= "" then
        if type(get_story_se_object) == "function" then
            local ok_story, story_se = pcall(get_story_se_object, target_value)
            if ok_story then se = story_se end
        end
        -- Teleport story NPC to the player so escort can begin immediately.
        if se and db and db.actor then
            local dist = explicit_dist or 15
            local pos, lvid, gvid = find_spawn_point_near_player(dist, dist)
            if pos then
                local squad = get_object_squad(se)
                if squad and TeleportSquad then
                    pcall(TeleportSquad, squad, pos, lvid, gvid)
                elseif type(se.position) == "function" then
                    pcall(function()
                        se.position = pos
                        se.m_level_vertex_id = lvid
                        se.m_game_vertex_id = gvid
                    end)
                end
            end
        end
    elseif (target_kind == "custom" or target_kind == "custom_npc") and target_value and target_value ~= "" then
        if panda_npc_creator and type(panda_npc_creator.get_active_npc_se) == "function" then
            local ok_existing, existing = pcall(panda_npc_creator.get_active_npc_se, target_value)
            if ok_existing then se = existing end
        end
        if not se and panda_npc_creator and type(panda_npc_creator.spawn_custom_npc) == "function" then
            pcall(panda_npc_creator.spawn_custom_npc, target_value, {
                use_player_pos = true,
                spawn_dist = explicit_dist,
                conv_data = CONV,
            })
            if type(panda_npc_creator.get_active_npc_se) == "function" then
                local ok_spawned, spawned = pcall(panda_npc_creator.get_active_npc_se, target_value)
                if ok_spawned then se = spawned end
            end
        end
        label = target_value
    elseif (target_kind == "spawn" or target_kind == "spawn_faction" or target_kind == "new_npc") and target_value and target_value ~= "" then
        local sec = find_squad_section(target_value)
        if sec then
            local min_dist, max_dist
            if explicit_dist then
                min_dist, max_dist = explicit_dist, explicit_dist
            else
                min_dist, max_dist = get_spawn_distance_range("companion_spawn_min", "companion_spawn_max", 20, 50)
            end
            local pos, lvid, gvid = find_spawn_point_near_player(min_dist, max_dist)
            local squad = create_squad_safely(sec, pos, lvid, gvid)
            local npc_id = nil
            if squad and type(squad.squad_members) == "function" then
                apply_spawned_faction_relation(squad, "friendly")
                for member in squad:squad_members() do
                    if not npc_id then npc_id = member.id end
                end
                se = npc_id and alife_object and alife_object(npc_id) or nil
                local name = target_value
                if se and se.character_name then
                    local ok_name, resolved_name = pcall(function() return se:character_name() end)
                    if ok_name and resolved_name and resolved_name ~= "" then name = resolved_name end
                end
                return tonumber(npc_id), name, squad.id
            end
        end
    else
        if type(get_story_se_object) == "function" then
            local ok_story, story_se = pcall(get_story_se_object, target_kind)
            if ok_story then se = story_se end
        end
    end

    local npc_id = se and tonumber(se.id) or nil
    if not npc_id then
        return nil, label or fallback_npc_name, nil
    end

    if se.character_name then
        local ok_name, resolved_name = pcall(function() return se:character_name() end)
        if ok_name and resolved_name and resolved_name ~= "" then label = resolved_name end
    end
    local squad = get_object_squad(se)
    return npc_id, label or fallback_npc_name or tostring(npc_id), squad and squad.id or nil
end

-- ============================================================
-- CONVERSATION FLOW (State Machine)
-- ============================================================

function load_choices_for_turn(prefix, faction, conv_id, turn, npc_name, contact_id, npc_se)
    local base_key = build_turn_string_prefix(prefix, faction, conv_id, 1)
    local p = build_turn_string_prefix(prefix, faction, conv_id, turn)
    local choices, count = {}, 0
    npc_se = resolve_runtime_npc_se(npc_se, contact_id)

    local function normalize_choice_channel(value)
        if not value then
            return "pda"
        end

        local normalized = tostring(value):lower():gsub("^%s+", ""):gsub("%s+$", "")
        if normalized == "f2f" then
            return "f2f"
        end

        return "pda"
    end

    local function load_registry_choice_metadata(choice_idx)
        local registry_key = base_key .. "_panda_f2f_registry"
        local raw = game.translate_string(registry_key)
        if raw == registry_key then
            registry_key = base_key .. "_registry"
            raw = game.translate_string(registry_key)
        end
        if not raw or raw == registry_key then
            return nil
        end

        raw = tostring(raw):gsub("&quot;", "\"")
        local turn_start = raw:find("\"turnNumber\"%s*:%s*" .. tostring(turn))
        if not turn_start then
            return nil
        end

        local next_turn_start = raw:find("\"turnNumber\"%s*:%s*%d+", turn_start + 1)
        local turn_block = raw:sub(turn_start, next_turn_start and (next_turn_start - 1) or #raw)
        local choice_start = turn_block:find("\"index\"%s*:%s*" .. tostring(choice_idx))
        if not choice_start then
            return nil
        end

        local next_choice_start = turn_block:find("\"index\"%s*:%s*%d+", choice_start + 1)
        local choice_block = turn_block:sub(choice_start, next_choice_start and (next_choice_start - 1) or #turn_block)
        local meta = {
            continue_channel = choice_block:match("\"continueChannel\"%s*:%s*\"([%w_%-]+)\""),
            cont_npc_id = choice_block:match("\"contNpcId\"%s*:%s*\"([^\"]+)\""),
            allow_generic_stalker = choice_block:match("\"allowGenericStalker\"%s*:%s*true") ~= nil,
            npc_faction_filters = {},
        }
        local factions_raw = choice_block:match("\"npcFactionFilters\"%s*:%s*%[(.-)%]")
        if factions_raw then
            for faction_id in factions_raw:gmatch("\"([^\"]+)\"") do
                table.insert(meta.npc_faction_filters, faction_id)
            end
        end
        return meta
    end

    local function resolve_choice_precond_key(choice_idx)
        local authored_key = p .. "_choice_" .. tostring(choice_idx) .. "_precond"
        local authored_val = game.translate_string(authored_key)
        if authored_val ~= authored_key then
            return authored_key
        end

        local legacy_key = p .. "_choice_precond_" .. tostring(choice_idx)
        local legacy_val = game.translate_string(legacy_key)
        if legacy_val ~= legacy_key then
            return legacy_key
        end

        return authored_key
    end

    if not check_preconditions_generic(p .. "_branch_precond", npc_se) then
        return choices, count
    end

    -- Get relationship score for reply variant selection
    local rel = contact_id and get_npc_relationship(contact_id) or 0

    for i = 1, 4 do
        local key = p.."_choice_"..i
        local text = game.translate_string(key)
        if text == key then break end

        local choice_precond_key = resolve_choice_precond_key(i)
        if check_preconditions_generic(choice_precond_key, npc_se) then
            local reply_key = p.."_reply_"..i
            local reply_text = game.translate_string(reply_key)
            if reply_text == reply_key then reply_text = "" end

            -- Check for relationship-conditional reply variants
            if reply_text ~= "" and contact_id then
                if rel >= 300 then
                    local high_key = p.."_reply_"..i.."_rel_high"
                    local high_text = game.translate_string(high_key)
                    if high_text ~= high_key then
                        reply_text = high_text
                    end
                elseif rel <= -300 then
                    local low_key = p.."_reply_"..i.."_rel_low"
                    local low_text = game.translate_string(low_key)
                    if low_text ~= low_key then
                        reply_text = low_text
                    end
                end
            end

            local cont_channel = game.translate_string(p.."_cont_channel_"..i)
            if cont_channel == p.."_cont_channel_"..i then
                cont_channel = game.translate_string(p.."_channel_"..i)
                if cont_channel == p.."_channel_"..i then
                    local registry_meta = load_registry_choice_metadata(i)
                    cont_channel = registry_meta and registry_meta.continue_channel or nil
                end
            end

            local registry_meta = load_registry_choice_metadata(i)

            local cont_npc_raw = game.translate_string(p.."_cont_npc_"..i)
            local next_npc_id = (cont_npc_raw ~= p.."_cont_npc_"..i) and cont_npc_raw:match("^%s*(.-)%s*$") or nil
            if next_npc_id == "" then next_npc_id = nil end
            if not next_npc_id and registry_meta and registry_meta.cont_npc_id and registry_meta.cont_npc_id ~= "" then
                next_npc_id = registry_meta.cont_npc_id
            end
            local next_turn = tonumber(game.translate_string(p.."_cont_"..i)) or nil
            local branch_visible = true
            local branch_speaker_target = nil
            local next_npc_faction_filters = registry_meta and registry_meta.npc_faction_filters or nil
            local next_allow_generic_stalker = registry_meta and registry_meta.allow_generic_stalker == true
            if next_turn then
                local next_turn_key = build_turn_string_prefix(prefix, faction, conv_id, next_turn)
                branch_speaker_target = read_branch_speaker_target(prefix, faction, conv_id, next_turn)
                if (not next_allow_generic_stalker) and branch_speaker_target.allow_generic_stalker then
                    next_npc_faction_filters = branch_speaker_target.npc_faction_filters
                    next_allow_generic_stalker = true
                end
                local effective_next_npc_id = next_npc_id or branch_speaker_target.npc_id
                local next_turn_npc_se = resolve_handoff_target_se(effective_next_npc_id, npc_se)
                branch_visible = check_preconditions_generic(next_turn_key .. "_branch_precond", next_turn_npc_se)
                next_npc_id = effective_next_npc_id
            end

            if branch_visible then
                local reply_image_raw = game.translate_string(reply_key .. "_image")
                if reply_image_raw == reply_key .. "_image" then reply_image_raw = nil end
                local reply_audio_fields = get_audio_fields_for_string_key(reply_key .. "_audio")
                local visible_index = count + 1
                -- Mutual-exclusion fan-out: each additional sibling becomes a parallel
                -- PDA continuation. A shared group token ties them so on_player_choice
                -- can mark losing siblings inert once the player engages one of them.
                local fanout_targets = nil
                local fanout_group = nil
                local fanout_count_raw = game.translate_string(p.."_fanout_count_"..i)
                local fanout_count = tonumber(fanout_count_raw) or 0
                if fanout_count and fanout_count > 0 then
                    local group_raw = game.translate_string(p.."_fanout_group_"..i)
                    if group_raw and group_raw ~= "" and group_raw ~= p.."_fanout_group_"..i then
                        fanout_group = group_raw
                    else
                        fanout_group = string.format("%s_g%s", p, tostring(i))
                    end
                    fanout_targets = {}
                    for j = 1, fanout_count do
                        local t_raw   = game.translate_string(p.."_fanout_"..i.."_"..j.."_turn")
                        local n_raw   = game.translate_string(p.."_fanout_"..i.."_"..j.."_npc")
                        local ch_raw  = game.translate_string(p.."_fanout_"..i.."_"..j.."_channel")
                        local dly_raw = game.translate_string(p.."_fanout_"..i.."_"..j.."_delay")
                        local t_turn  = tonumber(t_raw)
                        local t_npc   = n_raw and n_raw ~= "" and n_raw ~= (p.."_fanout_"..i.."_"..j.."_npc") and n_raw:match("^%s*(.-)%s*$") or nil
                        local t_ch    = (ch_raw == "f2f") and "f2f" or "pda"
                        local t_dly   = tonumber(dly_raw) or 0
                        if t_turn and t_npc and t_npc ~= "" then
                            fanout_targets[#fanout_targets + 1] = {
                                next_turn = t_turn,
                                next_npc_id = t_npc,
                                next_channel = t_ch,
                                pda_delay_seconds = t_dly,
                            }
                        end
                    end
                    if #fanout_targets == 0 then
                        fanout_targets = nil
                        fanout_group = nil
                    end
                end

                choices[visible_index] = {
                    source_choice_index = i,
                    text = sub_placeholders(text, npc_name, faction, npc_se, contact_id),
                    reply = sub_placeholders(reply_text, npc_name, faction, npc_se, contact_id),
                    reply_image = resolve_reply_image_texture(reply_text, reply_image_raw),
                    reply_audio_name = reply_audio_fields and reply_audio_fields.audio_name or nil,
                    reply_audio_path = reply_audio_fields and reply_audio_fields.audio_path or nil,
                    outcome = game.translate_string(p.."_outcome_"..i),
                    next_turn = next_turn,
                    next_channel = normalize_choice_channel(cont_channel),
                    pda_delay_seconds = tonumber(game.translate_string(p.."_pda_delay_"..i)) or nil,
                    next_npc_id = next_npc_id,
                    next_npc_faction_filters = next_npc_faction_filters,
                    next_allow_generic_stalker = next_allow_generic_stalker,
                    fanout_targets = fanout_targets,
                    fanout_group = fanout_group,
                }
                if choices[visible_index].outcome == p.."_outcome_"..i then choices[visible_index].outcome = "none" end
                -- Append "[Charisma 5]" / "[60% Chance]" hint to the choice text so
                -- players know the choice carries a check.
                local check_hint = build_dialogue_check_hint(choices[visible_index].outcome)
                if check_hint and check_hint ~= "" then
                    choices[visible_index].text = (choices[visible_index].text or "") .. " " .. check_hint
                end
                count = visible_index
            end
        end
    end
    return choices, count
end



function on_player_choice(idx, contact_id)
    -- Resolve which conversation to act on: use contact_id if given, else fall back to CONV
    local c
    if contact_id and active_conversations[contact_id] then
        c = active_conversations[contact_id]
    elseif CONV then
        c = CONV
    end

    if not c or not c.choices or not c.choices[idx] then return end

    local ch = c.choices[idx]
    local continuation_channel = (ch.next_channel == "f2f") and "f2f" or "pda"
    local npc_name = c.npc_name
    local npc_icon = c.npc_icon
    local cid = c.contact_id

    -- Mutual-exclusion fan-out: if this conversation belongs to an exclusion
    -- group (the player engaged one of N parallel NPC threads), mark all sibling
    -- threads inert so their delivered messages stay readable but no further
    -- branches fire. Also drop any siblings still sitting in the pending queue.
    if c.exclusion_group and c.exclusion_group ~= "" then
        local group = c.exclusion_group
        if type(active_conversations) == "table" then
            for sibling_cid, sibling in pairs(active_conversations) do
                if type(sibling) == "table"
                    and sibling.exclusion_group == group
                    and sibling_cid ~= cid
                    and not sibling.exclusion_inert then
                    sibling.exclusion_inert = true
                    sibling.choices = nil
                    sibling.num_choices = 0
                    sibling.reply_pending = false
                    -- Inline clear_pending_in_person_marker (defined later as a local).
                    sibling.pending_in_person_continuation = false
                    sibling.pending_in_person_turn = nil
                    sibling.pending_in_person_target = nil
                    sibling.pending_in_person_set_at = nil
                    sibling.pending_in_person_token = nil
                    sibling.pending_in_person_story_id = nil
                    sibling.pending_in_person_canonical_id = nil
                    clear_npc_typing_message(sibling_cid)
                    printf("PANDA_IC: fanout group=%s winner_cid=%s sibling_cid=%s marked inert", tostring(group), tostring(cid), tostring(sibling_cid))
                end
            end
        end
        if type(pending_pda_followups) == "table" then
            for pid, pending in pairs(pending_pda_followups) do
                if type(pending) == "table"
                    and pending.exclusion_group == group
                    and tostring(pending.contact_id or "") ~= cid then
                    pending_pda_followups[pid] = nil
                    printf("PANDA_IC: fanout group=%s winner_cid=%s pending sibling pid=%s dropped", tostring(group), tostring(cid), tostring(pid))
                end
            end
        end
        c.exclusion_group = nil
    end

    -- Add player choice to log, NO global tip
    pda_private_add_message(cid, npc_name, db.actor:character_name(), ch.text, db.actor:character_icon(), true, "sent")
    c.started_at = time_global and time_global() or c.started_at

    -- Remove from active table to prevent button-mashing abuse
    active_conversations[cid] = nil
    if CONV and CONV.contact_id == cid then CONV = nil end

    -- Check if outcome has already been triggered in this conversation
    local authored_choice_index = ch.source_choice_index or idx
    local outcome_key = tostring(c.turn) .. "_" .. tostring(authored_choice_index)
    local has_outcome = ch.outcome and ch.outcome ~= "none"
    local pauses_for_job = has_outcome and tostring(ch.outcome or ""):find("pause_job", 1, true) ~= nil
    local should_apply_outcome = false

    c.pending_resume_npc_id = ch.next_npc_id
    if ch.next_allow_generic_stalker == true and has_values(ch.next_npc_faction_filters) then
        c.pending_resume_npc_faction_filters = ch.next_npc_faction_filters
        c.pending_resume_allow_generic_stalker = true
    else
        c.pending_resume_npc_faction_filters = nil
        c.pending_resume_allow_generic_stalker = false
    end

    if has_outcome then
        c.applied_outcomes = c.applied_outcomes or {}
        if not c.applied_outcomes[outcome_key] then
            should_apply_outcome = true
            c.applied_outcomes[outcome_key] = true
        else
            printf("Outcome already applied for choice %s, skipping to prevent farming.", outcome_key)
        end

        local original_outcome = ch.outcome
        if should_apply_outcome and apply_dialogue_stat_outcomes(original_outcome) then
            ch.outcome = strip_dialogue_stat_outcomes(original_outcome)
        end

        -- Dialogue skill / random checks resolve inline so the success/fail
        -- branch overrides the choice's regular continuation.
        local check_override = preresolve_dialogue_check(original_outcome)
        if check_override then
            ch.next_turn = check_override
        end
    end

    -- Mark reply chain as active so UI doesn't prematurely clear typing
    c.reply_pending = true
    pda_reply_pending = true

    -- Estimate typing duration based on reply length (roughly 1s per 20 chars, min 2s, max 8s).
    -- When the reply is empty the choice ends the branch silently, so skip the typing animation.
    local reply_text = ch.reply or ""
    local reply_len = string.len(reply_text)
    local has_reply = reply_text ~= ""
    local typing_duration = has_reply and math.max(2, math.min(8, math.floor(reply_len / 20) + 1)) or 0

    -- Use per-conversation event IDs so multiple conversations don't clobber each other
    local ev_prefix = "pda_ic_" .. tostring(c.npc_id)

    -- Stage 2: After a short delay, mark as "delivered" (message reaches NPC's PDA)
    local delivered_delay = math.random(1, 2)
    CreateTimeEvent(ev_prefix, "delivery_ack", delivered_delay, function()
        if is_panda_ic_shutdown_in_progress() then
            return true
        end
        set_last_player_message_state(cid, "delivered")

        -- Stage 3: NPC reads the message
        local player_msg_len = string.len(ch.text or "")
        local read_delay = math.max(1, math.min(4, math.floor(player_msg_len / 30) + 1))
        CreateTimeEvent(ev_prefix, "npc_read", read_delay, function()
            if is_panda_ic_shutdown_in_progress() then
                return true
            end
            set_last_player_message_state(cid, "read")

            -- Stage 4: NPC thinks before typing (skipped entirely for empty replies)
            local think_delay = has_reply and math.random(1, 3) or 0
            CreateTimeEvent(ev_prefix, "npc_thinking", think_delay, function()
                if is_panda_ic_shutdown_in_progress() then
                    return true
                end

                -- Stage 5: NPC starts typing (only when there is something to say)
                if has_reply then
                    upsert_npc_typing_message(cid, npc_name, c.npc_icon)
                end
                CreateTimeEvent(ev_prefix, "npc_reply", typing_duration, function()
                    if is_panda_ic_shutdown_in_progress() then
                        return true
                    end
                    if has_reply then
                        clear_npc_typing_message(cid)
                    end

                    if ch.reply and ch.reply ~= "" then
                        if is_private_tab_visible and is_private_tab_visible() then
                            -- Tab is open and visible, no global alert
                        else
                            printf("Global alert: New message from %s", npc_name)
                        end
                        pda_private_add_message(cid, npc_name, npc_name, ch.reply, c.npc_icon, false, nil, nil, nil, {
                            reply_image_texture = ch.reply_image,
                            audio_name = ch.reply_audio_name,
                            audio_path = ch.reply_audio_path,
                            skip_personality = false,
                        })
                        c.started_at = time_global and time_global() or c.started_at
                        set_last_player_message_state(cid, "read")
                    end

                    if should_apply_outcome then
                        local outcome_delay_min = PANDA.get_config("outcome_delay_min") or 1
                        local outcome_delay_max = PANDA.get_config("outcome_delay_max") or 2
                        CreateTimeEvent(ev_prefix, "outcome", math.random(outcome_delay_min, outcome_delay_max), function()
                            if is_panda_ic_shutdown_in_progress() then
                                return true
                            end
                            apply_outcome(ch.outcome, npc_name, c.faction, c.npc_id, c.task_id, cid, c)
                            return true
                        end)
                    end

                    if pauses_for_job then
                        c.reply_pending = false
                        pda_reply_pending = false
                        return true
                    end

                    if ch.next_turn and continuation_channel == "pda" then
                        -- Multi-NPC handoff: if the choice specifies a different NPC for the next turn,
                        -- queue a PDA followup in the new NPC's contact thread instead of continuing inline.
                        local handed_off = false
                        local new_npc_se, new_npc_id
                        if ch.next_allow_generic_stalker and ch.next_npc_faction_filters and #ch.next_npc_faction_filters > 0 then
                            new_npc_se = pick_sim_branch_speaker_se(ch.next_npc_faction_filters)
                            new_npc_id = new_npc_se and tonumber(new_npc_se.id) or nil
                        elseif ch.next_npc_id and ch.next_npc_id ~= "" then
                            if ch.next_npc_id:sub(1,4) == "npc:" then
                                new_npc_se = resolve_or_spawn_custom_npc_se(ch.next_npc_id:sub(5), {
                                    conv_data = c,
                                })
                                new_npc_id = new_npc_se and tonumber(new_npc_se.id) or nil
                            elseif type(get_story_se_object) == "function" then
                                local ok_se, se = pcall(get_story_se_object, ch.next_npc_id)
                                new_npc_se = ok_se and se or nil
                                new_npc_id = new_npc_se and tonumber(new_npc_se.id) or nil
                            end
                        end
                        if new_npc_id and new_npc_id ~= tonumber(c.npc_id) then
                            local ok_nn, new_name = pcall(function() return new_npc_se:character_name() end)
                            local ok_ni, new_icon = pcall(function() return new_npc_se:character_icon() end)
                            local resolved_name = (ok_nn and new_name and new_name ~= "") and new_name or "Unknown"
                            local resolved_icon = (ok_ni and new_icon and new_icon ~= "") and new_icon or FALLBACK_NPC_ICON
                            queue_pda_followup_internal({
                                npc_id        = new_npc_id,
                                contact_id    = tostring(new_npc_id),
                                npc_name      = resolved_name,
                                npc_icon      = resolved_icon,
                                faction       = c.faction,   -- keep original conv faction for XML key lookup
                                prefix        = c.prefix,
                                conv_id       = c.conv_id,
                                turn          = ch.next_turn,
                                delay_seconds = ch.pda_delay_seconds or 0,
                                story_id      = ch.next_npc_id or tostring(new_npc_id),
                                canonical_id  = ch.next_npc_id and ch.next_npc_id:lower() or tostring(new_npc_id),
                                npc_refs      = c.npc_refs,
                                task_id       = c.task_id,
                                category      = c.category,
                                applied_outcomes = clone_plain_table(c.applied_outcomes) or {},
                                exclusion_group = ch.fanout_group,
                            })
                            dbg("PANDA_IC: multi-npc handoff pda contact_id=%s -> new_npc_id=%s story_id=%s conv_id=%s turn=%s",
                                tostring(cid), tostring(new_npc_id), tostring(ch.next_npc_id),
                                tostring(c.conv_id), tostring(ch.next_turn))
                            handed_off = true
                        elseif ch.next_npc_id and ch.next_npc_id ~= "" then
                            printf("PANDA_IC: multi-npc handoff pda failed to resolve story_npc_id=%s, falling back to same-npc continuation", tostring(ch.next_npc_id))
                        elseif ch.next_allow_generic_stalker then
                            printf("PANDA_IC: multi-npc handoff pda failed to resolve sim factions=%s, falling back to same-npc continuation", tostring(table.concat(ch.next_npc_faction_filters or {}, ",")))
                        end

                        if not handed_off and (tonumber(ch.pda_delay_seconds) or 0) > 0 then
                            queue_pda_followup_internal({
                                npc_id        = c.npc_id,
                                contact_id    = cid,
                                npc_name      = npc_name,
                                npc_icon      = c.npc_icon,
                                faction       = c.faction,
                                prefix        = c.prefix,
                                conv_id       = c.conv_id,
                                turn          = ch.next_turn,
                                delay_seconds = ch.pda_delay_seconds or 0,
                                story_id      = c.story_id,
                                canonical_id  = c.canonical_id,
                                fallback_name = c.fallback_name,
                                npc_refs      = c.npc_refs,
                                task_id       = c.task_id,
                                category      = c.category,
                                applied_outcomes = clone_plain_table(c.applied_outcomes) or {},
                                exclusion_group = ch.fanout_group,
                            })
                            handed_off = true
                        end

                        if not handed_off then
                            -- Same NPC: in-place continuation as before
                            local next_choices, num = load_choices_for_turn(c.prefix, c.faction, c.conv_id, ch.next_turn, npc_name, cid, resolve_runtime_npc_se(nil, c.npc_id))
                            if num > 0 then
                                -- Skill/chance check branches: the choice's _reply is a
                                -- shared generic ack, so the branch-specific narration
                                -- lives in the success/fail turn's _open body. Emit it
                                -- here so the player sees the actual outcome message.
                                if outcome_has_dialogue_check(ch.outcome) then
                                    local next_p = build_turn_string_prefix(c.prefix, c.faction, c.conv_id, ch.next_turn)
                                    local open_key = next_p .. "_open"
                                    local open_text = game.translate_string(open_key)
                                    if open_text and open_text ~= ""
                                        and open_text ~= open_key
                                        and open_text ~= "[MISSING_OPEN_LINE]" then
                                        local npc_se_for_sub = c.npc_id and alife_object(c.npc_id) or nil
                                        pda_private_add_message(
                                            cid,
                                            npc_name,
                                            npc_name,
                                            sub_placeholders(open_text, npc_name, c.faction, npc_se_for_sub, cid),
                                            c.npc_icon,
                                            false,
                                            nil, nil, nil,
                                            get_message_attachment_fields_for_string_key(open_key)
                                        )
                                    end
                                end
                                c.turn = ch.next_turn
                                c.choices = next_choices
                                c.num_choices = num
                                c.reply_pending = false
                                c.started_at = time_global and time_global() or c.started_at
                                -- Carry the fan-out group token onto the same-NPC continuation
                                -- so this thread acts as the "primary" mutual-exclusion member.
                                c.exclusion_group = ch.fanout_group
                                -- Re-register in multi-conv table
                                active_conversations[cid] = c
                                CONV = c
                            end
                        end

                        -- Mutual-exclusion fan-out: queue parallel PDA continuations to each
                        -- sibling NPC. All siblings share `ch.fanout_group` with the primary;
                        -- whichever the player picks a reply in first wins, the others go inert.
                        if ch.fanout_group and ch.fanout_targets and #ch.fanout_targets > 0 then
                            local primary_cid_skip = handed_off and new_npc_id and tostring(new_npc_id) or nil
                            for _, target in ipairs(ch.fanout_targets) do
                                local t_se, t_id
                                if target.next_npc_id and target.next_npc_id ~= "" then
                                    if target.next_npc_id:sub(1,4) == "npc:" then
                                        t_se = resolve_or_spawn_custom_npc_se(target.next_npc_id:sub(5), { conv_data = c })
                                        t_id = t_se and tonumber(t_se.id) or nil
                                    elseif type(get_story_se_object) == "function" then
                                        local ok_se, se = pcall(get_story_se_object, target.next_npc_id)
                                        t_se = ok_se and se or nil
                                        t_id = t_se and tonumber(t_se.id) or nil
                                    end
                                end
                                local sibling_cid = t_id and tostring(t_id) or nil
                                if t_id
                                    and t_id ~= tonumber(c.npc_id)
                                    and sibling_cid ~= primary_cid_skip then
                                    local ok_n, t_name = pcall(function() return t_se:character_name() end)
                                    local ok_i, t_icon = pcall(function() return t_se:character_icon() end)
                                    local resolved_name = (ok_n and t_name and t_name ~= "") and t_name or "Unknown"
                                    local resolved_icon = (ok_i and t_icon and t_icon ~= "") and t_icon or FALLBACK_NPC_ICON
                                    queue_pda_followup_internal({
                                        npc_id           = t_id,
                                        contact_id       = sibling_cid,
                                        npc_name         = resolved_name,
                                        npc_icon         = resolved_icon,
                                        faction          = c.faction,
                                        prefix           = c.prefix,
                                        conv_id          = c.conv_id,
                                        turn             = target.next_turn,
                                        delay_seconds    = tonumber(target.pda_delay_seconds) or 0,
                                        story_id         = target.next_npc_id,
                                        canonical_id     = target.next_npc_id:lower(),
                                        npc_refs         = c.npc_refs,
                                        task_id          = c.task_id,
                                        category         = c.category,
                                        applied_outcomes = clone_plain_table(c.applied_outcomes) or {},
                                        exclusion_group  = ch.fanout_group,
                                    })
                                    printf("PANDA_IC: fanout sibling queued group=%s contact_id=%s story=%s turn=%s",
                                        tostring(ch.fanout_group), sibling_cid, tostring(target.next_npc_id), tostring(target.next_turn))
                                elseif target.next_npc_id and target.next_npc_id ~= "" then
                                    printf("PANDA_IC: fanout sibling skipped story=%s (unresolved or duplicate of primary)", tostring(target.next_npc_id))
                                end
                            end
                        end
                    elseif ch.next_turn and continuation_channel == "f2f" then
                        c.pending_in_person_continuation = true
                        c.pending_in_person_turn = ch.next_turn
                        c.pending_in_person_set_at = time_global and time_global() or 0
                        local npc_se = c.npc_id and alife_object(c.npc_id) or nil
                        local handoff_identity = build_f2f_handoff_identity(npc_se, c.npc_id)
                        local handoff_token = make_f2f_handoff_token(c.npc_id, c.conv_id, ch.next_turn, c.pending_in_person_set_at)
                        local bridge = ensure_panda_f2f_bridge()
                        local handoff_dialog = "panda_f2f_hub_dialog"
                        if bridge and type(bridge.reset_runtime) == "function" then
                            local ok_reset = pcall(bridge.reset_runtime, "prepare_new_pda_f2f_handoff")
                            printf(
                                "PANDA_IC: pre-handoff bridge reset requested npc_id=%s conv_id=%s turn=%s ok=%s",
                                tostring(c.npc_id),
                                tostring(c.conv_id),
                                tostring(ch.next_turn),
                                tostring(ok_reset == true)
                            )
                        end
                        if bridge and type(bridge.allocate_hub_dialog_id) == "function" then
                            local ok_dialog, allocated_dialog = pcall(bridge.allocate_hub_dialog_id)
                            if ok_dialog and type(allocated_dialog) == "string" and allocated_dialog ~= "" then
                                handoff_dialog = allocated_dialog
                            end
                        end
                        c.pending_in_person_target = handoff_dialog
                        c.pending_in_person_token = handoff_token
                        c.pending_in_person_story_id = handoff_identity.story_id
                        c.pending_in_person_canonical_id = handoff_identity.canonical_id
                        -- Resolve the correct meet-target (may differ if cont_npc_id redirects to a new NPC)
                        local handoff_target_name = tostring(c.npc_name or "Unknown")
                        local handoff_target_id = tostring(c.npc_id or "Unknown")
                        local ht_se
                        if ch.next_npc_id and ch.next_npc_id ~= "" then
                            if ch.next_npc_id:sub(1,4) == "npc:" then
                                ht_se = resolve_or_spawn_custom_npc_se(ch.next_npc_id:sub(5), {
                                    conv_data = c,
                                })
                            elseif type(get_story_se_object) == "function" then
                                local ok_ht, _ht = pcall(get_story_se_object, ch.next_npc_id)
                                ht_se = ok_ht and _ht or nil
                            end
                        end
                        if ht_se then
                            local ht_id = tonumber(ht_se.id)
                            if ht_id then handoff_target_id = tostring(ht_id) end
                            local ok_htn, htn = pcall(function() return ht_se:character_name() end)
                            if ok_htn and htn and htn ~= "" then handoff_target_name = htn end
                        end
                        pda_private_add_message(
                            cid,
                            npc_name,
                            "PDA System",
                            string.format("Meet %s (ID: %s) to continue this conversation.", handoff_target_name, handoff_target_id),
                            c.npc_icon,
                            false,
                            nil,
                            nil,
                            nil,
                            { skip_personality = true }
                        )
                        local handoff_story_id = tostring(handoff_identity.story_id or "n/a")

                        printf("TRACE f2f-handoff npc_sid=%s story_id=%s canonical_id=%s conv_id=%s next_turn=%s channel=%s token=%s",
                            tostring(tonumber(c.npc_id) or 0),
                            tostring(handoff_story_id),
                            tostring(handoff_identity.canonical_id or "n/a"),
                            tostring(tonumber(c.conv_id) or 0),
                            tostring(tonumber(ch.next_turn) or 0),
                            tostring(continuation_channel),
                            tostring(handoff_token))

                        local handoff_row = {
                            contact_id = cid,
                            npc_id = c.npc_id,
                            npc_name = c.npc_name,
                            npc_icon = c.npc_icon,
                            conv_id = c.conv_id,
                            turn = ch.next_turn,
                            faction = c.faction,
                            prefix = c.prefix,
                            channel = "f2f",
                            dialog = handoff_dialog,
                            set_at = c.pending_in_person_set_at,
                            token = handoff_token,
                            story_id = handoff_identity.story_id,
                            canonical_id = handoff_identity.canonical_id,
                            fallback_name = handoff_identity.fallback_name,
                            npc_refs = c.npc_refs,
                            task_id = c.task_id,
                            category = c.category,
                            applied_outcomes = clone_plain_table(c.applied_outcomes) or {},
                            route_owner = nil,
                            route_dialog = handoff_dialog,
                            route_status = "pending",
                        }

                        -- Multi-NPC F2F handoff: if the choice targets a different NPC, override the
                        -- handoff identity so the F2F bridge waits for the player to approach that NPC.
                        if ch.next_npc_id and ch.next_npc_id ~= "" then
                            handoff_row.story_id    = ch.next_npc_id
                            handoff_row.canonical_id = ch.next_npc_id:lower()
                            local new_se
                            if ch.next_npc_id:sub(1,4) == "npc:" then
                                new_se = resolve_or_spawn_custom_npc_se(ch.next_npc_id:sub(5), {
                                    conv_data = c,
                                })
                            elseif type(get_story_se_object) == "function" then
                                local ok_new, _se = pcall(get_story_se_object, ch.next_npc_id)
                                new_se = ok_new and _se or nil
                            end
                            if new_se then
                                local new_f2f_id = tonumber(new_se.id)
                                if new_f2f_id then
                                    handoff_row.npc_id = new_f2f_id
                                    local ok_nn, nn = pcall(function() return new_se:character_name() end)
                                    local ok_ni, ni = pcall(function() return new_se:character_icon() end)
                                    if ok_nn and nn and nn ~= "" then handoff_row.npc_name = nn end
                                    if ok_ni and ni and ni ~= "" then handoff_row.npc_icon = ni end
                                    dbg("PANDA_IC: multi-npc handoff f2f contact_id=%s -> new_npc_id=%s story_id=%s",
                                        tostring(cid), tostring(new_f2f_id), tostring(ch.next_npc_id))
                                end
                            end
                        end

                        -- Keep active conversation state aligned with the actual F2F
                        -- target. Otherwise pda_f2f_handoffs points at the new NPC
                        -- while active_conversations still points at the old sender,
                        -- leaving stale pending state after the handoff is consumed.
                        if tonumber(handoff_row.npc_id) and tonumber(handoff_row.npc_id) ~= tonumber(c.npc_id) then
                            c.npc_id = handoff_row.npc_id
                            c.npc_name = handoff_row.npc_name
                            c.npc_icon = handoff_row.npc_icon
                            c.story_id = handoff_row.story_id
                            c.canonical_id = handoff_row.canonical_id
                            c.pending_in_person_story_id = handoff_row.story_id
                            c.pending_in_person_canonical_id = handoff_row.canonical_id
                        end

                        handoff_token = make_f2f_handoff_token(handoff_row.npc_id, c.conv_id, ch.next_turn, c.pending_in_person_set_at)
                        c.pending_in_person_token = handoff_token
                        handoff_row.token = handoff_token

                        queue_f2f_handoff_attachment(
                            cid,
                            npc_name,
                            npc_icon,
                            handoff_row.npc_id,
                            handoff_row.npc_name,
                            handoff_token
                        )

                        register_pending_f2f_handoff(cid, handoff_row)

                        local handoff_route = "no-route"
                        local owner_tag = string.format("pda_handoff_%s_%s_%s", tostring(cid), tostring(c.conv_id), tostring(ch.next_turn))
                        if bridge and type(bridge.hard_route_branch) == "function" then
                            local ok_route_call, route_applied = pcall(bridge.hard_route_branch, handoff_row.npc_id, owner_tag, handoff_dialog)
                            if ok_route_call and route_applied == true then
                                handoff_route = "bridge route"
                            end
                        end

                        if handoff_route ~= "bridge route" and xr_meet and type(xr_meet.override_dialog) == "function" then
                            local ok_override_call = pcall(xr_meet.override_dialog, handoff_row.npc_id, handoff_dialog)
                            if ok_override_call and has_xr_meet_dialog_override(handoff_row.npc_id, handoff_dialog) then
                                handoff_route = "xr_meet fallback"
                            end
                        end

                        handoff_row.route_owner = owner_tag
                        handoff_row.route_status = handoff_route
                        handoff_row.route_set_at = time_global and time_global() or c.pending_in_person_set_at

                        printf("PANDA_IC: f2f handoff registered npc_id=%s conv_id=%s turn=%s dialog=%s route=%s",
                            tostring(handoff_row.npc_id), tostring(c.conv_id), tostring(ch.next_turn), tostring(handoff_dialog), handoff_route)

                        -- Re-register in active_conversations so the pending_in_person
                        -- markers are trackable by consume_pending_f2f_handoff_internal
                        -- and sweep_expired_f2f_pending_markers. Without this, the conv
                        -- object is orphaned after on_player_choice removes it (line 5921).
                        active_conversations[cid] = c
                        CONV = c
                        -- The PDA thread is now waiting on an in-person continuation,
                        -- so keep the thread visible but remove the reply chips.
                        clear_pda_choices_for_pending_handoff(c)
                    end

                    if get_ui then
                        get_ui():Reset()
                    end

                    c.reply_pending = false
                    pda_reply_pending = false
                    return true
                end)
                return true
            end)
            return true
        end)
        return true
    end)

    -- Record cooldown only for terminal branches (no continuation turn)
    if not ch.next_turn then
        local composite_key = (c.prefix or "task") .. "_" .. c.faction .. "_" .. c.conv_id
        conv_last_played[composite_key] = game.get_game_time()
        -- Record storyline completion (author-defined id) for cross-conversation gating
        local sid = get_conversation_storyline_id(c.prefix, c.faction, c.conv_id)
        if sid then
            completed_storylines[sid] = true
            printf("PANDA_IC: storyline '%s' marked completed (conv %s/%s)", sid, tostring(c.faction), tostring(c.conv_id))
        end
    end
end

local function resolve_conversation_context_internal(npc_id, conversation_id, turn_number, channel)
    local resolved_channel = channel or "pda"
    local matched = nil

    if npc_id ~= nil then
        for _, conv in pairs(active_conversations) do
            if conv and conv.npc_id == npc_id then
                matched = conv
                break
            end
        end
    elseif CONV then
        matched = CONV
    end

    if not matched then
        return nil
    end

    if conversation_id ~= nil and matched.conv_id ~= conversation_id then
        return nil
    end

    if turn_number ~= nil and matched.turn ~= turn_number then
        return nil
    end

    if matched.channel == nil then
        matched.channel = resolved_channel
    end

    return matched
end

local function apply_choice_internal(conversation_context, choice_index, channel)
    if not conversation_context then
        return false
    end

    conversation_context.channel = channel or conversation_context.channel or "pda"
    on_player_choice(choice_index, conversation_context.contact_id)
    return true
end

has_xr_meet_dialog_override = function(npc_id, dialog_name)
    local sid = tonumber(npc_id)
    if not sid or sid <= 0 or not xr_meet then
        return false
    end

    if type(xr_meet.has_dialog_override) == "function" then
        local ok_override, has_override = pcall(function()
            return xr_meet.has_dialog_override(sid)
        end)
        if ok_override and has_override == true then
            return true
        end
    end

    local table_candidates = {
        "dialog_override",
        "dialog_overrides",
        "override_dialogs",
    }

    for _, field in ipairs(table_candidates) do
        local overrides = rawget(xr_meet, field)
        if type(overrides) == "table" then
            local rec = overrides[sid] or overrides[tostring(sid)]
            if rec == dialog_name then
                return true
            end
            if type(rec) == "table" then
                local rec_dialog = rec.dialog or rec.dialog_id or rec.id or rec.override or rec.dialog_name
                if rec_dialog == dialog_name then
                    return true
                end
            end
        end
    end

    return false
end

local function sync_pda_f2f_handoff_globals()
    if pda_f2f_handoffs then
        _G.pda_f2f_handoffs = pda_f2f_handoffs
    else
        _G.pda_f2f_handoffs = nil
    end
end

local function clear_pending_in_person_marker(conv)
    if type(conv) ~= "table" then
        return
    end

    conv.pending_in_person_continuation = false
    conv.pending_in_person_turn = nil
    conv.pending_in_person_target = nil
    conv.pending_in_person_set_at = nil
    conv.pending_in_person_token = nil
    conv.pending_in_person_story_id = nil
    conv.pending_in_person_canonical_id = nil
end

clear_pda_choices_for_pending_handoff = function(conv)
    if type(conv) ~= "table" then
        return
    end

    conv.choices = nil
    conv.num_choices = 0
end

remove_active_conversation_entry = function(contact_id)
    local contact_key = tostring(contact_id or "")
    if contact_key == "" then
        return false
    end

    local removed = false

    if type(active_conversations) == "table" and active_conversations[contact_key] then
        active_conversations[contact_key] = nil
        removed = true
    end

    if CONV and CONV.contact_id == contact_key then
        CONV = nil
        removed = true
    end

    return removed
end

cancel_all_active_conversations = function()
    if not type(active_conversations) == "table" then
        return
    end

    for contact_key in pairs(active_conversations) do
        active_conversations[contact_key] = nil
    end

    if CONV then
        CONV = nil
    end
end

abort_contact_f2f_state = function(contact_id, reason, options)
    local contact_key = tostring(contact_id or "")
    if contact_key == "" then
        return false, 0
    end

    options = type(options) == "table" and options or {}

    local convo = active_conversations and active_conversations[contact_key] or nil
    local handoff = pda_f2f_handoffs and pda_f2f_handoffs[contact_key] or nil
    local npc_sid = tonumber(handoff and handoff.npc_id or convo and convo.npc_id)
    local conv_id = tonumber(handoff and handoff.conv_id or convo and convo.conv_id)
    local turn = tonumber(handoff and handoff.turn or convo and convo.pending_in_person_turn)
    local token = handoff and handoff.token or convo and convo.pending_in_person_token or nil
    local set_at = tonumber(handoff and handoff.set_at or convo and convo.pending_in_person_set_at) or nil
    local route_owner = handoff and handoff.route_owner or nil
    local route_status = handoff and handoff.route_status or nil
    local any_cleanup = type(convo) == "table" or type(handoff) == "table"
    local removed_threads = 0

    if options.cancel_events == true then
        pda_reply_pending = false
        safe_remove_time_event("pda_ic", "delivery_ack")
        safe_remove_time_event("pda_ic", "npc_typing_start")
        safe_remove_time_event("pda_ic", "npc_reply")
        if npc_sid then
            local ev_prefix = "pda_ic_" .. tostring(npc_sid)
            safe_remove_time_event(ev_prefix, "delivery_ack")
            safe_remove_time_event(ev_prefix, "npc_read")
            safe_remove_time_event(ev_prefix, "npc_thinking")
            safe_remove_time_event(ev_prefix, "npc_reply")
            safe_remove_time_event(ev_prefix, "outcome")
        end
    end

    if npc_sid then
        local bridge = ensure_panda_f2f_bridge()
        local bridge_aborted = false
        local bridge_attempted = false
        if bridge and type(bridge.abort_session) == "function" then
            bridge_attempted = true
            local ok_abort, abort_result = pcall(bridge.abort_session, npc_sid, route_owner, tostring(reason or "unspecified"), token)
            bridge_aborted = ok_abort and abort_result == true
        elseif bridge and type(bridge.restore_branch_route) == "function" then
            bridge_attempted = true
            local ok_restore, restore_result = pcall(bridge.restore_branch_route, npc_sid, route_owner)
            bridge_aborted = ok_restore and restore_result == true
        end

        if not bridge_attempted and xr_meet and type(xr_meet.restore_dialog) == "function" then
            pcall(xr_meet.restore_dialog, npc_sid)
        end

        if type(consume_pending_f2f_handoff_internal) == "function" then
            any_cleanup = consume_pending_f2f_handoff_internal(npc_sid, conv_id, turn, token, set_at) == true or any_cleanup
        elseif type(handoff) == "table" and type(pda_f2f_handoffs) == "table" then
            pda_f2f_handoffs[contact_key] = nil
            sync_pda_f2f_handoff_globals()
            any_cleanup = true
        end
        printf(
            "PANDA_IC: abort_contact_f2f_state contact_id=%s reason=%s npc_id=%s conv_id=%s turn=%s token=%s route_status=%s bridge_aborted=%s",
            tostring(contact_key),
            tostring(reason or "unspecified"),
            tostring(npc_sid),
            tostring(conv_id or "nil"),
            tostring(turn or "nil"),
            tostring(token or "nil"),
            tostring(route_status or "nil"),
            tostring(bridge_aborted)
        )
    elseif type(handoff) == "table" and type(pda_f2f_handoffs) == "table" then
        pda_f2f_handoffs[contact_key] = nil
        sync_pda_f2f_handoff_globals()
    end

    if type(convo) == "table" then
        clear_pending_in_person_marker(convo)
    end

    if options.remove_conversation ~= false and active_conversations and active_conversations[contact_key] then
        any_cleanup = true
        active_conversations[contact_key] = nil
    end
    if options.remove_conversation ~= false and CONV and CONV.contact_id == contact_key then
        CONV = nil
    end

    if options.remove_thread == true then
        removed_threads = delete_contact_thread(contact_key)
        if removed_threads > 0 then
            any_cleanup = true
        end
    else
        local removed_attachments = remove_f2f_handoff_attachment(token, contact_key, npc_sid)
        if removed_attachments > 0 then
            any_cleanup = true
        end
    end

    return any_cleanup, removed_threads
end

local function normalize_pending_f2f_candidate(raw_handoff, source, match_mode)
    if type(raw_handoff) ~= "table" then
        return nil
    end

    local npc_sid = tonumber(raw_handoff.npc_id)
    local conv_id = tonumber(raw_handoff.conv_id)
    local turn = tonumber(raw_handoff.turn)
    if not npc_sid or npc_sid <= 0 or not conv_id or conv_id <= 0 or not turn or turn <= 0 then
        return nil
    end

    local set_at = tonumber(raw_handoff.set_at)
    if not set_at then
        return nil
    end

    local now = time_global and time_global() or nil
    if now and (now - set_at) > F2F_HANDOFF_ACTIONABLE_GRACE_MS then
        return nil
    end

    return {
        source = source or "unknown",
        match_mode = match_mode or "exact_id",
        contact_id = raw_handoff.contact_id,
        npc_id = npc_sid,
        conv_id = conv_id,
        turn = turn,
        faction = raw_handoff.faction,
        prefix = raw_handoff.prefix,
        channel = raw_handoff.channel or "f2f",
        dialog = raw_handoff.dialog,
        set_at = set_at,
        token = raw_handoff.token and tostring(raw_handoff.token) or nil,
        story_id = raw_handoff.story_id,
        canonical_id = raw_handoff.canonical_id,
        fallback_name = raw_handoff.fallback_name,
        npc_refs = normalize_npc_refs(raw_handoff.npc_refs),
        route_owner = raw_handoff.route_owner,
        route_dialog = raw_handoff.route_dialog,
        route_status = raw_handoff.route_status,
    }
end

select_preferred_pending_f2f_candidate = function(candidates)
    if type(candidates) ~= "table" or #candidates == 0 then
        return nil
    end

    table.sort(candidates, function(a, b)
        local a_exact = a and a.match_mode == "exact_id" and 1 or 0
        local b_exact = b and b.match_mode == "exact_id" and 1 or 0
        if a_exact ~= b_exact then
            return a_exact > b_exact
        end

        local a_set_at = tonumber(a and a.set_at) or 0
        local b_set_at = tonumber(b and b.set_at) or 0
        if a_set_at ~= b_set_at then
            return a_set_at > b_set_at
        end

        local a_token = tostring(a and a.token or "")
        local b_token = tostring(b and b.token or "")
        if a_token ~= b_token then
            return a_token > b_token
        end

        return tostring(a and a.source or "") < tostring(b and b.source or "")
    end)

    local exact_candidates = {}
    local fallback_candidates = {}
    for _, candidate in ipairs(candidates) do
        if candidate.match_mode == "exact_id" then
            exact_candidates[#exact_candidates + 1] = candidate
        else
            fallback_candidates[#fallback_candidates + 1] = candidate
        end
    end

    if #exact_candidates > 0 then
        return exact_candidates[1]
    end

    if #fallback_candidates == 1 then
        return fallback_candidates[1]
    end

    return nil
end

register_pending_f2f_handoff = function(contact_id, handoff_row)
    if type(handoff_row) ~= "table" then
        return false
    end

    local contact_key = tostring(contact_id or handoff_row.contact_id or "")
    local npc_sid = tonumber(handoff_row.npc_id)
    if contact_key == "" or not npc_sid or npc_sid <= 0 then
        return false
    end

    if type(handoff_row.route_dialog) ~= "string" or handoff_row.route_dialog == "" then
        handoff_row.route_dialog = handoff_row.dialog
    end

    pda_f2f_handoffs = pda_f2f_handoffs or {}

    local existing = pda_f2f_handoffs[contact_key]
    if type(existing) == "table"
        and tonumber(existing.npc_id) == npc_sid
        and tostring(existing.token or "") ~= tostring(handoff_row.token or "")
    then
        printf(
            "PANDA_IC: superseding pending f2f handoff key=%s npc_id=%s old_conv_id=%s old_turn=%s old_token=%s new_conv_id=%s new_turn=%s new_token=%s",
            tostring(contact_key),
            tostring(npc_sid),
            tostring(existing.conv_id or "nil"),
            tostring(existing.turn or "nil"),
            tostring(existing.token or "nil"),
            tostring(handoff_row.conv_id or "nil"),
            tostring(handoff_row.turn or "nil"),
            tostring(handoff_row.token or "nil")
        )
    end

    for key, existing_row in pairs(pda_f2f_handoffs) do
        if key ~= contact_key and type(existing_row) == "table" and tonumber(existing_row.npc_id) == npc_sid then
            printf(
                "PANDA_IC: superseding pending f2f handoff key=%s npc_id=%s old_conv_id=%s old_turn=%s old_token=%s new_conv_id=%s new_turn=%s new_token=%s",
                tostring(key),
                tostring(npc_sid),
                tostring(existing_row.conv_id or "nil"),
                tostring(existing_row.turn or "nil"),
                tostring(existing_row.token or "nil"),
                tostring(handoff_row.conv_id or "nil"),
                tostring(handoff_row.turn or "nil"),
                tostring(handoff_row.token or "nil")
            )
            pda_f2f_handoffs[key] = nil
        end
    end

    for key, conv in pairs(active_conversations or {}) do
        if key ~= contact_key and type(conv) == "table" and tonumber(conv.npc_id) == npc_sid and conv.pending_in_person_continuation == true then
            clear_pending_in_person_marker(conv)
        end
    end

    handoff_row.contact_id = contact_key
    handoff_row.npc_refs = normalize_npc_refs(handoff_row.npc_refs)
    pda_f2f_handoffs[contact_key] = handoff_row
    if type(active_conversations) == "table" and type(active_conversations[contact_key]) == "table" then
        local conv = active_conversations[contact_key]
        conv.npc_id = handoff_row.npc_id or conv.npc_id
        conv.npc_name = handoff_row.npc_name or conv.npc_name
        conv.npc_icon = handoff_row.npc_icon or conv.npc_icon
        conv.pending_in_person_continuation = true
        conv.pending_in_person_turn = handoff_row.turn
        conv.pending_in_person_target = handoff_row.route_dialog or handoff_row.dialog
        conv.pending_in_person_set_at = handoff_row.set_at
        conv.pending_in_person_token = handoff_row.token
        conv.pending_in_person_story_id = handoff_row.story_id or conv.story_id
        conv.pending_in_person_canonical_id = handoff_row.canonical_id or conv.canonical_id
        conv.story_id = handoff_row.story_id or conv.story_id
        conv.canonical_id = handoff_row.canonical_id or conv.canonical_id
        conv.npc_refs = handoff_row.npc_refs or conv.npc_refs
        clear_pda_choices_for_pending_handoff(conv)
    end
    sync_pda_f2f_handoff_globals()
    return true
end

local function get_pending_f2f_handoff_internal(npc_id)
    local npc_sid = tonumber(npc_id)
    if not npc_sid then
        return nil
    end

    local runtime_story_id = nil
    local runtime_canonical_id = nil
    if type(get_object_story_id) == "function" then
        local ok_story, story_id = pcall(function() return get_object_story_id(npc_sid) end)
        if ok_story and story_id and story_id ~= "" then
            runtime_story_id = tostring(story_id)
            runtime_canonical_id = tostring(story_id):lower()
        end
    end

    local function get_match_mode(handoff)
        if type(handoff) ~= "table" then
            return nil
        end

        if tonumber(handoff.npc_id) == npc_sid then
            return "exact_id"
        end

        local handoff_story_id = handoff.story_id and tostring(handoff.story_id) or nil
        local handoff_canonical_id = handoff.canonical_id and tostring(handoff.canonical_id):lower() or nil
        local handoff_fallback_name = handoff.fallback_name and tostring(handoff.fallback_name):lower() or nil

        if runtime_story_id and handoff_story_id and handoff_story_id == runtime_story_id then
            return "story_id"
        end
        if runtime_canonical_id and handoff_canonical_id and handoff_canonical_id == runtime_canonical_id then
            return "canonical_id"
        end
        if runtime_canonical_id and handoff_fallback_name and handoff_fallback_name == runtime_canonical_id then
            return "fallback_name"
        end

        return nil
    end

    local candidates = {}
    local seen = {}

    local function push_candidate(source, raw_handoff, match_mode, contact_id)
        if not match_mode then
            return
        end

        local normalized = normalize_pending_f2f_candidate(raw_handoff, source, match_mode)
        if not normalized then
            return
        end

        if contact_id ~= nil and normalized.contact_id == nil then
            normalized.contact_id = contact_id
        end

        local signature = table.concat({
            tostring(normalized.npc_id or "0"),
            tostring(normalized.conv_id or "0"),
            tostring(normalized.turn or "0"),
            tostring(normalized.token or ""),
            tostring(normalized.set_at or 0),
            tostring(normalized.match_mode or "unknown"),
        }, ":")
        if seen[signature] then
            return
        end

        seen[signature] = true
        candidates[#candidates + 1] = normalized
    end

    if pda_f2f_handoffs then
        for contact_id, handoff in pairs(pda_f2f_handoffs) do
            push_candidate("pda_f2f_handoffs", handoff, get_match_mode(handoff), contact_id)
        end
    end

    for contact_id, conv in pairs(active_conversations) do
        if type(conv) == "table" and conv.pending_in_person_continuation == true and conv.pending_in_person_turn then
            local pending_dialog = conv.pending_in_person_target or "panda_f2f_hub_dialog"
            local raw_conv_handoff = {
                contact_id = contact_id,
                npc_id = conv.npc_id,
                conv_id = conv.conv_id,
                turn = conv.pending_in_person_turn,
                faction = conv.faction,
                prefix = conv.prefix,
                channel = "f2f",
                dialog = pending_dialog,
                set_at = conv.pending_in_person_set_at,
                token = conv.pending_in_person_token,
                story_id = conv.pending_in_person_story_id or conv.story_id,
                canonical_id = conv.pending_in_person_canonical_id or conv.canonical_id,
                fallback_name = conv.fallback_name,
                npc_refs = conv.npc_refs,
                route_dialog = pending_dialog,
            }
            push_candidate("active_conversations", raw_conv_handoff, get_match_mode(raw_conv_handoff), contact_id)
        end
    end

    return select_preferred_pending_f2f_candidate(candidates)
end

consume_pending_f2f_handoff_internal = function(npc_id, conv_id, turn, token, set_at)
    local npc_sid = tonumber(npc_id)
    if not npc_sid then
        return false
    end

    local target_conv_id = tonumber(conv_id)
    local target_turn = tonumber(turn)
    local target_set_at = tonumber(set_at)
    local target_token = token and tostring(token) or nil

    local function handoff_matches_target(handoff)
        if type(handoff) ~= "table" then
            return false
        end

        if tonumber(handoff.npc_id) ~= npc_sid then
            return false
        end

        if target_token then
            return tostring(handoff.token or "") == target_token
        end

        if target_set_at then
            local handoff_set_at = tonumber(handoff.set_at)
            return handoff_set_at ~= nil and handoff_set_at == target_set_at
        end

        if target_conv_id and tonumber(handoff.conv_id) ~= target_conv_id then
            return false
        end

        if target_turn and tonumber(handoff.turn) ~= target_turn then
            return false
        end

        return true
    end

    local function conv_matches_target(conv)
        if type(conv) ~= "table" then
            return false
        end

        if tonumber(conv.npc_id) ~= npc_sid or conv.pending_in_person_continuation ~= true then
            return false
        end

        if target_token then
            return tostring(conv.pending_in_person_token or "") == target_token
        end

        if target_set_at then
            local pending_set_at = tonumber(conv.pending_in_person_set_at)
            return pending_set_at ~= nil and pending_set_at == target_set_at
        end

        if target_conv_id and tonumber(conv.conv_id) ~= target_conv_id then
            return false
        end

        if target_turn and tonumber(conv.pending_in_person_turn) ~= target_turn then
            return false
        end

        return true
    end

    local consumed = false

    if pda_f2f_handoffs then
        for key, handoff in pairs(pda_f2f_handoffs) do
            if handoff_matches_target(handoff) then
                remove_f2f_handoff_map_spot(handoff)
                pda_f2f_handoffs[key] = nil
                consumed = true
            elseif tonumber(handoff.npc_id) == npc_sid
                and (not target_conv_id or tonumber(handoff.conv_id) == target_conv_id)
                and (not target_turn or tonumber(handoff.turn) == target_turn)
            then
                printf(
                    "PANDA_IC: preserving newer f2f handoff key=%s npc_id=%s conv_id=%s turn=%s token=%s requested_token=%s set_at=%s requested_set_at=%s",
                    tostring(key),
                    tostring(handoff.npc_id),
                    tostring(handoff.conv_id),
                    tostring(handoff.turn),
                    tostring(handoff.token or "nil"),
                    tostring(target_token or "nil"),
                    tostring(handoff.set_at or "nil"),
                    tostring(target_set_at or "nil")
                )
            end
        end

        local has_remaining_handoffs = false
        for _ in pairs(pda_f2f_handoffs) do
            has_remaining_handoffs = true
            break
        end

        if has_remaining_handoffs then
            _G.pda_f2f_handoffs = pda_f2f_handoffs
        else
            pda_f2f_handoffs = nil
            _G.pda_f2f_handoffs = nil
        end
    end

    local consumed_contact_ids = {}

    for contact_id, conv in pairs(active_conversations or {}) do
        if conv_matches_target(conv) then
            clear_pending_in_person_marker(conv)
            consumed_contact_ids[#consumed_contact_ids + 1] = tostring(contact_id)
            consumed = true
        elseif tonumber(conv.npc_id) == npc_sid
            and conv.pending_in_person_continuation == true
            and (not target_conv_id or tonumber(conv.conv_id) == target_conv_id)
            and (not target_turn or tonumber(conv.pending_in_person_turn) == target_turn)
        then
            printf(
                "PANDA_IC: preserving newer pending_in_person marker npc_id=%s conv_id=%s turn=%s token=%s requested_token=%s set_at=%s requested_set_at=%s",
                tostring(conv.npc_id),
                tostring(conv.conv_id),
                tostring(conv.pending_in_person_turn),
                tostring(conv.pending_in_person_token or "nil"),
                tostring(target_token or "nil"),
                tostring(conv.pending_in_person_set_at or "nil"),
                tostring(target_set_at or "nil")
            )
        end
    end

    for _, contact_id in ipairs(consumed_contact_ids) do
        remove_active_conversation_entry(contact_id)
    end

    if consumed then
        remove_f2f_handoff_attachment(target_token, nil, npc_sid)
        clear_private_map_nav_task()
    end

    return consumed
end

clear_f2f_handoff_marker_internal = function(npc_id, conv_id, turn, token, set_at)
    local npc_sid = tonumber(npc_id)
    if not npc_sid then
        return false
    end

    local target_conv_id = tonumber(conv_id)
    local target_turn = tonumber(turn)
    local target_set_at = tonumber(set_at)
    local target_token = token and tostring(token) or nil
    local cleared = false

    local function handoff_matches_target(handoff)
        if type(handoff) ~= "table" then
            return false
        end

        if tonumber(handoff.npc_id) ~= npc_sid then
            return false
        end

        if target_token then
            return tostring(handoff.token or "") == target_token
        end

        if target_set_at then
            local handoff_set_at = tonumber(handoff.set_at)
            return handoff_set_at ~= nil and handoff_set_at == target_set_at
        end

        if target_conv_id and tonumber(handoff.conv_id) ~= target_conv_id then
            return false
        end

        if target_turn and tonumber(handoff.turn) ~= target_turn then
            return false
        end

        return true
    end

    if pda_f2f_handoffs then
        for _, handoff in pairs(pda_f2f_handoffs) do
            if handoff_matches_target(handoff) and remove_f2f_handoff_map_spot(handoff) == true then
                cleared = true
            end
        end
    end

    if remove_f2f_handoff_attachment(target_token, nil, npc_sid) > 0 then
        cleared = true
    end

    if clear_private_map_nav_task() == true then
        cleared = true
    end

    return cleared
end

build_savable_f2f_handoffs = function()
    if type(pda_f2f_handoffs) ~= "table" then
        return nil
    end

    local now = time_global and time_global() or nil
    local out = {}
    local saved_any = false

    for key, handoff in pairs(pda_f2f_handoffs) do
        if type(handoff) == "table" then
            local contact_key = tostring(handoff.contact_id or key)
            local actionable = is_handoff_actionable(handoff, now)
            if not is_contact_blocked(contact_key) and actionable == true then
                local cloned = {}
                for field_name, field_value in pairs(handoff) do
                    cloned[field_name] = field_value
                end
                cloned.contact_id = contact_key
                out[contact_key] = cloned
                saved_any = true
            end
        end
    end

    if saved_any then
        return out
    end

    return nil
end

local function sweep_expired_f2f_pending_markers(reason)
    local now = time_global and time_global() or nil
    if not now then
        return {
            stale_pending_cleared = 0,
            handoff_rows_removed = 0,
            source_reason = tostring(reason or "unspecified"),
        }
    end

    local stale_pending_cleared = 0
    local handoff_rows_removed = 0
    local stale_entries = {}

    for contact_id, conv in pairs(active_conversations or {}) do
        if type(conv) == "table" and conv.pending_in_person_continuation == true then
            local set_at = tonumber(conv.pending_in_person_set_at)
            local age_ms = set_at and (now - set_at) or nil
            if not set_at or age_ms > F2F_HANDOFF_ACTIONABLE_GRACE_MS then
                table.insert(stale_entries, {
                    contact_id = contact_id,
                    npc_id = tonumber(conv.npc_id),
                    conv_id = tonumber(conv.conv_id),
                    turn = tonumber(conv.pending_in_person_turn),
                    token = conv.pending_in_person_token,
                    set_at = set_at,
                    age_ms = age_ms,
                })
                remove_f2f_handoff_attachment(conv.pending_in_person_token, contact_id, conv.npc_id)
                conv.pending_in_person_continuation = false
                conv.pending_in_person_turn = nil
                conv.pending_in_person_target = nil
                conv.pending_in_person_set_at = nil
                conv.pending_in_person_token = nil
                conv.pending_in_person_story_id = nil
                conv.pending_in_person_canonical_id = nil
                stale_pending_cleared = stale_pending_cleared + 1
            end
        end
    end

    if #stale_entries > 0 and type(pda_f2f_handoffs) == "table" then
        for key, handoff in pairs(pda_f2f_handoffs) do
            if type(handoff) == "table" then
                local handoff_npc = tonumber(handoff.npc_id)
                local handoff_conv = tonumber(handoff.conv_id)
                local handoff_turn = tonumber(handoff.turn)
                for _, stale in ipairs(stale_entries) do
                    local npc_match = stale.npc_id and handoff_npc and stale.npc_id == handoff_npc
                    local conv_match = stale.conv_id and handoff_conv and stale.conv_id == handoff_conv
                    local turn_match = stale.turn and handoff_turn and stale.turn == handoff_turn
                    if npc_match and (conv_match or turn_match or (not stale.conv_id and not stale.turn)) then
                        remove_f2f_handoff_attachment(handoff.token or stale.token, key, handoff.npc_id)
                        pda_f2f_handoffs[key] = nil
                        handoff_rows_removed = handoff_rows_removed + 1
                        break
                    end
                end
            end
        end

        local has_remaining_handoffs = false
        for _ in pairs(pda_f2f_handoffs) do
            has_remaining_handoffs = true
            break
        end

        if has_remaining_handoffs then
            _G.pda_f2f_handoffs = pda_f2f_handoffs
        else
            pda_f2f_handoffs = nil
            _G.pda_f2f_handoffs = nil
        end
    end

    for _, stale in ipairs(stale_entries) do
        remove_active_conversation_entry(stale.contact_id)
    end

    if stale_pending_cleared > 0 or handoff_rows_removed > 0 then
        printf(
            "PANDA_IC: f2f marker safety sweep reason=%s stale_pending_cleared=%s handoff_rows_removed=%s",
            tostring(reason or "unspecified"),
            tostring(stale_pending_cleared),
            tostring(handoff_rows_removed)
        )
    end

    return {
        stale_pending_cleared = stale_pending_cleared,
        handoff_rows_removed = handoff_rows_removed,
        source_reason = tostring(reason or "unspecified"),
    }
end

local function resolve_npc_server_id(npc_se)
    if not npc_se then
        return nil
    end

    local sid = tonumber(npc_se.id)
    if not sid and type(npc_se.id) == "function" then
        local ok, from_fn = pcall(function() return npc_se:id() end)
        if ok then
            sid = tonumber(from_fn)
        end
    end

    if not sid or sid <= 0 then
        return nil
    end

    return math.floor(sid)
end

local function get_npc_story_or_name_id(npc_se)
    local sid = resolve_npc_server_id(npc_se)
    if sid and type(get_object_story_id) == "function" then
        local ok_story, story_id = pcall(function() return get_object_story_id(sid) end)
        if ok_story and story_id and story_id ~= "" then
            return tostring(story_id), "story"
        end
    end

    if npc_se and npc_se.name then
        local ok_name, fallback_name = pcall(function() return npc_se:name() end)
        if ok_name and fallback_name and fallback_name ~= "" then
            return tostring(fallback_name), "name"
        end
    end

    return nil, nil
end

build_f2f_handoff_identity = function(npc_se, fallback_npc_id)
    local out = {
        npc_id = resolve_npc_server_id(npc_se) or tonumber(fallback_npc_id) or nil,
        story_id = nil,
        canonical_id = nil,
        fallback_name = nil,
    }

    if out.npc_id and type(get_object_story_id) == "function" then
        local ok_story, story_id = pcall(function() return get_object_story_id(out.npc_id) end)
        if ok_story and story_id and story_id ~= "" then
            out.story_id = tostring(story_id)
        end
    end

    if PANDA_CONV_API and type(PANDA_CONV_API.get_npc_canonical_id) == "function" and npc_se then
        local ok_canonical, canonical_id = pcall(function()
            return PANDA_CONV_API.get_npc_canonical_id(npc_se)
        end)
        if ok_canonical and canonical_id and canonical_id ~= "" then
            out.canonical_id = tostring(canonical_id):lower()
        end
    end

    if npc_se and npc_se.name then
        local ok_name, fallback_name = pcall(function() return npc_se:name() end)
        if ok_name and fallback_name and fallback_name ~= "" then
            out.fallback_name = tostring(fallback_name)
        end
    end

    if not out.canonical_id then
        if out.story_id and out.story_id ~= "" then
            out.canonical_id = tostring(out.story_id):lower()
        elseif out.fallback_name and out.fallback_name ~= "" then
            out.canonical_id = tostring(out.fallback_name):lower()
        end
    end

    return out
end

local function normalize_identity_value(value)
    if value == nil then
        return nil
    end

    local normalized = tostring(value):lower()
    if normalized == "" or normalized == "nil" then
        return nil
    end

    return normalized
end

local function identities_overlap(target_identity, slot_npc_id, slot_story_id, slot_canonical_id)
    if type(target_identity) ~= "table" then
        return false, nil
    end

    local target_npc_id = tonumber(target_identity.npc_id)
    local slot_npc = tonumber(slot_npc_id)
    if target_npc_id and slot_npc and target_npc_id == slot_npc then
        return true, "npc_id"
    end

    local target_story_id = normalize_identity_value(target_identity.story_id)
    local target_canonical_id = normalize_identity_value(target_identity.canonical_id)
    local slot_story = normalize_identity_value(slot_story_id)
    local slot_canonical = normalize_identity_value(slot_canonical_id)

    if target_story_id and slot_story and target_story_id == slot_story then
        return true, "story_id"
    end
    if target_canonical_id and slot_canonical and target_canonical_id == slot_canonical then
        return true, "canonical_id"
    end
    if target_story_id and slot_canonical and target_story_id == slot_canonical then
        return true, "story_to_canonical"
    end
    if target_canonical_id and slot_story and target_canonical_id == slot_story then
        return true, "canonical_to_story"
    end

    return false, nil
end

is_conversation_identity_in_use = function(npc_se, options)
    options = type(options) == "table" and options or {}

    local identity = options.identity or build_f2f_handoff_identity(npc_se, options.fallback_npc_id)
    if type(identity) ~= "table" then
        identity = {}
    end
    identity.npc_id = tonumber(options.npc_id or identity.npc_id or (npc_se and npc_se.id)) or identity.npc_id
    identity.npc_refs = normalize_npc_refs(options.npc_refs or identity.npc_refs)

    for contact_key, conv in pairs(active_conversations or {}) do
        if type(conv) == "table" then
            local refs_matched, ref = npc_refs_overlap(identity.npc_refs, conv.npc_refs)
            if refs_matched then
                return true, "active_conversation:npc_ref:" .. tostring(ref), tostring(contact_key)
            end
            local matched, reason = identities_overlap(
                identity,
                conv.npc_id,
                conv.pending_in_person_story_id or conv.story_id,
                conv.pending_in_person_canonical_id or conv.canonical_id
            )
            if matched then
                return true, "active_conversation:" .. tostring(reason), tostring(contact_key)
            end
        end
    end

    for key, handoff in pairs(pda_f2f_handoffs or {}) do
        if type(handoff) == "table" then
            local actionable = true
            if type(is_handoff_actionable) == "function" then
                actionable = is_handoff_actionable(handoff, time_global and time_global() or nil)
            end
            if actionable then
                local refs_matched, ref = npc_refs_overlap(identity.npc_refs, handoff.npc_refs)
                if refs_matched then
                    return true, "pending_handoff:npc_ref:" .. tostring(ref), tostring(handoff.contact_id or key)
                end
                local matched, reason = identities_overlap(
                    identity,
                    handoff.npc_id,
                    handoff.story_id,
                    handoff.canonical_id
                )
                if matched then
                    return true, "pending_handoff:" .. tostring(reason), tostring(handoff.contact_id or key)
                end
            end
        end
    end

    for key, pending in pairs(pending_pda_followups or {}) do
        if type(pending) == "table" then
            local contact_key = tostring(pending.contact_id or key)
            if not is_contact_blocked(contact_key) then
                local refs_matched, ref = npc_refs_overlap(identity.npc_refs, pending.npc_refs)
                if refs_matched then
                    return true, "pending_pda_followup:npc_ref:" .. tostring(ref), contact_key
                end
                local matched, reason = identities_overlap(
                    identity,
                    pending.npc_id,
                    pending.story_id,
                    pending.canonical_id
                )
                if matched then
                    return true, "pending_pda_followup:" .. tostring(reason), contact_key
                end
            end
        end
    end

    return false, nil, nil
end

make_f2f_handoff_token = function(npc_id, conv_id, turn, set_at)
    local rand = math.random(100000, 999999)
    return string.format(
        "f2f_%s_%s_%s_%s_%s",
        tostring(tonumber(npc_id) or 0),
        tostring(tonumber(conv_id) or 0),
        tostring(tonumber(turn) or 0),
        tostring(tonumber(set_at) or 0),
        tostring(rand)
    )
end

PANDA_CONV_API = PANDA_CONV_API or {}

function PANDA_CONV_API.resolve_conversation_context(npc_id, conversation_id, turn_number, channel)
    return resolve_conversation_context_internal(npc_id, conversation_id, turn_number, channel or "pda")
end

function PANDA_CONV_API.check_preconditions(precond_key, npc_se, channel, context)
    local resolved_channel = channel or "pda"
    if type(context) == "table" and context.channel == nil then
        context.channel = resolved_channel
    end
    return check_preconditions_generic(precond_key, npc_se)
end

function PANDA_CONV_API.apply_choice(conversation_context, choice_index, channel)
    return apply_choice_internal(conversation_context, choice_index, channel or "pda")
end

function PANDA_CONV_API.apply_outcome(outcome_str, sender_npc_name, sender_faction, sender_npc_id, task_id, contact_id, conv_data, channel)
    return apply_outcome(
        outcome_str,
        sender_npc_name,
        sender_faction,
        sender_npc_id,
        task_id,
        contact_id,
        conv_data,
        channel or "pda"
    )
end

function PANDA_CONV_API.on_f2f_dialog_closed(npc_id, session_token, reason)
    return flush_deferred_dialog_npc_animation(npc_id, session_token, reason)
end

function PANDA_CONV_API.queue_pda_followup(followup)
    return queue_pda_followup_internal(followup)
end

function PANDA_CONV_API.register_f2f_handoff(contact_id, handoff_row)
    return register_pending_f2f_handoff(contact_id, handoff_row)
end

function PANDA_CONV_API.get_pending_f2f_handoff(npc_id)
    return get_pending_f2f_handoff_internal(npc_id)
end

function PANDA_CONV_API.consume_pending_f2f_handoff(npc_id, conv_id, turn, token, set_at)
    return consume_pending_f2f_handoff_internal(npc_id, conv_id, turn, token, set_at)
end

function PANDA_CONV_API.clear_f2f_handoff_marker(npc_id, conv_id, turn, token, set_at)
    return clear_f2f_handoff_marker_internal(npc_id, conv_id, turn, token, set_at)
end

function PANDA_CONV_API.sweep_expired_f2f_markers(reason)
    return sweep_expired_f2f_pending_markers(reason)
end

function PANDA_CONV_API.get_npc_canonical_id(npc_se)
    local raw_id = get_npc_story_or_name_id(npc_se)
    if not raw_id then
        return nil
    end
    return tostring(raw_id):lower()
end

function PANDA_CONV_API.check_cooldown(conv_id, faction, prefix)
    local cooldown_key = (prefix or "task") .. "_" .. tostring(faction or "loner") .. "_" .. tostring(conv_id or 0)
    local last = conv_last_played[cooldown_key]
    if not last then
        return false, 0
    end
    if not is_conversation_repeatable(prefix, faction, conv_id) then
        return true, 0
    end
    local seconds_since = game.get_game_time():diffSec(last)
    local default_cooldown = (PANDA.get_config("default_cooldown") or 60) * 60
    local on_cooldown = seconds_since < default_cooldown
    return on_cooldown, seconds_since
end

function PANDA_CONV_API.record_cooldown(conv_id, faction, prefix)
    local cooldown_key = (prefix or "task") .. "_" .. tostring(faction or "loner") .. "_" .. tostring(conv_id or 0)
    conv_last_played[cooldown_key] = game.get_game_time()
end

function start_interactive_conv(npc_se, conv_id, prefix, faction, task_id, category)
    local name = npc_se:character_name()
    local contact_id = make_contact_id(npc_se)
    local identity = build_f2f_handoff_identity(npc_se)
    local npc_refs = get_conversation_npc_refs(prefix, faction, conv_id)
    identity.npc_refs = npc_refs

    if is_contact_blocked(contact_id) then
        return false
    end

    local start_cooldown_key = (prefix or "task") .. "_" .. tostring(faction or "loner") .. "_" .. tostring(conv_id or 0)
    if conv_last_played[start_cooldown_key] and not is_conversation_repeatable(prefix, faction, conv_id) then
        return false
    end

    -- Block if this specific NPC already has an active conversation
    if active_conversations[contact_id] then return false end

    local identity_in_use, identity_reason, owner_key = is_conversation_identity_in_use(npc_se, {
        identity = identity,
    })
    if identity_in_use then
        printf(
            "PANDA_IC: start_interactive_conv blocked reason=%s owner=%s npc_id=%s story_id=%s canonical_id=%s conv_id=%s",
            tostring(identity_reason or "identity_in_use"),
            tostring(owner_key or "nil"),
            tostring(identity.npc_id or npc_se.id or "nil"),
            tostring(identity.story_id or "nil"),
            tostring(identity.canonical_id or "nil"),
            tostring(conv_id or "nil")
        )
        return false
    end

    -- Initialize relationship score for hostile NPCs on first contact
    if not npc_relationship_scores[contact_id] then
        local npc_obj = level.object_by_id(npc_se.id)
        if npc_obj and npc_obj:relation(db.actor) == game_object.enemy then
            npc_relationship_scores[contact_id] = -200  -- Wary default for hostile NPCs
        end
    end

    -- Clear smart terrain placeholder cache for fresh resolution this conversation
    clear_st_resolve_cache()

    local key
    if prefix == "task" or not prefix then
        key = "st_pda_ic_"..faction.."_"..tostring(conv_id).."_open"
    else
        key = "st_pda_ic_"..prefix.."_"..faction.."_"..tostring(conv_id).."_open"
    end

    local msg = game.translate_string(key)
    if msg == key then return false end

    local choices, num = load_choices_for_turn(prefix, faction, conv_id, 1, name, contact_id, npc_se)
    if num == 0 then return false end

    local conv_data = {
        npc_id = identity.npc_id or npc_se.id,
        contact_id = contact_id,
        npc_name = name,
        npc_icon = npc_se:character_icon() or FALLBACK_NPC_ICON,
        faction = faction,
        prefix = prefix,
        conv_id = conv_id,
        turn = 1,
        choices = choices,
        num_choices = num,
        task_id = task_id,
        category = category,
        applied_outcomes = {}, -- Track applied outcomes to prevent farming during UI loops
        started_at = time_global(),  -- Track when conversation started (for timeout)
        reply_pending = false,  -- Per-conversation reply pending flag
        story_id = identity.story_id,
        canonical_id = identity.canonical_id,
        fallback_name = identity.fallback_name,
        npc_refs = npc_refs,
    }

    -- Store in multi-conversation table keyed by contact_id
    active_conversations[contact_id] = conv_data
    -- Keep CONV pointing to the latest conversation for backward compatibility
    CONV = conv_data

    last_conv_npc_id = npc_se.id
    record_npc_use(npc_se.id)

    -- Register NPC metadata for typing personality transforms
    if pda_typing_personality and pda_typing_personality.register_npc then
        local rank_name = get_npc_rank_name(npc_se) or "experienced"
        pda_typing_personality.register_npc(contact_id, faction, rank_name)
    end

    -- Send ONLY the Generic Global Chat Alert
    dynamic_news_helper.send_tip(
        "You've received a Private Message from " .. name,
        "PDA Alert", 0, 10, conv_data.npc_icon, "news", "npc"
    )

    -- Add the actual message directly into the custom Private PDA Log
    pda_private_add_message(
        contact_id,
        name,
        name,
        sub_placeholders(msg, name, faction, npc_se, contact_id),
        conv_data.npc_icon,
        false,
        nil,
        nil,
        nil,
        get_message_attachment_fields_for_string_key(key)
    )

    -- Force refresh of UI if PDA is actively open so the message pops up immediately
    if get_ui then
        get_ui():Reset()
    end

    return true
end

-- ============================================================
-- TARGETED NPC CONVERSATION SCANNING
-- ============================================================
-- Extracts req_story_npc:<id> from a precondition string.
-- Returns the story_id or nil if not present.
local function extract_story_npc_id(precond_str)
    if not precond_str or precond_str == "" then return nil end
    return string.match(precond_str, "req_story_npc:([%w_%-]+)")
end

local function extract_custom_story_target(precond_str)
    if not precond_str or precond_str == "" then return nil, nil end
    return string.match(precond_str, "req_custom_story_npc:([%w_%-]+):([^,%)]+)")
end

-- Scans all conversations for a faction and finds those that require a specific
-- story NPC or custom story target. For each, resolves the NPC in alife and
-- checks whether all preconditions pass. Returns a list of {npc_se, conv_id}
-- tables.
local function collect_story_npc_conversations(xml_fac, prefix)
    local results = {}
    local base = (prefix and prefix ~= "task") and ("st_pda_ic_" .. tostring(prefix) .. "_") or "st_pda_ic_"
    local mode = PANDA.get_config("cooldown_mode")
    local penalty = PANDA.get_config("cooldown_penalty") / 100
    local hard_min = PANDA.get_config("cooldown_hard_min") * 60

    -- Discover max_id using the same scan as pick_random_conv_id_generic
    local max_id = 0
    while true do
        local p = base .. xml_fac .. "_" .. tostring(max_id + 1) .. "_open"
        if game.translate_string(p) == p then break end
        max_id = max_id + 1
    end
    if max_id == 0 then return results end

    for cid = 1, max_id do
        -- Skip F2F-only conversations (they are triggered face-to-face, not via PDA)
        local start_mode_key = base .. xml_fac .. "_" .. tostring(cid) .. "_start_mode"
        local start_mode_val = game.translate_string(start_mode_key)
        if start_mode_val ~= start_mode_key and start_mode_val == "f2f" then goto story_continue end

        local precond_key = base .. xml_fac .. "_" .. tostring(cid) .. "_precond"
        local precond_val = game.translate_string(precond_key)
        if precond_val == precond_key then precond_val = "" end

        local story_id = extract_story_npc_id(precond_val)
        local custom_tpl_id, custom_smart_ref = extract_custom_story_target(precond_val)
        if story_id or custom_tpl_id then
            local npc_se = nil
            local target_desc = nil
            local npc_refs = get_conversation_npc_refs(prefix, xml_fac, cid)
            if story_id then
                npc_se = get_story_se_object(story_id)
                target_desc = "story_id=" .. tostring(story_id)
            elseif custom_tpl_id then
                target_desc = "template_id=" .. tostring(custom_tpl_id)
                if panda_npc_creator and type(panda_npc_creator.ensure_story_target_spawned) == "function" then
                    pcall(panda_npc_creator.ensure_story_target_spawned, custom_tpl_id, custom_smart_ref)
                end
                if panda_npc_creator and type(panda_npc_creator.get_active_npc_se) == "function" then
                    local ok_custom, custom_se = pcall(panda_npc_creator.get_active_npc_se, custom_tpl_id)
                    if ok_custom then
                        npc_se = custom_se
                    end
                end
            end
            if npc_se and npc_se:alive() then
                local identity_in_use, identity_reason, owner_key = is_conversation_identity_in_use(npc_se, { npc_refs = npc_refs })
                if identity_in_use then
                    printf(
                        "PANDA_IC: skip targeted NPC candidate npc_id=%s target=%s conv_id=%s reason=%s owner=%s",
                        tostring(tonumber(npc_se.id) or 0),
                        tostring(target_desc or "unknown"),
                        tostring(tonumber(cid) or 0),
                        tostring(identity_reason or "identity_in_use"),
                        tostring(owner_key or "nil")
                    )
                else
                -- NPC cooldown
                if not is_npc_on_cooldown(npc_se.id) then
                    -- Conversation cooldown
                    local cooldown_key = (prefix or "task") .. "_" .. xml_fac .. "_" .. cid
                    local last = conv_last_played[cooldown_key]
                    local skip = false
                    local weight = 100

                    if last then
                        if not is_conversation_repeatable(prefix, xml_fac, cid) then
                            skip = true
                        else
                            local seconds_since = game.get_game_time():diffSec(last)
                            local on_cooldown = seconds_since < (PANDA.get_config("default_cooldown") * 60)
                            if on_cooldown then
                                if mode == 1 then
                                    skip = true
                                elseif seconds_since < hard_min then
                                    skip = true
                                else
                                    weight = penalty * 100
                                end
                            end
                        end
                    end

                    if not skip then
                        -- Full precondition check (including req_story_npc / req_custom_story_npc itself)
                        local branch_precond_key = base .. xml_fac .. "_" .. tostring(cid) .. "_branch_precond"
                        if check_preconditions_generic(precond_key, npc_se)
                            and check_preconditions_generic(branch_precond_key, npc_se)
                        then
                            table.insert(results, {npc_se = npc_se, conv_id = cid, prefix = prefix, weight = weight, npc_refs = npc_refs})
                            printf("Story NPC conv %s matched — NPC %s (story_id=%s, weight=%s)",
                                tostring(tonumber(cid) or 0),
                                tostring(npc_se:character_name()),
                                tostring(target_desc or "target"),
                                tostring(tonumber(weight) or 0))
                            printf("TRACE story-match npc_sid=%s story_id=%s conv_id=%s next_turn=%s channel=%s",
                                tostring(tonumber(npc_se.id) or 0),
                                tostring(target_desc or "target"),
                                tostring(tonumber(cid) or 0),
                                tostring("n/a"),
                                tostring("pda"))
                        end
                    end
                end
                end
            end
        end
        ::story_continue::
    end

    return results
end

-- ============================================================
-- INTERACTIVE CONVERSATION ATTEMPT (merged system — no prefix)
-- Preconditions on each conversation handle NPC filtering
-- (friendly/hostile, faction, rank, etc.) via goodwill checks.
-- Story NPC conversations are mixed into the same pool as
-- simulated NPC conversations for equal selection chance.
-- ============================================================
local function attempt_interactive_conversation()
    if is_panda_ic_shutdown_in_progress() then
        return false
    end
    printf("Attempting interactive conversation (merged system)")

    local player_comm = get_actor_true_community() or "stalker"
    local xml_fac = (player_comm == "stalker") and "loner" or player_comm

    -- Phase 1: Collect targeted NPC conversation candidates
    local panda_prefixes = get_panda_story_prefixes(xml_fac)
    local story_matches = collect_story_npc_conversations(xml_fac)
    for _, panda_prefix in ipairs(panda_prefixes) do
        local panda_story_matches = collect_story_npc_conversations(xml_fac, panda_prefix)
        for _, m in ipairs(panda_story_matches) do
            table.insert(story_matches, m)
        end
    end
    printf(string.format("Found %d targeted NPC conversation candidates", #story_matches))

    -- Phase 2: Collect simulated NPC conversation candidates (existing flow)
    local sim_matches = {}
    local npc_list = get_all_eligible_npcs()
    printf(string.format("Found %d eligible simulated NPCs", #npc_list))

    local pool = {}
    for i = 1, #npc_list do pool[i] = npc_list[i] end

    while #pool > 0 do
        local idx = math.random(#pool)
        local candidate = table.remove(pool, idx)
        local identity_in_use, identity_reason, owner_key = is_conversation_identity_in_use(candidate)
        if identity_in_use then
            printf(
                "PANDA_IC: skip simulated NPC candidate npc_id=%s reason=%s owner=%s",
                tostring(tonumber(candidate.id) or 0),
                tostring(identity_reason or "identity_in_use"),
                tostring(owner_key or "nil")
            )
        else
            local candidate_conv = pick_random_conv_id_generic(nil, xml_fac, nil, candidate)
            local found_candidate = false
            if candidate_conv then
                local npc_refs = get_conversation_npc_refs(nil, xml_fac, candidate_conv)
                local ref_in_use, ref_reason, ref_owner = is_conversation_identity_in_use(candidate, { npc_refs = npc_refs })
                if ref_in_use then
                    printf(
                        "PANDA_IC: skip simulated conversation candidate npc_id=%s conv_id=%s reason=%s owner=%s",
                        tostring(tonumber(candidate.id) or 0),
                        tostring(tonumber(candidate_conv) or 0),
                        tostring(ref_reason or "identity_in_use"),
                        tostring(ref_owner or "nil")
                    )
                else
                    table.insert(sim_matches, {npc_se = candidate, conv_id = candidate_conv, prefix = nil, weight = 100, npc_refs = npc_refs})
                    found_candidate = true
                end
            end
            for _, panda_prefix in ipairs(panda_prefixes) do
                local panda_candidate_conv = pick_random_conv_id_generic(panda_prefix, xml_fac, nil, candidate)
                if panda_candidate_conv then
                    local npc_refs = get_conversation_npc_refs(panda_prefix, xml_fac, panda_candidate_conv)
                    local ref_in_use, ref_reason, ref_owner = is_conversation_identity_in_use(candidate, { npc_refs = npc_refs })
                    if ref_in_use then
                        printf(
                            "PANDA_IC: skip simulated conversation candidate npc_id=%s conv_id=%s prefix=%s reason=%s owner=%s",
                            tostring(tonumber(candidate.id) or 0),
                            tostring(tonumber(panda_candidate_conv) or 0),
                            tostring(panda_prefix or "legacy"),
                            tostring(ref_reason or "identity_in_use"),
                            tostring(ref_owner or "nil")
                        )
                    else
                        table.insert(sim_matches, {npc_se = candidate, conv_id = panda_candidate_conv, prefix = panda_prefix, weight = 100, npc_refs = npc_refs})
                        found_candidate = true
                    end
                end
            end
            if found_candidate then
                -- Stop after finding one simulated match (preserves existing behavior
                -- where one random NPC is selected from the pool)
                break
            end
        end
    end

    -- Phase 3: Merge both pools and do weighted random selection
    local all_matches = {}
    for _, m in ipairs(story_matches) do
        if m.npc_se and not is_contact_blocked(make_contact_id(m.npc_se)) then
            table.insert(all_matches, m)
        end
    end
    for _, m in ipairs(sim_matches) do
        if m.npc_se and not is_contact_blocked(make_contact_id(m.npc_se)) then
            table.insert(all_matches, m)
        end
    end

    if #all_matches == 0 then
        printf("No interactive conversation found for faction %s (no story or simulated NPC matches).", xml_fac)
        return false
    end

    -- Weighted random pick from merged pool
    local total_weight = 0
    for _, m in ipairs(all_matches) do total_weight = total_weight + m.weight end

    local r = math.random(total_weight)
    local accum = 0
    local pick = all_matches[1]
    for _, m in ipairs(all_matches) do
        accum = accum + m.weight
        if r <= accum then
            pick = m
            break
        end
    end

    printf("Picked NPC: %s (ID %s)",
        tostring(pick.npc_se:character_name()),
        tostring(tonumber(pick.npc_se.id) or 0))
    printf("Selected conv_id = %s prefix = %s", tostring(tonumber(pick.conv_id) or 0), tostring(pick.prefix or "legacy"))

    return start_interactive_conv(pick.npc_se, pick.conv_id, pick.prefix, xml_fac, nil, nil)
end

-- ============================================================
-- CONVERSATION TIMEOUT SYSTEM
-- ============================================================
-- Each conversation can define a timeout (in real seconds) and an annoyed
-- message that gets sent when the player ignores the NPC.  Timeouts are
-- read from XML: st_pda_ic_<prefix>_<fac>_<id>_timeout  (seconds, e.g. "120")
--                 st_pda_ic_<prefix>_<fac>_<id>_timeout_msg (annoyed text)
-- If no XML timeout is found, a random default between 90-300 seconds is used.

local CONV_TIMEOUT_DEFAULT_MIN = 90   -- seconds (real-time)
local CONV_TIMEOUT_DEFAULT_MAX = 300

local function get_conv_timeout_config(prefix, faction, conv_id)
    local base
    if prefix == "task" or not prefix then
        base = "st_pda_ic_" .. faction .. "_" .. tostring(conv_id)
    else
        base = "st_pda_ic_" .. prefix .. "_" .. faction .. "_" .. tostring(conv_id)
    end

    local timeout_key = base .. "_timeout"
    local timeout_msg_key = base .. "_timeout_msg"

    local timeout_val = game.translate_string(timeout_key)
    local timeout_secs = nil
    if timeout_val ~= timeout_key then
        timeout_secs = tonumber(timeout_val)
    end
    if not timeout_secs then
        timeout_secs = math.random(CONV_TIMEOUT_DEFAULT_MIN, CONV_TIMEOUT_DEFAULT_MAX)
    end

    local timeout_msg = game.translate_string(timeout_msg_key)
    if timeout_msg == timeout_msg_key then
        timeout_msg = nil  -- Will use a generic fallback
    end

    return timeout_secs, timeout_msg
end

local GENERIC_TIMEOUT_MESSAGES = {
    "You know what, forget it. I don't have time for this.",
    "Still there? No? Fine, I'll find someone else.",
    "Guess you're not interested. Signal lost.",
    "I waited long enough. Don't bother replying.",
    "Typical. Can't even get a straight answer in this place.",
}

function check_conversation_timeouts()
    if is_panda_ic_shutdown_in_progress() then
        return
    end
    if not active_conversations then return end
    local now = time_global()

    local expired = {}
    for cid, conv in pairs(active_conversations) do
        -- Skip conversations that have a pending job (they are "paused")
        if conv.started_at
            and not conv.reply_pending
            and not has_pending_job(cid)
            and conv.pending_in_person_continuation ~= true
        then
            local timeout_secs, timeout_msg = get_conv_timeout_config(
                conv.prefix, conv.faction, conv.conv_id
            )
            -- time_global returns milliseconds
            local elapsed_ms = now - conv.started_at
            local elapsed_secs = elapsed_ms / 1000

            if elapsed_secs >= timeout_secs then
                table.insert(expired, { contact_id = cid, conv = conv, msg = timeout_msg })
            end
        end
    end

    for _, exp in ipairs(expired) do
        local conv = exp.conv
        local annoyed_msg = exp.msg
            or GENERIC_TIMEOUT_MESSAGES[math.random(#GENERIC_TIMEOUT_MESSAGES)]

        -- Substitute placeholders in the annoyed message
        annoyed_msg = sub_placeholders(annoyed_msg, conv.npc_name, conv.faction, conv.npc_id and alife_object(conv.npc_id) or nil, exp.contact_id)

        -- Add the annoyed message to the chat log
        pda_private_add_message(exp.contact_id, conv.npc_name, conv.npc_name, annoyed_msg, conv.npc_icon, false)

        abort_contact_f2f_state(exp.contact_id, "conversation_timeout", {
            remove_conversation = true,
            cancel_events = true,
        })

        -- Record cooldown
        local composite_key = (conv.prefix or "task") .. "_" .. conv.faction .. "_" .. conv.conv_id
        conv_last_played[composite_key] = game.get_game_time()

        printf("Conversation with %s timed out after %.0f seconds", conv.npc_name,
            (now - conv.started_at) / 1000)
    end

    -- Refresh UI if any expired
    if #expired > 0 and pda_private_tab and pda_private_tab.get_ui then
        pda_private_tab.get_ui():Reset()
    end
end

-- ============================================================
-- MAIN TRIGGER & SCHEDULING
-- ============================================================

local function is_actor_currently_in_dialog()
    if not (db and db.actor) then
        return false
    end

    if db.actor_dialog then
        return true
    end

    if db.actor.is_talking then
        local ok, talking = pcall(function()
            return db.actor:is_talking()
        end)
        if ok and talking then
            return true
        end
    end

    return false
end

is_handoff_actionable = function(handoff, now_ms)
    if type(handoff) ~= "table" then
        return false, "invalid_type"
    end

    local npc_id = tonumber(handoff.npc_id)
    local conv_id = tonumber(handoff.conv_id)
    local turn = tonumber(handoff.turn)

    if not npc_id or npc_id <= 0 then
        return false, "invalid_npc_id"
    end

    if not conv_id or conv_id <= 0 then
        return false, "invalid_conv_id"
    end

    if not turn or turn <= 0 then
        return false, "invalid_turn"
    end

    if now_ms then
        local set_at = tonumber(handoff.set_at)
        if not set_at then
            return false, "missing_set_at"
        end

        local age_ms = now_ms - set_at
        if age_ms > F2F_HANDOFF_ACTIONABLE_GRACE_MS then
            return false, string.format("stale_age age_ms=%s grace_ms=%s", tostring(age_ms), tostring(F2F_HANDOFF_ACTIONABLE_GRACE_MS))
        end
    end

    return true, nil
end

local function has_pending_f2f_handoff_entries()
    if type(pda_f2f_handoffs) ~= "table" then
        return false
    end

    local now = time_global and time_global() or nil
    local has_actionable = false
    local pruned_any = false

    for key, handoff in pairs(pda_f2f_handoffs) do
        local contact_key = tostring(handoff and handoff.contact_id or key)
        local actionable, reason = is_handoff_actionable(handoff, now)
        if actionable and is_contact_blocked(contact_key) then
            actionable = false
            reason = "blocked_contact"
        end
        if actionable then
            has_actionable = true
        else
            remove_f2f_handoff_attachment(handoff and handoff.token, contact_key, handoff and handoff.npc_id)
            pda_f2f_handoffs[key] = nil
            pruned_any = true
            printf(
                "PANDA_IC: purged stale f2f handoff key=%s reason=%s npc_id=%s conv_id=%s turn=%s set_at=%s",
                tostring(key),
                tostring(reason or "invalid"),
                tostring(handoff and handoff.npc_id),
                tostring(handoff and handoff.conv_id),
                tostring(handoff and handoff.turn),
                tostring(handoff and handoff.set_at)
            )
        end
    end

    if pruned_any then
        local has_remaining = false
        for _ in pairs(pda_f2f_handoffs) do
            has_remaining = true
            break
        end

        if has_remaining then
            _G.pda_f2f_handoffs = pda_f2f_handoffs
        else
            pda_f2f_handoffs = nil
            _G.pda_f2f_handoffs = nil
        end
    end

    return has_actionable
end

local function bridge_reports_active_f2f_session()
    local bridge = ensure_panda_f2f_bridge()
    if not bridge then
        return false, nil
    end

    local probes = {
        "is_session_active",
        "has_active_session",
        "is_active_for_actor",
        "session_active_for_actor",
    }

    for _, fn_name in ipairs(probes) do
        local fn = bridge[fn_name]
        if type(fn) == "function" then
            local ok, active = pcall(fn, db and db.actor or nil)
            if ok and active == true then
                return true, fn_name
            end
        end
    end

    return false, nil
end

local function is_f2f_session_active_for_actor()
    if has_pending_f2f_handoff_entries() then
        return true, "handoff_table"
    end

    for _, conv in pairs(active_conversations or {}) do
        if type(conv) == "table" and conv.pending_in_person_continuation == true then
            return true, "pending_in_person_continuation"
        end
    end

    local bridge_active, bridge_probe = bridge_reports_active_f2f_session()
    if bridge_active then
        return true, "bridge_runtime:" .. tostring(bridge_probe)
    end

    return false, nil
end

local function log_f2f_scanner_suppression_once(source_reason)
    local source = tostring(source_reason or "unknown")
    local source_changed = source ~= _panda_state.f2f_scanner_suppress_last_source
    local now = time_global and time_global() or nil
    if (not source_changed)
        and now
        and _panda_state.f2f_scanner_suppress_last_log_at
        and (now - _panda_state.f2f_scanner_suppress_last_log_at) < F2F_SCANNER_SUPPRESS_LOG_WINDOW_MS
    then
        return
    end

    _panda_state.f2f_scanner_suppress_last_source = source

    if now then
        _panda_state.f2f_scanner_suppress_last_log_at = now
    end

    printf(
        "PANDA_IC: scanner suppressed reason=f2f_session_active source=%s",
        source
    )
end

function try_trigger_interactive_conv()
    if is_panda_ic_shutdown_in_progress() then
        return false
    end
    if not PANDA.get_config("enabled") then
        printf("Trigger skipped: disabled")
        return false
    end
    if not is_player_chat_online() then
        printf("Trigger skipped: player chat is offline")
        return false
    end
    sweep_expired_f2f_pending_markers("periodic_scanner_gate")
    local f2f_active, f2f_source = is_f2f_session_active_for_actor()
    if f2f_active then
        -- Guard: while an F2F handoff/session is active, skip scanner selection and
        -- precondition evaluation so we do not overwrite shared conversation context.
        log_f2f_scanner_suppression_once(f2f_source)
        return false
    end
    -- Allow up to 3 simultaneous conversations (configurable)
    local max_active = 3
    if count_active_conversations() >= max_active then
        printf("Trigger skipped: %d active conversations (max %d)", count_active_conversations(), max_active)
        return false
    end
    if not db.actor then
        printf("Trigger skipped: no actor")
        return false
    end
    if is_actor_currently_in_dialog() then
        printf("Trigger skipped: actor currently in dialog")
        return false
    end
    if PANDA.get_config("require_pda_equipped") and not db.actor:item_in_slot(8) then
        printf("Trigger skipped: PDA not equipped")
        return false
    end

    -- Merged system: all conversations are interactive.
    -- Preconditions on each conversation handle NPC filtering
    -- (friendly/hostile via goodwill, faction, rank, etc.)
    return attempt_interactive_conversation()
end

local function schedule_next_trigger(interval_min)
    local tf = level.get_time_factor() or 10
    if tf <= 0 then tf = 10 end
    interval_min = math.max(1, tonumber(interval_min) or 1)
    -- Convert in-game minutes to real seconds
    local delay = (interval_min * 60) / tf
    CreateTimeEvent("pda_ic_trigger", "tick", delay, function()
        if is_panda_ic_shutdown_in_progress() then
            return true
        end
        -- Check for timed-out conversations before triggering new ones
        check_conversation_timeouts()
        try_trigger_interactive_conv()
        schedule_next_trigger(math.random(PANDA.get_config("trigger_min"), PANDA.get_config("trigger_max")))
        return true
    end)
end

-- Also run timeout checks more frequently (every 10 real seconds)
local function schedule_timeout_checker()
    CreateTimeEvent("pda_ic_timeout", "check", 10, function()
        if is_panda_ic_shutdown_in_progress() then
            return true
        end
        check_conversation_timeouts()
        sweep_expired_f2f_pending_markers("periodic_timeout_checker")
        return false  -- Keep repeating
    end)
end

local function schedule_location_ref_checker()
    local interval = tonumber(PANDA.get_config("location_check_interval")) or 5
    if interval < 1 then interval = 1 end

    CreateTimeEvent("pda_ic_location", "check", interval, function()
        if is_panda_ic_shutdown_in_progress() then
            return true
        end
        check_location_references()
        return false
    end)
end

local function schedule_job_checker()
    CreateTimeEvent("pda_ic_jobs", "check", 5, function()
        if is_panda_ic_shutdown_in_progress() then
            return true
        end
        check_pending_jobs()
        return false -- Keep repeating
    end)
end

local function schedule_pda_followup_checker()
    CreateTimeEvent("pda_ic_followups", "check", 1, function()
        if is_panda_ic_shutdown_in_progress() then
            return true
        end
        check_pending_pda_followups()
        return false
    end)
end


-- ============================================================
-- KEYBOARD CALLBACKS
-- ============================================================
function on_key_press_cb(key)
    if is_panda_ic_shutdown_in_progress() then
        return
    end
    -- debug trigger if enabled. All choice interactions are in the PDA UI now.
    if key == DIK_SPACE and not CONV and PANDA.get_config("debug_trigger") then
        try_trigger_interactive_conv()
    end
end

-- ============================================================
-- SAVE / LOAD (cooldowns)
-- ============================================================
function save_state(m)
    m.pda_ic_cooldowns = conv_last_played
    m.pda_ic_npc_cooldowns = npc_last_used
    m.pda_private_log = pda_private_log -- SAVE TO FILE
    m.pda_private_blocked_contacts = pda_private_blocked_contacts
    m.pda_player_chat_online = pda_player_chat_online
    m.pda_npc_relationship_scores = npc_relationship_scores
    m.pda_completed_storylines = completed_storylines
    if pda_ic_dialogue_stats and type(pda_ic_dialogue_stats.save_state) == "function" then
        pda_ic_dialogue_stats.save_state(m)
    end
    -- Save active conversations (strip non-serializable fields)
    local save_convs = {}
    for cid, c in pairs(active_conversations) do
        if not is_contact_blocked(cid) then
            save_convs[cid] = {
                npc_id = c.npc_id, contact_id = c.contact_id,
                npc_name = c.npc_name, npc_icon = c.npc_icon,
                faction = c.faction, prefix = c.prefix, conv_id = c.conv_id,
                turn = c.turn, task_id = c.task_id, category = c.category,
                channel = c.channel,
                applied_outcomes = c.applied_outcomes, started_at = c.started_at,
                story_id = c.story_id, canonical_id = c.canonical_id, fallback_name = c.fallback_name,
                npc_refs = c.npc_refs,
                pending_in_person_continuation = c.pending_in_person_continuation,
                pending_in_person_turn = c.pending_in_person_turn,
                pending_in_person_target = c.pending_in_person_target,
                pending_in_person_set_at = c.pending_in_person_set_at,
                pending_in_person_token = c.pending_in_person_token,
                pending_in_person_story_id = c.pending_in_person_story_id,
                pending_in_person_canonical_id = c.pending_in_person_canonical_id,
                exclusion_group = c.exclusion_group,
                exclusion_inert = c.exclusion_inert,
            }
        end
    end
    m.pda_active_conversations = save_convs
    m.pda_f2f_handoffs = build_savable_f2f_handoffs()
    m.pda_pending_location_refs = pending_location_refs
    m.pda_next_location_ref_id = next_location_ref_id
    m.pda_pending_jobs = pending_jobs
    m.pda_next_job_id = next_job_id
    m.pda_pending_pda_followups = nil
    if type(pending_pda_followups) == "table" then
        local saved_followups = {}
        for key, followup in pairs(pending_pda_followups) do
            if type(followup) == "table" then
                local contact_id = tostring(followup.contact_id or key)
                if not is_contact_blocked(contact_id) then
                    saved_followups[key] = clone_plain_table(followup)
                    saved_followups[key].contact_id = contact_id
                end
            end
        end
        if next(saved_followups) ~= nil then
            m.pda_pending_pda_followups = saved_followups
        end
    end
    m.pda_next_pda_followup_id = next_pda_followup_id

    local adapter = get_anomaly_artifact_adapter()
    if adapter and adapter.save_state then
        adapter.save_state(m)
    end

    local task_bridge = ensure_panda_task_bridge()
    if task_bridge and type(task_bridge.save_state) == "function" then
        task_bridge.save_state(m)
    end

    if panda_npc_creator and type(panda_npc_creator.save_state) == "function" then
        panda_npc_creator.save_state(m)
    end
end

function load_state(m)
    panda_ic_shutdown_in_progress = false
    reset_all_dialog_npc_animation_state("load_state")
    if m.pda_ic_cooldowns then conv_last_played = m.pda_ic_cooldowns end
    if m.pda_ic_npc_cooldowns then npc_last_used = m.pda_ic_npc_cooldowns end
    if m.pda_npc_relationship_scores then npc_relationship_scores = m.pda_npc_relationship_scores end
    if type(m.pda_completed_storylines) == "table" then
        completed_storylines = m.pda_completed_storylines
    else
        completed_storylines = {}
    end
    if pda_ic_dialogue_stats and type(pda_ic_dialogue_stats.load_state) == "function" then
        pda_ic_dialogue_stats.load_state(m)
    end
    active_conversations = {}
    CONV = nil
    pda_reply_pending = false
    pending_location_refs = {}
    next_location_ref_id = 1
    pending_jobs = {}
    next_job_id = 1
    pending_pda_followups = {}
    next_pda_followup_id = 1
    if m.pda_private_log then
        pda_private_log = m.pda_private_log -- LOAD FROM FILE
        local i = #pda_private_log
        while i >= 1 do
            local entry = pda_private_log[i]
            if entry and entry.is_typing then
                table.remove(pda_private_log, i)
            elseif entry and entry.is_player then
                entry.delivery_state = normalize_delivery_state(entry.delivery_state)
                if entry.delivery_timestamp == nil then
                    entry.delivery_timestamp = get_delivery_time_marker()
                end
            end
            -- Migration: old saves have contact_name but no contact_id
            if entry and not entry.contact_id then
                entry.contact_id = entry.contact_name
            end
            i = i - 1
        end
    end

    if m.pda_private_blocked_contacts then
        pda_private_blocked_contacts = m.pda_private_blocked_contacts
    end

    if m.pda_player_chat_online ~= nil then
        pda_player_chat_online = m.pda_player_chat_online
    end

    if m.pda_pending_location_refs then
        pending_location_refs = m.pda_pending_location_refs
    end

    if m.pda_next_location_ref_id then
        next_location_ref_id = m.pda_next_location_ref_id
    end

    local task_bridge = install_panda_task_bridge_callbacks()
    local legacy_task_jobs = {}
    if m.pda_pending_jobs then
        for key, job in pairs(m.pda_pending_jobs) do
            if type(job) == "table" then
                local cloned_job = clone_plain_table(job) or {}
                cloned_job.channel = cloned_job.channel or "pda"
                cloned_job.npc_refs = normalize_npc_refs(cloned_job.npc_refs)
                if task_bridge and type(task_bridge.is_task_family) == "function" and task_bridge.is_task_family(cloned_job.job_type) then
                    table.insert(legacy_task_jobs, cloned_job)
                else
                    cloned_job.started_at = time_global()
                    pending_jobs[key] = cloned_job
                end
            else
                pending_jobs[key] = job
            end
        end
    end

    if m.pda_next_job_id then
        next_job_id = m.pda_next_job_id
    end

    if type(m.pda_pending_pda_followups) == "table" then
        for key, followup in pairs(m.pda_pending_pda_followups) do
            if type(followup) == "table" then
                local contact_id = tostring(followup.contact_id or key)
                if not is_contact_blocked(contact_id) then
                    pending_pda_followups[key] = clone_plain_table(followup)
                    pending_pda_followups[key].contact_id = contact_id
                    pending_pda_followups[key].npc_refs = normalize_npc_refs(pending_pda_followups[key].npc_refs)
                end
            end
        end
    end

    if m.pda_next_pda_followup_id then
        next_pda_followup_id = tonumber(m.pda_next_pda_followup_id) or next_pda_followup_id
    end

    -- Restore explicit f2f handoff table before any bridge-dependent post-load logic runs.
    pda_f2f_handoffs = nil
    if type(m.pda_f2f_handoffs) == "table" then
        local now = time_global and time_global() or nil
        local restored_handoffs = {}
        for key, handoff in pairs(m.pda_f2f_handoffs) do
            if type(handoff) == "table" then
                local contact_key = tostring(handoff.contact_id or key)
                local actionable = is_handoff_actionable(handoff, now)
                if not is_contact_blocked(contact_key) and actionable == true then
                    local cloned = {}
                    for field_name, field_value in pairs(handoff) do
                        cloned[field_name] = field_value
                    end
                    cloned.contact_id = contact_key
                    cloned.npc_refs = normalize_npc_refs(cloned.npc_refs)
                    restored_handoffs[contact_key] = cloned
                end
            end
        end
        if next(restored_handoffs) ~= nil then
            pda_f2f_handoffs = restored_handoffs
        end
    end
    if pda_f2f_handoffs then
        _G.pda_f2f_handoffs = pda_f2f_handoffs
    else
        _G.pda_f2f_handoffs = nil
    end

    local adapter = get_anomaly_artifact_adapter()
    if adapter and adapter.load_state then
        adapter.load_state(m)
    end

    if task_bridge and type(task_bridge.load_state) == "function" then
        task_bridge.load_state(m)
    end

    if task_bridge and #legacy_task_jobs > 0 then
        local migration_failures = 0
        for _, job in ipairs(legacy_task_jobs) do
            local ok, err = task_bridge.migrate_legacy_job(job)
            if not ok then
                migration_failures = migration_failures + 1
                printf(
                    "PANDA_IC: legacy task migration failed job_type=%s contact_id=%s job_id=%s reason=%s",
                    tostring(job.job_type or "nil"),
                    tostring(job.contact_id or "nil"),
                    tostring(job.id or "nil"),
                    tostring(err or "unknown")
                )
            end
        end

        if migration_failures > 0 then
            dynamic_news_helper.send_tip(
                "Some legacy P.A.N.D.A tasks could not be restored.",
                "P.A.N.D.A",
                0,
                10,
                FALLBACK_NPC_ICON,
                "danger",
                "npc"
            )
        end
    end

    -- Restore active conversations and rebuild their choices
    if m.pda_active_conversations then
        for key, saved in pairs(m.pda_active_conversations) do
            -- Migration: old saves keyed by npc_name; re-key using npc_id if available
            local cid = saved.contact_id or (saved.npc_id and tostring(saved.npc_id)) or key
            saved.contact_id = cid
            if not is_contact_blocked(cid) then
                if saved.exclusion_inert == true then
                    -- Fan-out loser: thread was already delivered but follow-ups disabled.
                    -- Preserve the entry without re-arming its choices.
                    saved.choices = nil
                    saved.num_choices = 0
                    saved.reply_pending = false
                    saved.channel = saved.channel or "pda"
                    saved.npc_refs = normalize_npc_refs(saved.npc_refs)
                    active_conversations[cid] = saved
                else
                    local choices, num = load_choices_for_turn(
                        saved.prefix, saved.faction, saved.conv_id, saved.turn, saved.npc_name, cid, resolve_runtime_npc_se(nil, saved.npc_id)
                    )
                    if num > 0 then
                        saved.choices = choices
                        saved.num_choices = num
                        saved.reply_pending = false
                        saved.channel = saved.channel or "pda"
                        saved.pending_in_person_continuation = saved.pending_in_person_continuation == true
                        saved.pending_in_person_turn = saved.pending_in_person_turn
                        saved.pending_in_person_target = saved.pending_in_person_target
                        saved.pending_in_person_set_at = saved.pending_in_person_set_at
                        saved.pending_in_person_token = saved.pending_in_person_token
                        saved.pending_in_person_story_id = saved.pending_in_person_story_id or saved.story_id
                        saved.pending_in_person_canonical_id = saved.pending_in_person_canonical_id or saved.canonical_id
                        saved.npc_refs = normalize_npc_refs(saved.npc_refs)
                        if saved.pending_in_person_continuation == true then
                            clear_pda_choices_for_pending_handoff(saved)
                        end
                        active_conversations[cid] = saved
                        CONV = saved  -- last one loaded becomes CONV for compat
                    end
                end
            end
        end
    end

    local recovered_handoffs = 0
    if pda_f2f_handoffs then
        for _, handoff in pairs(pda_f2f_handoffs) do
            if type(handoff) == "table" then
                recovered_handoffs = recovered_handoffs + 1
            end
        end
    end

    local pending_contacts = {}
    for cid, conv in pairs(active_conversations) do
        if conv and conv.pending_in_person_continuation == true then
            table.insert(pending_contacts, tostring(cid))
        end
    end
    local pending_contacts_str = (#pending_contacts > 0) and table.concat(pending_contacts, ",") or "none"
    printf("PANDA_IC: load_state recovered f2f_handoffs=%d pending_in_person_contacts=%s",
        recovered_handoffs, pending_contacts_str)

    sweep_expired_f2f_pending_markers("load_state")

    if panda_npc_creator and type(panda_npc_creator.load_state) == "function" then
        panda_npc_creator.load_state(m)
    end
end

-- ============================================================
-- INITIALIZATION
-- ============================================================
function on_game_start()
    -- Ensure this function runs only once
    if _callbacks_registered then return end

    panda_ic_shutdown_in_progress = false

    local dialogue_skills_mod = ensure_panda_dialogue_skills()
    if dialogue_skills_mod and type(dialogue_skills_mod.on_game_start) == "function" then
        dialogue_skills_mod.on_game_start()
    end

    -- Wire optional f2f bridge integration early at startup
    ensure_panda_f2f_bridge()
    install_panda_task_bridge_callbacks()

    -- Add the private tab to the PDA via mac_mcm
    local function ensure_private_messages_mac_app()
        if not mac_mcm or type(mac_mcm.add_app) ~= "function" then
            printf("PANDA_IC: MAC not found, private tab not registered.")
            return false
        end

        local private_tab_func = pda_private_tab and pda_private_tab.get_ui or nil
        if type(private_tab_func) ~= "function" then
            printf("PANDA_IC: pda_private_tab.get_ui unavailable, private tab not registered.")
            return false
        end

        local apps = mac_mcm.PDA_APPS or {}
        local current_app = apps.pda_private
        local legacy_app = apps.app_privatee
        local has_legacy_alias = legacy_app
            and (legacy_app.tab == LEGACY_PRIVATE_MESSAGES_SECTION
                or legacy_app.tab == PRIVATE_MESSAGES_SECTION
                or legacy_app.func == private_tab_func)

        local current_is_normalized = current_app
            and current_app.name == "st_pda_private_tab"
            and current_app.texture == "ui_pda_private_app"
            and current_app.tab == PRIVATE_MESSAGES_SECTION
            and current_app.func == private_tab_func

        if current_is_normalized and not has_legacy_alias then
            return true
        end

        if has_legacy_alias and type(mac_mcm.remove_app) == "function" and apps.app_privatee then
            mac_mcm.remove_app("app_privatee")
        end

        if current_app and type(mac_mcm.remove_app) == "function" then
            mac_mcm.remove_app("pda_private")
        end

        mac_mcm.add_app("pda_private", {
            name = "st_pda_private_tab",
            texture = "ui_pda_private_app",
            -- Fatal Error's hidden PDA button is named eptPrivateMessages.
            tab = PRIVATE_MESSAGES_SECTION,
            func = private_tab_func
        })

        return true
    end

    local function install_private_messages_section_alias()
        if _panda_state.private_messages_section_alias_installed then
            return
        end

        if not pda or type(pda.set_active_subdialog) ~= "function" then
            return
        end

        local prev_set_active_subdialog = pda.set_active_subdialog
        pda.set_active_subdialog = function(section)
            if section == LEGACY_PRIVATE_MESSAGES_SECTION then
                section = PRIVATE_MESSAGES_SECTION
            end

            return prev_set_active_subdialog(section)
        end

        _panda_state.private_messages_section_alias_installed = true
    end

    ensure_private_messages_mac_app()

    -- Register essential callbacks
    RegisterScriptCallback("actor_on_first_update", setup_engine_overrides)
    RegisterScriptCallback("actor_on_first_update", ensure_private_messages_mac_app)
    RegisterScriptCallback("actor_on_first_update", install_private_messages_section_alias)
    RegisterScriptCallback("on_key_press", on_key_press_cb)
    RegisterScriptCallback("save_state", save_state)
    RegisterScriptCallback("load_state", load_state)
    RegisterScriptCallback("on_game_end", on_game_shutdown_cb)
    RegisterScriptCallback("npc_on_before_hit", panda_npc_invulnerability_check)
    RegisterScriptCallback("npc_on_death_callback", panda_dialog_npc_animation_on_death)
    RegisterScriptCallback("actor_on_item_put_in_box", on_item_put_in_box_cb)
    reset_all_dialog_npc_animation_state("script_init")

    -- Schedule the first trigger
    schedule_next_trigger(1)
    -- Schedule conversation timeout checker
    schedule_timeout_checker()
    -- Schedule smart-location reference checker
    schedule_location_ref_checker()
    -- Schedule pending job checker (kill tracking)
    schedule_job_checker()
    -- Schedule delayed F2F -> PDA follow-up delivery
    schedule_pda_followup_checker()

    local panda_npc_creator_mod = ensure_panda_npc_creator()
    if panda_npc_creator_mod and type(panda_npc_creator_mod.on_game_start) == "function" then
        panda_npc_creator_mod.on_game_start()
    end

    _callbacks_registered = true
end
