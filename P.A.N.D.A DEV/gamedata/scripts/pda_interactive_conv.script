local function normalize_smart_name_from_ref(location_ref)
    if not location_ref or location_ref == "" then
        return nil
    end

    if string.find(location_ref, "^st_.+_name$") then
        return string.sub(location_ref, 4, -6)
    end

    return location_ref
end

local function resolve_smart_from_reference(location_ref)
    if not SIMBOARD or not SIMBOARD.get_smart_by_name then
        return nil, normalize_smart_name_from_ref(location_ref)
    end

    local smart_name = normalize_smart_name_from_ref(location_ref)
    if not smart_name then
        return nil, nil
    end

    local smart = SIMBOARD:get_smart_by_name(smart_name)
    if not smart and smart_name ~= location_ref then
        smart = SIMBOARD:get_smart_by_name(location_ref)
    end

    return smart, smart_name
end

local function get_position_from_object(obj)
    if not obj then
        return nil
    end

    if type(obj.position) == "function" then
        return obj:position()
    end

    return obj.position
end

local function resolve_smart_position_from_reference(location_ref)
    local smart = nil
    local smart_name = nil

    smart, smart_name = resolve_smart_from_reference(location_ref)

    if smart then
        local smart_pos = get_position_from_object(smart)
        if smart_pos then
            return smart_pos, smart_name
        end
    end

    if smart_name and SIMBOARD and SIMBOARD.smarts_by_names then
        local by_name = SIMBOARD.smarts_by_names[smart_name]
        local smart_pos = get_position_from_object(by_name)
        if smart_pos then
            return smart_pos, smart_name
        end
    end

    return nil, smart_name
end

local function get_npc_position(npc_se)
    if not npc_se then
        return nil
    end

    local npc_obj = level.object_by_id(npc_se.id)
    if npc_obj then
        local npc_pos = get_position_from_object(npc_obj)
        if npc_pos then
            return npc_pos
        end
    end

    local npc_alife = alife_object(npc_se.id)
    local alife_pos = get_position_from_object(npc_alife)
    if alife_pos then
        return alife_pos
    end

    return get_position_from_object(npc_se)
end

local function get_location_display_name(location_ref)
    if not location_ref or location_ref == "" then
        return "Unknown location"
    end

    local translated = game.translate_string(location_ref)
    if translated and translated ~= location_ref then
        return translated
    end

    local smart_name = normalize_smart_name_from_ref(location_ref)
    return smart_name or location_ref
end

local function get_location_watch_spot_type()
    local spot = PANDA and PANDA.get_config and PANDA.get_config("location_watch_spot_type") or nil
    if not spot or spot == "" then
        return "primary_object"
    end
    return spot
end

local function add_map_spot_for_ref(location_ref, spot_type, hint)
    local smart = nil
    local smart_name = nil

    smart, smart_name = resolve_smart_from_reference(location_ref)
    if not (smart) and smart_name and SIMBOARD and SIMBOARD.smarts_by_names then
        smart = SIMBOARD.smarts_by_names[smart_name]
    end

    if not (smart and smart.id) then
        printf("PANDA_IC: add_map_spot_for_ref failed to resolve smart id for '%s' (normalized '%s')", tostring(location_ref), tostring(smart_name))
        return nil
    end

    spot_type = (spot_type and spot_type ~= "") and spot_type or "primary_object"
    hint = (hint and hint ~= "") and hint or "default"

    if level.map_has_object_spot(smart.id, spot_type) == 0 then
        level.map_add_object_spot_ser(smart.id, spot_type, hint)
    end

    return smart.id, smart_name
end

local function remove_map_spot_for_id(obj_id, spot_type)
    if not obj_id then
        return
    end

    spot_type = (spot_type and spot_type ~= "") and spot_type or "primary_object"
    if level.map_has_object_spot(obj_id, spot_type) ~= 0 then
        level.map_remove_object_spot(obj_id, spot_type)
    end
end


local function register_location_reference(location_ref, sender_npc_name, sender_npc_id, radius, sender_contact_id)
    local smart, smart_name = resolve_smart_from_reference(location_ref)
    local watch_id = next_location_ref_id
    next_location_ref_id = next_location_ref_id + 1

    local entry = {
        id = watch_id,
        location_ref = location_ref,
        smart_name = smart_name,
        sender_name = sender_npc_name,
        sender_id = sender_npc_id,
        sender_contact_id = sender_contact_id or (sender_npc_id and tostring(sender_npc_id)),
        radius = radius,
        trigger_cmds = {},
    }

    pending_location_refs[watch_id] = entry

    if not smart then
        printf("PANDA_IC: location reference queued but smart not yet resolved: %s", tostring(location_ref))
    end

    -- Add a PDA map marker on the smart terrain so the player can find it
    if smart then
        local display_name = get_location_display_name(location_ref)
        local marker_hint = utils_data.parse_string_keys(
            game.translate_string("st_pda_ic_location_marker_hint"),
            {
                ["location"] = display_name,
                ["name"] = sender_npc_name or "Unknown",
            }
        )
        local spot_type = get_location_watch_spot_type()
        local spot_id = add_map_spot_for_ref(location_ref, spot_type, marker_hint)
        entry.map_spot_id = spot_id
        entry.map_spot_type = spot_type
    end

    -- Send a map attachment message in the private chat instead of a global tip notification.
    -- The renderer in pda_private_tab will display this as a clickable file-icon attachment.
    local sender_icon = (sender_npc_id and level.object_by_id(sender_npc_id) and level.object_by_id(sender_npc_id):character_icon()) or FALLBACK_NPC_ICON
    local contact_id = entry.sender_contact_id or (sender_npc_id and tostring(sender_npc_id))
    pda_private_add_message(
        contact_id,
        sender_npc_name,
        sender_npc_name or game.translate_string("st_pda_ic_outcome_sender"),
        "Map Coordinates:",
        sender_icon,
        false,
        "delivered",
        nil,
        nil,
        {
            msg_type          = "map_attachment",
            map_spot_id       = entry.map_spot_id,
            map_spot_type     = entry.map_spot_type,
            location_ref      = location_ref,
            location_name     = get_location_display_name(location_ref),
            skip_personality  = true,
        }
    )

    return entry
end

local function register_anomaly_zone_reference(zone_name, sender_npc_name, sender_npc_id, sender_contact_id)
    if not zone_name or zone_name == "" then
        return nil
    end

    local zone = db and db.anomaly_by_name and db.anomaly_by_name[zone_name]
    if not zone or not zone.object or not zone.object.id then
        return nil
    end

    local sender_icon = (sender_npc_id and level.object_by_id(sender_npc_id) and level.object_by_id(sender_npc_id):character_icon()) or FALLBACK_NPC_ICON
    local contact_id = sender_contact_id or (sender_npc_id and tostring(sender_npc_id))
    local spot_id = zone.object:id()
    local spot_type = "primary_object"
    local marker_hint = utils_data.parse_string_keys(
        game.translate_string("st_pda_ic_location_marker_hint"),
        {
            ["location"] = zone_name,
            ["name"] = sender_npc_name or "Unknown",
        }
    )

    if level.map_has_object_spot(spot_id, spot_type) == 0 then
        level.map_add_object_spot_ser(spot_id, spot_type, marker_hint)
    end

    pda_private_add_message(
        contact_id,
        sender_npc_name,
        sender_npc_name or game.translate_string("st_pda_ic_outcome_sender"),
        "Map Coordinates:",
        sender_icon,
        false,
        "delivered",
        nil,
        nil,
        {
            msg_type = "map_attachment",
            map_spot_id = spot_id,
            map_spot_type = spot_type,
            location_name = zone_name,
            skip_personality = true,
        }
    )

    return spot_id
end

function check_location_references()
    if not db.actor then
        return
    end

    local actor_pos = db.actor:position()
    local reached = {}

    for id, entry in pairs(pending_location_refs) do
        local smart = entry.smart_name and SIMBOARD and SIMBOARD.get_smart_by_name and SIMBOARD:get_smart_by_name(entry.smart_name) or nil
        local smart_pos = get_position_from_object(smart)
        if smart and smart_pos then
            -- If the smart was resolved late, place the PDA marker now
            if not entry.map_spot_id then
                local display_name = get_location_display_name(entry.location_ref)
                local marker_hint = utils_data.parse_string_keys(
                    game.translate_string("st_pda_ic_location_marker_hint"),
                    {
                        ["location"] = display_name,
                        ["name"] = entry.sender_name or "Unknown",
                    }
                )
                local spot_type = entry.map_spot_type or get_location_watch_spot_type()
                entry.map_spot_id = add_map_spot_for_ref(entry.location_ref, spot_type, marker_hint)
                entry.map_spot_type = spot_type

                -- Backfill map_spot_id into any existing map_attachment log entries for
                -- this location reference so the chat icon becomes immediately navigable.
                local contact_id = entry.sender_contact_id or (entry.sender_id and tostring(entry.sender_id))
                if contact_id and entry.map_spot_id then
                    for _, log_entry in ipairs(pda_private_log) do
                        if log_entry.msg_type == "map_attachment"
                        and (log_entry.contact_id == contact_id)
                        and log_entry.location_ref == entry.location_ref
                        and not log_entry.map_spot_id then
                            log_entry.map_spot_id   = entry.map_spot_id
                            log_entry.map_spot_type = entry.map_spot_type
                        end
                    end
                end
            end

            local radius = tonumber(entry.radius) or (PANDA.get_config("location_watch_radius") or 85)
            if actor_pos:distance_to(smart_pos) <= radius then
                reached[#reached + 1] = { id = id, entry = entry }
            end
        end
    end

    for _, payload in ipairs(reached) do
        local entry = payload.entry
        local msg = utils_data.parse_string_keys(
            game.translate_string("st_pda_ic_location_reached"),
            {
                ["name"] = entry.sender_name or "Unknown",
                ["location"] = get_location_display_name(entry.location_ref),
            }
        )

        dynamic_news_helper.send_tip(
            msg,
            game.translate_string("st_pda_ic_outcome_sender"),
            0,
            10,
            FALLBACK_NPC_ICON,
            "beep_2",
            "npc"
        )

        -- Derive contact_id for job tracking
        local trigger_contact_id = entry.sender_contact_id or (entry.sender_id and tostring(entry.sender_id)) or nil

        -- If this contact has a pending job, enable the spawn collector
        -- so any squads created by trigger commands get tracked
        local had_job = trigger_contact_id and pending_jobs[trigger_contact_id]
        if had_job then
            _job_spawn_collector = {}
        end

        for _, cmd in ipairs(entry.trigger_cmds or {}) do
            apply_outcome(cmd, entry.sender_name, nil, entry.sender_id, nil, trigger_contact_id)
        end

        -- Register any collected squads with the pending job
        if had_job and _job_spawn_collector and #_job_spawn_collector > 0 then
            job_register_squads(trigger_contact_id, _job_spawn_collector)
        end
        if had_job then
            _job_spawn_collector = nil
        end

        -- Remove the PDA map marker now that the player has arrived
        if entry.map_spot_id then
            remove_map_spot_for_id(entry.map_spot_id, entry.map_spot_type or get_location_watch_spot_type())
        end

        pending_location_refs[payload.id] = nil
    end
end

-- ============================================================
-- MULTI-CONVERSATION HELPERS
-- ============================================================
function get_active_conv(contact_id)
    if not contact_id then return nil end
    return active_conversations[contact_id]
end

function get_active_conv_for_selected()
    -- Returns the conversation for whatever contact the PDA tab currently shows
    if pda_private_tab and pda_private_tab.is_private_tab_visible and pda_private_tab.is_private_tab_visible() then
        -- Fallback: return CONV (the latest)
    end
    return CONV
end

function get_any_active_conv()
    -- Returns any active conversation (for compatibility checks like "is anything active?")
    for _, c in pairs(active_conversations) do
        return c
    end
    return nil
end

function count_active_conversations()
    local n = 0
    for _ in pairs(active_conversations) do n = n + 1 end
    return n
end

-- ============================================================
-- JOB SYSTEM: Track spawned hostiles and resume conversation
-- ============================================================

-- Create a pending job that monitors spawned squads.
-- When all tracked squads are dead, resumes conversation at success_turn.
-- On timeout, resumes at fail_turn.
function create_pending_job(contact_id, npc_id, npc_name, faction, squad_ids, timeout, success_turn, fail_turn, conv_data, extra)
    if not contact_id then return end

    -- Use passed conv_data (from on_player_choice) or fall back to active_conversations
    local conv = conv_data or active_conversations[contact_id]

    local has_squads = squad_ids and #squad_ids > 0
    local job = {
        id = next_job_id,
        contact_id = contact_id,
        npc_id = npc_id,
        npc_name = npc_name,
        faction = faction,
        squad_ids = squad_ids or {},
        squads_registered = has_squads,  -- false when spawns are deferred (e.g. watch_location_trigger)
        timeout = timeout or 600,
        success_turn = success_turn,
        fail_turn = fail_turn,
        started_at = time_global(),
        -- Preserve conversation data for resumption
        conv_prefix = conv and conv.prefix or nil,
        conv_id = conv and conv.conv_id or nil,
        conv_icon = conv and conv.npc_icon or FALLBACK_NPC_ICON,
        applied_outcomes = conv and conv.applied_outcomes or {},
    }

    -- Merge task-specific extra fields (job_type, task_item, task_destination, etc.)
    if extra then
        for k, v in pairs(extra) do
            job[k] = v
        end
    end

    next_job_id = next_job_id + 1
    pending_jobs[contact_id] = job

    printf("PANDA_IC: Created job #%d (%s) for %s — tracking %d squads (registered=%s), timeout %ds, success→t%s, fail→t%s",
        job.id, tostring(job.job_type or "kill"), tostring(npc_name), #squad_ids, tostring(has_squads), timeout,
        tostring(success_turn), tostring(fail_turn))
end

-- Register additional squad IDs for a contact's active job.
-- Called by watch_location_trigger deferred spawns when the collector is not active
-- (e.g. spawns triggered by location arrival after the original outcome batch).
function job_register_squads(contact_id, new_squad_ids)
    local job = pending_jobs[contact_id]
    if not job or not new_squad_ids then return end
    for _, sid in ipairs(new_squad_ids) do
        table.insert(job.squad_ids, sid)
    end
    job.squads_registered = true
    printf("PANDA_IC: Job #%d for %s — added %d more squads (total %d)",
        job.id, tostring(job.npc_name), #new_squad_ids, #job.squad_ids)
end

-- Check if all tracked squads in a job are dead.
local function job_all_squads_dead(job)
    -- If squads haven't been registered yet (deferred spawns via watch_location_trigger),
    -- the job cannot succeed yet — we're still waiting for the player to reach the area
    -- and trigger the actual spawns. The job will timeout if they never arrive.
    if not job.squads_registered then
        return false
    end

    if not job.squad_ids or #job.squad_ids == 0 then
        return true -- No squads to track means instant success
    end

    for _, squad_id in ipairs(job.squad_ids) do
        local squad = alife_object(squad_id)
        if squad then
            -- Check if any member is still alive
            local any_alive = false
            for k in squad:squad_members() do
                local obj = level.object_by_id(k.id)
                if obj and obj:alive() then
                    any_alive = true
                    break
                end
                -- If object is not online, check server object existence
                if not obj then
                    local se = alife_object(k.id)
                    if se then
                        any_alive = true
                        break
                    end
                end
            end
            if any_alive then
                return false
            end
        end
        -- Squad doesn't exist anymore = dead
    end

    return true
end

-- ============================================================
-- TASK HELPERS: Completion checks for custom task types
-- ============================================================

-- Check if player has >= count of an item in inventory.
local function job_player_has_items(item_section, count)
    if not db.actor then return false end
    local found = 0
    db.actor:iterate_inventory(function(owner, item)
        if item:section() == item_section then found = found + 1 end
    end, db.actor)
    return found >= (count or 1)
end

-- Check if player is within radius of a smart terrain.
local function job_player_near_smart(smart_ref, radius)
    if not db.actor or not smart_ref then return false end
    local pos = resolve_smart_position_from_reference(smart_ref)
    if not pos then return false end
    return db.actor:position():distance_to(pos) <= (radius or 50)
end

-- Check if a specific NPC (by server ID) is dead.
local function job_npc_dead(npc_id)
    if not npc_id then return false end
    local se = alife_object(npc_id)
    if not se then return true end -- server object gone = dead
    local obj = level.object_by_id(npc_id)
    if obj and not obj:alive() then return true end
    return false
end

-- Remove items from player inventory (used on task completion).
local function job_take_player_items(item_section, count)
    if not db.actor or not item_section then return end
    local taken = 0
    local to_remove = {}
    db.actor:iterate_inventory(function(owner, item)
        if taken < count and item:section() == item_section then
            table.insert(to_remove, item:id())
            taken = taken + 1
        end
    end, db.actor)
    for _, id in ipairs(to_remove) do
        local se = alife_object(id)
        if se then alife_release(se) end
    end
end

-- Resume a paused conversation at the specified turn.
local function job_resume_conversation(job, turn, is_success)
    local cid = job.contact_id
    local npc_name = job.npc_name
    local faction = job.faction
    local prefix = job.conv_prefix
    local conv_id = job.conv_id
    local npc_icon = job.conv_icon

    if not conv_id then
        printf("PANDA_IC: Cannot resume job #%d — no conv_id stored", job.id)
        return
    end

    -- Load the choices for the target turn
    local choices, num = load_choices_for_turn(prefix, faction, conv_id, turn, npc_name, cid)
    if num == 0 then
        printf("PANDA_IC: Job #%d resume failed — no choices for turn %d", job.id, turn)
        return
    end

    -- Create a fresh conversation entry in active_conversations
    local conv_data = {
        npc_id = job.npc_id,
        contact_id = cid,
        npc_name = npc_name,
        npc_icon = npc_icon,
        faction = faction,
        prefix = prefix,
        conv_id = conv_id,
        turn = turn,
        choices = choices,
        num_choices = num,
        task_id = nil,
        category = nil,
        applied_outcomes = job.applied_outcomes or {},
        started_at = time_global(),
        reply_pending = false,
    }

    active_conversations[cid] = conv_data
    CONV = conv_data

    printf("PANDA_IC: Job #%d resumed conversation at turn %d (%s)",
        job.id, turn, is_success and "SUCCESS" or "FAIL/TIMEOUT")

    -- Refresh UI
    if get_ui then
        get_ui():Reset()
    end
end

-- Main job monitor — called periodically.
function check_pending_jobs()
    if not pending_jobs or not db.actor then return end

    local now = time_global()
    local completed = {}

    for cid, job in pairs(pending_jobs) do
        local elapsed_secs = (now - job.started_at) / 1000
        local job_type = job.job_type or "kill"
        local is_complete = false
        local is_failed = false

        -- Type-dispatched completion checks
        if job_type == "kill" or job_type == "eliminate" then
            -- Default: all tracked squads must be dead
            is_complete = job_all_squads_dead(job)

        elseif job_type == "delivery" or job_type == "dead_drop" then
            -- Player must be at destination AND have the item
            if job_player_near_smart(job.task_destination, job.task_radius or 50)
               and job_player_has_items(job.task_item, 1) then
                job_take_player_items(job.task_item, 1)
                is_complete = true
            end

        elseif job_type == "fetch" then
            -- Player must have required items in inventory
            if job_player_has_items(job.task_item, job.task_item_count or 1) then
                job_take_player_items(job.task_item, job.task_item_count or 1)
                is_complete = true
            end

        elseif job_type == "bounty" then
            -- Target NPC must be dead
            if job.task_target_id and job_npc_dead(job.task_target_id) then
                is_complete = true
            end

        elseif job_type == "escort" then
            -- NPC must reach destination alive; NPC death = failure
            if job.task_target_id then
                if job_npc_dead(job.task_target_id) then
                    is_failed = true
                    local msg = game.translate_string("st_pda_ic_task_escort_npc_died")
                    pda_private_add_message(job.contact_id, job.npc_name, job.npc_name, msg, job.conv_icon, false)
                elseif job_player_near_smart(job.task_destination, job.task_radius or 50) then
                    -- Dismiss companion on arrival
                    local npc_obj = level.object_by_id(job.task_target_id)
                    if npc_obj then
                        local squad = get_object_squad(npc_obj)
                        if squad and axr_companions and axr_companions.companion_squads then
                            axr_companions.companion_squads[squad.id] = nil
                            axr_companions.remove_from_actor_squad(squad)
                        end
                    end
                    is_complete = true
                end
            end

        elseif job_type == "artifact" then
            -- Player must have the required artifact in inventory
            if job_player_has_items(job.task_item, 1) then
                job_take_player_items(job.task_item, 1)
                is_complete = true
                -- Clean up adapter record if it exists
                local adapter = get_anomaly_artifact_adapter()
                if adapter and adapter.remove_record then
                    -- Prefer runtime task id (new format), but keep legacy fallback for older saves/jobs.
                    local runtime_task_id = job.task_runtime_id or job.task_item
                    if runtime_task_id then
                        adapter.remove_record(runtime_task_id)
                    end
                end
            end
        end

        -- Timeout check (unless already determined)
        if not is_complete and not is_failed and elapsed_secs >= job.timeout then
            is_failed = true
        end

        if is_complete then
            table.insert(completed, { contact_id = cid, job = job, success = true })
        elseif is_failed then
            table.insert(completed, { contact_id = cid, job = job, success = false })
        end
    end

    for _, result in ipairs(completed) do
        local job = result.job
        pending_jobs[result.contact_id] = nil

        if result.success then
            -- Send a system notification about job completion
            local msg = game.translate_string("st_pda_ic_job_success")
            pda_private_add_message(job.contact_id, job.npc_name, job.npc_name, msg, job.conv_icon, false)

            -- Resume at success turn
            if job.success_turn then
                job_resume_conversation(job, job.success_turn, true)
            end
        else
            -- Send timeout/failure notification
            local msg = game.translate_string("st_pda_ic_job_fail")
            pda_private_add_message(job.contact_id, job.npc_name, job.npc_name, msg, job.conv_icon, false)

            -- Resume at fail turn (if provided)
            if job.fail_turn then
                job_resume_conversation(job, job.fail_turn, false)
            end
        end

        printf("PANDA_IC: Job #%d (%s) for %s completed — %s (%.0fs elapsed)",
            job.id, tostring(job.job_type or "kill"), tostring(job.npc_name),
            result.success and "SUCCESS" or "TIMEOUT/FAIL",
            (now - job.started_at) / 1000)
    end

    -- Refresh UI if any jobs completed
    if #completed > 0 and pda_private_tab and pda_private_tab.get_ui then
        pda_private_tab.get_ui():Reset()
    end
end

-- Check if a contact has an active job (used by timeout checker to skip paused convos)
function has_pending_job(contact_id)
    return pending_jobs[contact_id] ~= nil
end

local tracked_panda_ic_events = {
    pda_ic_spawn = {},
    pda_ic_courier = {},
    pda_ic_companion = {},
    pda_ic_tp = {}
}

local function track_panda_ic_event(group, name)
    if not group or not name or name == "" then
        return
    end

    if not tracked_panda_ic_events[group] then
        tracked_panda_ic_events[group] = {}
    end

    tracked_panda_ic_events[group][name] = true
end

-- Safe time‑event removal – prevents crash if the function doesn't exist
safe_remove_time_event = function(id, name)
    if remove_time_event then
        pcall(remove_time_event, id, name)
    elseif RemoveTimeEvent then
        pcall(RemoveTimeEvent, id, name)
    else
        -- No removal function available – do nothing
    end
end

function cleanup_panda_ic_events()
    -- Repeating scheduler groups
    safe_remove_time_event("pda_ic_trigger", "tick")
    safe_remove_time_event("pda_ic_timeout", "check")
    safe_remove_time_event("pda_ic_location", "check")
    safe_remove_time_event("pda_ic_jobs", "check")

    -- Legacy global event chain
    safe_remove_time_event("pda_ic", "delivery_ack")
    safe_remove_time_event("pda_ic", "npc_typing_start")
    safe_remove_time_event("pda_ic", "npc_reply")

    -- Outcome helper groups
    for group, names in pairs(tracked_panda_ic_events) do
        for name in pairs(names) do
            safe_remove_time_event(group, name)
        end
        tracked_panda_ic_events[group] = {}
    end

    -- Per-conversation chains + typing indicators
    if active_conversations then
        for contact_id, convo in pairs(active_conversations) do
            local npc_id = convo and convo.npc_id
            if npc_id then
                local ev_prefix = "pda_ic_" .. tostring(npc_id)
                safe_remove_time_event(ev_prefix, "delivery_ack")
                safe_remove_time_event(ev_prefix, "npc_read")
                safe_remove_time_event(ev_prefix, "npc_thinking")
                safe_remove_time_event(ev_prefix, "npc_reply")
                safe_remove_time_event(ev_prefix, "outcome")
            end
            clear_npc_typing_message(contact_id)
        end
    end

    -- Also clear any orphan typing entries that are no longer in active_conversations
    for i = #pda_private_log, 1, -1 do
        local entry = pda_private_log[i]
        if entry and entry.is_typing then
            table.remove(pda_private_log, i)
        end
    end

    -- Conversation runtime state reset (idempotent)
    active_conversations = {}
    pda_reply_pending = false
    CONV = nil
end

function on_game_shutdown_cb()
    local handoff_contacts = {}
    if type(pda_f2f_handoffs) == "table" then
        for contact_id in pairs(pda_f2f_handoffs) do
            handoff_contacts[#handoff_contacts + 1] = tostring(contact_id)
        end
    end
    for contact_id in pairs(active_conversations or {}) do
        local contact_key = tostring(contact_id)
        local already_queued = false
        for _, existing in ipairs(handoff_contacts) do
            if existing == contact_key then
                already_queued = true
                break
            end
        end
        if not already_queued then
            handoff_contacts[#handoff_contacts + 1] = contact_key
        end
    end

    for _, contact_id in ipairs(handoff_contacts) do
        abort_contact_f2f_state(contact_id, "on_game_shutdown", {
            remove_conversation = true,
            cancel_events = true,
            remove_thread = false,
        })
    end

    local bridge = ensure_panda_f2f_bridge()
    if bridge and type(bridge.reset_runtime) == "function" then
        pcall(bridge.reset_runtime, "on_game_shutdown")
    end

    pda_f2f_handoffs = nil
    sync_pda_f2f_handoff_globals()
    cleanup_panda_ic_events()
end

-- NPC invulnerability check for make_npc_invulnerable outcome
_panda_invulnerable_npcs = nil
function panda_npc_invulnerability_check(npc, shit, bone_id, flags)
    if _panda_invulnerable_npcs and npc and npc:id() then
        if _panda_invulnerable_npcs[npc:id()] then
            flags.ret_value = false
        end
    end
end

local function printf(fmt, ...)
    if PANDA.get_config("debug_logging") then
        local normalized_fmt = tostring(fmt or "")
        if string.sub(normalized_fmt, 1, 9) ~= "PANDA_IC:" then
            normalized_fmt = "PANDA_IC: " .. normalized_fmt
        end
        _G.printf(normalized_fmt, ...)
    end
end

local function str_explode(str, sep)
    if sep=="" or not sep then return {} end
    local t = {}
    for s in string.gmatch(str, "([^"..sep.."]+)") do
        table.insert(t, s)
    end
    return t
end

local function shuffle_table(t)
    for i = #t, 2, -1 do
        local j = math.random(i)
        t[i], t[j] = t[j], t[i]
    end
end

local function limit_random_list(list, max)
    if #list <= max then return list end
    shuffle_table(list)
    local limited = {}
    for i = 1, max do
        table.insert(limited, list[i])
    end
    return limited
end


local function normalize_faction(fac)
    if not fac then return nil end
    local FACTION_MAP = {
        loner = "stalker", stalker = "stalker", duty = "dolg", dolg = "dolg",
        freedom = "freedom", csky = "csky", clear_sky = "csky", ecolog = "ecolog",
        scientist = "ecolog", mercenary = "killer", killer = "killer",
        military = "army", army = "army", bandit = "bandit", monolith = "monolith",
        zombie = "zombied", zombied = "zombied", isg = "isg", renegade = "renegade",
        greh = "greh"
    }
    fac = fac:match("^%s*(.-)%s*$"):gsub("^%-", "")
    return FACTION_MAP[fac] or fac
end

local function resolve_actor_id_for_goodwill(context)
    if AC_ID ~= nil then
        return AC_ID
    end

    if db and db.actor and db.actor.id then
        local ok, actor_id = pcall(function()
            return db.actor:id()
        end)
        if ok and actor_id ~= nil then
            return actor_id
        end
    end

    printf("WARNING: PANDA_IC: unable to resolve actor id for goodwill API%s", context and (" (" .. tostring(context) .. ")") or "")
    return nil
end

function change_faction_goodwill(faction, delta)
    local comm = normalize_faction(faction)
    if not comm then
        printf("Invalid faction for goodwill change: %s", faction)
        return
    end

    local actor_id = resolve_actor_id_for_goodwill("change_faction_goodwill")
    if actor_id == nil then
        return
    end

    if relation_registry and relation_registry.change_community_goodwill then
        relation_registry.change_community_goodwill(comm, actor_id, delta)
    else
        printf("WARNING: relation_registry not available")
    end
end

function reveal_random_stash()
    if treasure_manager and treasure_manager.create_random_stash then
        treasure_manager.create_random_stash(nil, nil, nil, true)
    else
        printf("WARNING: treasure_manager not found!")
    end
end

local function queue_stash_attachment_reward(sender_npc_name, sender_npc_id, sender_contact_id)
    local sender_icon = (sender_npc_id and level.object_by_id(sender_npc_id) and level.object_by_id(sender_npc_id):character_icon()) or FALLBACK_NPC_ICON
    local contact_id = sender_contact_id or (sender_npc_id and tostring(sender_npc_id))

    pda_private_add_message(
        contact_id,
        sender_npc_name,
        sender_npc_name or game.translate_string("st_pda_ic_outcome_sender"),
        "Map Coordinates:",
        sender_icon,
        false,
        "delivered",
        nil,
        nil,
        {
            msg_type = "map_attachment",
            attachment_action = "reward_stash",
            attachment_label = "Stash Coordinates:",
            location_name = game.translate_string("st_pda_ic_outcome_stash_attachment_file"),
            attachment_claimed = false,
            skip_personality = true,
        }
    )
end

local function queue_stash_attachment_reward_custom(sender_npc_name, sender_npc_id, sender_contact_id, custom_items)
    local sender_icon = (sender_npc_id and level.object_by_id(sender_npc_id) and level.object_by_id(sender_npc_id):character_icon()) or FALLBACK_NPC_ICON
    local contact_id = sender_contact_id or (sender_npc_id and tostring(sender_npc_id))

    pda_private_add_message(
        contact_id,
        sender_npc_name,
        sender_npc_name or game.translate_string("st_pda_ic_outcome_sender"),
        "Map Coordinates:",
        sender_icon,
        false,
        "delivered",
        nil,
        nil,
        {
            msg_type = "map_attachment",
            attachment_action = "reward_stash_custom",
            attachment_label = "Stash Coordinates:",
            location_name = game.translate_string("st_pda_ic_outcome_stash_attachment_file"),
            attachment_claimed = false,
            custom_items = custom_items,
            skip_personality = true,
        }
    )
end

function process_map_attachment_action(entry)
    if type(entry) ~= "table" then
        return false
    end

    if entry.attachment_claimed then
        return false
    end

    if entry.attachment_action == "reward_stash" then
        reveal_random_stash()
        entry.attachment_claimed = true
        return true
    end

    if entry.attachment_action == "reward_stash_custom" then
        local bonus = entry.custom_items or {}
        if treasure_manager and treasure_manager.create_random_stash then
            treasure_manager.create_random_stash(nil, nil, bonus, true)
        end
        entry.attachment_claimed = true
        return true
    end

    return false
end


-- Helper to find NPC server object by character name
function get_npc_by_name(name)
    for i = 1, 65534 do
        local se_obj = alife_object(i)
        if se_obj and se_obj:character_name() == name then
            return se_obj
        end
    end
    return nil
end
-- ============================================================
-- ENGINE OVERRIDES
-- ============================================================
local _overrides_done = false
function setup_engine_overrides()
    if _overrides_done then return end
    if not db.actor then return end

    local o_get_npc = mob_trade.GetTalkingNpc
    mob_trade.GetTalkingNpc = function()
        if fake_talking_npc_id then
            return level.object_by_id(fake_talking_npc_id)
        end
        return o_get_npc()
    end

    local o_is_talk = db.actor.is_talking
    db.actor.is_talking = function(...)
        if fake_talking_npc_id then return true end
        return o_is_talk(...)
    end

    local o_get_spk = _G.get_speaker
    _G.get_speaker = function(...)
        if fake_talking_npc_id then
            return level.object_by_id(fake_talking_npc_id)
        end
        return o_get_spk(...)
    end

    local o_give_msg = db.actor.give_talk_message2
    db.actor.give_talk_message2 = function(...)
        if fake_talking_npc_id then
            return
        else
            return o_give_msg(...)
        end
    end

    _overrides_done = true
end

-- ============================================================
-- TASK DISCOVERY 
-- ============================================================
function discover_all_available_tasks()
    local player_comm = get_actor_true_community() or "stalker"
    local eligible_npcs = get_eligible_npcs_for_community(player_comm)
    if #eligible_npcs == 0 then return {} end

    for _, npc_se in ipairs(eligible_npcs) do
        local npc_obj = level.object_by_id(npc_se.id)
        if npc_obj then
            fake_talking_npc_id = npc_se.id
            local is_sim = string.find(npc_obj:section(), "sim_") ~= nil
            axr_task_manager.generate_available_tasks(npc_obj, is_sim)
            fake_talking_npc_id = nil
        end
    end

    local master_job_list = {}
    for _, npc_se in ipairs(eligible_npcs) do
        local task_list = axr_task_manager.available_tasks[npc_se.id]
        if task_list and #task_list > 0 then
            for _, task_id in ipairs(task_list) do
                local category = TASK_ID_TO_CAT[task_id]
                if category then
                    table.insert(master_job_list, {
                        npc_se = npc_se,
                        task_id = task_id,
                        category = category
                    })
                end
            end
        end
    end

    printf("Discovered %d total available jobs from %d NPCs.", #master_job_list, #eligible_npcs)
    return master_job_list
end

-- ============================================================
-- NPC COOLDOWN HELPERS
-- ============================================================
local function is_npc_on_cooldown(npc_id)
    local last = npc_last_used[npc_id]
    if not last then return false end
    local cd_min = PANDA.get_config("npc_cooldown") or 10
    return (game.get_game_time():diffSec(last) / 60) < cd_min
end

local function record_npc_use(npc_id)
    npc_last_used[npc_id] = game.get_game_time()
end

-- Vanilla patterns:
--   * Story/important NPCs have a story id (get_object_story_id(id) ~= nil)
--   * Simulated NPCs are spawned from sim_* sections (most commonly sim_default_*)
-- We only want simulated stalkers for random PDA conversations.
local function is_simulated_conversation_npc(npc_obj, npc_se, npc_id)
    if not npc_id then return false end

    if get_object_story_id(npc_id) then
        return false
    end

    local section = nil
    if npc_obj and type(npc_obj.section) == "function" then
        section = npc_obj:section()
    elseif npc_se and type(npc_se.section_name) == "function" then
        section = npc_se:section_name()
    end

    if not section or section == "" then
        return false
    end

    return string.find(section, "sim_default_") ~= nil or string.find(section, "sim_") ~= nil
end

-- ============================================================
-- NPC FILTERING (with cooldown check)
-- ============================================================
function get_friendly_npcs()
    local friendly = {}
    local online = db.OnlineStalkers or {}
    local min_dist = PANDA.get_config("min_distance_for_call") or 150
    local player_pos = db.actor:position()
    local player_comm = get_actor_true_community() or "stalker"

    for i = 1, #online do
        local id = online[i]
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive() and not obj:is_talking() 
           and not obj:best_enemy() and id ~= last_conv_npc_id and not is_npc_on_cooldown(id) then
            local comm = obj:character_community()
            if comm and comm ~= "trader" and comm ~= "actor" and comm ~= "zombied" and comm ~= "monolith" then
                if obj:relation(db.actor) ~= game_object.enemy or comm == player_comm then
                    local dist = player_pos:distance_to(obj:position())
                    if dist >= min_dist then
                        local se = alife_object(id)
                        if se and (not se.squad_id or se.squad_id ~= db.actor:squad_id()) and is_simulated_conversation_npc(obj, se, id) then
                            table.insert(friendly, se)
                        end
                    end
                end
            end
        end
    end

    local max = PANDA.get_config("max_npcs_per_trigger") or 10
    return limit_random_list(friendly, max)
end

function get_hostile_npcs()
    local hostile = {}
    local online = db.OnlineStalkers or {}
    local min_dist = PANDA.get_config("min_distance_for_call") or 100
    local player_pos = db.actor:position()
    local player_comm = get_actor_true_community() or "stalker"

    for i = 1, #online do
        local id = online[i]
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive() and not obj:is_talking()
           and not obj:best_enemy() and id ~= last_conv_npc_id and not is_npc_on_cooldown(id) then
            local comm = obj:character_community()
            if comm and comm ~= "trader" and comm ~= "actor" and comm ~= "zombied" and comm ~= "monolith" then
                if obj:relation(db.actor) == game_object.enemy and comm ~= player_comm then
                    local dist = player_pos:distance_to(obj:position())
                    if dist >= min_dist then
                        local se = alife_object(id)
                        if se and (not se.squad_id or se.squad_id ~= db.actor:squad_id()) and is_simulated_conversation_npc(obj, se, id) then
                            table.insert(hostile, se)
                        end
                    end
                end
            end
        end
    end

    local max = PANDA.get_config("max_npcs_per_trigger") or 10
    return limit_random_list(hostile, max)
end

-- Get ALL eligible NPCs regardless of relation (for merged conversation system).
-- Preconditions on each conversation handle friendly/hostile filtering via goodwill.
function get_all_eligible_npcs()
    local npcs = {}
    local online = db.OnlineStalkers or {}
    local min_dist = PANDA.get_config("min_distance_for_call") or 100
    local player_pos = db.actor:position()

    for i = 1, #online do
        local id = online[i]
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive() and not obj:is_talking()
           and not obj:best_enemy() and id ~= last_conv_npc_id and not is_npc_on_cooldown(id) then
            local comm = obj:character_community()
            if comm and comm ~= "trader" and comm ~= "actor" and comm ~= "zombied" and comm ~= "monolith" then
                local dist = player_pos:distance_to(obj:position())
                if dist >= min_dist then
                    local se = alife_object(id)
                    if se and (not se.squad_id or se.squad_id ~= db.actor:squad_id()) and is_simulated_conversation_npc(obj, se, id) then
                        table.insert(npcs, se)
                    end
                end
            end
        end
    end

    local max = PANDA.get_config("max_npcs_per_trigger") or 10
    return limit_random_list(npcs, max)
end

function get_eligible_npcs_for_community(player_comm)
    local eligible = {}
    local online = db.OnlineStalkers or {}
    for i = 1, #online do
        local id = online[i]
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive() and not obj:is_talking()
           and not obj:best_enemy() and id ~= last_conv_npc_id and not is_npc_on_cooldown(id) then
            local comm = obj:character_community()
            if comm and comm ~= "trader" and comm ~= "actor" and comm ~= "zombied" and comm ~= "monolith" then
                if comm == player_comm or PANDA.get_config("allow_cross_faction") then
                    local se = alife_object(id)
                    if se and (not se.squad_id or se.squad_id ~= db.actor:squad_id()) and is_simulated_conversation_npc(obj, se, id) then
                        table.insert(eligible, se)
                    end
                end
            end
        end
    end

    local max = PANDA.get_config("max_npcs_per_trigger") or 10
    return limit_random_list(eligible, max)
end

function pick_random_npc_from_list(list)
    if #list == 0 then return nil end
    return list[math.random(#list)]
end

function find_npc_with_task()
    local jobs = discover_all_available_tasks()
    if #jobs == 0 then
        printf("No available tasks found.")
        return nil
    end

    local valid_jobs = {}
    for _, job in ipairs(jobs) do
        local npc_obj = level.object_by_id(job.npc_se.id)
        if npc_obj and npc_obj:alive() and not npc_obj:is_talking() and not is_npc_on_cooldown(job.npc_se.id) then
            table.insert(valid_jobs, job)
        end
    end

    if #valid_jobs == 0 then
        printf("All task‑givers became invalid or on cooldown.")
        return nil
    end

    local chosen = valid_jobs[math.random(#valid_jobs)]
    return chosen.npc_se, chosen.task_id, chosen.category
end

function panda_give_task(task_id, npc_id)
    if not task_id or not npc_id then return false end
    local npc_obj = level.object_by_id(npc_id)
    if not npc_obj then return false end

    -- FIX: Prevent giving a task that is already active (avoids resetting/looping delivery tasks)
    if db.actor:get_task(task_id, true) then
        printf("Task %s is already active!", task_id)
        return false
    end

    local prev_fake_id = fake_talking_npc_id
    fake_talking_npc_id = npc_id

    local original_dist_le = xr_conditions.dist_to_actor_le
    xr_conditions.dist_to_actor_le = function() return true end

    local old_abort = _G.abort
    _G.abort = function(msg, ...)
        if PANDA.get_config("debug_logging") then
            _G.printf("PANDA_IC: Suppressed abort (non-critical): %s", msg or "unknown error")
        end
    end

    local ok, err = pcall(function()
        local on_job_descr = task_manager.task_ini:r_string_ex(task_id, "on_job_descr")
        if on_job_descr then
            local cond_ok, cond = pcall(xr_logic.parse_condlist, db.actor, "task_manager", "condlist", on_job_descr)
            if cond_ok and cond then
                -- FIX: Pass 'npc_obj' instead of 'db.actor' as the second argument.
                -- Many engine tasks (especially delivery) use the npc argument to generate the target correctly!
                pcall(xr_logic.pick_section_from_condlist, db.actor, npc_obj, cond)
            else
                printf("Warning: Failed to parse on_job_descr for task %s: %s", task_id, tostring(cond))
            end
        end

        local fetch = task_manager.task_ini:r_string_ex(task_id, "fetch_descr")
        if fetch then
            pcall(axr_task_manager.trigger_fetch_func, task_id)
        end

        task_manager.get_task_manager():give_task(task_id, npc_id)
    end)

    _G.abort = old_abort
    xr_conditions.dist_to_actor_le = original_dist_le
    fake_talking_npc_id = prev_fake_id

    if not ok then
        printf("Error giving task: %s", tostring(err))
        return false
    end

    if not db.actor:get_task(task_id, true) then
        printf("PANDA: Task [%s] failed to assign post-pcall (Precondition failure?)", task_id)
        return false
    end
    return true
end

