--[[
================================================================================
    P.A.N.D.A by Panda 
    pda_interactive_conv.script
    
    REFACTORED (V7) with fixes:
    - Fixed non‑task conversations falling back to task dialogue due to missing prefixes.
    - Fixed chance modifier string parsing error.
    - Fixed reward_stash outcome to correctly use treasure_manager.
    - Fixed faction goodwill changing function.
    - Added NPC cooldown to avoid repetition.
    - Added fallback to non‑task when task conversation not found.
    - Fixed conversation restart issue by cancelling duplicate open_ui events.
    - Added safe removal of time events to prevent crashes if the function is missing.
================================================================================
--]]

-- ============================================================
-- CONSTANTS & KEY MAPPINGS
-- ============================================================
local DIK_SPACE, DIK_0, DIK_1, DIK_2, DIK_3, DIK_4 = 57, 11, 2, 3, 4, 5
local CHOICE_KEYS = { [DIK_1]=1, [DIK_2]=2, [DIK_3]=3, [DIK_4]=4 }
local FALLBACK_NPC_ICON = "ui_inGame2_Neutral_1"

local safe_remove_time_event

-- Global used by engine overrides to simulate talking state
fake_talking_npc_id = nil
pda_private_tab_open = false

function set_pda_private_tab_open(state)
    pda_private_tab_open = state == true
end

pda_private_log = {} -- Initialize the table
pda_private_blocked_contacts = {}

local function get_delivery_time_marker()
    if time_global then
        return time_global()
    end

    return nil
end

local function normalize_delivery_state(state)
    if state == "delivered" or state == "read" then
        return state
    end

    return "sent"
end

-- Function to add messages to the log
function pda_private_add_message(contact_name, sender_name, text, icon, is_player, delivery_state, delivery_timestamp)
    if contact_name and pda_private_blocked_contacts[contact_name] then
        return false
    end

    -- Grab the current game time
    local game_time = game.get_game_time()
    local Y, M, D, h, m, s, ms = 0, 0, 0, 0, 0, 0, 0
    Y, M, D, h, m, s, ms = game_time:get(Y, M, D, h, m, s, ms)
    
    -- Format it into a string (DD/MM/YYYY HH:MM) for display
    local current_time = string.format("%02d/%02d/%04d %02d:%02d", D, M, Y, h, m)
    
    -- Store raw time data for accurate relative time calculations
    local raw_time = {
        year = Y, month = M, day = D, 
        hour = h, minute = m, second = s
    }

    table.insert(pda_private_log, 1, { -- Insert at index 1 so newest are first
        contact_name = contact_name,   -- Crucial for grouping threads!
        sender = sender_name,
        text = text,
        sender_icon = icon or "ui_inGame2_Neutral_1",
        timestamp = current_time, 
        raw_time = raw_time,  -- NEW: Store raw time for calculations
        is_player = is_player or false,
        delivery_state = (is_player and normalize_delivery_state(delivery_state)) or nil,
        delivery_timestamp = (is_player and (delivery_timestamp or get_delivery_time_marker())) or nil
    })
    
    -- Optional: Limit log to 100 messages to prevent save bloat (increased from 50)
    if #pda_private_log > 100 then
        table.remove(pda_private_log)
    end

    return true
end

function delete_contact_thread(contact_name)
    if not contact_name then
        return 0
    end

    local removed = 0
    local i = #pda_private_log
    while i >= 1 do
        local entry = pda_private_log[i]
        if entry and entry.contact_name == contact_name then
            table.remove(pda_private_log, i)
            removed = removed + 1
        end
        i = i - 1
    end

    return removed
end

function is_contact_blocked(contact_name)
    return contact_name ~= nil and pda_private_blocked_contacts[contact_name] == true
end

function block_contact(contact_name)
    if not contact_name then
        return false, 0
    end

    pda_private_blocked_contacts[contact_name] = true
    local removed = delete_contact_thread(contact_name)

    local convo = active_conversations and active_conversations[contact_name]

    -- Remove from multi-conversation table
    if active_conversations[contact_name] then
        active_conversations[contact_name] = nil
    end
    if CONV and CONV.npc_name == contact_name then
        CONV = nil
    end

    -- Cancel any pending message delivery timers
    pda_reply_pending = false
    -- Legacy fallback timer group (older builds)
    safe_remove_time_event("pda_ic", "delivery_ack")
    safe_remove_time_event("pda_ic", "npc_typing_start")
    safe_remove_time_event("pda_ic", "npc_reply")

    -- Current per-conversation timer group
    if convo and convo.npc_id then
        local ev_prefix = "pda_ic_" .. tostring(convo.npc_id)
        safe_remove_time_event(ev_prefix, "delivery_ack")
        safe_remove_time_event(ev_prefix, "npc_read")
        safe_remove_time_event(ev_prefix, "npc_thinking")
        safe_remove_time_event(ev_prefix, "npc_reply")
        safe_remove_time_event(ev_prefix, "outcome")
    end

    clear_npc_typing_message(contact_name)

    return true, removed
end

function unblock_contact(contact_name)
    if not contact_name then
        return false
    end

    pda_private_blocked_contacts[contact_name] = nil
    return true
end

function set_last_player_message_state(contact_name, state)
    local normalized_state = normalize_delivery_state(state)
    for i = 1, #pda_private_log do
        local entry = pda_private_log[i]
        if entry and entry.is_player and entry.contact_name == contact_name then
            entry.delivery_state = normalized_state
            entry.delivery_timestamp = get_delivery_time_marker()
            return true
        end
    end

    return false
end
function upsert_npc_typing_message(contact_name, sender_name, icon)
    if not contact_name then
        return false
    end

    for i = 1, #pda_private_log do
        local entry = pda_private_log[i]
        if entry and entry.contact_name == contact_name and entry.is_typing then
            entry.sender = sender_name or contact_name
            entry.sender_icon = icon or entry.sender_icon or FALLBACK_NPC_ICON
            entry.timestamp = entry.timestamp or ""
            return true
        end
    end

    pda_private_add_message(contact_name, sender_name or contact_name, "Typing...", icon or FALLBACK_NPC_ICON, false)
    local latest = pda_private_log[1]
    if latest then
        latest.is_typing = true
    end

    return true
end

function clear_npc_typing_message(contact_name)
    if not contact_name then
        return false
    end

    local removed = false
    local i = #pda_private_log
    while i >= 1 do
        local entry = pda_private_log[i]
        if entry and entry.contact_name == contact_name and entry.is_typing then
            table.remove(pda_private_log, i)
            removed = true
        end
        i = i - 1
    end

    return removed
end


