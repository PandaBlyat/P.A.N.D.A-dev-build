local function make_panda_runtime_task_id(family, conv_data)
    local conv_name = conv_data and (conv_data.conv_id or conv_data.prefix) or nil
    if not conv_name or conv_name == "" then
        conv_name = "conversation"
    end

    conv_name = tostring(conv_name)
        :gsub("%W+", "_")
        :gsub("^_+", "")
        :gsub("_+$", "")

    if conv_name == "" then
        conv_name = "conversation"
    end

    local family_name = tostring(family or "task")
        :gsub("%W+", "_")
        :gsub("^_+", "")
        :gsub("_+$", "")

    if family_name == "" then
        family_name = "task"
    end

    return string.format("panda_%s_%s_%d", family_name, conv_name, math.random(100000, 999999))
end

local function make_artifact_runtime_task_id(conv_data)
    return make_panda_runtime_task_id("artifact", conv_data)
end


