local function normalize_smart_name_from_ref(location_ref)
    if not location_ref or location_ref == "" then
        return nil
    end

    if string.find(location_ref, "^st_.+_name$") then
        return string.sub(location_ref, 4, -6)
    end

    return location_ref
end

local function resolve_smart_from_reference(location_ref)
    if not SIMBOARD or not SIMBOARD.get_smart_by_name then
        return nil, normalize_smart_name_from_ref(location_ref)
    end

    local smart_name = normalize_smart_name_from_ref(location_ref)
    if not smart_name then
        return nil, nil
    end

    local smart = SIMBOARD:get_smart_by_name(smart_name)
    if not smart and smart_name ~= location_ref then
        smart = SIMBOARD:get_smart_by_name(location_ref)
    end

    return smart, smart_name
end

local function get_position_from_object(obj)
    if not obj then
        return nil
    end

    if type(obj.position) == "function" then
        return obj:position()
    end

    return obj.position
end

local function resolve_smart_position_from_reference(location_ref)
    local smart = nil
    local smart_name = nil

    smart, smart_name = resolve_smart_from_reference(location_ref)

    if smart then
        local smart_pos = get_position_from_object(smart)
        if smart_pos then
            return smart_pos, smart_name
        end
    end

    if smart_name and SIMBOARD and SIMBOARD.smarts_by_names then
        local by_name = SIMBOARD.smarts_by_names[smart_name]
        local smart_pos = get_position_from_object(by_name)
        if smart_pos then
            return smart_pos, smart_name
        end
    end

    return nil, smart_name
end

local function get_npc_position(npc_se)
    if not npc_se then
        return nil
    end

    local npc_obj = level.object_by_id(npc_se.id)
    if npc_obj then
        local npc_pos = get_position_from_object(npc_obj)
        if npc_pos then
            return npc_pos
        end
    end

    local npc_alife = alife_object(npc_se.id)
    local alife_pos = get_position_from_object(npc_alife)
    if alife_pos then
        return alife_pos
    end

    return get_position_from_object(npc_se)
end

local function get_location_display_name(location_ref)
    if not location_ref or location_ref == "" then
        return "Unknown location"
    end

    local translated = game.translate_string(location_ref)
    if translated and translated ~= location_ref then
        return translated
    end

    local smart_name = normalize_smart_name_from_ref(location_ref)
    return smart_name or location_ref
end

local function get_location_watch_spot_type()
    local spot = PANDA and PANDA.get_config and PANDA.get_config("location_watch_spot_type") or nil
    if not spot or spot == "" then
        return "primary_object"
    end
    return spot
end

local function add_map_spot_for_ref(location_ref, spot_type, hint)
    local smart = nil
    local smart_name = nil

    smart, smart_name = resolve_smart_from_reference(location_ref)
    if not (smart) and smart_name and SIMBOARD and SIMBOARD.smarts_by_names then
        smart = SIMBOARD.smarts_by_names[smart_name]
    end

    if not (smart and smart.id) then
        printf("PANDA_IC: add_map_spot_for_ref failed to resolve smart id for '%s' (normalized '%s')", tostring(location_ref), tostring(smart_name))
        return nil
    end

    spot_type = (spot_type and spot_type ~= "") and spot_type or "primary_object"
    hint = (hint and hint ~= "") and hint or "default"

    if level.map_has_object_spot(smart.id, spot_type) == 0 then
        level.map_add_object_spot_ser(smart.id, spot_type, hint)
    end

    return smart.id, smart_name
end

local function remove_map_spot_for_id(obj_id, spot_type)
    if not obj_id then
        return
    end

    spot_type = (spot_type and spot_type ~= "") and spot_type or "primary_object"
    if level.map_has_object_spot(obj_id, spot_type) ~= 0 then
        level.map_remove_object_spot(obj_id, spot_type)
    end
end

local function add_map_spot_for_object_id(obj_id, spot_type, hint)
    obj_id = tonumber(obj_id)
    if not obj_id then
        printf("PANDA_IC: add_map_spot_for_object_id missing obj_id")
        return nil
    end

    spot_type = (spot_type and spot_type ~= "") and spot_type or "primary_object"
    hint = (hint and hint ~= "") and hint or "default"

    if not (level and level.map_add_object_spot_ser) then
        printf("PANDA_IC: add_map_spot_for_object_id level API unavailable obj_id=%s", tostring(obj_id))
        return obj_id
    end

    -- Remove first if a stale spot of the same type lingers (engine sometimes
    -- reports has_object_spot != 0 across loads, which would silently block
    -- the new add). Then add unconditionally.
    if level.map_has_object_spot and level.map_has_object_spot(obj_id, spot_type) ~= 0 then
        dbg("PANDA_IC: add_map_spot_for_object_id removing stale spot obj_id=%s spot=%s",
            tostring(obj_id), tostring(spot_type))
        level.map_remove_object_spot(obj_id, spot_type)
    end

    level.map_add_object_spot_ser(obj_id, spot_type, hint)
    dbg("PANDA_IC: add_map_spot_for_object_id ADDED obj_id=%s spot=%s hint=%s",
        tostring(obj_id), tostring(spot_type), tostring(hint))

    return obj_id
end

local function remove_f2f_handoff_attachment(token, contact_id, npc_id)
    local removed = 0
    local token_str = token and tostring(token) or nil
    local contact_str = contact_id and tostring(contact_id) or nil
    local npc_num = tonumber(npc_id)

    local i = #pda_private_log
    while i >= 1 do
        local entry = pda_private_log[i]
        local matches = entry
            and entry.msg_type == "map_attachment"
            and entry.attachment_action == "f2f_handoff"
            and ((token_str and tostring(entry.f2f_handoff_token or "") == token_str)
                or (not token_str
                    and ((contact_str and tostring(entry.contact_id or "") == contact_str)
                        or (npc_num and tonumber(entry.f2f_handoff_npc_id) == npc_num))))

        if matches then
            if entry.map_spot_id then
                remove_map_spot_for_id(entry.map_spot_id, entry.map_spot_type or "primary_object")
            end
            table.remove(pda_private_log, i)
            removed = removed + 1
        end
        i = i - 1
    end

    return removed
end

local function remove_f2f_handoff_map_spot(handoff)
    if type(handoff) ~= "table" then
        return false
    end

    local spot_id = handoff.map_spot_id
    if not spot_id then
        return false
    end

    remove_map_spot_for_id(spot_id, handoff.map_spot_type or "secondary_task_location")
    handoff.map_spot_id = nil
    handoff.map_spot_type = nil
    return true
end

local function clear_private_map_nav_task()
    if not (db and db.actor and db.actor.get_task) then
        return false
    end

    local ok_task, nav_task = pcall(function()
        return db.actor:get_task(PDA_PRIVATE_MAP_NAV_TASK_ID, true)
    end)
    if not ok_task or not nav_task then
        return false
    end

    local cleared = false
    if nav_task.remove_map_locations then
        local ok_remove = pcall(function()
            nav_task:remove_map_locations(false)
        end)
        cleared = ok_remove == true or cleared
    end

    if task_manager and task_manager.get_task_manager then
        local ok_tm, tm = pcall(task_manager.get_task_manager)
        if ok_tm and tm and type(tm.task_info) == "table" then
            tm.task_info[PDA_PRIVATE_MAP_NAV_TASK_ID] = nil
        end
    end

    return cleared
end

local function queue_f2f_handoff_attachment(contact_id, sender_npc_name, sender_icon, target_npc_id, target_npc_name, token, options)
    options = type(options) == "table" and options or {}
    local target_id = tonumber(target_npc_id)
    dbg("PANDA_IC: queue_f2f_handoff_attachment contact_id=%s target_npc_id=%s target_npc_name=%s",
        tostring(contact_id), tostring(target_npc_id), tostring(target_npc_name))
    if not contact_id or not target_id then
        printf("PANDA_IC: queue_f2f_handoff_attachment aborted (missing contact_id or target_id)")
        return nil
    end

    local target_name = target_npc_name or "Unknown"
    -- secondary_task_location matches the yellow quest pin used by bounty/secondary tasks
    -- so the player recognises it as a story marker rather than a static smart-terrain icon.
    local spot_type = "secondary_task_location"
    local marker_hint = string.format("Locate %s to continue story", target_name)
    local spot_id = add_map_spot_for_object_id(target_id, spot_type, marker_hint)
    dbg("PANDA_IC: queue_f2f_handoff_attachment spot_id=%s spot_type=%s",
        tostring(spot_id), tostring(spot_type))

    if options.suppress_chat_attachment == true then
        return spot_id
    end

    pda_private_add_message(
        contact_id,
        sender_npc_name,
        sender_npc_name or game.translate_string("st_pda_ic_outcome_sender"),
        string.format("Locate %s", target_name),
        sender_icon or FALLBACK_NPC_ICON,
        false,
        "delivered",
        nil,
        nil,
        {
            msg_type = "map_attachment",
            attachment_action = "f2f_handoff",
            attachment_label = string.format("Locate %s:", target_name),
            map_spot_id = spot_id,
            map_spot_type = spot_type,
            location_name = target_name,
            attachment_icon = options.attachment_icon or PDA_MARKER_TASK_ICON,
            attachment_hover_icon = options.attachment_hover_icon or options.attachment_icon or PDA_MARKER_TASK_ICON,
            f2f_handoff_token = token,
            f2f_handoff_npc_id = target_id,
            skip_personality = true,
        }
    )

    return spot_id
end

-- Public wrapper so panda_f2f_bridge can drop the same handoff attachment
-- (map pin + chat entry) when an F2F dialogue branches to a new NPC.
function queue_f2f_handoff_attachment_public(contact_id, sender_npc_name, sender_icon, target_npc_id, target_npc_name, token, options)
    dbg("PANDA_IC: queue_f2f_handoff_attachment_public entry contact_id=%s target_npc_id=%s",
        tostring(contact_id), tostring(target_npc_id))
    return queue_f2f_handoff_attachment(contact_id, sender_npc_name, sender_icon, target_npc_id, target_npc_name, token, options)
end

pda_interactive_conv.queue_f2f_handoff_attachment_public = queue_f2f_handoff_attachment_public


local function register_location_reference(location_ref, sender_npc_name, sender_npc_id, radius, sender_contact_id, opts)
    local smart, smart_name = resolve_smart_from_reference(location_ref)
    local watch_id = next_location_ref_id
    next_location_ref_id = next_location_ref_id + 1
    local skip_map_spot = type(opts) == "table" and opts.skip_map_spot == true

    local entry = {
        id = watch_id,
        location_ref = location_ref,
        smart_name = smart_name,
        sender_name = sender_npc_name,
        sender_id = sender_npc_id,
        sender_contact_id = sender_contact_id or (sender_npc_id and tostring(sender_npc_id)),
        radius = radius,
        trigger_cmds = {},
        skip_map_spot = skip_map_spot,
    }

    pending_location_refs[watch_id] = entry

    if not smart then
        printf("PANDA_IC: location reference queued but smart not yet resolved: %s", tostring(location_ref))
    end

    -- Add a PDA map marker on the smart terrain so the player can find it.
    -- Skip when the caller already creates a task-system marker (eliminate/rescue
    -- tasks) — otherwise the smart terrain shows two stacked spots.
    if smart and not skip_map_spot then
        local display_name = get_location_display_name(location_ref)
        local marker_hint = utils_data.parse_string_keys(
            game.translate_string("st_pda_ic_location_marker_hint"),
            {
                ["location"] = display_name,
                ["name"] = sender_npc_name or "Unknown",
            }
        )
        local spot_type = get_location_watch_spot_type()
        local spot_id = add_map_spot_for_ref(location_ref, spot_type, marker_hint)
        entry.map_spot_id = spot_id
        entry.map_spot_type = spot_type
    end

    -- Send a map attachment message in the private chat instead of a global tip notification.
    -- The renderer in pda_private_tab will display this as a clickable file-icon attachment.
    local sender_icon = resolve_sender_icon(sender_npc_id)
    local contact_id = entry.sender_contact_id or (sender_npc_id and tostring(sender_npc_id))
    pda_private_add_message(
        contact_id,
        sender_npc_name,
        sender_npc_name or game.translate_string("st_pda_ic_outcome_sender"),
        "Map Coordinates:",
        sender_icon,
        false,
        "delivered",
        nil,
        nil,
        {
            msg_type          = "map_attachment",
            map_spot_id       = entry.map_spot_id,
            map_spot_type     = entry.map_spot_type,
            location_ref      = location_ref,
            location_name     = get_location_display_name(location_ref),
            skip_personality  = true,
        }
    )

    return entry
end

local function register_anomaly_zone_reference(zone_name, sender_npc_name, sender_npc_id, sender_contact_id)
    if not zone_name or zone_name == "" then
        return nil
    end

    local zone = db and db.anomaly_by_name and db.anomaly_by_name[zone_name]
    if not zone or not zone.object or not zone.object.id then
        return nil
    end

    local sender_icon = resolve_sender_icon(sender_npc_id)
    local contact_id = sender_contact_id or (sender_npc_id and tostring(sender_npc_id))
    local spot_id = zone.object:id()
    local spot_type = "primary_object"
    local marker_hint = utils_data.parse_string_keys(
        game.translate_string("st_pda_ic_location_marker_hint"),
        {
            ["location"] = zone_name,
            ["name"] = sender_npc_name or "Unknown",
        }
    )

    if level.map_has_object_spot(spot_id, spot_type) == 0 then
        level.map_add_object_spot_ser(spot_id, spot_type, marker_hint)
    end

    pda_private_add_message(
        contact_id,
        sender_npc_name,
        sender_npc_name or game.translate_string("st_pda_ic_outcome_sender"),
        "Map Coordinates:",
        sender_icon,
        false,
        "delivered",
        nil,
        nil,
        {
            msg_type = "map_attachment",
            map_spot_id = spot_id,
            map_spot_type = spot_type,
            location_name = zone_name,
            skip_personality = true,
        }
    )

    return spot_id
end

function check_location_references()
    if is_panda_ic_shutdown_in_progress() then
        return
    end
    if not db.actor then
        return
    end

    local actor_pos = db.actor:position()
    local reached = {}

    for id, entry in pairs(pending_location_refs) do
        local smart = entry.smart_name and SIMBOARD and SIMBOARD.get_smart_by_name and SIMBOARD:get_smart_by_name(entry.smart_name) or nil
        local smart_pos = get_position_from_object(smart)
        if smart and smart_pos then
            -- If the smart was resolved late, place the PDA marker now
            if not entry.map_spot_id and not entry.skip_map_spot then
                local display_name = get_location_display_name(entry.location_ref)
                local marker_hint = utils_data.parse_string_keys(
                    game.translate_string("st_pda_ic_location_marker_hint"),
                    {
                        ["location"] = display_name,
                        ["name"] = entry.sender_name or "Unknown",
                    }
                )
                local spot_type = entry.map_spot_type or get_location_watch_spot_type()
                entry.map_spot_id = add_map_spot_for_ref(entry.location_ref, spot_type, marker_hint)
                entry.map_spot_type = spot_type

                -- Backfill map_spot_id into any existing map_attachment log entries for
                -- this location reference so the chat icon becomes immediately navigable.
                local contact_id = entry.sender_contact_id or (entry.sender_id and tostring(entry.sender_id))
                if contact_id and entry.map_spot_id then
                    for _, log_entry in ipairs(pda_private_log) do
                        if log_entry.msg_type == "map_attachment"
                        and (log_entry.contact_id == contact_id)
                        and log_entry.location_ref == entry.location_ref
                        and not log_entry.map_spot_id then
                            log_entry.map_spot_id   = entry.map_spot_id
                            log_entry.map_spot_type = entry.map_spot_type
                        end
                    end
                end
            end

            local radius = tonumber(entry.radius) or (PANDA.get_config("location_watch_radius") or 85)
            if actor_pos:distance_to(smart_pos) <= radius then
                reached[#reached + 1] = { id = id, entry = entry }
            end
        end
    end

    for _, payload in ipairs(reached) do
        local entry = payload.entry
        local msg = utils_data.parse_string_keys(
            game.translate_string("st_pda_ic_location_reached"),
            {
                ["name"] = entry.sender_name or "Unknown",
                ["location"] = get_location_display_name(entry.location_ref),
            }
        )

        dynamic_news_helper.send_tip(
            msg,
            game.translate_string("st_pda_ic_outcome_sender"),
            0,
            10,
            FALLBACK_NPC_ICON,
            "beep_2",
            "npc"
        )

        -- Derive contact_id for job tracking
        local trigger_contact_id = entry.sender_contact_id or (entry.sender_id and tostring(entry.sender_id)) or nil

        -- If this contact has a pending job, enable the spawn collector
        -- so any squads created by trigger commands get tracked
        local had_job = trigger_contact_id and pending_jobs[trigger_contact_id]
        if had_job then
            _panda_ic_runtime.job_spawn_collector = {}
        end

        for _, cmd in ipairs(entry.trigger_cmds or {}) do
            apply_outcome(cmd, entry.sender_name, nil, entry.sender_id, nil, trigger_contact_id)
        end

        -- Register any collected squads with the pending job
        if had_job and _panda_ic_runtime.job_spawn_collector and #_panda_ic_runtime.job_spawn_collector > 0 then
            job_register_squads(trigger_contact_id, _panda_ic_runtime.job_spawn_collector)
        end
        if had_job then
            _panda_ic_runtime.job_spawn_collector = nil
        end

        -- Remove the PDA map marker now that the player has arrived
        if entry.map_spot_id then
            remove_map_spot_for_id(entry.map_spot_id, entry.map_spot_type or get_location_watch_spot_type())
        end

        pending_location_refs[payload.id] = nil
    end
end

-- ============================================================
-- MULTI-CONVERSATION HELPERS
-- ============================================================
function get_active_conv(contact_id)
    if not contact_id then return nil end
    return active_conversations[contact_id]
end

function get_active_conv_for_selected()
    -- Returns the conversation for whatever contact the PDA tab currently shows
    if pda_private_tab and pda_private_tab.is_private_tab_visible and pda_private_tab.is_private_tab_visible() then
        -- Fallback: return CONV (the latest)
    end
    return CONV
end

function get_any_active_conv()
    -- Returns any active conversation (for compatibility checks like "is anything active?")
    for _, c in pairs(active_conversations) do
        return c
    end
    return nil
end

function count_active_conversations()
    local n = 0
    for _ in pairs(active_conversations) do n = n + 1 end
    return n
end

-- ============================================================
-- JOB SYSTEM: Track spawned hostiles and resume conversation
-- ============================================================

-- Create a pending job that monitors spawned squads.
-- When all tracked squads are dead, resumes conversation at success_turn.
-- On timeout, resumes at fail_turn.
function create_pending_job(contact_id, npc_id, npc_name, faction, squad_ids, timeout, success_turn, fail_turn, conv_data, extra)
    if not contact_id then return end

    -- Use passed conv_data (from on_player_choice) or fall back to active_conversations
    local conv = conv_data or active_conversations[contact_id]

    local has_squads = squad_ids and #squad_ids > 0
    local job = {
        id = next_job_id,
        contact_id = contact_id,
        npc_id = npc_id,
        npc_name = npc_name,
        faction = faction,
        squad_ids = squad_ids or {},
        squads_registered = has_squads,  -- false when spawns are deferred (e.g. watch_location_trigger)
        timeout = timeout or 600,
        success_turn = success_turn,
        fail_turn = fail_turn,
        started_at = time_global(),
        -- Preserve conversation data for resumption
        conv_prefix = conv and conv.prefix or nil,
        conv_id = conv and conv.conv_id or nil,
        conv_icon = conv and conv.npc_icon or FALLBACK_NPC_ICON,
        channel = conv and conv.channel or "pda",
        applied_outcomes = conv and conv.applied_outcomes or {},
        npc_refs = conv and conv.npc_refs or nil,
        resume_npc_id = conv and conv.pending_resume_npc_id or nil,
        resume_npc_faction_filters = (conv and conv.pending_resume_allow_generic_stalker == true and has_values(conv.pending_resume_npc_faction_filters))
            and conv.pending_resume_npc_faction_filters or nil,
        resume_allow_generic_stalker = conv and conv.pending_resume_allow_generic_stalker == true and has_values(conv.pending_resume_npc_faction_filters),
    }

    -- Merge task-specific extra fields (job_type, task_item, task_destination, etc.)
    if extra then
        for k, v in pairs(extra) do
            job[k] = v
        end
    end

    next_job_id = next_job_id + 1
    pending_jobs[contact_id] = job

    printf("PANDA_IC: Created job #%d (%s) for %s — tracking %d squads (registered=%s), timeout %ds, success→t%s, fail→t%s",
        job.id, tostring(job.job_type or "kill"), tostring(npc_name), #squad_ids, tostring(has_squads), timeout,
        tostring(success_turn), tostring(fail_turn))
end

-- Register additional squad IDs for a contact's active job.
-- Called by watch_location_trigger deferred spawns when the collector is not active
-- (e.g. spawns triggered by location arrival after the original outcome batch).
function job_register_squads(contact_id, new_squad_ids)
    local job = pending_jobs[contact_id]
    if not job or not new_squad_ids then return end
    for _, sid in ipairs(new_squad_ids) do
        table.insert(job.squad_ids, sid)
    end
    job.squads_registered = true
    printf("PANDA_IC: Job #%d for %s — added %d more squads (total %d)",
        job.id, tostring(job.npc_name), #new_squad_ids, #job.squad_ids)
end

-- Check if all tracked squads in a job are dead.
local function job_all_squads_dead(job)
    -- If squads haven't been registered yet (deferred spawns via watch_location_trigger),
    -- the job cannot succeed yet — we're still waiting for the player to reach the area
    -- and trigger the actual spawns. The job will timeout if they never arrive.
    if not job.squads_registered then
        return false
    end

    if not job.squad_ids or #job.squad_ids == 0 then
        return true -- No squads to track means instant success
    end

    for _, squad_id in ipairs(job.squad_ids) do
        local squad = alife_object(squad_id)
        if squad then
            -- Check if any member is still alive
            local any_alive = false
            for k in squad:squad_members() do
                local obj = level.object_by_id(k.id)
                if obj and obj:alive() then
                    any_alive = true
                    break
                end
                -- If object is not online, check server object existence
                if not obj then
                    local se = alife_object(k.id)
                    if se then
                        any_alive = true
                        break
                    end
                end
            end
            if any_alive then
                return false
            end
        end
        -- Squad doesn't exist anymore = dead
    end

    return true
end

local function read_branch_speaker_npc_id(prefix, faction, conv_id, turn)
    local base_key
    if prefix == "task" or not prefix then
        base_key = "st_pda_ic_" .. tostring(faction) .. "_" .. tostring(conv_id)
    else
        base_key = "st_pda_ic_" .. tostring(prefix) .. "_" .. tostring(faction) .. "_" .. tostring(conv_id)
    end

    local turn_number = tonumber(turn)
    if turn_number and turn_number > 1 then
        base_key = base_key .. "_t" .. tostring(turn_number)
    end

    local key = base_key .. "_npc"
    local raw = game.translate_string(key)
    if not raw or raw == key then
        return nil
    end

    raw = tostring(raw):gsub("^%s+", ""):gsub("%s+$", "")
    if raw == "" then
        return nil
    end
    return raw
end

local function read_trimmed_string_key(key)
    local raw = game.translate_string(key)
    if not raw or raw == key then
        return nil
    end
    raw = tostring(raw):gsub("^%s+", ""):gsub("%s+$", "")
    if raw == "" then
        return nil
    end
    return raw
end

local function parse_csv_list(raw)
    local values = {}
    if not raw or raw == "" then
        return values
    end
    for value in tostring(raw):gmatch("([^,]+)") do
        value = value:gsub("^%s+", ""):gsub("%s+$", "")
        if value ~= "" then
            table.insert(values, value)
        end
    end
    return values
end

has_values = function(list)
    return type(list) == "table" and #list > 0
end

local function read_branch_speaker_target(prefix, faction, conv_id, turn)
    local base_key
    if prefix == "task" or not prefix then
        base_key = "st_pda_ic_" .. tostring(faction) .. "_" .. tostring(conv_id)
    else
        base_key = "st_pda_ic_" .. tostring(prefix) .. "_" .. tostring(faction) .. "_" .. tostring(conv_id)
    end

    local turn_number = tonumber(turn)
    if turn_number and turn_number > 1 then
        base_key = base_key .. "_t" .. tostring(turn_number)
    end

    local target = {
        npc_id = read_branch_speaker_npc_id(prefix, faction, conv_id, turn),
        allow_generic_stalker = false,
        npc_faction_filters = {},
    }

    local allow_raw = read_trimmed_string_key(base_key .. "_npc_allow_generic")
    if allow_raw then
        allow_raw = allow_raw:lower()
        target.allow_generic_stalker = allow_raw == "1" or allow_raw == "true" or allow_raw == "yes"
    end

    target.npc_faction_filters = parse_csv_list(read_trimmed_string_key(base_key .. "_npc_factions"))
    return target
end

local function read_turn_channel_from_registry(prefix, faction, conv_id, turn)
    local base_key
    if prefix == "task" or not prefix then
        base_key = "st_pda_ic_" .. tostring(faction) .. "_" .. tostring(conv_id)
    else
        base_key = "st_pda_ic_" .. tostring(prefix) .. "_" .. tostring(faction) .. "_" .. tostring(conv_id)
    end

    local registry_key = base_key .. "_panda_f2f_registry"
    local raw = game.translate_string(registry_key)
    if raw == registry_key then
        registry_key = base_key .. "_registry"
        raw = game.translate_string(registry_key)
    end
    if not raw or raw == registry_key then
        return "pda"
    end

    raw = tostring(raw):gsub("&quot;", "\"")
    local turn_start = raw:find("\"turnNumber\"%s*:%s*" .. tostring(turn))
    if not turn_start then
        return "pda"
    end

    local next_turn_start = raw:find("\"turnNumber\"%s*:%s*%d+", turn_start + 1)
    local turn_block = raw:sub(turn_start, next_turn_start and (next_turn_start - 1) or #raw)
    local channel = turn_block:match("\"channel\"%s*:%s*\"([%w_%-]+)\"")
    return tostring(channel or "pda"):lower() == "f2f" and "f2f" or "pda"
end

local function pick_sim_branch_speaker_se(faction_filters)
    if type(faction_filters) ~= "table" or #faction_filters == 0 then
        return nil
    end
    if not db or not db.OnlineStalkers or not level or not level.object_by_id then
        return nil
    end

    local allowed = {}
    for _, faction_id in ipairs(faction_filters) do
        allowed[tostring(faction_id)] = true
    end

    local actor_pos = db.actor and get_position_from_object(db.actor) or nil
    local near, any = {}, {}
    for i = 1, #db.OnlineStalkers do
        local id = db.OnlineStalkers[i]
        local st = db.storage and db.storage[id] or nil
        local obj = (st and st.object) or level.object_by_id(id)
        if obj and IsStalker(obj, obj:clsid()) and obj:alive() and not get_object_story_id(id) then
            local community = obj:character_community()
            if community and allowed[community] then
                local se = alife_object and alife_object(id) or nil
                if se then
                    local obj_pos = get_position_from_object(obj)
                    local dist = (actor_pos and obj_pos) and obj_pos:distance_to(actor_pos) or 999999
                    local row = { se = se, dist = dist }
                    table.insert(any, row)
                    if dist <= 150 then
                        table.insert(near, row)
                    end
                end
            end
        end
    end

    local pool = (#near > 0) and near or any
    if #pool == 0 then
        return nil
    end
    table.sort(pool, function(a, b) return (a.dist or 999999) < (b.dist or 999999) end)
    return pool[1].se
end

local function resolve_branch_speaker_npc(branch_target, fallback_npc_id, fallback_name, fallback_icon)
    local branch_npc_id = nil
    local faction_filters = nil
    local allow_generic = false

    if type(branch_target) == "table" then
        branch_npc_id = branch_target.npc_id
        faction_filters = branch_target.npc_faction_filters
        allow_generic = branch_target.allow_generic_stalker == true
    else
        branch_npc_id = branch_target
    end

    local branch_se = nil
    if allow_generic and faction_filters and #faction_filters > 0 then
        branch_se = pick_sim_branch_speaker_se(faction_filters)
        if not branch_se then
            printf("PANDA_IC: Branch sim speaker did not resolve for factions '%s', using previous contact", table.concat(faction_filters, ","))
        end
    end

    if branch_se then
        local ok_id, resolved_id = pcall(function() return branch_se.id end)
        local npc_id = ok_id and tonumber(resolved_id) or nil
        if npc_id then
            local ok_name, resolved_name = pcall(function() return branch_se:character_name() end)
            local ok_icon, resolved_icon = pcall(function() return branch_se:character_icon() end)
            return npc_id,
                tostring(npc_id),
                (ok_name and resolved_name and resolved_name ~= "") and resolved_name or fallback_name,
                (ok_icon and resolved_icon and resolved_icon ~= "") and resolved_icon or (fallback_icon or FALLBACK_NPC_ICON),
                branch_se
        end
    end

    if not branch_npc_id or branch_npc_id == "" then
        return fallback_npc_id, tostring(fallback_npc_id or ""), fallback_name, fallback_icon, nil
    end

    branch_se = nil
    if branch_npc_id:sub(1, 4) == "npc:" and panda_npc_creator and type(panda_npc_creator.get_active_npc_se) == "function" then
        local ok_custom, custom_se = pcall(panda_npc_creator.get_active_npc_se, branch_npc_id:sub(5))
        if ok_custom and custom_se then
            branch_se = custom_se
        end
    elseif type(get_story_se_object) == "function" then
        local ok_story, story_se = pcall(get_story_se_object, branch_npc_id)
        if ok_story and story_se then
            branch_se = story_se
        end
    end

    if not branch_se then
        printf("PANDA_IC: Branch speaker '%s' did not resolve, using previous contact", tostring(branch_npc_id))
        return fallback_npc_id, tostring(fallback_npc_id or ""), fallback_name, fallback_icon, nil
    end

    local ok_id, resolved_id = pcall(function() return branch_se.id end)
    local npc_id = ok_id and tonumber(resolved_id) or nil
    if not npc_id then
        return fallback_npc_id, tostring(fallback_npc_id or ""), fallback_name, fallback_icon, nil
    end

    local ok_name, resolved_name = pcall(function() return branch_se:character_name() end)
    local ok_icon, resolved_icon = pcall(function() return branch_se:character_icon() end)
    return npc_id,
        tostring(npc_id),
        (ok_name and resolved_name and resolved_name ~= "") and resolved_name or fallback_name,
        (ok_icon and resolved_icon and resolved_icon ~= "") and resolved_icon or (fallback_icon or FALLBACK_NPC_ICON),
        branch_se
end

local build_turn_string_prefix
local resolve_runtime_npc_se
local get_audio_fields_for_string_key
local get_message_attachment_fields_for_string_key
local sanitize_pda_ui_texture_name
local recruit_escort_companion
local resolve_escort_target

-- ============================================================
-- TASK HELPERS: Completion checks for custom task types
-- ============================================================

-- Check if player has >= count of an item in inventory.
local function job_player_has_items(item_section, count)
    if not db.actor then return false end
    local found = 0
    db.actor:iterate_inventory(function(owner, item)
        if item:section() == item_section then found = found + 1 end
    end, db.actor)
    return found >= (count or 1)
end

-- Check if player is within radius of a smart terrain.
local function job_player_near_smart(smart_ref, radius)
    if not db.actor or not smart_ref then return false end
    local pos = resolve_smart_position_from_reference(smart_ref)
    if not pos then return false end
    return db.actor:position():distance_to(pos) <= (radius or 50)
end

local function pick_delivery_target_near_smart(smart_ref, radius)
    local smart_pos = resolve_smart_position_from_reference(smart_ref)
    if not smart_pos or not db or not db.OnlineStalkers then
        return nil
    end

    local candidates = {}
    local max_dist = tonumber(radius) or 150
    for i = 1, #db.OnlineStalkers do
        local id = db.OnlineStalkers[i]
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive() and not obj:is_talking() and not obj:best_enemy() then
            local comm = obj:character_community()
            if comm and comm ~= "actor" and comm ~= "zombied" and comm ~= "monolith" then
                local obj_pos = get_position_from_object(obj)
                if obj_pos and obj_pos:distance_to(smart_pos) <= max_dist then
                    local se = alife_object(id)
                    if se and (not se.squad_id or se.squad_id ~= db.actor:squad_id()) then
                        table.insert(candidates, { se = se, obj = obj })
                    end
                end
            end
        end
    end

    if #candidates == 0 then
        return nil
    end

    return candidates[math.random(#candidates)]
end

-- Pick a random eligible delivery target anywhere in the loaded world. Used when the
-- author left the destination empty so the engine picks the recipient itself.
local function pick_random_delivery_target()
    if not db or not db.OnlineStalkers or not db.actor then
        return nil
    end

    local candidates = {}
    local actor_squad_id = db.actor.squad_id and db.actor:squad_id() or nil
    for i = 1, #db.OnlineStalkers do
        local id = db.OnlineStalkers[i]
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive() and not obj:is_talking() and not obj:best_enemy() then
            local comm = obj:character_community()
            if comm and comm ~= "actor" and comm ~= "zombied" and comm ~= "monolith" then
                local se = alife_object(id)
                if se and (not actor_squad_id or not se.squad_id or se.squad_id ~= actor_squad_id) then
                    table.insert(candidates, { se = se, obj = obj })
                end
            end
        end
    end

    if #candidates == 0 then
        return nil
    end

    return candidates[math.random(#candidates)]
end

local function get_delivery_target_label(target)
    if not target then
        return nil
    end

    local obj = target.obj
    if obj and obj.character_name then
        local ok_name, resolved_name = pcall(function() return obj:character_name() end)
        if ok_name and resolved_name and resolved_name ~= "" then
            return resolved_name
        end
    end

    local se = target.se
    if se and se.character_name then
        local ok_name, resolved_name = pcall(function() return se:character_name() end)
        if ok_name and resolved_name and resolved_name ~= "" then
            return resolved_name
        end
    end

    return nil
end

-- Check if a specific NPC (by server ID) is dead.
local function job_npc_dead(npc_id)
    if not npc_id then return false end
    local se = alife_object(npc_id)
    if not se then return true end -- server object gone = dead
    local obj = level.object_by_id(npc_id)
    if obj and not obj:alive() then return true end
    return false
end

-- Remove items from player inventory (used on task completion).
local function job_take_player_items(item_section, count)
    if not db.actor or not item_section then return end
    local taken = 0
    local to_remove = {}
    db.actor:iterate_inventory(function(owner, item)
        if taken < count and item:section() == item_section then
            table.insert(to_remove, item:id())
            taken = taken + 1
        end
    end, db.actor)
    for _, id in ipairs(to_remove) do
        local se = alife_object(id)
        if se then alife_release(se) end
    end
end

-- Resume a paused conversation at the specified turn.
local function job_resume_conversation(job, turn, is_success)
    local cid = job.contact_id
    local npc_name = job.npc_name
    local faction = job.faction
    local prefix = job.conv_prefix
    local conv_id = job.conv_id
    local npc_icon = job.conv_icon

    if not conv_id then
        printf("PANDA_IC: Cannot resume job #%d — no conv_id stored", job.id)
        return
    end

    local branch_target = read_branch_speaker_target(prefix, faction, conv_id, turn)
    local has_resume_override = (job.resume_npc_id and job.resume_npc_id ~= "")
        or (job.resume_allow_generic_stalker == true and has_values(job.resume_npc_faction_filters))
    if has_resume_override then
        branch_target = {
            npc_id = job.resume_npc_id,
            allow_generic_stalker = job.resume_allow_generic_stalker == true,
            npc_faction_filters = job.resume_npc_faction_filters or {},
        }
    end
    local resume_npc_id, resume_contact_id, resume_npc_name, resume_npc_icon, resume_npc_se =
        resolve_branch_speaker_npc(branch_target, job.npc_id, npc_name, npc_icon)

    if branch_target and branch_target.allow_generic_stalker == true and has_values(branch_target.npc_faction_filters)
        and tonumber(resume_npc_id) == tonumber(job.npc_id)
    then
        printf("PANDA_IC: Job #%d resume blocked — no sim speaker resolved for factions=%s turn=%s",
            job.id, table.concat(branch_target.npc_faction_filters, ","), tostring(turn))
        return
    end

    local target_channel = read_turn_channel_from_registry(prefix, faction, conv_id, turn)
    if target_channel == "f2f" then
        local set_at = time_global and time_global() or 0
        local handoff_token = make_f2f_handoff_token(resume_npc_id, conv_id, turn, set_at)
        local bridge = ensure_panda_f2f_bridge()
        local handoff_dialog = "panda_f2f_hub_dialog"
        if bridge and type(bridge.allocate_hub_dialog_id) == "function" then
            local ok_dialog, allocated_dialog = pcall(bridge.allocate_hub_dialog_id)
            if ok_dialog and type(allocated_dialog) == "string" and allocated_dialog ~= "" then
                handoff_dialog = allocated_dialog
            end
        end

        dynamic_news_helper.send_tip(
            "Meet " .. tostring(resume_npc_name) .. " to continue this conversation.",
            "PDA Alert", 0, 10, resume_npc_icon, "news", "npc"
        )
        pda_private_add_message(
            resume_contact_id,
            resume_npc_name,
            "PDA System",
            string.format("Meet %s (ID: %s) to continue this conversation.", tostring(resume_npc_name), tostring(resume_npc_id)),
            resume_npc_icon,
            false,
            nil,
            nil,
            nil,
            { skip_personality = true }
        )

        local handoff_identity = nil
        if build_f2f_handoff_identity then
            handoff_identity = build_f2f_handoff_identity(resume_npc_se, resume_npc_id, resume_npc_name)
        end
        handoff_identity = handoff_identity or {
            story_id = branch_target and branch_target.npc_id or nil,
            canonical_id = branch_target and branch_target.npc_id and tostring(branch_target.npc_id):lower() or tostring(resume_npc_id),
            fallback_name = resume_npc_name,
        }

        local conv_data = {
            npc_id = resume_npc_id,
            contact_id = resume_contact_id,
            npc_name = resume_npc_name,
            npc_icon = resume_npc_icon,
            faction = faction,
            prefix = prefix,
            conv_id = conv_id,
            turn = turn,
            choices = nil,
            num_choices = 0,
            task_id = nil,
            category = nil,
            applied_outcomes = job.applied_outcomes or {},
            started_at = set_at,
            reply_pending = false,
            channel = "f2f",
            pending_in_person_continuation = true,
            pending_in_person_turn = turn,
            pending_in_person_target = handoff_dialog,
            pending_in_person_set_at = set_at,
            pending_in_person_token = handoff_token,
            pending_in_person_story_id = handoff_identity.story_id,
            pending_in_person_canonical_id = handoff_identity.canonical_id,
            npc_refs = normalize_npc_refs(job.npc_refs),
        }

        active_conversations[resume_contact_id] = conv_data
        CONV = conv_data

        local handoff_row = {
            contact_id = resume_contact_id,
            npc_id = resume_npc_id,
            npc_name = resume_npc_name,
            npc_icon = resume_npc_icon,
            conv_id = conv_id,
            turn = turn,
            faction = faction,
            prefix = prefix,
            channel = "f2f",
            dialog = handoff_dialog,
            set_at = set_at,
            token = handoff_token,
            story_id = handoff_identity.story_id,
            canonical_id = handoff_identity.canonical_id,
            fallback_name = handoff_identity.fallback_name,
            npc_refs = normalize_npc_refs(job.npc_refs),
            applied_outcomes = job.applied_outcomes or {},
            route_owner = nil,
            route_dialog = handoff_dialog,
            route_status = "pending",
        }

        queue_f2f_handoff_attachment(resume_contact_id, resume_npc_name, resume_npc_icon, resume_npc_id, resume_npc_name, handoff_token)
        register_pending_f2f_handoff(resume_contact_id, handoff_row)

        local owner_tag = string.format("task_handoff_%s_%s_%s", tostring(resume_contact_id), tostring(conv_id), tostring(turn))
        local handoff_route = "no-route"
        if bridge and type(bridge.hard_route_branch) == "function" then
            local ok_route_call, route_applied = pcall(bridge.hard_route_branch, handoff_row.npc_id, owner_tag, handoff_dialog)
            if ok_route_call and route_applied == true then
                handoff_route = "bridge route"
            end
        end

        if handoff_route ~= "bridge route" and xr_meet and type(xr_meet.override_dialog) == "function" then
            local ok_override_call = pcall(xr_meet.override_dialog, handoff_row.npc_id, handoff_dialog)
            if ok_override_call and has_xr_meet_dialog_override(handoff_row.npc_id, handoff_dialog) then
                handoff_route = "xr_meet fallback"
            end
        end

        handoff_row.route_owner = owner_tag
        handoff_row.route_status = handoff_route
        handoff_row.route_set_at = set_at

        printf("PANDA_IC: Job #%d queued F2F resume at turn %d (%s) npc_id=%s route=%s",
            job.id, turn, is_success and "SUCCESS" or "FAIL/TIMEOUT", tostring(resume_npc_id), handoff_route)
        if get_ui then
            get_ui():Reset()
        end
        return
    end

    -- Load the choices for the target turn
    local choices, num = load_choices_for_turn(prefix, faction, conv_id, turn, resume_npc_name, resume_contact_id, resume_npc_se or resolve_runtime_npc_se(nil, resume_npc_id))
    if num == 0 then
        printf("PANDA_IC: Job #%d resume failed — no choices for turn %d", job.id, turn)
        return
    end

    local prefix_key = build_turn_string_prefix(prefix, faction, conv_id, turn)
    local open_key = prefix_key .. "_open"
    local open_text = game.translate_string(open_key)
    if open_text == open_key then
        open_text = nil
    end

    -- Create a fresh conversation entry in active_conversations
    local conv_data = {
        npc_id = resume_npc_id,
        contact_id = resume_contact_id,
        npc_name = resume_npc_name,
        npc_icon = resume_npc_icon,
        faction = faction,
        prefix = prefix,
        conv_id = conv_id,
        turn = turn,
        choices = choices,
        num_choices = num,
        task_id = nil,
        category = nil,
        applied_outcomes = job.applied_outcomes or {},
        started_at = time_global(),
        reply_pending = false,
        channel = job.channel or "pda",
        npc_refs = normalize_npc_refs(job.npc_refs),
    }

    if resume_contact_id ~= cid then
        active_conversations[cid] = nil
    end
    active_conversations[resume_contact_id] = conv_data
    CONV = conv_data

    if open_text and open_text ~= "" then
        local open_attachment_fields = get_message_attachment_fields_for_string_key(open_key)
        dynamic_news_helper.send_tip(
            "You've received a Private Message from " .. tostring(resume_npc_name),
            "PDA Alert", 0, 10, resume_npc_icon, "news", "npc"
        )
        pda_private_add_message(
            resume_contact_id,
            resume_npc_name,
            resume_npc_name,
            sub_placeholders(open_text, resume_npc_name, faction, resume_npc_se, resume_contact_id),
            resume_npc_icon,
            false,
            nil,
            nil,
            nil,
            open_attachment_fields
        )
    end

    printf("PANDA_IC: Job #%d resumed conversation at turn %d (%s)",
        job.id, turn, is_success and "SUCCESS" or "FAIL/TIMEOUT")

    -- Refresh UI
    if get_ui then
        get_ui():Reset()
    end
end

-- Main job monitor — called periodically.
function check_pending_jobs()
    if is_panda_ic_shutdown_in_progress() then
        return
    end
    if not pending_jobs or not db.actor then return end

    local now = time_global()
    local completed = {}

    for cid, job in pairs(pending_jobs) do
        local elapsed_secs = (now - job.started_at) / 1000
        local job_type = job.job_type or "kill"
        local is_complete = false
        local is_failed = false

        -- Type-dispatched completion checks
        if job_type == "kill" or job_type == "eliminate" then
            -- Default: all tracked squads must be dead
            is_complete = job_all_squads_dead(job)

        elseif job_type == "delivery" or job_type == "dead_drop" then
            -- Player must be at destination AND have the item
            if job_player_near_smart(job.task_destination, job.task_radius or 50)
               and job_player_has_items(job.task_item, 1) then
                job_take_player_items(job.task_item, 1)
                is_complete = true
            end

        elseif job_type == "fetch" then
            -- Player must have required items in inventory
            if job_player_has_items(job.task_item, job.task_item_count or 1) then
                job_take_player_items(job.task_item, job.task_item_count or 1)
                is_complete = true
            end

        elseif job_type == "bounty" then
            -- Target NPC must be dead
            if job.task_target_id and job_npc_dead(job.task_target_id) then
                is_complete = true
            end

        elseif job_type == "escort" then
            -- NPC must reach destination alive; NPC death = failure
            if job.task_target_id then
                if job_npc_dead(job.task_target_id) then
                    is_failed = true
                    local msg = game.translate_string("st_pda_ic_task_escort_npc_died")
                    pda_private_add_message(job.contact_id, job.npc_name, job.npc_name, msg, job.conv_icon, false)
                elseif job_player_near_smart(job.task_destination, job.task_radius or 50) then
                    -- Dismiss companion on arrival
                    local npc_obj = level.object_by_id(job.task_target_id)
                    if npc_obj then
                        local squad = get_object_squad(npc_obj)
                        if squad and axr_companions and axr_companions.companion_squads then
                            axr_companions.companion_squads[squad.id] = nil
                            axr_companions.remove_from_actor_squad(squad)
                        end
                    end
                    is_complete = true
                end
            end

        elseif job_type == "artifact" then
            -- Player must have the required artifact in inventory
            if job_player_has_items(job.task_item, 1) then
                job_take_player_items(job.task_item, 1)
                is_complete = true
                -- Clean up adapter record if it exists
                local adapter = get_anomaly_artifact_adapter()
                if adapter and adapter.remove_record then
                    -- Prefer runtime task id (new format), but keep legacy fallback for older saves/jobs.
                    local runtime_task_id = job.task_runtime_id or job.task_item
                    if runtime_task_id then
                        adapter.remove_record(runtime_task_id)
                    end
                end
            end
        end

        -- Timeout check (unless already determined)
        if not is_complete and not is_failed and elapsed_secs >= job.timeout then
            is_failed = true
        end

        if is_complete then
            table.insert(completed, { contact_id = cid, job = job, success = true })
        elseif is_failed then
            table.insert(completed, { contact_id = cid, job = job, success = false })
        end
    end

    for _, result in ipairs(completed) do
        local job = result.job
        pending_jobs[result.contact_id] = nil

        if result.success then
            if not job.success_turn then
                local msg = game.translate_string("st_pda_ic_job_success")
                pda_private_add_message(job.contact_id, job.npc_name, job.npc_name, msg, job.conv_icon, false)
            end

            -- Resume at success turn
            if job.success_turn then
                job_resume_conversation(job, job.success_turn, true)
            end
        else
            if not job.fail_turn then
                local msg = game.translate_string("st_pda_ic_job_fail")
                pda_private_add_message(job.contact_id, job.npc_name, job.npc_name, msg, job.conv_icon, false)
            end

            -- Resume at fail turn (if provided)
            if job.fail_turn then
                job_resume_conversation(job, job.fail_turn, false)
            end
        end

        printf("PANDA_IC: Job #%d (%s) for %s completed — %s (%.0fs elapsed)",
            job.id, tostring(job.job_type or "kill"), tostring(job.npc_name),
            result.success and "SUCCESS" or "TIMEOUT/FAIL",
            (now - job.started_at) / 1000)
    end

    -- Refresh UI if any jobs completed
    if #completed > 0 and pda_private_tab and pda_private_tab.get_ui then
        pda_private_tab.get_ui():Reset()
    end
end

-- Check if a contact has an active job (used by timeout checker to skip paused convos)
function has_pending_job(contact_id)
    return pending_jobs[contact_id] ~= nil
end

local function clone_plain_table(src)
    if type(src) ~= "table" then
        return nil
    end

    local out = {}
    for key, value in pairs(src) do
        local value_type = type(value)
        if value_type ~= "function" and value_type ~= "userdata" and value_type ~= "thread" then
            out[key] = value
        end
    end

    return out
end

build_turn_string_prefix = function(prefix, faction, conv_id, turn)
    local base_key
    if prefix == "task" or not prefix then
        base_key = "st_pda_ic_" .. tostring(faction) .. "_" .. tostring(conv_id)
    else
        base_key = "st_pda_ic_" .. tostring(prefix) .. "_" .. tostring(faction) .. "_" .. tostring(conv_id)
    end

    local turn_number = tonumber(turn)
    if turn_number and turn_number > 1 then
        base_key = base_key .. "_t" .. tostring(turn_number)
    end

    return base_key
end

resolve_runtime_npc_se = function(npc_se, npc_id)
    if npc_se then
        return npc_se
end

    local sid = tonumber(npc_id)
    if sid and sid > 0 and alife_object then
        local se = alife_object(sid)
        if se then
            return se
        end
    end

    return nil
end

local function resolve_or_spawn_custom_npc_se(template_id, context)
    if not template_id or template_id == "" or not panda_npc_creator then
        return nil
    end

    if type(panda_npc_creator.get_active_npc_se) == "function" then
        local ok_existing, existing = pcall(panda_npc_creator.get_active_npc_se, template_id)
        if ok_existing and existing then
            return existing
        end
    end

    if type(panda_npc_creator.spawn_custom_npc) == "function" then
        pcall(panda_npc_creator.spawn_custom_npc, template_id, context or {})
    end

    if type(panda_npc_creator.get_active_npc_se) == "function" then
        local ok_spawned, spawned = pcall(panda_npc_creator.get_active_npc_se, template_id)
        if ok_spawned and spawned then
            return spawned
        end
    end

    return nil
end

local function resolve_handoff_target_se(story_npc_id, fallback_npc_se)
    if not story_npc_id or story_npc_id == "" then
        return fallback_npc_se
    end

    if story_npc_id:sub(1, 4) == "npc:" and panda_npc_creator and type(panda_npc_creator.get_active_npc_se) == "function" then
        local ok_custom, custom_se = pcall(panda_npc_creator.get_active_npc_se, story_npc_id:sub(5))
        if ok_custom and custom_se then
            return custom_se
        end
    end

    if type(get_story_se_object) == "function" then
        local ok_story, story_se = pcall(get_story_se_object, story_npc_id)
        if ok_story and story_se then
            return story_se
        end
    end

    return fallback_npc_se
end

local PANDA_EMOJI_REPLY_TEXTURES = {
    artifact = "panda_file",
    warning = "panda_file",
    radio = "panda_file",
    stash = "panda_file",
    target = "panda_file",
}

sanitize_pda_ui_texture_name = function(value)
    if not value then return nil end
    local name = tostring(value):gsub("^%s+", ""):gsub("%s+$", "")
    if name == "" then return nil end
    name = name:gsub("%.dds$", "")
    if not name:match("^[%w_%-]+$") then
        printf("PANDA_IC: rejected unsafe PDA reply image texture '%s'", tostring(value))
        return nil
    end
    return name
end

local function resolve_reply_image_texture(text, explicit_image)
    local explicit = sanitize_pda_ui_texture_name(explicit_image)
    if explicit then return explicit end

    local shortcode = tostring(text or ""):match(":([%w_%-]+):")
    if shortcode then
        return PANDA_EMOJI_REPLY_TEXTURES[shortcode]
    end
    return nil
end

local function sanitize_pda_audio_name(value)
    if not value then return nil end
    local name = tostring(value):gsub("^%s+", ""):gsub("%s+$", "")
    if name == "" then return nil end

    name = name:gsub("/", "\\")
    local lower = string.lower(name)
    if lower:sub(-4) == ".ogg" or lower:sub(-4) == ".wav" then
        name = name:sub(1, -5)
    end

    if name == "" or name:find("%.%.", 1, true) or name:find(":", 1, true) or name:sub(1, 1) == "\\" then
        printf("PANDA_IC: rejected unsafe PDA audio attachment '%s'", tostring(value))
        return nil
    end

    if not name:match("^[%w_%-\\]+$") then
        printf("PANDA_IC: rejected unsafe PDA audio attachment '%s'", tostring(value))
        return nil
    end

    return name
end

local function build_audio_fields(raw_audio)
    local name = sanitize_pda_audio_name(raw_audio)
    if not name then return nil end
    return {
        audio_name = name,
        audio_path = "panda\\audio\\" .. name,
    }
end

get_audio_fields_for_string_key = function(key)
    if not key then return nil end
    local audio_raw = game.translate_string(key)
    if audio_raw == key then return nil end
    return build_audio_fields(audio_raw)
end

get_message_attachment_fields_for_string_key = function(base_key)
    if not base_key then return nil end
    local fields = get_audio_fields_for_string_key(base_key .. "_audio") or {}
    local image_key = base_key .. "_image"
    local image_raw = game.translate_string(image_key)
    if image_raw ~= image_key then
        fields.reply_image_texture = sanitize_pda_ui_texture_name(image_raw)
    end
    return next(fields) and fields or nil
end

local function queue_pda_followup_internal(raw_entry)
    if type(raw_entry) ~= "table" then
        return false
    end

    local npc_id = tonumber(raw_entry.npc_id)
    local conv_id = tonumber(raw_entry.conv_id)
    local turn = tonumber(raw_entry.turn)
    local faction = raw_entry.faction
    local contact_id = tostring(raw_entry.contact_id or npc_id or "")
    if contact_id == "" or not npc_id or not conv_id or not turn or not faction then
        return false
    end

    local delay_seconds = tonumber(raw_entry.delay_seconds) or 0
    if delay_seconds < 0 then
        delay_seconds = 0
    end
    delay_seconds = math.floor(delay_seconds)

    for id, pending in pairs(pending_pda_followups) do
        if type(pending) == "table" and tostring(pending.contact_id or "") == contact_id then
            pending_pda_followups[id] = nil
        end
    end

    local entry_id = next_pda_followup_id
    next_pda_followup_id = next_pda_followup_id + 1

    pending_pda_followups[entry_id] = {
        id = entry_id,
        npc_id = npc_id,
        contact_id = contact_id,
        npc_name = raw_entry.npc_name,
        npc_icon = raw_entry.npc_icon,
        faction = faction,
        prefix = raw_entry.prefix,
        conv_id = conv_id,
        turn = turn,
        delay_seconds = delay_seconds,
        trigger_at = (time_global and time_global() or 0) + (delay_seconds * 1000),
        task_id = raw_entry.task_id,
        category = raw_entry.category,
        story_id = raw_entry.story_id,
        canonical_id = raw_entry.canonical_id,
        fallback_name = raw_entry.fallback_name,
        npc_refs = normalize_npc_refs(raw_entry.npc_refs),
        applied_outcomes = clone_plain_table(raw_entry.applied_outcomes) or {},
        exclusion_group = raw_entry.exclusion_group,
    }

    printf(
        "PANDA_IC: queued pda follow-up contact_id=%s npc_id=%s conv_id=%s turn=%s delay_s=%s",
        tostring(contact_id),
        tostring(npc_id),
        tostring(conv_id),
        tostring(turn),
        tostring(delay_seconds)
    )

    return true
end

local function activate_pending_pda_followup(entry)
    if type(entry) ~= "table" then
        return false, "bad_entry"
    end

    local contact_id = tostring(entry.contact_id or entry.npc_id or "")
    if contact_id == "" then
        return false, "missing_contact_id"
    end

    if is_contact_blocked(contact_id) then
        return false, "contact_blocked"
    end

    local npc_id = tonumber(entry.npc_id)
    local conv_id = tonumber(entry.conv_id)
    local turn = tonumber(entry.turn) or 1
    if not npc_id or not conv_id or not entry.faction then
        return false, "missing_identity"
    end

    local npc_se = nil
    if alife_object then
        npc_se = alife_object(npc_id)
    end
    if not npc_se and level and level.object_by_id then
        npc_se = level.object_by_id(npc_id)
    end

    local npc_name = tostring(entry.npc_name or "Unknown")
    if npc_name == "" or npc_name == "Unknown" then
        local ok_name, resolved_name = pcall(function()
            return npc_se and npc_se:character_name() or nil
        end)
        if ok_name and resolved_name and resolved_name ~= "" then
            npc_name = tostring(resolved_name)
        end
    end

    local npc_icon = entry.npc_icon or FALLBACK_NPC_ICON
    local ok_icon, resolved_icon = pcall(function()
        return npc_se and npc_se:character_icon() or nil
    end)
    if ok_icon and resolved_icon and resolved_icon ~= "" then
        npc_icon = resolved_icon
    end

    local prefix_key = build_turn_string_prefix(entry.prefix, entry.faction, conv_id, turn)
    local open_key = prefix_key .. "_open"
    local open_text = game.translate_string(open_key)
    if open_text == open_key then
        return false, "missing_open_text"
    end

    local choices, num = load_choices_for_turn(entry.prefix, entry.faction, conv_id, turn, npc_name, contact_id, npc_se)
    if num == 0 then
        return false, "missing_choices"
    end

    remove_active_conversation_entry(contact_id)
    clear_npc_typing_message(contact_id)

    local conv_data = {
        npc_id = npc_id,
        contact_id = contact_id,
        npc_name = npc_name,
        npc_icon = npc_icon,
        faction = entry.faction,
        prefix = entry.prefix,
        conv_id = conv_id,
        turn = turn,
        choices = choices,
        num_choices = num,
        task_id = entry.task_id,
        category = entry.category,
        applied_outcomes = clone_plain_table(entry.applied_outcomes) or {},
        started_at = time_global and time_global() or 0,
        reply_pending = false,
        story_id = entry.story_id,
        canonical_id = entry.canonical_id,
        fallback_name = entry.fallback_name,
        npc_refs = normalize_npc_refs(entry.npc_refs),
        channel = "pda",
        exclusion_group = entry.exclusion_group,
    }

    active_conversations[contact_id] = conv_data
    CONV = conv_data
    last_conv_npc_id = npc_id
    record_npc_use(npc_id)

    if pda_typing_personality and pda_typing_personality.register_npc and npc_se then
        local rank_name = get_npc_rank_name(npc_se) or "experienced"
        pda_typing_personality.register_npc(contact_id, entry.faction, rank_name)
    end

    dynamic_news_helper.send_tip(
        "You've received a Private Message from " .. npc_name,
        "PDA Alert", 0, 10, npc_icon, "news", "npc"
    )

    pda_private_add_message(
        contact_id,
        npc_name,
        npc_name,
        sub_placeholders(open_text, npc_name, entry.faction, npc_se, contact_id),
        npc_icon,
        false,
        nil,
        nil,
        nil,
        get_message_attachment_fields_for_string_key(open_key)
    )

    if get_ui then
        get_ui():Reset()
    end

    return true
end

local function check_pending_pda_followups()
    if not db.actor then
        return
    end

    local now = time_global and time_global() or 0
    for id, entry in pairs(pending_pda_followups) do
        if type(entry) ~= "table" then
            pending_pda_followups[id] = nil
        else
            local contact_id = tostring(entry.contact_id or entry.npc_id or "")
            if contact_id ~= "" and is_contact_blocked(contact_id) then
                pending_pda_followups[id] = nil
            else
                local trigger_at = tonumber(entry.trigger_at) or 0
                if trigger_at <= now then
                    local ok, reason = activate_pending_pda_followup(entry)
                    pending_pda_followups[id] = nil
                    if not ok then
                        printf(
                            "PANDA_IC: dropped queued pda follow-up contact_id=%s npc_id=%s conv_id=%s turn=%s reason=%s",
                            tostring(contact_id or "nil"),
                            tostring(entry.npc_id or "nil"),
                            tostring(entry.conv_id or "nil"),
                            tostring(entry.turn or "nil"),
                            tostring(reason or "unknown")
                        )
                    end
                end
            end
        end
    end
end

local function queue_panda_task_pda_followup(record, turn)
    if type(record) ~= "table" then
        return false, "bad_record"
    end

    local npc_id = tonumber(record.npc_id or record.giver_id)
    local conv_id = tonumber(record.conv_id)
    local next_turn = tonumber(turn)
    local faction = record.faction
    local contact_id = tostring(record.contact_id or npc_id or "")
    if contact_id == "" or not npc_id or not conv_id or not next_turn or not faction then
        return false, "missing_identity"
    end

    local branch_target = read_branch_speaker_target(record.conv_prefix, faction, conv_id, next_turn)
    if record.resume_npc_id or record.resume_allow_generic_stalker == true then
        branch_target = {
            npc_id = record.resume_npc_id,
            allow_generic_stalker = record.resume_allow_generic_stalker == true,
            npc_faction_filters = record.resume_npc_faction_filters or {},
        }
    end
    local resume_npc_id, resume_contact_id, resume_npc_name, resume_npc_icon, resume_npc_se =
        resolve_branch_speaker_npc(branch_target, npc_id, record.npc_name, record.conv_icon)
    if not resume_npc_id then
        return false, "missing_resume_npc"
    end
    local identity = build_f2f_handoff_identity(resume_npc_se, resume_npc_id)

    local ok = queue_pda_followup_internal({
        npc_id = resume_npc_id,
        contact_id = resume_contact_id,
        npc_name = resume_npc_name,
        npc_icon = resume_npc_icon,
        faction = faction,
        prefix = record.conv_prefix,
        conv_id = conv_id,
        turn = next_turn,
        delay_seconds = 0,
        story_id = identity.story_id,
        canonical_id = identity.canonical_id,
        fallback_name = identity.fallback_name,
        npc_refs = normalize_npc_refs(record.npc_refs),
        applied_outcomes = clone_plain_table(record.applied_outcomes) or {},
    })
    if ok then
        check_pending_pda_followups()
        return true
    end

    return false, "queue_failed"
end

local function queue_panda_task_f2f_followup(record, turn)
    if type(record) ~= "table" then
        return false, "bad_record"
    end

    local npc_id = tonumber(record.npc_id or record.giver_id)
    local conv_id = tonumber(record.conv_id)
    local next_turn = tonumber(turn)
    local contact_id = tostring(record.contact_id or npc_id or "")
    if contact_id == "" or not npc_id or not conv_id or not next_turn then
        return false, "missing_identity"
    end

    if type(register_pending_f2f_handoff) ~= "function" then
        return false, "handoff_unavailable"
    end

    local branch_target = read_branch_speaker_target(record.conv_prefix, record.faction, conv_id, next_turn)
    if record.resume_npc_id or record.resume_allow_generic_stalker == true then
        branch_target = {
            npc_id = record.resume_npc_id,
            allow_generic_stalker = record.resume_allow_generic_stalker == true,
            npc_faction_filters = record.resume_npc_faction_filters or {},
        }
    end
    local target_npc_id, target_contact_id, target_name, target_icon, target_se =
        resolve_branch_speaker_npc(branch_target, npc_id, record.npc_name, record.conv_icon)
    if not target_npc_id then
        return false, "missing_target_npc"
    end

    local npc_se = target_se or resolve_runtime_npc_se(nil, target_npc_id)
    local set_at = time_global and time_global() or 0
    local handoff_identity = type(build_f2f_handoff_identity) == "function"
        and build_f2f_handoff_identity(npc_se, target_npc_id)
        or { story_id = nil, canonical_id = nil, fallback_name = nil }
    local handoff_token
    if type(make_f2f_handoff_token) == "function" then
        handoff_token = make_f2f_handoff_token(target_npc_id, conv_id, next_turn, set_at)
    else
        handoff_token = string.format("task_handoff_%s_%s_%s_%s", tostring(target_npc_id), tostring(conv_id), tostring(next_turn), tostring(set_at))
    end

    local handoff_dialog = "panda_f2f_hub_dialog"
    local bridge = ensure_panda_f2f_bridge()
    if bridge and type(bridge.allocate_hub_dialog_id) == "function" then
        local ok_dialog, allocated_dialog = pcall(bridge.allocate_hub_dialog_id)
        if ok_dialog and type(allocated_dialog) == "string" and allocated_dialog ~= "" then
            handoff_dialog = allocated_dialog
        end
    end

    local handoff_row = {
        contact_id = target_contact_id,
        npc_id = target_npc_id,
        npc_name = target_name,
        npc_icon = target_icon,
        conv_id = conv_id,
        turn = next_turn,
        faction = record.faction,
        prefix = record.conv_prefix,
        channel = "f2f",
        dialog = handoff_dialog,
        set_at = set_at,
        token = handoff_token,
        story_id = handoff_identity.story_id,
        canonical_id = handoff_identity.canonical_id,
        fallback_name = handoff_identity.fallback_name,
        npc_refs = normalize_npc_refs(record.npc_refs),
        applied_outcomes = clone_plain_table(record.applied_outcomes) or {},
        route_owner = nil,
        route_dialog = handoff_dialog,
        route_status = "pending",
    }

    if not register_pending_f2f_handoff(target_contact_id, handoff_row) then
        return false, "register_failed"
    end

    local owner_tag = string.format("task_handoff_%s_%s_%s", tostring(target_contact_id), tostring(conv_id), tostring(next_turn))
    local handoff_route = "no-route"
    if bridge and type(bridge.hard_route_branch) == "function" then
        local ok_route_call, route_applied = pcall(bridge.hard_route_branch, handoff_row.npc_id, owner_tag, handoff_dialog)
        if ok_route_call and route_applied == true then
            handoff_route = "bridge route"
        end
    end

    if handoff_route ~= "bridge route" and xr_meet and type(xr_meet.override_dialog) == "function" then
        local ok_override_call = pcall(xr_meet.override_dialog, handoff_row.npc_id, handoff_dialog)
        if ok_override_call and has_xr_meet_dialog_override(handoff_row.npc_id, handoff_dialog) then
            handoff_route = "xr_meet fallback"
        end
    end

    handoff_row.route_owner = owner_tag
    handoff_row.route_status = handoff_route
    handoff_row.route_set_at = set_at

    dynamic_news_helper.send_tip(
        "You've received a Private Message from " .. tostring(target_name),
        "PDA Alert", 0, 10, target_icon or FALLBACK_NPC_ICON, "news", "npc"
    )

    pda_private_add_message(
        target_contact_id,
        target_name,
        "PDA System",
        string.format("Meet %s to continue this conversation.", tostring(target_name or "contact")),
        target_icon or FALLBACK_NPC_ICON,
        false,
        nil,
        nil,
        nil,
        { skip_personality = true }
    )

    queue_f2f_handoff_attachment(
        target_contact_id,
        target_name,
        target_icon,
        target_npc_id,
        target_name,
        handoff_token
    )

    return true
end

local function handle_panda_task_resolution(record, success)
    if type(record) ~= "table" or record.suppress_followup == true then
        return
    end

    local next_turn = success and tonumber(record.success_turn) or tonumber(record.fail_turn)
    if not next_turn then
        return
    end

    local channel = tostring(record.channel or "pda")
    local ok, reason
    if channel == "f2f" then
        ok, reason = queue_panda_task_f2f_followup(record, next_turn)
    else
        ok, reason = queue_panda_task_pda_followup(record, next_turn)
    end

    if not ok then
        printf(
            "PANDA_IC: task follow-up queue failed task_id=%s channel=%s success=%s reason=%s",
            tostring(record.external_task_id or record.task_id or "nil"),
            tostring(channel),
            tostring(success == true),
            tostring(reason or "unknown")
        )
    end
end

local function install_panda_task_bridge_callbacks()
    local bridge = ensure_panda_task_bridge()
    if not bridge or type(bridge.set_callbacks) ~= "function" then
        return nil
    end

    bridge.set_callbacks({
        on_task_resolved = handle_panda_task_resolution,
    })

    return bridge
end

-- Fires when the player places any item into an inventory box via the loot UI.
-- Handles panda_task_dead_drop_stash: if the box is the task target and the item matches,
-- delete it from the box and mark the deposit as done so evaluate_status returns "complete".
local function on_item_put_in_box_cb(box, item)
    if not box or not item then return end

    local bridge = ensure_panda_task_bridge()
    if not bridge or type(bridge.find_active_dead_drop_stash) ~= "function" then return end

    local slot_id = bridge.find_active_dead_drop_stash(box:id(), item:section())
    if not slot_id then return end

    -- Remove the deposited item from the stash box.
    local item_se = alife_object and alife_object(item:id()) or nil
    if item_se and alife_release then
        alife_release(item_se)
    else
        printf("PANDA_IC: dead_drop_stash | could not release deposited item id=%s", tostring(item:id()))
    end

    -- Flag the record so evaluate_status returns "complete" on next poll.
    if type(bridge.update_record) == "function" then
        bridge.update_record(slot_id, { deposit_done = true, item_consumed = true })
    end

    printf("PANDA_IC: dead_drop_stash | deposit accepted for slot '%s'", tostring(slot_id))
end

local tracked_panda_ic_events = {
    pda_ic_spawn = {},
    pda_ic_courier = {},
    pda_ic_companion = {},
    pda_ic_tp = {}
}

local function track_panda_ic_event(group, name)
    if not group or not name or name == "" then
        return
    end

    if not tracked_panda_ic_events[group] then
        tracked_panda_ic_events[group] = {}
    end

    tracked_panda_ic_events[group][name] = true
end

-- Safe time‑event removal – prevents crash if the function doesn't exist
safe_remove_time_event = function(id, name)
    if remove_time_event then
        pcall(remove_time_event, id, name)
    elseif RemoveTimeEvent then
        pcall(RemoveTimeEvent, id, name)
    else
        -- No removal function available – do nothing
    end
end

is_panda_ic_shutdown_in_progress = function()
    return panda_ic_shutdown_in_progress == true
end

function cleanup_panda_ic_events(options)
    options = type(options) == "table" and options or {}
    local preserve_active_conversations = options.preserve_active_conversations == true

    -- Repeating scheduler groups
    safe_remove_time_event("pda_ic_trigger", "tick")
    safe_remove_time_event("pda_ic_timeout", "check")
    safe_remove_time_event("pda_ic_location", "check")
    safe_remove_time_event("pda_ic_jobs", "check")
    safe_remove_time_event("pda_ic_followups", "check")

    -- Legacy global event chain
    safe_remove_time_event("pda_ic", "delivery_ack")
    safe_remove_time_event("pda_ic", "npc_typing_start")
    safe_remove_time_event("pda_ic", "npc_reply")

    -- Outcome helper groups
    for group, names in pairs(tracked_panda_ic_events) do
        for name in pairs(names) do
            safe_remove_time_event(group, name)
        end
        tracked_panda_ic_events[group] = {}
    end

    -- Per-conversation chains + typing indicators
    if active_conversations then
        for contact_id, convo in pairs(active_conversations) do
            local npc_id = convo and convo.npc_id
            if npc_id then
                local ev_prefix = "pda_ic_" .. tostring(npc_id)
                safe_remove_time_event(ev_prefix, "delivery_ack")
                safe_remove_time_event(ev_prefix, "npc_read")
                safe_remove_time_event(ev_prefix, "npc_thinking")
                safe_remove_time_event(ev_prefix, "npc_reply")
                safe_remove_time_event(ev_prefix, "outcome")
            end
            if type(convo) == "table" then
                convo.reply_pending = false
            end
            clear_npc_typing_message(contact_id)
        end
    end

    -- Also clear any orphan typing entries that are no longer in active_conversations
    for i = #pda_private_log, 1, -1 do
        local entry = pda_private_log[i]
        if entry and entry.is_typing then
            table.remove(pda_private_log, i)
        end
    end

    -- Conversation runtime state reset (idempotent)
    if not preserve_active_conversations then
        active_conversations = {}
    end
    pda_reply_pending = false
    CONV = nil
end

ensure_panda_task_bridge = function()
    if _panda_state.task_bridge_checked and panda_task_bridge and type(panda_task_bridge.set_callbacks) == "function" then
        return panda_task_bridge
    end

    if not _panda_state.task_bridge_checked then
        _panda_state.task_bridge_checked = true

        if not panda_task_bridge then
            local ok = pcall(function()
                if require then
                    require("panda_task_bridge")
                end
            end)

            if not ok then
                pcall(function()
                    dofile("gamedata\\scripts\\panda_task_bridge.script")
                end)
            end
        end
    end

    if not panda_task_bridge or type(panda_task_bridge.set_callbacks) ~= "function" then
        printf("PANDA_IC: warning: panda_task_bridge unavailable after module load")
        return nil
    end

    return panda_task_bridge
end

function on_game_shutdown_cb()
    if panda_ic_shutdown_in_progress == true then
        return
    end

    panda_ic_shutdown_in_progress = true
    cleanup_panda_ic_events({
        preserve_active_conversations = true,
    })
    reset_all_dialog_npc_animation_state("on_game_shutdown")

    local bridge = ensure_panda_f2f_bridge()
    if bridge and type(bridge.begin_shutdown_cleanup) == "function" then
        pcall(bridge.begin_shutdown_cleanup, "on_game_shutdown")
    elseif bridge and type(bridge.mark_shutdown_in_progress) == "function" then
        pcall(bridge.mark_shutdown_in_progress, "on_game_shutdown")
    end

    -- Drop the cached PDA private tab CUIScriptWnd singleton so its dangling
    -- references to about-to-be-freed C++ widgets cannot be reused on the next
    -- main-menu reload. A fresh instance is built next time the PDA opens.
    if pda_private_tab and type(pda_private_tab.reset_singleton) == "function" then
        pcall(pda_private_tab.reset_singleton)
    end
end

-- NPC invulnerability check for make_npc_invulnerable outcome
_panda_invulnerable_npcs = nil
function panda_npc_invulnerability_check(npc, shit, bone_id, flags)
    if _panda_invulnerable_npcs and npc and npc:id() then
        if _panda_invulnerable_npcs[npc:id()] then
            flags.ret_value = false
        end
    end
end

function ensure_pda_interactive_dialog_anim()
    if pda_interactive_dialog_anim and type(pda_interactive_dialog_anim.configure) == "function" then
        pda_interactive_dialog_anim.configure({
            safe_remove_time_event = safe_remove_time_event,
