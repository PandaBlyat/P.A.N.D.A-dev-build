    },

    -- MEADOW (prefix: pol)
    meadow = {
        "st_pol_sim_1_name",                    -- Factory Yard
        "st_pol_smart_terrain_1_1_name",        -- Village
        "st_pol_smart_terrain_1_2_name",        -- Canteen #14
        "st_pol_smart_terrain_1_3_name",        -- Old Car Park
        "st_pol_smart_terrain_2_1_name",        -- Factory Administration
        "st_pol_smart_terrain_2_2_name",        -- Factory Workshops
    },
}

-- Resolve a %<level>_panda_st% placeholder to a random smart terrain key from that level
function resolve_level_smart_terrain(level_key)
    local list = SMART_TERRAIN_LEVEL_LISTS[level_key]
    if not list or #list == 0 then
        printf("PANDA_IC: no smart terrain list for level key '%s'", tostring(level_key))
        return nil
    end
    return list[math.random(#list)]
end

-- Get a translated name for a level smart terrain placeholder
function resolve_level_smart_terrain_name(level_key)
    local st_key = resolve_level_smart_terrain(level_key)
    if not st_key then return nil end
    local translated = game.translate_string(st_key)
    if translated == st_key then
        return nil, st_key -- translation missing, return raw key
    end
    return translated, st_key
end

local function build_substitution_table(npc_name, npc_faction, npc_se, contact_id)
    local act = db.actor
    local player_name = act and act:character_name() or "Stalker"
    local player_comm = get_actor_true_community() or "stalker"
    if player_comm == "actor" then player_comm = "stalker" end

    local display_npc_fac = (npc_faction == "loner") and "stalker" or (npc_faction or "stalker")
    local cur_level = level and level.name and level.name() or "unknown"

    -- Player money
    local money = act and act:money() or 0
    -- Player rank
    local rank_name = (act and ranks and ranks.get_obj_rank_name) and ranks.get_obj_rank_name(act) or "unknown"
    -- Player reputation
    local reputation = act and act.character_reputation and act:character_reputation() or 0
    -- Companion count
    local comp_count = 0
    if axr_companions and axr_companions.companion_squads then
        for _ in pairs(axr_companions.companion_squads) do comp_count = comp_count + 1 end
    end
    -- Time of day
    local gt = game.get_game_time()
    local Y, M, D, h, mi = 0, 0, 0, 0, 0
    Y, M, D, h, mi = gt:get(Y, M, D, h, mi, 0, 0)
    local time_of_day = (h >= 6 and h < 12) and "morning" or (h >= 12 and h < 18) and "afternoon" or (h >= 18 and h < 22) and "evening" or "night"

    -- NPC rank
    local npc_rank_name = "unknown"
    if npc_se and ranks and ranks.get_obj_rank_name then
        local npc_obj = level.object_by_id(npc_se.id)
        if npc_obj then
            npc_rank_name = ranks.get_obj_rank_name(npc_obj) or "unknown"
        end
    end

    -- Player health percentage
    local player_health = act and math.floor((act.health or 0) * 100) or 0

    -- Kill statistics
    local stalker_kills = 0
    local mutant_kills = 0
    if act_statistic and act_statistic.get_stat then
        stalker_kills = act_statistic.get_stat("killed_stalkers") or 0
        mutant_kills = act_statistic.get_stat("killed_monsters") or 0
    elseif game_stats and game_stats.get_actor_stat then
        stalker_kills = game_stats.get_actor_stat("killed_stalkers") or 0
        mutant_kills = game_stats.get_actor_stat("killed_monsters") or 0
    end

    -- Relationship score
    local rel_score = 0
    if contact_id and relationship_scores then
        rel_score = relationship_scores[contact_id] or 0
    elseif npc_se and relationship_scores then
        rel_score = relationship_scores[npc_se.id] or 0
    end

    -- Game days survived
    local game_days = level.get_time_days and level.get_time_days() or 0

    -- Player satiety
    local player_satiety = 100
    if act and act.cast_Actor and act:cast_Actor() and act:cast_Actor().conditions then
        local cond = act:cast_Actor():conditions()
        if cond and cond.GetSatiety then
            player_satiety = math.floor(cond:GetSatiety() * 100)
        end
    end

    -- Player radiation
    local player_radiation = act and math.floor((act.radiation or 0) * 100) or 0

    -- Current weather
    local weather_name = level.get_weather and tostring(level.get_weather()) or "unknown"

    -- Total carry weight
    local total_weight = act and act.get_total_weight and string.format("%.1f", act:get_total_weight()) or "0"

    return {
        ["player_name"] = player_name,
        ["npc_name"] = npc_name or "Stalker",
        ["player_faction"] = game.translate_string("st_faction_"..player_comm),
        ["npc_faction"] = game.translate_string("st_faction_"..display_npc_fac),
        ["current_level"] = game.translate_string(cur_level),
        ["player_money"] = tostring(money),
        ["player_rank"] = rank_name,
        ["player_reputation"] = tostring(reputation),
        ["companion_count"] = tostring(comp_count),
        ["time_of_day"] = time_of_day,
        ["game_hour"] = string.format("%02d:%02d", h, mi),
        ["npc_rank"] = npc_rank_name,
        ["player_health"] = tostring(player_health),
        ["stalker_kills"] = tostring(stalker_kills),
        ["mutant_kills"] = tostring(mutant_kills),
        ["relationship_score"] = tostring(rel_score),
        ["game_days"] = tostring(game_days),
        ["player_satiety"] = tostring(player_satiety),
        ["player_radiation"] = tostring(player_radiation),
        ["player_rank_name"] = rank_name,
        ["npc_rank_name"] = npc_rank_name,
        ["weather"] = weather_name,
        ["total_weight"] = total_weight,
        ["game_day_number"] = tostring(D),
    }
end

-- Cache of resolved smart terrain placeholders per-conversation to keep
-- references consistent within a single conversation flow.
local _st_resolve_cache = {}

function clear_st_resolve_cache()
    _st_resolve_cache = {}
end

local function sub_placeholders(str, npc_name, npc_faction, npc_se, contact_id)
    if not str or str == "" then return str end

    -- First resolve any %<level>_panda_st% patterns.
    -- Each unique level key gets resolved once per conversation (cached)
    -- so that all turns referencing e.g. %cordon_panda_st% get the same location.
    str = string.gsub(str, "%%(%w+)_panda_st%%", function(level_key)
        if not _st_resolve_cache[level_key] then
            local translated, raw_key = resolve_level_smart_terrain_name(level_key)
            if translated then
                _st_resolve_cache[level_key] = { name = translated, key = raw_key }
            else
                printf("failed to resolve %%%s_panda_st%% placeholder", tostring(level_key))
                return "%"..level_key.."_panda_st%"
            end
        end
        return _st_resolve_cache[level_key].name
    end)

    -- Resolve %<level>_panda_st_key% placeholders for outcome commands.
    str = string.gsub(str, "%%(%w+)_panda_st_key%%", function(level_key)
        if not _st_resolve_cache[level_key] then
            local translated, raw_key = resolve_level_smart_terrain_name(level_key)
            if translated then
                _st_resolve_cache[level_key] = { name = translated, key = raw_key }
            else
                printf("failed to resolve %%%s_panda_st_key%% placeholder", tostring(level_key))
                return "%"..level_key.."_panda_st_key%"
            end
        end
        return _st_resolve_cache[level_key].key
    end)

    -- Then do normal $placeholder substitutions
    local subs = build_substitution_table(npc_name, npc_faction, npc_se, contact_id)
    return utils_data.parse_string_keys(str, subs)
end

-- Resolve %<level>_panda_st_key% to the raw smart terrain key (for use in outcomes).
-- Must be called AFTER sub_placeholders has resolved the cache for that level.
function get_cached_st_key(level_key)
    local cached = _st_resolve_cache[level_key]
    return cached and cached.key or nil
end

local function get_rank_order_value(rank_name)
    if not rank_name then return 1 end
    return RANK_ORDER[tostring(rank_name):lower()] or 1
end

local function get_npc_rank_name(npc_se)
    if not npc_se or not ranks or not ranks.get_obj_rank_name then
        return nil
    end

    local npc_obj = level.object_by_id(npc_se.id)
    if not npc_obj then
        return nil
    end

    return ranks.get_obj_rank_name(npc_obj)
end

local function get_npc_faction(npc_se)
    if not npc_se then
        return nil
    end

    local npc_obj = level.object_by_id(npc_se.id)
    if npc_obj and npc_obj.character_community then
        return normalize_faction(npc_obj:character_community())
    end

    -- Fallbacks for cases where only server entity data is available.
    if npc_se.community then
        return normalize_faction(npc_se.community)
    end

    if npc_se.m_community then
        return normalize_faction(npc_se.m_community)
    end

    return nil
end

local function get_manager_remaining_seconds(manager_module, getter_name, delta_key, last_time_key)
    if not manager_module or not manager_module[getter_name] then
        return nil
    end

    local manager = manager_module[getter_name]()
    if not manager then
        return nil
    end

    local delta = manager[delta_key]
    local last_time = manager[last_time_key]
    if not delta or not last_time then
        return nil
    end

    local now = game.get_game_time()
    if not now then
        return nil
    end

    return math.floor(delta - now:diffSec(last_time))
end

local function is_weather_fx_active_now()
    local active = false

    if level_weathers and level_weathers.get_weather_manager then
        local wm = level_weathers.get_weather_manager()
        if wm and wm.weather_fx then
            active = true
        end
    end

    if not active and level and level.get_wfx_time then
        active = (level.get_wfx_time() or 0) > 0
    end

    return active
end

local PRECONDITION_MACROS = {
    danger_context = "any(req_time_night|req_weather_fx_active|req_surge_soon:900|req_psi_storm_soon:900)",
}

local function precond_trace(fmt, ...)
    if PANDA.get_config("debug_logging") or PANDA.get_config("precond_verbose_debug") then
        _G.printf("PANDA_IC[precond]: " .. fmt, ...)
    end
end

local function split_top_level(str, delimiter)
    local result = {}
    local start_idx = 1
    local depth = 0

    for i = 1, #str do
        local ch = string.sub(str, i, i)
        if ch == "(" then
            depth = depth + 1
        elseif ch == ")" then
            depth = math.max(depth - 1, 0)
        elseif ch == delimiter and depth == 0 then
            local chunk = string.sub(str, start_idx, i - 1):match("^%s*(.-)%s*$")
            if chunk ~= "" then
                table.insert(result, chunk)
            end
            start_idx = i + 1
        end
    end

    local tail = string.sub(str, start_idx):match("^%s*(.-)%s*$")
    if tail ~= "" then
        table.insert(result, tail)
    end

    return result
end

local function unwrap_wrapper(token, prefix)
    local full_prefix = prefix .. "("
    if string.sub(token, 1, #full_prefix) ~= full_prefix then
        return nil
    end

    if string.sub(token, -1) ~= ")" then
        return nil
    end

    return string.sub(token, #full_prefix + 1, -2)
end

local function evaluate_precondition_entry(entry, npc_se, act, get_goodwill_actor_id)
    local parts = str_explode(entry, ":")
    local cmd = parts[1]

    -- ========== MONEY ==========
    if cmd == "req_money" then
        if act:money() < (tonumber(parts[2]) or 0) then return false, "insufficient money" end
    elseif cmd == "req_money_max" then
        if act:money() >= (tonumber(parts[2]) or 0) then return false, "money above max" end

    -- ========== RANK ==========
    elseif cmd == "req_rank" then
        local p_rank = ranks.get_obj_rank_name(act) or "novice"
        if get_rank_order_value(p_rank) < get_rank_order_value(parts[2]) then return false, "rank below minimum" end
    elseif cmd == "req_rank_max" then
        local p_rank = ranks.get_obj_rank_name(act) or "novice"
        if get_rank_order_value(p_rank) > get_rank_order_value(parts[2]) then return false, "rank above max" end
    elseif cmd == "req_npc_rank" then
        local npc_rank = get_npc_rank_name(npc_se)
        if not npc_rank then return false, "npc rank unavailable" end
        if get_rank_order_value(npc_rank) < get_rank_order_value(parts[2]) then return false, "npc rank below minimum" end
    elseif cmd == "req_npc_rank_max" then
        local npc_rank = get_npc_rank_name(npc_se)
        if not npc_rank then return false, "npc rank unavailable" end
        if get_rank_order_value(npc_rank) > get_rank_order_value(parts[2]) then return false, "npc rank above max" end

    -- ========== REPUTATION ==========
    elseif cmd == "req_rep" then
        if act:character_reputation() < (tonumber(parts[2]) or 0) then return false, "reputation below minimum" end
    elseif cmd == "req_rep_max" then
        if act:character_reputation() > (tonumber(parts[2]) or 0) then return false, "reputation above max" end

    -- ========== KILLS ==========
    elseif cmd == "req_kills" then
        local kills = 0
        if act_statistic and act_statistic.get_stat then
            kills = act_statistic.get_stat("killed_stalkers") or 0
        elseif game_stats and game_stats.get_actor_stat then
            kills = game_stats.get_actor_stat("killed_stalkers") or 0
        end
        if kills < (tonumber(parts[2]) or 0) then return false, "stalker kills below minimum" end
    elseif cmd == "req_mutant_kills" then
        local kills = 0
        if act_statistic and act_statistic.get_stat then
            kills = act_statistic.get_stat("killed_monsters") or 0
        elseif game_stats and game_stats.get_actor_stat then
            kills = game_stats.get_actor_stat("killed_monsters") or 0
        end
        if kills < (tonumber(parts[2]) or 0) then return false, "mutant kills below minimum" end

    -- ========== FACTION ==========
    elseif cmd == "req_faction" then
        local player_comm = get_actor_true_community() or "stalker"
        local required_fac = normalize_faction(parts[2])
        if player_comm ~= required_fac then return false, "player faction mismatch" end
    elseif cmd == "req_not_faction" then
        local player_comm = get_actor_true_community() or "stalker"
        local excluded_fac = normalize_faction(parts[2])
        if player_comm == excluded_fac then return false, "player faction excluded" end
    elseif cmd == "req_npc_faction" then
        local npc_fac = get_npc_faction(npc_se)
        local required_fac = normalize_faction(parts[2])
        if not npc_fac or npc_fac ~= required_fac then return false, "npc faction mismatch" end
    elseif cmd == "req_npc_not_faction" then
        local npc_fac = get_npc_faction(npc_se)
        local excluded_fac = normalize_faction(parts[2])
        if npc_fac and npc_fac == excluded_fac then return false, "npc faction excluded" end

    -- ========== NPC RELATION ==========
    elseif cmd == "req_npc_friendly" then
        if not npc_se then return false, "npc missing" end
        local npc_fac = get_npc_faction(npc_se)
        if not npc_fac then return false, "npc faction unavailable" end
        if parts[2] and parts[2] ~= "" then
            local required_fac = normalize_faction(parts[2])
            if npc_fac ~= required_fac then return false, "npc faction mismatch" end
        end
        local actor_id = get_goodwill_actor_id("req_npc_friendly")
        if actor_id == nil then return false, "actor id unavailable" end
        local gw = 0
        if relation_registry and relation_registry.community_goodwill then
            gw = relation_registry.community_goodwill(npc_fac, actor_id) or 0
        end
        if gw < 0 then return false, "npc goodwill hostile" end
        local npc_obj = level.object_by_id(npc_se.id)
        if npc_obj and npc_obj:relation(db.actor) == game_object.enemy then return false, "npc personal relation hostile" end
    elseif cmd == "req_npc_hostile" then
        if not npc_se then return false, "npc missing" end
        local npc_fac = get_npc_faction(npc_se)
        if not npc_fac then return false, "npc faction unavailable" end
        if parts[2] and parts[2] ~= "" then
            local required_fac = normalize_faction(parts[2])
            if npc_fac ~= required_fac then return false, "npc faction mismatch" end
        end
        local actor_id = get_goodwill_actor_id("req_npc_hostile")
        if actor_id == nil then return false, "actor id unavailable" end
        local gw = 0
        if relation_registry and relation_registry.community_goodwill then
            gw = relation_registry.community_goodwill(npc_fac, actor_id) or 0
        end
        if gw >= 0 then return false, "npc goodwill not hostile" end
        local npc_obj = level.object_by_id(npc_se.id)
        if npc_obj and npc_obj:relation(db.actor) < game_object.enemy then return false, "npc personal relation not hostile" end

    -- ========== LEVEL / LOCATION ==========
    elseif cmd == "req_level" then
        local cur_level = level and level.name and level.name() or "unknown"
        if cur_level ~= parts[2] then return false, "wrong level" end
    elseif cmd == "req_not_level" then
        local cur_level = level and level.name and level.name() or "unknown"
        if cur_level == parts[2] then return false, "excluded level" end
    elseif cmd == "req_actor_near_smart" then
        local smart_ref = parts[2]
        if not smart_ref or smart_ref == "" then return false, "missing smart ref" end
        local dist = tonumber(parts[3]) or 50
        local actor_pos = act:position()
        local smart_pos = resolve_smart_position_from_reference(smart_ref)
        if not smart_pos or actor_pos:distance_to(smart_pos) >= dist then return false, "actor too far from smart" end
    elseif cmd == "req_npc_near_smart" then
        if not npc_se then return false, "npc missing" end
        local smart_ref = parts[2]
        if not smart_ref or smart_ref == "" then return false, "missing smart ref" end
        local dist = tonumber(parts[3]) or 50
        local npc_pos = get_npc_position(npc_se)
        local smart_pos = resolve_smart_position_from_reference(smart_ref)
        if not npc_pos or not smart_pos or npc_pos:distance_to(smart_pos) >= dist then return false, "npc too far from smart" end
    elseif cmd == "req_actor_in_zone" then
        local zone_name = parts[2]
        if not zone_name or zone_name == "" then return false, "missing zone" end
        local zone = db.zone_by_name and db.zone_by_name[zone_name] or nil
        if not zone or not zone:inside(act:position()) then return false, "actor not in zone" end
    elseif cmd == "req_detector_tier" then
        local required_tier = parts[2] or "basic"
        local adapter = get_anomaly_artifact_adapter()
        if not adapter or not adapter.require_detector_tier then
            return false, "anomaly adapter unavailable"
        end
        local ok = adapter.require_detector_tier(required_tier)
        if not ok then
            return false, "detector tier below requirement"
        end

    -- ========== DISTANCE TO NPC ==========
    elseif cmd == "req_distance_max" or cmd == "req_distance_min" then
        -- Checked elsewhere during NPC filtering.

    -- ========== COMPANIONS ==========
    elseif cmd == "req_companions" then
        local comps = 0
        if axr_companions and axr_companions.companion_squads then
            for _ in pairs(axr_companions.companion_squads) do comps = comps + 1 end
        end
        if comps < (tonumber(parts[2]) or 0) then return false, "companions below minimum" end
    elseif cmd == "req_companions_max" then
        local comps = 0
        if axr_companions and axr_companions.companion_squads then
            for _ in pairs(axr_companions.companion_squads) do comps = comps + 1 end
        end
        if comps > (tonumber(parts[2]) or 0) then return false, "companions above max" end

    -- ========== FACTION GOODWILL ==========
    elseif cmd == "req_goodwill" then
        local amount = tonumber(parts[2]) or 0
        local fac = normalize_faction(parts[3] or "stalker")
        local actor_id = get_goodwill_actor_id("req_goodwill")
        if actor_id == nil then return false, "actor id unavailable" end
        local gw = 0
        if relation_registry and relation_registry.community_goodwill then
            gw = relation_registry.community_goodwill(fac, actor_id) or 0
        end
        if gw < amount then return false, "goodwill below minimum" end
    elseif cmd == "req_goodwill_max" then
        local amount = tonumber(parts[2]) or 0
        local fac = normalize_faction(parts[3] or "stalker")
        local actor_id = get_goodwill_actor_id("req_goodwill_max")
        if actor_id == nil then return false, "actor id unavailable" end
        local gw = 0
        if relation_registry and relation_registry.community_goodwill then
            gw = relation_registry.community_goodwill(fac, actor_id) or 0
        end
        if gw > amount then return false, "goodwill above max" end

    -- ========== ITEMS ==========
    elseif cmd == "req_has_item" then
        local item_sec = parts[2]
        if not item_sec then return false, "missing item section" end
        local found = false
        act:iterate_inventory(function(owner, item)
            if item:section() == item_sec then found = true end
        end, act)
        if not found then return false, "item missing" end
    elseif cmd == "req_equipped" then
        local item_sec = parts[2]
        if not item_sec then return false, "missing item section" end
        local found = false
        for slot = 0, 12 do
            local slot_item = act:item_in_slot(slot)
            if slot_item and slot_item:section() == item_sec then
                found = true
                break
            end
        end
        if not found then return false, "item not equipped" end
    elseif cmd == "req_equipped_slot" then
        local slot = tonumber(parts[2]) or 0
        if not act:item_in_slot(slot) then return false, "slot empty" end

    -- ========== ACHIEVEMENTS ==========
    elseif cmd == "req_achievement" then
        local ach_name = parts[2]
        if not ach_name then return false, "missing achievement" end
        local has_ach = false
        if game_achievements and game_achievements.has_achievement then
            has_ach = game_achievements.has_achievement(ach_name)
        elseif achieved then
            has_ach = achieved[ach_name] == true
        end
        if not has_ach then return false, "achievement missing" end

    -- ========== TIME ==========
    elseif cmd == "req_time_day" then
        local gt = game.get_game_time()
        local Y, M, D, h = 0, 0, 0, 0
        Y, M, D, h = gt:get(Y, M, D, h, 0, 0, 0)
        if h < 6 or h >= 20 then return false, "outside day window" end
    elseif cmd == "req_time_night" then
        local gt = game.get_game_time()
        local Y, M, D, h = 0, 0, 0, 0
        Y, M, D, h = gt:get(Y, M, D, h, 0, 0, 0)
        if h >= 6 and h < 20 then return false, "outside night window" end

    -- ========== EVENT TIMING / WEATHER FX ==========
    elseif cmd == "req_surge_soon" then
        local threshold = tonumber(parts[2]) or 0
        local remaining = get_manager_remaining_seconds(surge_manager, "get_surge_manager", "_delta", "last_surge_time")
        printf("Precondition req_surge_soon: threshold=%s, remaining=%s", tostring(threshold), tostring(remaining))
        if not remaining or remaining > threshold then return false, "surge not soon enough" end
    elseif cmd == "req_not_surge_soon" then
        local threshold = tonumber(parts[2]) or 0
        local remaining = get_manager_remaining_seconds(surge_manager, "get_surge_manager", "_delta", "last_surge_time")
        printf("Precondition req_not_surge_soon: threshold=%s, remaining=%s", tostring(threshold), tostring(remaining))
        if not remaining or remaining <= threshold then return false, "surge too soon" end
    elseif cmd == "req_psi_storm_soon" then
        local threshold = tonumber(parts[2]) or 0
        local remaining = get_manager_remaining_seconds(psi_storm_manager, "get_psi_storm_manager", "_delta", "last_psi_storm_time")
        printf("Precondition req_psi_storm_soon: threshold=%s, remaining=%s", tostring(threshold), tostring(remaining))
        if not remaining or remaining > threshold then return false, "psi storm not soon enough" end
    elseif cmd == "req_weather_fx_active" then
        local active = is_weather_fx_active_now()
        printf("Precondition req_weather_fx_active: active=%s", tostring(active))
        if not active then return false, "weather fx inactive" end
    elseif cmd == "req_weather_fx_not_active" then
        local active = is_weather_fx_active_now()
        printf("Precondition req_weather_fx_not_active: active=%s", tostring(active))
        if active then return false, "weather fx active" end

    -- ========== HEALTH ==========
    elseif cmd == "req_health_min" then
        if act.health < (tonumber(parts[2]) or 0) then return false, "health below minimum" end
    elseif cmd == "req_health_max" then
        if act.health > (tonumber(parts[2]) or 0) then return false, "health above max" end

    -- ========== PLAYER CONDITION ==========
    elseif cmd == "req_radiation_min" then
        local rad = act:get_radiation() * 100
        if rad < (tonumber(parts[2]) or 0) then return false, "radiation below minimum" end
    elseif cmd == "req_radiation_max" then
        local rad = act:get_radiation() * 100
        if rad > (tonumber(parts[2]) or 0) then return false, "radiation above max" end
    elseif cmd == "req_hunger" then
        local satiety = 1
        if actor_status and actor_status.get_satienty then
            satiety = actor_status.get_satienty()
        end
        if satiety < 2 then return false, "player not hungry" end
    elseif cmd == "req_not_hungry" then
        local satiety = 1
        if actor_status and actor_status.get_satienty then
            satiety = actor_status.get_satienty()
        end
        if satiety >= 2 then return false, "player hungry" end
    elseif cmd == "req_bleeding" then
        if act.bleeding <= 0 then return false, "player not bleeding" end
    elseif cmd == "req_overweight" then
        local max_weight = (db.actor.get_actor_max_weight and db.actor:get_actor_max_weight()) or 60
        local cur_weight = (db.actor.get_total_weight and db.actor:get_total_weight()) or 0
        if cur_weight <= max_weight then return false, "player not overweight" end

    -- ========== HAS ITEM TYPE ==========
    elseif cmd == "req_has_item_type" then
        local item_type = parts[2]
        if not item_type then return false, "missing item type" end
        local TYPE_CHECKERS = {
            weapon = IsWeapon, outfit = IsOutfit, artefact = IsArtefact,
            headgear = IsHeadgear, pistol = IsPistol, rifle = IsRifle,
            shotgun = IsShotgun, sniper = IsSniper, melee = IsMelee,
            explosive = IsExplosive,
        }
        local checker = TYPE_CHECKERS[item_type:lower()]
        if not checker then return false, "unknown item type: " .. tostring(item_type) end
        local found = false
        act:iterate_inventory(function(owner, item)
            if not found and checker(item) then found = true end
        end, act)
        if not found then return false, "no item of type " .. item_type end

    -- ========== ARTEFACTS / FACTION KILLS ==========
    elseif cmd == "req_artefacts_found" then
        local found = 0
        if act_statistic and act_statistic.get_stat then
            found = act_statistic.get_stat("artefacts_found") or 0
        elseif game_stats and game_stats.get_actor_stat then
            found = game_stats.get_actor_stat("artefacts_found") or 0
        end
        if found < (tonumber(parts[2]) or 0) then return false, "artefacts found below minimum" end
    elseif cmd == "req_faction_kills" then
        local required_count = tonumber(parts[2]) or 0
        local target_faction = normalize_faction(parts[3] or "bandit")
        local kills = 0
        if act_statistic and act_statistic.get_stat then
            kills = act_statistic.get_stat("killed_" .. target_faction) or 0
        elseif game_stats and game_stats.get_actor_stat then
            kills = game_stats.get_actor_stat("killed_" .. target_faction) or 0
        end
        if kills < required_count then return false, "faction kills below minimum" end
    elseif cmd == "req_enemy_kills" then
        local required_count = tonumber(parts[2]) or 0
        local kills = 0
        if act_statistic and act_statistic.get_stat then
            kills = act_statistic.get_stat("killed_stalkers_e") or act_statistic.get_stat("killed_stalkers") or 0
        elseif game_stats and game_stats.get_actor_stat then
            kills = game_stats.get_actor_stat("killed_stalkers_e") or game_stats.get_actor_stat("killed_stalkers") or 0
        end
        if kills < required_count then return false, "enemy kills below minimum" end

    -- ========== NOT HAS ITEM / ITEM COUNT ==========
    elseif cmd == "req_not_has_item" then
        local item_sec = parts[2]
        if not item_sec then return false, "missing item section" end
        local found = false
        act:iterate_inventory(function(owner, item)
            if item:section() == item_sec then found = true end
        end, act)
        if found then return false, "item present (should not be)" end
    elseif cmd == "req_has_item_count" then
        local item_sec = parts[2]
        local required = tonumber(parts[3]) or 1
        if not item_sec then return false, "missing item section" end
        local count = 0
        act:iterate_inventory(function(owner, item)
            if item:section() == item_sec then count = count + 1 end
        end, act)
        if count < required then return false, "item count below minimum" end

    -- ========== KNOWLEDGE / INFO PORTIONS ==========
    elseif cmd == "req_has_info" then
        local info_id = parts[2]
        if not info_id or info_id == "" then return false, "missing info id" end
        if not has_alife_info(info_id) then return false, "info portion missing" end
    elseif cmd == "req_not_has_info" then
        local info_id = parts[2]
        if not info_id or info_id == "" then return false, "missing info id" end
        if has_alife_info(info_id) then return false, "info portion present (should not be)" end

    -- ========== RELATIONSHIP SCORE ==========
    elseif cmd == "req_relationship_min" then
        local min_score = tonumber(parts[2]) or 0
        local rel_score = 0
        if npc_se and relationship_scores then
            rel_score = relationship_scores[npc_se.id] or 0
        end
        if rel_score < min_score then return false, "relationship below minimum" end
    elseif cmd == "req_relationship_max" then
        local max_score = tonumber(parts[2]) or 0
        local rel_score = 0
        if npc_se and relationship_scores then
            rel_score = relationship_scores[npc_se.id] or 0
        end
        if rel_score > max_score then return false, "relationship above max" end

    -- ========== TIME HOUR ==========
    elseif cmd == "req_time_hour_min" then
        local gt = game.get_game_time()
        local Y, M, D, h = 0, 0, 0, 0
        Y, M, D, h = gt:get(Y, M, D, h, 0, 0, 0)
        if h < (tonumber(parts[2]) or 0) then return false, "hour below minimum" end
    elseif cmd == "req_time_hour_max" then
        local gt = game.get_game_time()
        local Y, M, D, h = 0, 0, 0, 0
        Y, M, D, h = gt:get(Y, M, D, h, 0, 0, 0)
        if h > (tonumber(parts[2]) or 23) then return false, "hour above max" end

    -- ========== NPC STATE ==========
    elseif cmd == "req_npc_alive" then
        if not npc_se then return false, "npc missing" end
        local se_obj = alife_object(npc_se.id)
        if not se_obj then return false, "npc dead or released" end
    elseif cmd == "req_npc_on_level" then
        if not npc_se then return false, "npc missing" end
        local required_level = parts[2]
        if not required_level then return false, "missing level" end
        local npc_level = alife():level_name(game_graph():vertex(npc_se.m_game_vertex_id):level_id())
        if npc_level ~= required_level then return false, "npc on wrong level" end

    -- ========== GAME PROGRESS ==========
    elseif cmd == "req_game_days_min" then
        local days = level.get_time_days and level.get_time_days() or 0
        if days < (tonumber(parts[2]) or 0) then return false, "game days below minimum" end
    elseif cmd == "req_game_days_max" then
        local days = level.get_time_days and level.get_time_days() or 0
        if days > (tonumber(parts[2]) or 9999) then return false, "game days above max" end
    elseif cmd == "req_visited_level" then
        local lvl = parts[2]
        if not lvl then return false, "missing level" end
        local visited = false
        if game_statistics and game_statistics.has_actor_visited_level then
            visited = game_statistics.has_actor_visited_level(lvl)
        end
        if not visited then return false, "level not visited" end
    elseif cmd == "req_not_visited_level" then
        local lvl = parts[2]
        if not lvl then return false, "missing level" end
        local visited = false
        if game_statistics and game_statistics.has_actor_visited_level then
            visited = game_statistics.has_actor_visited_level(lvl)
        end
        if visited then return false, "level already visited" end

    -- ─── NEW PRECONDITIONS ──────────────────────────────────────────────────

    -- Player Condition: satiety
    elseif cmd == "req_satiety_min" then
        local threshold = (tonumber(parts[2]) or 0) / 100
        local satiety = 1
        if act.cast_Actor and act:cast_Actor() and act:cast_Actor().conditions then
            local cond = act:cast_Actor():conditions()
            if cond and cond.GetSatiety then satiety = cond:GetSatiety() end
        end
        if satiety < threshold then return false, "satiety below minimum" end
    elseif cmd == "req_satiety_max" then
        local threshold = (tonumber(parts[2]) or 100) / 100
        local satiety = 1
        if act.cast_Actor and act:cast_Actor() and act:cast_Actor().conditions then
            local cond = act:cast_Actor():conditions()
            if cond and cond.GetSatiety then satiety = cond:GetSatiety() end
        end
        if satiety > threshold then return false, "satiety above maximum" end
    elseif cmd == "req_thirsty" then
        local thirsty = false
        if act.cast_Actor and act:cast_Actor() and act:cast_Actor().conditions then
            local cond = act:cast_Actor():conditions()
            if cond and cond.GetThirsty then
                thirsty = cond:GetThirsty() > 0
            elseif cond and cond.GetSatiety then
                thirsty = cond:GetSatiety() < 0.3
            end
        end
        if not thirsty then return false, "player not thirsty" end
    elseif cmd == "req_not_thirsty" then
        local thirsty = false
        if act.cast_Actor and act:cast_Actor() and act:cast_Actor().conditions then
            local cond = act:cast_Actor():conditions()
            if cond and cond.GetThirsty then
                thirsty = cond:GetThirsty() > 0
            elseif cond and cond.GetSatiety then
                thirsty = cond:GetSatiety() < 0.3
            end
        end
        if thirsty then return false, "player is thirsty" end

    -- Equipment checks
    elseif cmd == "req_weapon_equipped" then
        local has_weapon = (act:item_in_slot(1) ~= nil) or (act:item_in_slot(2) ~= nil)
        if not has_weapon then return false, "no weapon equipped" end
    elseif cmd == "req_no_weapon_equipped" then
        local has_weapon = (act:item_in_slot(1) ~= nil) or (act:item_in_slot(2) ~= nil)
        if has_weapon then return false, "weapon is equipped" end
    elseif cmd == "req_outfit_equipped" then
        if act:item_in_slot(6) == nil then return false, "no outfit equipped" end

    -- World state: emission active
    elseif cmd == "req_surge_active" then
        local active = false
        if surge_manager and surge_manager.is_started then
            active = surge_manager.is_started()
        elseif xr_conditions and xr_conditions.is_surge_started then
            active = xr_conditions.is_surge_started()
        end
        if not active then return false, "no emission active" end
    elseif cmd == "req_not_surge_active" then
        local active = false
        if surge_manager and surge_manager.is_started then
            active = surge_manager.is_started()
        elseif xr_conditions and xr_conditions.is_surge_started then
            active = xr_conditions.is_surge_started()
        end
        if active then return false, "emission is active" end

    -- Weather check
    elseif cmd == "req_weather" then
        local required = parts[2]
        if not required then return false, "missing weather type" end
        local current = level.get_weather and level.get_weather() or ""
        if tostring(current) ~= required then return false, "weather mismatch" end

    -- Hour range with midnight wrap
    elseif cmd == "req_game_hour_between" then
        local h_min = tonumber(parts[2]) or 0
        local h_max = tonumber(parts[3]) or 23
        local cur_h = level.get_time_hours and level.get_time_hours() or 0
        local in_range
        if h_min <= h_max then
            in_range = (cur_h >= h_min and cur_h <= h_max)
        else
            in_range = (cur_h >= h_min or cur_h <= h_max)
        end
        if not in_range then return false, "hour not in range" end

    -- Game month
    elseif cmd == "req_game_month" then
        local req_month = tonumber(parts[2]) or 1
        local gt = game.get_game_time()
        local Y, M, D, h, mi = 0, 0, 0, 0, 0
        Y, M, D, h, mi = gt:get(Y, M, D, h, mi, 0, 0)
        if M ~= req_month then return false, "month mismatch" end

    -- Faction relations
    elseif cmd == "req_factions_enemies" then
        local f1 = normalize_faction(parts[2] or "stalker")
        local f2 = normalize_faction(parts[3] or "bandit")
        local enemies = false
        if game_relations and game_relations.is_factions_enemies then
            enemies = game_relations.is_factions_enemies(f1, f2)
        end
        if not enemies then return false, "factions not enemies" end
    elseif cmd == "req_factions_friends" then
        local f1 = normalize_faction(parts[2] or "stalker")
        local f2 = normalize_faction(parts[3] or "stalker")
        local friends = false
        if game_relations and game_relations.is_factions_friends then
            friends = game_relations.is_factions_friends(f1, f2)
        end
        if not friends then return false, "factions not friends" end

    -- NPC rank name match
    elseif cmd == "req_npc_rank_name" then
        local required_rank = parts[2]
        if not required_rank then return false, "missing rank" end
        if not npc_se then return false, "npc missing" end
        local npc_obj = level.object_by_id(npc_se.id)
        local npc_rank = "unknown"
        if npc_obj and ranks and ranks.get_obj_rank_name then
            npc_rank = ranks.get_obj_rank_name(npc_obj) or "unknown"
        end
        if npc_rank ~= required_rank then return false, "npc rank mismatch" end

    -- Carry weight
    elseif cmd == "req_total_weight_min" then
        local w = act:get_total_weight() or 0
        if w < (tonumber(parts[2]) or 0) then return false, "weight below minimum" end
    elseif cmd == "req_total_weight_max" then
        local w = act:get_total_weight() or 0
        if w > (tonumber(parts[2]) or 9999) then return false, "weight above maximum" end

    -- Visited smart terrain
    elseif cmd == "req_visited_smart" then
        local smart_name = parts[2]
        if not smart_name then return false, "missing smart terrain" end
        local visited = false
        if game_statistics and game_statistics.has_actor_visited_smart then
            visited = game_statistics.has_actor_visited_smart(smart_name)
        end
        if not visited then return false, "smart terrain not visited" end

    -- Distance from NPC
    elseif cmd == "req_distance_min" then
        local min_dist = tonumber(parts[2]) or 0
        if not npc_se then return false, "npc missing" end
        local npc_obj = level.object_by_id(npc_se.id)
        if npc_obj then
            local dist = npc_obj:position():distance_to(act:position())
            if dist < min_dist then return false, "too close to npc" end
        end
    elseif cmd == "req_distance_max" then
        local max_dist = tonumber(parts[2]) or 9999
        if not npc_se then return false, "npc missing" end
        local npc_obj = level.object_by_id(npc_se.id)
        if npc_obj then
            local dist = npc_obj:position():distance_to(act:position())
            if dist > max_dist then return false, "too far from npc" end
        end

    -- ========== STORY NPC ==========
    elseif cmd == "req_story_npc" then
        local required_sid = parts[2]
        if not required_sid then return false, "missing story id" end
        if not npc_se then return false, "npc missing" end

        local canonical_required = tostring(required_sid):lower()
        local runtime_candidates = {}
        local seen_candidates = {}
        local function push_candidate(value)
            if value == nil then
                return
            end
            local normalized = tostring(value):lower()
            if normalized == "" or seen_candidates[normalized] then
                return
            end
            seen_candidates[normalized] = true
            runtime_candidates[#runtime_candidates + 1] = normalized
        end

        if PANDA_CONV_API and type(PANDA_CONV_API.get_npc_canonical_id) == "function" then
            push_candidate(PANDA_CONV_API.get_npc_canonical_id(npc_se))
        end

        local sid = tonumber(npc_se.id)
        if not sid and type(npc_se.id) == "function" then
            local ok_sid, sid_from_fn = pcall(function() return npc_se:id() end)
            if ok_sid then
                sid = tonumber(sid_from_fn)
            end
        end
        if sid and sid > 0 and type(get_object_story_id) == "function" then
            local ok_story, raw_story_id = pcall(function() return get_object_story_id(math.floor(sid)) end)
            if ok_story then
                push_candidate(raw_story_id)
            end
        end

        if npc_se.name then
            local ok_name, runtime_name = pcall(function() return npc_se:name() end)
            if ok_name then
                push_candidate(runtime_name)
            end
        end
        if npc_se.character_name then
            local ok_char_name, character_name = pcall(function() return npc_se:character_name() end)
            if ok_char_name then
                push_candidate(character_name)
            end
        end

        local matched = false
        for _, candidate in ipairs(runtime_candidates) do
            if candidate == canonical_required then
                matched = true
                break
            end
        end

        if not matched then
            local checked = (#runtime_candidates > 0 and table.concat(runtime_candidates, "|") or "<none>")
            if #checked > 128 then
                checked = checked:sub(1, 128) .. "..."
            end
            return false, "story npc mismatch (need " .. required_sid .. "; checked " .. checked .. ")"
        end

    else
        return nil, "unknown command"
    end

    return true, "ok"
end

function check_preconditions_generic(precond_key, npc_se)
    local val = game.translate_string(precond_key)
    if val == precond_key then return true end
    local act = db.actor
    if not act then return false end
    local unknown_policy = tostring(PANDA.get_config("precond_unknown_policy") or "strict")
    local goodwill_actor_id = nil
    local function get_goodwill_actor_id(context)
        if goodwill_actor_id ~= nil then
            return goodwill_actor_id
        end

        goodwill_actor_id = resolve_actor_id_for_goodwill(context)
        return goodwill_actor_id
    end

    local function eval_expr(expr, depth, macro_stack)
        depth = depth or 0
        macro_stack = macro_stack or {}

        local token = (expr or ""):match("^%s*(.-)%s*$")
        if token == "" then
            precond_trace("%sEmpty expression -> pass", string.rep("  ", depth))
            return true
        end

        local indent = string.rep("  ", depth)

        local macro_name = token:match("^macro:(.+)$")
        if macro_name then
            macro_name = macro_name:match("^%s*(.-)%s*$")
            local macro_expr = PRECONDITION_MACROS[macro_name]
            if not macro_expr then
                precond_trace("%sMacro '%s' not found", indent, tostring(macro_name))
                if unknown_policy == "warn-and-skip" then
                    return true
                end
                return false
            end
            if macro_stack[macro_name] then
                precond_trace("%sMacro recursion detected for '%s'", indent, tostring(macro_name))
                return false
            end
            precond_trace("%sMacro '%s' -> %s", indent, tostring(macro_name), tostring(macro_expr))
            macro_stack[macro_name] = true
            local passed = eval_expr(macro_expr, depth + 1, macro_stack)
            macro_stack[macro_name] = nil
            precond_trace("%sMacro '%s' result=%s", indent, tostring(macro_name), tostring(passed))
            return passed
        end

        local any_inner = unwrap_wrapper(token, "any")
        if any_inner then
            local options = split_top_level(any_inner, "|")
            precond_trace("%sOR block start (%d options): %s", indent, #options, token)
            for idx, option in ipairs(options) do
                local passed = eval_expr(option, depth + 1, macro_stack)
                precond_trace("%sOR option %d -> %s", indent, idx, tostring(passed))
                if passed then
                    precond_trace("%sOR block PASS via option %d", indent, idx)
                    return true
                end
            end
            precond_trace("%sOR block FAIL", indent)
            return false
        end

        local not_inner = unwrap_wrapper(token, "not")
        if not_inner then
            local inner_passed = eval_expr(not_inner, depth + 1, macro_stack)
            precond_trace("%sNOT block inner=%s final=%s", indent, tostring(inner_passed), tostring(not inner_passed))
            return not inner_passed
        end

        local and_terms = split_top_level(token, ",")
        if #and_terms > 1 then
            precond_trace("%sAND block start (%d terms): %s", indent, #and_terms, token)
            for idx, term in ipairs(and_terms) do
                local passed = eval_expr(term, depth + 1, macro_stack)
                precond_trace("%sAND term %d -> %s", indent, idx, tostring(passed))
                if not passed then
                    precond_trace("%sAND block FAIL at term %d", indent, idx)
                    return false
                end
            end
            precond_trace("%sAND block PASS", indent)
            return true
        end

        local passed, reason = evaluate_precondition_entry(token, npc_se, act, get_goodwill_actor_id)
        if passed == nil then
            precond_trace("%sUnknown precondition token '%s' (policy=%s)", indent, token, unknown_policy)
            if unknown_policy == "warn-and-skip" then
                return true
            end
            return false
        end

        precond_trace("%sLeaf '%s' -> %s (%s)", indent, token, tostring(passed), tostring(reason))
        return passed
    end

    return eval_expr(val, 0, {})
end

function is_conv_on_cooldown_generic(key)
    local last = conv_last_played[key]
    if not last then return false end
    local cd_min = PANDA.get_config("default_cooldown")
    return (game.get_game_time():diffSec(last) / 60) < cd_min
end

function pick_random_conv_id_generic(prefix, xml_fac, category, npc_se)
    local base
    if prefix == "task" or not prefix then
        base = "st_pda_ic_"
    else
        base = "st_pda_ic_" .. prefix .. "_"
    end

    local max_id = 0
    while true do
        local p = base .. xml_fac .. "_" .. tostring(max_id+1) .. "_open"
        if game.translate_string(p) == p then break end
        max_id = max_id + 1
    end
    if max_id == 0 then return nil end

    local candidates = {}  -- { id = cid, weight = number }
    local mode = PANDA.get_config("cooldown_mode")
    local penalty = PANDA.get_config("cooldown_penalty") / 100  -- as multiplier
    local hard_min = PANDA.get_config("cooldown_hard_min") * 60  -- convert to seconds

    for i = 1, max_id do
        local cid = i
        local skip = false

        -- Preconditions
        local precond_key = base .. xml_fac .. "_" .. tostring(cid) .. "_precond"
        if not check_preconditions_generic(precond_key, npc_se) then skip = true end

        -- Category filtering for task conversations
        if not skip and prefix == "task" then
            local has_cat = false
            local target_cat = CATEGORY_ALIAS[category] or category
            for oi = 1, 4 do
                local outcome_key = base .. xml_fac .. "_" .. cid .. "_outcome_" .. oi
                local os = game.translate_string(outcome_key)
                if os and os ~= outcome_key then
                    local cat = string.match(os, "give_task_cat:([^,]+)")
                    if cat and (CATEGORY_ALIAS[cat] or cat) == target_cat then
                        has_cat = true
                        break
                    end
                    if not cat and (target_cat == "random" or target_cat == "any") then
                        has_cat = true
                        break
                    end
                end
            end
            if not has_cat then skip = true end
        end

        if skip then goto continue end

        -- Cooldown handling
        local cooldown_key = (prefix or "task") .. "_" .. xml_fac .. "_" .. cid
        local last = conv_last_played[cooldown_key]
        local on_cooldown = false
        local seconds_since = 0
        if last then
            seconds_since = game.get_game_time():diffSec(last)
            on_cooldown = seconds_since < (PANDA.get_config("default_cooldown") * 60)
        end

        if mode == 1 then  -- strict: block if on cooldown
            if on_cooldown then skip = true end
        else  -- flexible
            if on_cooldown then
                -- If within hard minimum, still block
                if seconds_since < hard_min then
                    skip = true
                else
                    -- Apply weight penalty
                    local weight = penalty * 100  -- base weight 100
                    table.insert(candidates, {id = cid, weight = weight})
                end
            else
                -- Not on cooldown, full weight
                table.insert(candidates, {id = cid, weight = 100})
            end
        end

        if not skip and mode == 1 then
            table.insert(candidates, {id = cid, weight = 100})
        end

        ::continue::
    end

    if #candidates == 0 then return nil end

    -- Weighted random selection
    local total_weight = 0
    for _, cand in ipairs(candidates) do
        total_weight = total_weight + cand.weight
    end
    local r = math.random(total_weight)
    local accum = 0
    for _, cand in ipairs(candidates) do
        accum = accum + cand.weight
        if r <= accum then
            return cand.id
        end
    end
    return candidates[1].id  -- fallback
end


-- ============================================================
-- OUTCOME HANDLERS
-- ============================================================

local spawn_squad_at_smart_terrain

local function apply_outcome_internal(outcome_str, sender_npc_name, sender_faction, sender_npc_id, pre_found_task_id, sender_contact_id, conv_data, channel)
    if not outcome_str or outcome_str == "" or outcome_str == "none" then return false end
    local resolved_channel = channel or (conv_data and conv_data.channel) or "pda"
    if conv_data and conv_data.channel == nil then
        conv_data.channel = resolved_channel
    end

    -- Resolve dynamic placeholders in outcome command strings (including smart terrain refs)
    -- so commands like watch_location_trigger:%cordon_panda_st_key% work at runtime.
    local sender_se = sender_npc_id and alife_object(sender_npc_id) or nil
    outcome_str = sub_placeholders(outcome_str, sender_npc_name, sender_faction, sender_se, sender_contact_id)

    local task_given = false
    local spawn_mult = (PANDA.get_config("spawn_chance_mult") or 100) / 100

    local function format_money_value(amount)
        local n = math.floor(math.abs(tonumber(amount) or 0))
        local grouped = tostring(n)
        while true do
            local next_grouped, replaced = string.gsub(grouped, "^(%-?%d+)(%d%d%d)", "%1 %2")
            grouped = next_grouped
            if replaced == 0 then break end
        end
        return grouped
    end

    local function push_money_notification(amount_delta)
        if not sender_contact_id then
            return
        end

        local abs_amount = math.abs(tonumber(amount_delta) or 0)
        if abs_amount <= 0 then
            return
        end

        local is_gain = amount_delta > 0
        local prefix = is_gain and "+" or "-"
        local icon = is_gain and "ui\\green_ruble" or "ui\\red_ruble"
        local text = string.format("Account %s%s RU", prefix, format_money_value(abs_amount))

        pda_private_add_message(
            sender_contact_id,
            sender_npc_name,
            "System Notification",
            text,
            level.object_by_id(sender_npc_id) and level.object_by_id(sender_npc_id):character_icon() or FALLBACK_NPC_ICON,
            false,
            nil,
            nil,
            icon,
            { skip_personality = true }
        )
    end

    local function process_command(cmd_str)
        local chance_val, rest = string.match(cmd_str, "^chance:(%d+):(.+)$")
        if chance_val and rest then
            local adjusted = math.floor(tonumber(chance_val) * spawn_mult)
            adjusted = math.max(0, math.min(100, adjusted))
            if math.random(100) <= adjusted then
                process_command(rest)
            end
            return
        end

        local parts = str_explode(cmd_str, ":")
        local cmd = parts[1]

        if cmd == "start_anomaly_scan_task" then
            local adapter = get_anomaly_artifact_adapter()
            if adapter then
                local ok, err = adapter.start_scan_task(
                    parts[2],
                    parts[3],
                    parts[4] or "basic",
                    tonumber(parts[5]) or 0,
                    sender_npc_id
                )
                if not ok then
                    printf("PANDA_IC: start_anomaly_scan_task failed (%s)", tostring(err))
                end
            else
                printf("PANDA_IC: start_anomaly_scan_task ignored (adapter unavailable)")
            end

        elseif cmd == "start_artifact_retrieval_task" then
            local adapter = get_anomaly_artifact_adapter()
            if adapter then
                local ok, err = adapter.start_artifact_task(
                    parts[2],
                    parts[3],
                    parts[4],
                    parts[5] or "basic",
                    tonumber(parts[6]) or 0,
                    sender_npc_id
                )
                if not ok then
                    printf("PANDA_IC: start_artifact_retrieval_task failed (%s)", tostring(err))
                end
            else
                printf("PANDA_IC: start_artifact_retrieval_task ignored (adapter unavailable)")
            end

        elseif cmd == "spawn_artifact_on_npc" then
            -- Syntax: spawn_artifact_on_npc:<task_id>:<artifact_section>:<target_npc_id>
            local adapter = get_anomaly_artifact_adapter()
            if adapter then
                local artifact_sec = parts[3]
                local target_npc_id = tonumber(parts[4]) or sender_npc_id
                local ok, err = adapter.spawn_artifact_on_npc(parts[2], artifact_sec, target_npc_id)
                if not ok then
                    printf("PANDA_IC: spawn_artifact_on_npc failed (%s)", tostring(err))
                end
            end

        elseif cmd == "spawn_artifact_in_zone" then
            local adapter = get_anomaly_artifact_adapter()
            if adapter then
                local ok, err = adapter.spawn_artifact_in_zone(parts[2], parts[3], parts[4])
                if not ok then
                    printf("PANDA_IC: spawn_artifact_in_zone failed (%s)", tostring(err))
                end
            end

        elseif cmd == "require_detector_tier" then
            local adapter = get_anomaly_artifact_adapter()
            if adapter then
                printf("PANDA_IC: require_detector_tier outcome is legacy; prefer req_detector_tier preconditions for gating")
                local ok = adapter.require_detector_tier(parts[2] or "basic")
                if not ok then
                    printf("PANDA_IC: detector requirement failed for tier '%s'", tostring(parts[2]))
                end
            end

        elseif cmd == "turn_in_artifact" then
            local adapter = get_anomaly_artifact_adapter()
            if adapter then
                local ok, err = adapter.turn_in_artifact(parts[2], parts[3])
                if not ok then
                    printf("PANDA_IC: turn_in_artifact failed (%s)", tostring(err))
                end
            end

        elseif cmd == "set_anomaly_target" then
            local adapter = get_anomaly_artifact_adapter()
            if adapter then
                local ok, err = adapter.set_anomaly_target(parts[2], parts[3])
                if not ok then
                    printf("PANDA_IC: set_anomaly_target failed (%s)", tostring(err))
                end
            end

        elseif cmd == "fail_if_artifact_lost" then
            local adapter = get_anomaly_artifact_adapter()
            if adapter then
                local enabled = tostring(parts[3] or "true") ~= "false"
                local ok, err = adapter.set_fail_if_artifact_lost(parts[2], enabled)
                if not ok then
                    printf("PANDA_IC: fail_if_artifact_lost failed (%s)", tostring(err))
                end
            end

        elseif cmd == "give_task_cat" then
            if panda_give_task(pre_found_task_id, sender_npc_id) then
                task_given = true
                dynamic_news_helper.send_tip(
                    game.translate_string("st_pda_ic_outcome_task_given"),
                    sender_npc_name, 0, 10,
                    level.object_by_id(sender_npc_id):character_icon(),
                    "beep_2", "npc"
                )
            else
                dynamic_news_helper.send_tip(
                    "Error assigning task protocol.",
                    sender_npc_name, 0, 5,
                    level.object_by_id(sender_npc_id):character_icon(),
                    "beep_1", "npc"
                )
            end

        elseif cmd == "reward_money" then
            local reward = tonumber(parts[2]) or 0
            db.actor:give_money(reward)
            push_money_notification(reward)

        elseif cmd == "punish_money" then
            local amt = tonumber(parts[2]) or 0
            local removed = 0
            if db.actor:money() >= amt then
                db.actor:give_money(-amt)
                removed = amt
            else
                removed = db.actor:money()
                db.actor:give_money(-removed)
            end
            push_money_notification(-removed)

        -- Spawn commands now use: <cmd>:<faction_or_type>:<distance>[:<delay_seconds>]
        -- Examples:
        --   spawn_hostile:bandit:80           (spawn ~80m away, default delay)
        --   spawn_friendly:stalker:60:5       (spawn friendly squad ~60m away after 5s)
        --   spawn_npc:dolg:45                 (spawn faction-default squad ~45m away)
        --   spawn_mutant:boar:120:10          (spawn ~120m away, 10s delay)
        --   spawn_companion:stalker:35:3      (spawn ~35m away, 3s delay)
        elseif cmd == "spawn_hostile" then
            local distance = tonumber(parts[3])
            local delay = tonumber(parts[4]) or 90
            spawn_hunting_squad(parts[2] or "bandit", distance, false, delay, "hostile")

        elseif cmd == "spawn_friendly" then
            local distance = tonumber(parts[3])
            local delay = tonumber(parts[4]) or 30
            spawn_hunting_squad(parts[2] or "stalker", distance, false, delay, "friendly")

        elseif cmd == "spawn_npc" then
            local distance = tonumber(parts[3])
            local delay = tonumber(parts[4]) or 30
            spawn_hunting_squad(parts[2] or "stalker", distance, false, delay, "default")

        elseif cmd == "spawn_mutant" then
            local distance = tonumber(parts[3])
            local delay = tonumber(parts[4]) or 90
            spawn_hunting_squad(parts[2] or "random", distance, true, delay)

        elseif cmd == "spawn_mutant_at_smart" then
            local mutant_type = parts[2] or "random"
            local smart_ref = parts[3]
            local delay = tonumber(parts[4]) or 0
            if smart_ref and smart_ref ~= "" then
                spawn_squad_at_smart_terrain(mutant_type, smart_ref, true, delay, sender_contact_id)
            else
                printf("PANDA_IC: spawn_mutant_at_smart missing smart reference in '%s'", tostring(cmd_str))
            end

        elseif cmd == "spawn_hostile_at_smart" then
            local hostile_faction = normalize_faction(parts[2] or "bandit")
            local smart_ref = parts[3]
            local delay = tonumber(parts[4]) or 0
            if smart_ref and smart_ref ~= "" then
                spawn_squad_at_smart_terrain(hostile_faction, smart_ref, false, delay, sender_contact_id, "hostile")
            else
                printf("PANDA_IC: spawn_hostile_at_smart missing smart reference in '%s'", tostring(cmd_str))
            end

        elseif cmd == "spawn_companion" then
            local distance = tonumber(parts[3])
            local delay = tonumber(parts[4]) or 30
            spawn_native_companion(parts[2] or "stalker", distance, delay)

        elseif cmd == "reward_rep" then
            db.actor:change_character_reputation(tonumber(parts[2]) or 0)

        elseif cmd == "punish_rep" then
            db.actor:change_character_reputation(-(tonumber(parts[2]) or 0))

        elseif cmd == "reward_gw" then
            local amount = tonumber(parts[2]) or 0
            local faction = parts[3] or "stalker"
            change_faction_goodwill(faction, amount)

        elseif cmd == "punish_gw" then
            local amount = tonumber(parts[2]) or 0
            local faction = parts[3] or "stalker"
            change_faction_goodwill(faction, -amount)

        elseif cmd == "give_item" then
            local item_sec = parts[2]
            if item_sec and ini_sys:section_exist(item_sec) then
                alife_create_item(item_sec, db.actor)
                local msg = utils_data.parse_string_keys(
                    game.translate_string("st_pda_ic_outcome_item_gain"),
                    {["what"] = ui_item.get_sec_name(item_sec)}
                )
                dynamic_news_helper.send_tip(msg, "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc")
            end

        elseif cmd == "courier_item" then
            spawn_native_courier(parts[2] or "medkit_army")

        elseif cmd == "reward_stash" then
            queue_stash_attachment_reward(sender_npc_name, sender_npc_id, sender_contact_id)

        elseif cmd == "watch_location" then
            local location_ref = parts[2]
            if location_ref and location_ref ~= "" then
                local radius = tonumber(parts[3]) or (PANDA.get_config("location_watch_radius") or 85)
                register_location_reference(location_ref, sender_npc_name, sender_npc_id, radius, sender_contact_id)
            else
                printf("PANDA_IC: watch_location missing location reference in '%s'", tostring(cmd_str))
            end

        elseif cmd == "watch_location_trigger" then
            local location_ref = parts[2]
            local delayed_cmd = nil
            local radius = PANDA.get_config("location_watch_radius") or 85

            if #parts >= 4 then
                local maybe_radius = tonumber(parts[#parts])
                local cmd_end = #parts
                if maybe_radius then
                    radius = maybe_radius
                    cmd_end = #parts - 1
                end

                if cmd_end >= 3 then
                    delayed_cmd = table.concat(parts, ":", 3, cmd_end)
                end
            end

            if location_ref and location_ref ~= "" and delayed_cmd and delayed_cmd ~= "" then
                local ref = register_location_reference(location_ref, sender_npc_name, sender_npc_id, radius, sender_contact_id)
                -- Support multiple trigger commands separated by "+"
                -- Example: teleport_npc_to_smart:loc+spawn_mutant_at_smart:snork:loc
                for sub_cmd in string.gmatch(delayed_cmd, "([^+]+)") do
                    sub_cmd = sub_cmd:match("^%s*(.-)%s*$")
                    if sub_cmd ~= "" then
                        table.insert(ref.trigger_cmds, sub_cmd)
                    end
                end
            else
                printf("PANDA_IC: watch_location_trigger malformed in '%s'", tostring(cmd_str))
            end

        -- ========== TELEPORT NPC (to smart terrain) ==========
        elseif cmd == "teleport_npc_to_smart" then
            local smart_ref = parts[2]
            local delay = tonumber(parts[3]) or 0
            if smart_ref and smart_ref ~= "" and sender_npc_id then
                teleport_npc_to_smart_terrain(sender_npc_id, smart_ref, sender_npc_name, delay)
            else
                printf("PANDA_IC: teleport_npc_to_smart missing smart reference or npc_id in '%s'", tostring(cmd_str))
            end

        -- ========== TELEPORT NPC (near player) ==========
        elseif cmd == "teleport_npc_to_player" then
            local delay = tonumber(parts[2]) or 0
            if sender_npc_id then
                teleport_npc_near_player(sender_npc_id, sender_npc_name, delay)
            else
                printf("PANDA_IC: teleport_npc_to_player missing npc_id in '%s'", tostring(cmd_str))
            end

        -- ========== RECRUIT COMPANION (convert conversation NPC) ==========
        elseif cmd == "recruit_companion" then
            local cannot_dismiss = parts[2] == "no_dismiss"
            if sender_npc_id then
                recruit_npc_as_companion(sender_npc_id, sender_npc_name, cannot_dismiss)
            else
                printf("PANDA_IC: recruit_companion missing npc_id in '%s'", tostring(cmd_str))
            end

        -- ========== PAUSE JOB (wait for spawned hostiles to die) ==========
        -- Syntax: pause_job:<timeout_seconds>:<success_turn>:<fail_turn>
        -- Must be in the same outcome string as spawn commands.
        -- Pauses the conversation until all squads spawned in this outcome batch are dead.
        elseif cmd == "pause_job" then
            local timeout = tonumber(parts[2]) or 600
            local success_turn = tonumber(parts[3])
            local fail_turn = tonumber(parts[4])
            if not success_turn then
                printf("PANDA_IC: pause_job missing success_turn in '%s'", tostring(cmd_str))
            else
                -- Defer actual job creation to after all commands in this batch finish.
                -- Store params so the post-batch handler can create the job.
                _pending_job_params = {
                    timeout = timeout,
                    success_turn = success_turn,
                    fail_turn = fail_turn,
                    sender_npc_id = sender_npc_id,
                    sender_npc_name = sender_npc_name,
                    sender_contact_id = sender_contact_id,
                    sender_faction = sender_faction,
                    conv_data = conv_data,
                }
            end

        -- ========== TAKE ITEM ==========
        elseif cmd == "take_item" then
            local item_sec = parts[2]
            if item_sec then
                local found_obj = nil
                act:iterate_inventory(function(owner, item)
                    if not found_obj and item:section() == item_sec then found_obj = item end
                end, act)
                if found_obj then
                    alife_release(alife():object(found_obj:id()))
                    local msg = utils_data.parse_string_keys(
                        game.translate_string("st_pda_ic_outcome_item_taken"),
                        {["what"] = ui_item.get_sec_name(item_sec)}
                    )
                    dynamic_news_helper.send_tip(msg, "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc")
                end
            end

        -- ========== GIVE ITEM COUNT ==========
        elseif cmd == "give_item_count" then
            local item_sec = parts[2]
            local count = tonumber(parts[3]) or 1
            if item_sec and ini_sys:section_exist(item_sec) then
                for i = 1, count do
                    alife_create_item(item_sec, db.actor)
                end
                local msg = string.format(
                    game.translate_string("st_pda_ic_outcome_items_given"),
                    count, ui_item.get_sec_name(item_sec)
                )
                dynamic_news_helper.send_tip(msg, "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc")
            end

        -- ========== REWARD STASH WITH SPECIFIC ITEMS ==========
        elseif cmd == "reward_stash_items" then
            local items_str = parts[2]
            if items_str and items_str ~= "" then
                local bonus_items = {}
                for item_sec in string.gmatch(items_str, "([^+]+)") do
                    item_sec = item_sec:match("^%s*(.-)%s*$")
                    if item_sec ~= "" and ini_sys:section_exist(item_sec) then
                        table.insert(bonus_items, item_sec)
                    end
                end
                if #bonus_items > 0 then
                    queue_stash_attachment_reward_custom(sender_npc_name, sender_npc_id, sender_contact_id, bonus_items)
                else
                    queue_stash_attachment_reward(sender_npc_name, sender_npc_id, sender_contact_id)
                end
            else
                queue_stash_attachment_reward(sender_npc_name, sender_npc_id, sender_contact_id)
            end

        -- ========== KNOWLEDGE / INFO PORTIONS ==========
        elseif cmd == "give_info" then
            local info_id = parts[2]
            if info_id and info_id ~= "" then
                give_info(info_id)
                dynamic_news_helper.send_tip(
                    game.translate_string("st_pda_ic_outcome_info_gained"),
                    "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
                )
            end
        elseif cmd == "disable_info" then
            local info_id = parts[2]
            if info_id and info_id ~= "" then
                disable_info(info_id)
                dynamic_news_helper.send_tip(
                    game.translate_string("st_pda_ic_outcome_info_removed"),
                    "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
                )
            end

        -- ========== PLAYER EFFECTS ==========
        elseif cmd == "heal_player" then
            local amount = (tonumber(parts[2]) or 0) / 100
            amount = math.max(0, math.min(1, amount))
            db.actor.health = amount
        elseif cmd == "damage_player" then
            local amount = (tonumber(parts[2]) or 0) / 100
            amount = math.max(0, math.min(0.99, amount))
            db.actor.health = -amount
        elseif cmd == "give_radiation" then
            local amount = (tonumber(parts[2]) or 0) / 100
            amount = math.max(0, math.min(1, amount))
            db.actor:change_radiation(amount)
        elseif cmd == "cure_radiation" then
            local cur_rad = db.actor:get_radiation()
            if cur_rad > 0 then
                db.actor:change_radiation(-cur_rad)
            end

        -- ========== NPC RELATION CHANGES ==========
        elseif cmd == "dismiss_companion" then
            if sender_npc_id then
                local npc_obj = level.object_by_id(sender_npc_id)
                if npc_obj and axr_companions then
                    axr_companions.dismiss_companion(npc_obj)
                    dynamic_news_helper.send_tip(
                        game.translate_string("st_pda_ic_outcome_npc_dismissed"),
                        sender_npc_name or "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
                    )
                end
            end
        elseif cmd == "set_npc_hostile" then
            if sender_npc_id then
                local npc_obj = level.object_by_id(sender_npc_id)
                if npc_obj then
                    npc_obj:set_relation(game_object.enemy, db.actor)
                    npc_obj:force_set_goodwill(-5000, db.actor)
                    dynamic_news_helper.send_tip(
                        game.translate_string("st_pda_ic_outcome_npc_hostile"),
                        sender_npc_name or "System", 0, 10, FALLBACK_NPC_ICON, "danger", "npc"
                    )
                end
            end
        elseif cmd == "set_npc_friendly" then
            if sender_npc_id then
                local npc_obj = level.object_by_id(sender_npc_id)
                if npc_obj then
                    npc_obj:set_relation(game_object.friend, db.actor)
                    npc_obj:force_set_goodwill(5000, db.actor)
                    dynamic_news_helper.send_tip(
                        game.translate_string("st_pda_ic_outcome_npc_friendly"),
                        sender_npc_name or "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
                    )
                end
            end
        elseif cmd == "kill_npc" then
            if sender_npc_id then
                local npc_obj = level.object_by_id(sender_npc_id)
                if npc_obj and npc_obj.alive and npc_obj:alive() then
                    npc_obj:kill(npc_obj)
                else
                    local se_obj = alife_object(sender_npc_id)
                    if se_obj then
                        alife_release(se_obj)
                    end
                end
                dynamic_news_helper.send_tip(
                    game.translate_string("st_pda_ic_outcome_npc_killed"),
                    sender_npc_name or "System", 0, 10, FALLBACK_NPC_ICON, "danger", "npc"
                )
            end

        elseif cmd == "change_npc_faction" then
            local new_faction = normalize_faction(parts[2] or "stalker")
            if sender_npc_id then
                local se_npc = alife_object(sender_npc_id)
                if se_npc then
                    if SIMBOARD and SIMBOARD.change_faction then
                        SIMBOARD:change_faction(se_npc, new_faction)
                    elseif se_npc.community then
                        se_npc:community(new_faction)
                    end
                    dynamic_news_helper.send_tip(
                        game.translate_string("st_pda_ic_outcome_npc_faction_change"),
                        sender_npc_name or "System", 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
                    )
                end
            end

        -- ========== SPAWN AT SMART (friendly / neutral) ==========
        elseif cmd == "spawn_friendly_at_smart" then
            local friendly_faction = normalize_faction(parts[2] or "stalker")
            local smart_ref = parts[3]
            local delay = tonumber(parts[4]) or 0
            if smart_ref and smart_ref ~= "" then
                spawn_squad_at_smart_terrain(friendly_faction, smart_ref, false, delay, sender_contact_id, "friendly")
            else
                printf("PANDA_IC: spawn_friendly_at_smart missing smart reference in '%s'", tostring(cmd_str))
            end
        elseif cmd == "spawn_squad_at_smart" then
            local faction = normalize_faction(parts[2] or "stalker")
            local smart_ref = parts[3]
            local delay = tonumber(parts[4]) or 0
            if smart_ref and smart_ref ~= "" then
                spawn_squad_at_smart_terrain(faction, smart_ref, false, delay, sender_contact_id, "default")
            else
                printf("PANDA_IC: spawn_squad_at_smart missing smart reference in '%s'", tostring(cmd_str))
            end

        elseif cmd == "spawn_companion_at_smart" then
            local faction = normalize_faction(parts[2] or "stalker")
            local smart_ref = parts[3]
            local delay = tonumber(parts[4]) or 0
            if smart_ref and smart_ref ~= "" then
                spawn_squad_at_smart_terrain(faction, smart_ref, false, delay, sender_contact_id, "companion")
            else
                printf("PANDA_IC: spawn_companion_at_smart missing smart reference in '%s'", tostring(cmd_str))
            end

        -- ─── NEW OUTCOME HANDLERS ────────────────────────────────────────────

        -- Player Effects: hunger
        elseif cmd == "give_hunger" then
            local amount = (tonumber(parts[2]) or 10) / 100
            if act.cast_Actor and act:cast_Actor() and act:cast_Actor().conditions then
                local cond = act:cast_Actor():conditions()
                if cond and cond.ChangeSatiety then
                    cond:ChangeSatiety(-amount)
                end
            end
        elseif cmd == "cure_hunger" then
            local amount = (tonumber(parts[2]) or 50) / 100
            if act.cast_Actor and act:cast_Actor() and act:cast_Actor().conditions then
                local cond = act:cast_Actor():conditions()
                if cond and cond.ChangeSatiety then
                    cond:ChangeSatiety(amount)
                end
            end

        -- Player Effects: speed
        elseif cmd == "boost_speed" then
            local mult = tonumber(parts[2]) or 1.5
            local dur = tonumber(parts[3]) or 60
            act:set_actor_run_coef(mult)
            act:set_actor_sprint_koef(mult)
            CreateTimeEvent(0, "panda_speed_reset_" .. tostring(time_global()), dur, function()
                if db.actor then
                    db.actor:set_actor_run_coef(0)
                    db.actor:set_actor_sprint_koef(0)
                end
                return true
            end)
        elseif cmd == "slow_speed" then
            local mult = tonumber(parts[2]) or 0.5
            local dur = tonumber(parts[3]) or 60
            act:set_actor_run_coef(mult)
            act:set_actor_sprint_koef(mult)
            CreateTimeEvent(0, "panda_speed_reset_" .. tostring(time_global()), dur, function()
                if db.actor then
                    db.actor:set_actor_run_coef(0)
                    db.actor:set_actor_sprint_koef(0)
                end
                return true
            end)

        -- Player Effects: rank
        elseif cmd == "change_rank" then
            local amount = tonumber(parts[2]) or 0
            if game_statistics and game_statistics.increment_rank then
                game_statistics.increment_rank(amount)
            else
                local cur = act:character_rank()
                act:set_character_rank(cur + amount)
            end

        -- Player Effects: teleport player
        elseif cmd == "teleport_player_to_smart" then
            local smart_ref = parts[2]
            local delay = tonumber(parts[3]) or 0
            if smart_ref and smart_ref ~= "" then
                local smart_pos = resolve_smart_position_from_reference(smart_ref)
                if smart_pos then
                    if delay > 0 then
                        CreateTimeEvent(0, "panda_tp_player_" .. tostring(time_global()), delay, function()
                            if db.actor then
                                db.actor:set_actor_position(smart_pos)
                            end
                            return true
                        end)
                    else
                        act:set_actor_position(smart_pos)
                    end
                end
            end

        -- NPC: change rank
        elseif cmd == "change_npc_rank" then
            local amount = tonumber(parts[2]) or 0
            if sender_npc_id then
                local npc_obj = level.object_by_id(sender_npc_id)
                if npc_obj then
                    local cur = npc_obj:character_rank()
                    npc_obj:set_character_rank(cur + amount)
                end
            end

        -- NPC: give item
        elseif cmd == "equip_npc_item" then
            local item_sec = parts[2]
            if item_sec and sender_npc_id then
                local se_npc = alife_object(sender_npc_id)
                if se_npc and ini_sys:section_exist(item_sec) then
                    alife_create_item(item_sec, se_npc)
                end
            end

        -- NPC: companion behavior state
        elseif cmd == "set_companion_state" then
            local state = parts[2] or "follow"
            if sender_npc_id and axr_companions then
                local npc_obj = level.object_by_id(sender_npc_id)
                if npc_obj then
                    if state == "follow" and axr_companions.set_companion_to_follow_state then
                        axr_companions.set_companion_to_follow_state(npc_obj)
                    elseif state == "wait" and axr_companions.set_companion_to_wait_state then
                        axr_companions.set_companion_to_wait_state(npc_obj)
                    elseif state == "patrol" and axr_companions.set_companion_to_patrol_state then
                        axr_companions.set_companion_to_patrol_state(npc_obj)
                    elseif state == "attack" and axr_companions.set_companion_to_attack_state then
                        axr_companions.set_companion_to_attack_state(npc_obj)
                    elseif state == "stealth" and axr_companions.set_companion_to_stealth_substate then
                        axr_companions.set_companion_to_stealth_substate(npc_obj)
                    elseif state == "ignore_combat" and axr_companions.set_companion_to_ignore_combat_state then
                        axr_companions.set_companion_to_ignore_combat_state(npc_obj)
                    end
                end
            end

        -- NPC: set neutral
        elseif cmd == "set_npc_neutral" then
            if sender_npc_id then
                local npc_obj = level.object_by_id(sender_npc_id)
                if npc_obj then
                    npc_obj:set_relation(game_object.neutral, db.actor)
                    npc_obj:force_set_goodwill(0, db.actor)
                end
            end

        -- NPC: invulnerability
        elseif cmd == "make_npc_invulnerable" then
            local dur = tonumber(parts[2]) or 300
            if sender_npc_id then
                if not _panda_invulnerable_npcs then _panda_invulnerable_npcs = {} end
                _panda_invulnerable_npcs[sender_npc_id] = true
                CreateTimeEvent(0, "panda_invuln_" .. tostring(sender_npc_id), dur, function()
                    if _panda_invulnerable_npcs then
                        _panda_invulnerable_npcs[sender_npc_id] = nil
                    end
                    return true
                end)
            end

        -- NPC: spawn backup near NPC
        elseif cmd == "spawn_squad_for_npc" then
            local faction = normalize_faction(parts[2] or "stalker")
            local count = tonumber(parts[3]) or 1
            if sender_npc_id then
                local npc_obj = level.object_by_id(sender_npc_id)
                if npc_obj then
                    for i = 1, math.min(count, 5) do
                        spawn_hunting_squad(faction, 30, false, i * 5, "default")
                    end
                end
            end

        -- Faction relations
        elseif cmd == "change_faction_relations" then
            local f1 = normalize_faction(parts[2] or "stalker")
            local f2 = normalize_faction(parts[3] or "bandit")
            local amount = tonumber(parts[4]) or 0
            if game_relations and game_relations.change_faction_relations then
                game_relations.change_faction_relations(f1, f2, amount, false)
            end

        -- Change player faction
        elseif cmd == "change_player_faction" then
            local new_fac = normalize_faction(parts[2] or "stalker")
            if act.set_character_community then
                act:set_character_community(new_fac, 0, 0)
            end

        -- Ceasefire
        elseif cmd == "ceasefire" then
            local radius = tonumber(parts[2]) or 100
            local actor_pos = act:position()
            for id = 1, 65535 do
                local obj = level.object_by_id(id)
                if obj and obj:alive() and IsStalker(obj) and obj:id() ~= act:id() then
                    local dist = obj:position():distance_to(actor_pos)
                    if dist <= radius then
                        obj:set_relation(game_object.neutral, db.actor)
                        obj:force_set_goodwill(0, db.actor)
                    end
                end
            end

        -- World: weather
        elseif cmd == "set_weather" then
            local weather = parts[2] or "w_clear1"
            if level.set_weather then
                level.set_weather(weather, true)
            end

        -- World: game news
        elseif cmd == "give_game_news" then
            local title = parts[2] or "News"
            local message = parts[3] or ""
            local dur = tonumber(parts[4]) or 5
            act:give_game_news(title, message, "ui_inGame2_PDA", 0, dur * 1000)

        -- Knowledge: tasks
        elseif cmd == "give_task" then
            local task_id = parts[2]
            if task_id and task_manager and task_manager.get_task_manager then
                local tm = task_manager.get_task_manager()
                if tm and tm.give_task then
                    tm:give_task(task_id)
                end
            end
        elseif cmd == "complete_task" then
            local task_id = parts[2]
            if task_id and task_manager and task_manager.task_complete then
                task_manager.task_complete(task_id)
            end
        elseif cmd == "fail_task" then
            local task_id = parts[2]
            if task_id and task_manager and task_manager.task_fail then
                task_manager.task_fail(task_id)
            end

        -- ========== CUSTOM TASKS ==========
        -- Each panda_task_* command sets up its scenario and creates a pending job
        -- with a job_type field for type-specific completion checks.

        -- Delivery: courier spawns with item, player delivers to destination
        -- Syntax: panda_task_delivery:<item_section>:<destination_smart>:<timeout>:<success_turn>:<fail_turn>
        elseif cmd == "panda_task_delivery" then
            local item_sec = parts[2]
            local dest_smart = parts[3]
            local timeout = tonumber(parts[4]) or 600
            local s_turn = tonumber(parts[5])
            local f_turn = tonumber(parts[6])
            if not item_sec or not dest_smart or not s_turn then
                printf("PANDA_IC: panda_task_delivery missing params in '%s'", tostring(cmd_str))
            else
                -- Spawn courier with the item
                spawn_native_courier(item_sec)
                -- Mark destination on PDA map
                local radius = PANDA.get_config("location_watch_radius") or 50
                register_location_reference(dest_smart, sender_npc_name, sender_npc_id, radius, sender_contact_id)
                -- Notify player
                local msg = game.translate_string("st_pda_ic_task_delivery_start")
                pda_private_add_message(sender_contact_id, sender_npc_name, sender_npc_name, msg,
                    conv_data and conv_data.npc_icon or FALLBACK_NPC_ICON, false)
                -- Create job
                create_pending_job(sender_contact_id, sender_npc_id, sender_npc_name, sender_faction,
                    {}, timeout, s_turn, f_turn, conv_data, {
                        job_type = "delivery",
                        task_item = item_sec,
                        task_destination = dest_smart,
                        task_radius = radius,
                        squads_registered = true,
                    })
            end

        -- Fetch: player must find/collect items (periodic inventory check)
        -- Syntax: panda_task_fetch:<item_section>:<count>:<timeout>:<success_turn>:<fail_turn>
        elseif cmd == "panda_task_fetch" then
            local item_sec = parts[2]
            local count = tonumber(parts[3]) or 1
            local timeout = tonumber(parts[4]) or 600
            local s_turn = tonumber(parts[5])
            local f_turn = tonumber(parts[6])
            if not item_sec or not s_turn then
                printf("PANDA_IC: panda_task_fetch missing params in '%s'", tostring(cmd_str))
            else
                -- Notify player
                local msg = game.translate_string("st_pda_ic_task_fetch_start")
                pda_private_add_message(sender_contact_id, sender_npc_name, sender_npc_name, msg,
                    conv_data and conv_data.npc_icon or FALLBACK_NPC_ICON, false)
                -- Create job (no squads, inventory-based check)
                create_pending_job(sender_contact_id, sender_npc_id, sender_npc_name, sender_faction,
                    {}, timeout, s_turn, f_turn, conv_data, {
                        job_type = "fetch",
                        task_item = item_sec,
                        task_item_count = count,
                        squads_registered = true,
                    })
            end

        -- Bounty: spawn target NPC at location, track kill
        -- Syntax: panda_task_bounty:<faction>:<rank>:<smart_terrain>:<timeout>:<success_turn>:<fail_turn>
        elseif cmd == "panda_task_bounty" then
            local target_fac = parts[2]
            local target_rank = parts[3]
            local smart_ref = parts[4]
            local timeout = tonumber(parts[5]) or 900
            local s_turn = tonumber(parts[6])
            local f_turn = tonumber(parts[7])
            if not target_fac or not smart_ref or not s_turn then
                printf("PANDA_IC: panda_task_bounty missing params in '%s'", tostring(cmd_str))
            else
                -- Spawn target at smart terrain
                local target_id = nil
                local sec = find_squad_section(target_fac)
                if sec then
                    local smart = resolve_smart_from_reference(smart_ref)
                    if smart then
                        local spos = get_position_from_object(smart)
                        local slvid = smart.m_level_vertex_id
                        local sgvid = smart.m_game_vertex_id
                        if spos then
                            local sp, sl, sg = find_spawn_point_near_smart(10, 20, spos, slvid, sgvid)
                            local sq = create_squad_safely(sec, sp or spos, sl or slvid, sg or sgvid)
                            if sq then
                                -- Set hostile
                                sq.scripted_target = smart:name()
                                for k in sq:squad_members() do
                                    if not target_id then target_id = k.id end
                                end
                            end
                        end
                    end
                end
                -- Mark location on PDA map
                local radius = PANDA.get_config("location_watch_radius") or 85
                register_location_reference(smart_ref, sender_npc_name, sender_npc_id, radius, sender_contact_id)
                -- Notify player
                local msg = game.translate_string("st_pda_ic_task_bounty_start")
                pda_private_add_message(sender_contact_id, sender_npc_name, sender_npc_name, msg,
                    conv_data and conv_data.npc_icon or FALLBACK_NPC_ICON, false)
                -- Create job
                create_pending_job(sender_contact_id, sender_npc_id, sender_npc_name, sender_faction,
                    {}, timeout, s_turn, f_turn, conv_data, {
                        job_type = "bounty",
                        task_target_id = target_id,
                        squads_registered = true,
                    })
            end

        -- Dead Drop: deposit item at marked stash location
        -- Syntax: panda_task_dead_drop:<item_section>:<destination_smart>:<timeout>:<success_turn>:<fail_turn>
        elseif cmd == "panda_task_dead_drop" then
            local item_sec = parts[2]
            local dest_smart = parts[3]
            local timeout = tonumber(parts[4]) or 600
            local s_turn = tonumber(parts[5])
            local f_turn = tonumber(parts[6])
            if not item_sec or not dest_smart or not s_turn then
                printf("PANDA_IC: panda_task_dead_drop missing params in '%s'", tostring(cmd_str))
            else
                -- Mark destination on PDA map
                local radius = PANDA.get_config("location_watch_radius") or 50
                register_location_reference(dest_smart, sender_npc_name, sender_npc_id, radius, sender_contact_id)
                -- Notify player
                local msg = game.translate_string("st_pda_ic_task_dead_drop_start")
                pda_private_add_message(sender_contact_id, sender_npc_name, sender_npc_name, msg,
                    conv_data and conv_data.npc_icon or FALLBACK_NPC_ICON, false)
                -- Create job
                create_pending_job(sender_contact_id, sender_npc_id, sender_npc_name, sender_faction,
                    {}, timeout, s_turn, f_turn, conv_data, {
                        job_type = "dead_drop",
                        task_item = item_sec,
                        task_destination = dest_smart,
                        task_radius = radius,
                        squads_registered = true,
                    })
            end

        -- Escort: NPC becomes companion, escort to destination
        -- Syntax: panda_task_escort:<destination_smart>:<timeout>:<success_turn>:<fail_turn>
        elseif cmd == "panda_task_escort" then
            local dest_smart = parts[2]
            local timeout = tonumber(parts[3]) or 900
            local s_turn = tonumber(parts[4])
            local f_turn = tonumber(parts[5])
            if not dest_smart or not s_turn then
                printf("PANDA_IC: panda_task_escort missing params in '%s'", tostring(cmd_str))
            else
                -- Recruit conversation NPC as companion
                if sender_npc_id then
                    recruit_npc_as_companion(sender_npc_id, sender_npc_name, true)
                end
                -- Mark destination on PDA map
                local radius = PANDA.get_config("location_watch_radius") or 50
                register_location_reference(dest_smart, sender_npc_name, sender_npc_id, radius, sender_contact_id)
                -- Notify player
                local msg = game.translate_string("st_pda_ic_task_escort_start")
                pda_private_add_message(sender_contact_id, sender_npc_name, sender_npc_name, msg,
                    conv_data and conv_data.npc_icon or FALLBACK_NPC_ICON, false)
                -- Create job
                create_pending_job(sender_contact_id, sender_npc_id, sender_npc_name, sender_faction,
                    {}, timeout, s_turn, f_turn, conv_data, {
                        job_type = "escort",
                        task_target_id = sender_npc_id,
                        task_destination = dest_smart,
                        task_radius = radius,
                        squads_registered = true,
                    })
            end

        -- Elimination: spawn enemies at location, player clears them
        -- Syntax: panda_task_eliminate:<target_type>:<smart_terrain>:<radius>:<timeout>:<success_turn>:<fail_turn>
        elseif cmd == "panda_task_eliminate" then
            local target_type = parts[2]
            local smart_ref = parts[3]
            local spawn_radius = tonumber(parts[4]) or 100
            local timeout = tonumber(parts[5]) or 900
            local s_turn = tonumber(parts[6])
            local f_turn = tonumber(parts[7])
            if not target_type or not smart_ref or not s_turn then
                printf("PANDA_IC: panda_task_eliminate missing params in '%s'", tostring(cmd_str))
            else
                -- Determine if target is an explicit mutant squad or an NPC squad/faction alias
                local is_mutant = is_mutant_squad_key(target_type)
                -- Spawn enemies at smart terrain (uses collector for squad tracking)
                spawn_squad_at_smart_terrain(target_type, smart_ref, is_mutant, 0, sender_contact_id, "hostile")
                -- Mark location on PDA map
                register_location_reference(smart_ref, sender_npc_name, sender_npc_id, spawn_radius, sender_contact_id)
                -- Notify player
                local msg = game.translate_string("st_pda_ic_task_eliminate_start")
                pda_private_add_message(sender_contact_id, sender_npc_name, sender_npc_name, msg,
                    conv_data and conv_data.npc_icon or FALLBACK_NPC_ICON, false)
                -- Note: For eliminate, we use the _job_spawn_collector pattern.
                -- Store params so post-batch handler creates the job with collected squads.
                _pending_job_params = {
                    timeout = timeout,
                    success_turn = s_turn,
                    fail_turn = f_turn,
                    sender_npc_id = sender_npc_id,
                    sender_npc_name = sender_npc_name,
                    sender_contact_id = sender_contact_id,
                    sender_faction = sender_faction,
                    conv_data = conv_data,
                    extra = { job_type = "eliminate" },
                }
            end

        -- Artifact retrieval: player must find and return a specific artifact
        -- Syntax (legacy): panda_task_artifact:<artifact_section>:<zone_name|any>:<detector_tier>:<timeout>:<success_turn>:<fail_turn>
        -- Syntax (v2):     panda_task_artifact:<artifact_section>:<zone_mode>:<zone_name>:<detector_tier>:<timeout>:<success_turn>:<fail_turn>
        -- zone_name supports deterministic level tokens like level:gar / level:esc.
        elseif cmd == "panda_task_artifact" then
            local artifact_sec = parts[2]
            local zone_mode = "legacy"
            local zone_name = parts[3]
            local detector_tier_meta
            local timeout
            local s_turn
            local f_turn

            if parts[3] == "specific" or parts[3] == "any" or parts[3] == "random_level" then
                zone_mode = parts[3]
                zone_name = parts[4]
                local detector_index = 5
                local timeout_index = 6
                local success_index = 7
                local fail_index = 8

                if zone_name == "level" and parts[5] then
                    zone_name = "level:" .. tostring(parts[5])
                    detector_index = 6
                    timeout_index = 7
                    success_index = 8
                    fail_index = 9
                end

                detector_tier_meta = parts[detector_index] or "basic"
                timeout = tonumber(parts[timeout_index]) or 900
                s_turn = tonumber(parts[success_index])
                f_turn = tonumber(parts[fail_index])
            else
                detector_tier_meta = parts[4] or "basic"
                timeout = tonumber(parts[5]) or 900
                s_turn = tonumber(parts[6])
                f_turn = tonumber(parts[7])
            end

            if not s_turn then
                printf("PANDA_IC: panda_task_artifact missing params in '%s'", tostring(cmd_str))
            else
                local adapter = get_anomaly_artifact_adapter()
                local task_runtime_id = make_artifact_runtime_task_id(conv_data)
                local resolved_zone = nil

                if zone_name and zone_name ~= "" and zone_name ~= "any" then
                    local zone_err = nil
                    resolved_zone, zone_err = resolve_artifact_zone_target(zone_name)
                    if not resolved_zone then
                        printf("PANDA_IC: panda_task_artifact zone resolve failed (%s), using natural-find mode", tostring(zone_err))
                    end
                end

                local spawned_artifact_section = artifact_sec
                if adapter and resolved_zone then
                    local spawn_ok, spawn_err, spawned_section = adapter.spawn_artifact_in_zone(
                        task_runtime_id, artifact_sec, resolved_zone
                    )
                    if not spawn_ok then
                        printf("PANDA_IC: panda_task_artifact zone spawn failed (%s), player must find naturally", tostring(spawn_err))
                        resolved_zone = nil
                    elseif spawned_section and spawned_section ~= "" then
                        spawned_artifact_section = spawned_section
                    end
                elseif zone_name and zone_name ~= "" and zone_name ~= "any" and not resolved_zone then
                    printf("PANDA_IC: panda_task_artifact no resolved zone, player must find naturally")
                end

                if not spawned_artifact_section or spawned_artifact_section == "" then
                    printf("PANDA_IC: panda_task_artifact requires explicit artifact_section when zone spawn is unavailable")
                    return
                end

                -- Create adapter record for auxiliary tracking
                if adapter then
                    adapter.start_artifact_task(
                        task_runtime_id, artifact_sec,
                        resolved_zone,
                        detector_tier_meta, timeout, sender_npc_id
                    )
                end
                if resolved_zone then
                    register_anomaly_zone_reference(resolved_zone, sender_npc_name, sender_npc_id, sender_contact_id)
                end
                -- Notify player
                local msg = game.translate_string("st_pda_ic_task_artifact_start")
                pda_private_add_message(sender_contact_id, sender_npc_name, sender_npc_name, msg,
                    conv_data and conv_data.npc_icon or FALLBACK_NPC_ICON, false)
                -- Create pending job (reuses existing job system for monitoring + conversation resume)
                create_pending_job(sender_contact_id, sender_npc_id, sender_npc_name, sender_faction,
                    {}, timeout, s_turn, f_turn, conv_data, {
                        job_type = "artifact",
                        task_item = spawned_artifact_section,
                        task_runtime_id = task_runtime_id,
                        task_zone = resolved_zone or zone_name,
                        task_zone_mode = zone_mode,
                        -- Metadata only (for PDA/job display). Do NOT use for gating:
                        -- gate with req_detector_tier preconditions instead.
                        task_detector_tier = detector_tier_meta,
                        squads_registered = true,
                    })
            end

        else
            printf("Unknown outcome command: %s", cmd_str)
        end
    end

    -- Enable spawn collector so any squads created during this batch are tracked
    local prev_collector = _job_spawn_collector
    _job_spawn_collector = {}
    _pending_job_params = nil

    for entry in string.gmatch(outcome_str, "([^,]+)") do
        entry = entry:match("^%s*(.-)%s*$")
        if entry ~= "" then
            process_command(entry)
        end
    end

    -- If pause_job was in this batch, create the job with collected squad IDs
    local collected_squads = _job_spawn_collector
    _job_spawn_collector = prev_collector

    if _pending_job_params and collected_squads then
        local jp = _pending_job_params
        _pending_job_params = nil
        local cid = jp.sender_contact_id
        if cid then
            create_pending_job(cid, jp.sender_npc_id, jp.sender_npc_name, jp.sender_faction,
                collected_squads, jp.timeout, jp.success_turn, jp.fail_turn, jp.conv_data, jp.extra)
        else
            printf("PANDA_IC: pause_job has no contact_id, cannot create job")
        end
    else
        _pending_job_params = nil
    end

    return task_given
end

function apply_outcome(outcome_str, sender_npc_name, sender_faction, sender_npc_id, pre_found_task_id, sender_contact_id, conv_data, channel)
    return apply_outcome_internal(
        outcome_str,
        sender_npc_name,
        sender_faction,
        sender_npc_id,
        pre_found_task_id,
        sender_contact_id,
        conv_data,
        channel or "pda"
    )
end

function find_squad_section(faction)
    if faction and faction ~= "" and ini_sys:section_exist(faction) then
        return faction
    end
    local tiers = { "_advanced", "_novice", "_veteran", "_alpha" }
    for _, t in ipairs(tiers) do
        local s = faction .. "_sim_squad" .. t
        if ini_sys:section_exist(s) then return s end
    end
    return "merc_sim_squad_advanced" 
end

local MUTANT_SQUADS = {
    "simulation_lurker", "simulation_bloodsucker_1_2", "simulation_psysucker",
    "simulation_snork_2_3", "simulation_fracture", "simulation_mix_dogs",
    "simulation_pseudodog", "simulation_cat", "simulation_chimera",
    "simulation_controller", "simulation_burer", "simulation_boar"
}

function resolve_mutant_section(mutant_type)
    if mutant_type and mutant_type ~= "" and ini_sys:section_exist(mutant_type) then
        return mutant_type
    end
    if mutant_type == "random" then
        return MUTANT_SQUADS[math.random(#MUTANT_SQUADS)]
    end
    for _, s in ipairs(MUTANT_SQUADS) do
        if string.find(s, mutant_type, 1, true) then return s end
    end
    return "simulation_bloodsucker_1_2" 
end

local function is_mutant_squad_key(target)
    if not target or target == "" then
        return false
    end

    if target == "random" then
        return true
    end

    if ini_sys:section_exist(target) then
        local faction = ini_sys:r_string_ex(target, "faction") or ""
        return faction == "monster"
            or faction == "zombied"
            or string.find(faction, "monster_", 1, true) ~= nil
    end

    for _, s in ipairs(MUTANT_SQUADS) do
        if string.find(s, target, 1, true) then
            return true
        end
    end

    return false
end

local function apply_spawned_faction_relation(obj, relation_mode)
    if not obj or obj:clsid() ~= clsid.online_offline_group_s or not db.actor then
        return
    end

    relation_mode = relation_mode or "default"
    if relation_mode == "hostile" then
        obj:set_squad_relation("enemy")
    elseif relation_mode == "friendly" then
        obj:set_squad_relation("friend")
    else
        return
    end

    local relation = relation_mode == "hostile" and game_object.enemy or game_object.friend
    local goodwill = relation_mode == "hostile" and -5000 or 5000

    for k in obj:squad_members() do
        local o = level.object_by_id(k.id)
        if o then
            o:set_relation(relation, db.actor)
            o:force_set_goodwill(goodwill, db.actor)
        end
    end
end

local function get_faction_spawn_notification_keys(relation_mode)
    if relation_mode == "hostile" then
        return "st_pda_ic_outcome_hostile_warn", "st_pda_ic_outcome_hostile_arrive"
    elseif relation_mode == "friendly" then
        return "st_pda_ic_outcome_friendly_warn", "st_pda_ic_outcome_friendly_arrive"
    end

    return nil, nil
end

local function spawn_faction_squad_near_player(fac, distance, delay, relation_mode)
    delay = tonumber(delay) or 30
    fac = normalize_faction(fac)
    local sec = find_squad_section(fac)
    if not sec then
        printf("No squad section found for faction %s", tostring(fac))
        return
    end

    local sender = game.translate_string("st_pda_ic_outcome_sender")
    local warn_key, arrive_key = get_faction_spawn_notification_keys(relation_mode)

    if warn_key and PANDA.get_config("show_hunt_notifications") then
        dynamic_news_helper.send_tip(
            game.translate_string(warn_key),
            sender, 2, 10, FALLBACK_NPC_ICON, relation_mode == "hostile" and "danger" or "beep_1", "gr"
        )
    end

    local key = "spawn_faction_" .. tostring(math.random(100000))
    track_panda_ic_event("pda_ic_spawn", key)
    CreateTimeEvent("pda_ic_spawn", key, delay, function()
        if not db.actor then return true end

        local min_dist, max_dist
        local dist = tonumber(distance)
        if dist and dist > 0 then
            min_dist, max_dist = dist, dist
        else
            min_dist, max_dist = get_spawn_distance_range("spawn_distance_min", "spawn_distance_max", 30, 60)
        end

        local pos, l, g = find_spawn_point_near_player(min_dist, max_dist)
        local obj = create_squad_safely(sec, pos, l, g)

        if obj and obj:clsid() == clsid.online_offline_group_s then
            local squad_id = obj.id
            if relation_mode == "hostile" then
                obj.scripted_target = "actor"
                obj.rush_to_target = true
            else
                obj.scripted_target = nil
                obj.rush_to_target = false
            end

            apply_spawned_faction_relation(obj, relation_mode)

            if arrive_key then
                local arrival_event = "arrival_" .. squad_id
                track_panda_ic_event("pda_ic_spawn", arrival_event)
                CreateTimeEvent("pda_ic_spawn", arrival_event, math.random(5, 10), function()
                    if not db.actor then return true end
                    local s = alife_object(squad_id)
                    if not s then return true end
                    local commander = level.object_by_id(s:commander_id())
                    if commander and commander:alive() then
                        local actor_dist = commander:position():distance_to(db.actor:position())
                        if actor_dist < 150 and PANDA.get_config("show_hunt_notifications") then
                            dynamic_news_helper.send_tip(
                                game.translate_string(arrive_key),
                                sender, 0, 10, FALLBACK_NPC_ICON,
                                relation_mode == "hostile" and "danger" or "beep_1", "gr"
                            )
                        end
                    end
                    return true
                end)
            end

            if relation_mode == "hostile" then
                local start_time = game.get_game_time()
                local monitor_event = "monitor_" .. squad_id
                track_panda_ic_event("pda_ic_spawn", monitor_event)
                CreateTimeEvent("pda_ic_spawn", monitor_event, 30, function()
                    if not db.actor then return true end
                    local s = alife_object(squad_id)
                    if not s then return true end

                    local any_alive = false
                    for k in s:squad_members() do
                        local o = level.object_by_id(k.id)
                        if o and o:alive() then
                            any_alive = true
                            break
                        end
                    end

                    if not any_alive then
                        return true
                    end

                    local elapsed_min = game.get_game_time():diffSec(start_time) / 60
                    if elapsed_min > 10 then
                        if PANDA.get_config("show_hunt_notifications") then
                            dynamic_news_helper.send_tip(
                                game.translate_string("st_pda_ic_hunt_timeout"),
                                sender, 0, 10, FALLBACK_NPC_ICON, "attention", "gr"
                            )
                        end
                        if alife() and alife().release then
                            alife():release(s, true)
                        end
                        return true
                    end
                    return false
                end)
            end
        else
            printf("Failed to create faction squad for relation mode '%s'.", tostring(relation_mode))
        end
        return true
    end)
end

spawn_squad_at_smart_terrain = function(squad_key, smart_ref, is_mutant, delay, job_contact_id, relation_mode)
    delay = tonumber(delay) or 0
    relation_mode = relation_mode or "default"
    local sender = game.translate_string("st_pda_ic_outcome_sender")

    local function do_spawn()
        if not db.actor then
            return true
        end

        local smart, smart_name = resolve_smart_from_reference(smart_ref)
        if not smart then
            printf("PANDA_IC: spawn at smart failed — smart terrain '%s' not found", tostring(smart_ref))
            return true
        end

        local smart_pos = get_position_from_object(smart)
        local smart_lvid = smart.m_level_vertex_id
        local smart_gvid = smart.m_game_vertex_id
        if not (smart_pos and smart_lvid and smart_gvid) then
            printf("PANDA_IC: spawn at smart failed — smart terrain '%s' missing position or vertex info", tostring(smart_ref))
            return true
        end

        local sec = is_mutant and resolve_mutant_section(squad_key) or find_squad_section(squad_key)
        if not sec then
            printf("PANDA_IC: spawn at smart failed — no section for '%s'", tostring(squad_key))
            return true
        end

        local spawn_pos, spawn_lvid, spawn_gvid = find_spawn_point_near_smart(10, 20, smart_pos, smart_lvid, smart_gvid)
        local obj = create_squad_safely(sec, spawn_pos, spawn_lvid, spawn_gvid)
        if not obj or obj:clsid() ~= clsid.online_offline_group_s then
            printf("PANDA_IC: spawn at smart failed — could not create squad '%s'", tostring(sec))
            return true
        end

        obj.scripted_target = nil
        obj.rush_to_target = false

        if SIMBOARD and SIMBOARD.assign_squad_to_smart then
            SIMBOARD:assign_squad_to_smart(obj, smart.id)
        end

        if is_mutant then
            for k in obj:squad_members() do
                local o = level.object_by_id(k.id)
                if o then
                    o:set_relation(game_object.enemy, db.actor)
                end
            end
        elseif relation_mode == "companion" then
            apply_spawned_faction_relation(obj, "friendly")
            -- Recruit the spawned squad into companion system
            if axr_companions and axr_companions.add_companion_squad then
                axr_companions.add_companion_squad(obj.id)
            elseif axr_companions and axr_companions.companion_squads then
                axr_companions.companion_squads[obj.id] = true
            end
        else
            apply_spawned_faction_relation(obj, relation_mode)
        end

        -- Register delayed spawn with the pending job so kill tracking works
        if job_contact_id and pending_jobs[job_contact_id] then
            job_register_squads(job_contact_id, { obj.id })
        end

        local loc_name = get_location_display_name(smart_ref)
        local warn_key = nil
        if is_mutant then
            warn_key = "st_pda_ic_outcome_mutant_warn"
        else
            warn_key = get_faction_spawn_notification_keys(relation_mode)
        end

        if warn_key and PANDA.get_config("show_hunt_notifications") then
            local notify_msg = utils_data.parse_string_keys(
                game.translate_string(warn_key),
                {
                    ["location"] = loc_name,
                    ["smart"] = smart_name or tostring(smart_ref),
                }
            )
            dynamic_news_helper.send_tip(
                notify_msg,
                sender,
                0,
                10,
                FALLBACK_NPC_ICON,
                (is_mutant or relation_mode == "hostile") and "danger" or "beep_1",
                "gr"
            )
        end

        return true
    end

    if delay > 0 then
        local event_name = "spawn_smart_" .. tostring(math.random(100000))
        track_panda_ic_event("pda_ic_spawn", event_name)
        CreateTimeEvent("pda_ic_spawn", event_name, delay, do_spawn)
    else
        do_spawn()
    end
end

function find_spawn_point_near_smart(min, max, smart_pos, smart_lvid, smart_gvid)
    for _ = 1, 20 do
        local d = math.random(min, max)
        local dir = vector():set(math.random(-100,100), 0, math.random(-100,100)):normalize()
        local n = level.vertex_in_direction(smart_lvid, dir, d)
        if n and n < 4294967295 then
            return level.vertex_position(n), n, smart_gvid
        end
    end
    return smart_pos, smart_lvid, smart_gvid
end

function find_spawn_point_near_player(min, max)
    local a = db.actor
    local p, l, g = a:position(), a:level_vertex_id(), a:game_vertex_id()

    min = tonumber(min) or 10
    max = tonumber(max) or min
    if min > max then
        min, max = max, min
    end

    for _ = 1, 20 do
        local d = math.random(min, max)
        local dir = vector():set(math.random(-100,100), 0, math.random(-100,100)):normalize()
        local n = level.vertex_in_direction(l, dir, d)
        if n and n < 4294967295 then
            return level.vertex_position(n), n, g
        end
    end
    return p, l, g 
end

local function get_spawn_distance_range(min_key, max_key, default_min, default_max)
    local min = tonumber(PANDA.get_config(min_key)) or default_min
    local max = tonumber(PANDA.get_config(max_key)) or default_max

    if min > max then
        min, max = max, min
    end

    min = math.max(1, min)
    max = math.max(min, max)

    return min, max
end

function create_squad_safely(sec, pos, lvid, gvid)
    local obj = alife():create(sec, pos, lvid, gvid)
    if obj and obj:clsid() == clsid.online_offline_group_s then
        if obj.create_npc then
            obj:create_npc(nil, pos, lvid, gvid)
        end
        for k in obj:squad_members() do
            local se = k.object or (k.id and alife():object(k.id))
            if se then
                SIMBOARD:setup_squad_and_group(se)
            end
        end
        -- If a job spawn collector is active, register this squad for tracking
        if _job_spawn_collector then
            table.insert(_job_spawn_collector, obj.id)
            printf("PANDA_IC: Job collector captured squad ID %d (%s)", obj.id, tostring(sec))
        end
    end
    return obj
end

function spawn_hunting_squad(fac, distance, is_mutant, delay, relation_mode)
    relation_mode = relation_mode or "hostile"

    if not is_mutant then
        spawn_faction_squad_near_player(fac, distance, delay, relation_mode)
        return
    end

    delay = tonumber(delay) or 90
    fac = normalize_faction(fac)
    local sec = resolve_mutant_section(fac)
    if not sec then
        printf("No squad section found for mutant")
        return
    end

    local key = "spawn_hunt_" .. tostring(math.random(100000))
    local sender = game.translate_string("st_pda_ic_outcome_sender")

    -- Stage 1: Initial warning
    if PANDA.get_config("show_hunt_notifications") then
        dynamic_news_helper.send_tip(
            game.translate_string("st_pda_ic_outcome_mutant_warn"),
            sender, 2, 10, FALLBACK_NPC_ICON, "danger", "gr"
        )
    end

    track_panda_ic_event("pda_ic_spawn", key)
    CreateTimeEvent("pda_ic_spawn", key, delay, function()
        if not db.actor then return true end

        local min, max
        local dist = tonumber(distance)
        if dist and dist > 0 then
            min, max = dist, dist
        else
            min, max = get_spawn_distance_range("mutant_spawn_min", "mutant_spawn_max", 40, 100)
        end

        local pos, l, g = find_spawn_point_near_player(min, max)
        local obj = create_squad_safely(sec, pos, l, g)

        if obj and obj:clsid() == clsid.online_offline_group_s then
            local squad_id = obj.id
            obj.scripted_target = "actor"
            obj.rush_to_target = true

            for k in obj:squad_members() do
                local o = level.object_by_id(k.id)
                if o then
                    o:set_relation(game_object.enemy, db.actor)
                end
            end

            -- Stage 2: Notify arrival
            local arrival_event = "arrival_"..squad_id
            track_panda_ic_event("pda_ic_spawn", arrival_event)
            CreateTimeEvent("pda_ic_spawn", arrival_event, math.random(5, 10), function()
                if not db.actor then return true end
                local s = alife_object(squad_id)
                if not s then return true end
                local commander = level.object_by_id(s:commander_id())
                if commander and commander:alive() then
                    local actor_dist = commander:position():distance_to(db.actor:position())
                    if actor_dist < 150 and PANDA.get_config("show_hunt_notifications") then
                        dynamic_news_helper.send_tip(
                            game.translate_string("st_pda_ic_outcome_mutant_arrive"),
                            sender, 0, 10, FALLBACK_NPC_ICON, "danger", "gr"
                        )
                    end
                end
                return true
            end)

            -- Stage 3: Monitor and timeout
            local start_time = game.get_game_time()
            local monitor_event = "monitor_"..squad_id
            track_panda_ic_event("pda_ic_spawn", monitor_event)
            CreateTimeEvent("pda_ic_spawn", monitor_event, 30, function()
                if not db.actor then return true end
                local s = alife_object(squad_id)
                if not s then return true end

                local any_alive = false
                for k in s:squad_members() do
                    local o = level.object_by_id(k.id)
                    if o and o:alive() then
                        any_alive = true
                        break
                    end
                end

                if not any_alive then
                    return true
                end

                local elapsed_min = game.get_game_time():diffSec(start_time) / 60
                if elapsed_min > 10 then
                    if PANDA.get_config("show_hunt_notifications") then
                        dynamic_news_helper.send_tip(
                            game.translate_string("st_pda_ic_hunt_timeout"),
                            sender, 0, 10, FALLBACK_NPC_ICON, "attention", "gr"
                        )
                    end
                    if alife() and alife().release then
                        alife():release(s, true)
                    end
                    return true
                end
                return false
            end)

        else
            printf("Failed to create hunting squad (squad creation returned nil or wrong class).")
        end
        return true
    end)
end

function spawn_native_companion(fac, distance, delay)
    delay = tonumber(delay) or 30

    -- Check companion limit
    local comps = 0
    if axr_companions and axr_companions.companion_squads then
        for _ in pairs(axr_companions.companion_squads) do
            comps = comps + 1
        end
    end
    local max_comps = PANDA.get_config("companion_limit") or 4
    if comps >= max_comps then
        printf("Companion limit reached (%d/%d), cannot spawn more.", comps, max_comps)
        return
    end

    fac = normalize_faction(fac)
    local sec = find_squad_section(fac)
    if not sec then
        printf("No squad section found for faction %s", fac)
        return
    end

    local sender = game.translate_string("st_pda_ic_outcome_sender")
    if PANDA.get_config("show_companion_notifications") then
        dynamic_news_helper.send_tip(
            game.translate_string("st_pda_ic_outcome_friendly_warn"),
            sender, 2, 10, FALLBACK_NPC_ICON, "beep_1", "gr"
        )
    end

    local spawn_comp_event = "spawn_comp_"..math.random(100000)
    track_panda_ic_event("pda_ic_spawn", spawn_comp_event)
    CreateTimeEvent("pda_ic_spawn", spawn_comp_event, delay, function()
        if not db.actor then return true end

        local min_dist, max_dist
        local dist = tonumber(distance)
        if dist and dist > 0 then
            min_dist, max_dist = dist, dist
        else
            min_dist, max_dist = get_spawn_distance_range("companion_spawn_min", "companion_spawn_max", 20, 50)
        end
        local pos, l, g = find_spawn_point_near_player(min_dist, max_dist)

        local sq = create_squad_safely(sec, pos, l, g)
        if not sq or sq:clsid() ~= clsid.online_offline_group_s then
            printf("Failed to create companion squad.")
            return true
        end

        axr_companions.companion_squads[sq.id] = sq

        local companion_name = nil
        for m in sq:squad_members() do
            local se = alife_object(m.id)
            if se then
                se_save_var(se.id, se:name(), "companion", true)
                se_save_var(se.id, se:name(), "companion_cannot_dismiss", true)
                if not companion_name then
                    companion_name = se:character_name() or game.translate_string("st_pda_ic_companion_default")
                end
            end
        end

        sq.scripted_target = "actor"
        sq.rush_to_target = false
        if sq.set_follow_distance then
            sq:set_follow_distance(10)
        end

        local squad_id = sq.id
        local arrival_checked = false
        local function check_arrival()
            if not db.actor then return true end
            local s = alife_object(squad_id)
            if not s then return true end

            local commander = level.object_by_id(s:commander_id())
            if not commander or not commander:alive() then
                axr_companions.companion_squads[squad_id] = nil
                return true
            end

            local dist = commander:position():distance_to(db.actor:position())
            if dist < 30 and not arrival_checked then
                arrival_checked = true
                local name = companion_name or commander:character_name() or game.translate_string("st_pda_ic_companion_default")
                if PANDA.get_config("show_companion_notifications") then
                    dynamic_news_helper.send_tip(
                        game.translate_string("st_pda_ic_outcome_companion_arrive_named"):gsub("%$name", name),
                        sender, 0, 10,
                        commander:character_icon() or fac,
                        "beep_1", "gr"
                    )
                end
                return true
            elseif dist >= 30 then
                return false
            else
                return true
            end
        end

        local companion_arrival_event = "arrival_"..squad_id
        track_panda_ic_event("pda_ic_companion", companion_arrival_event)
        CreateTimeEvent("pda_ic_companion", companion_arrival_event, 2, check_arrival)

        local function cleanup_companion()
            axr_companions.companion_squads[squad_id] = nil
            printf("Companion squad %d removed.", squad_id)
        end

        local companion_monitor_event = "monitor_"..squad_id
        track_panda_ic_event("pda_ic_companion", companion_monitor_event)
        CreateTimeEvent("pda_ic_companion", companion_monitor_event, 10, function()
            if not db.actor then return true end
            local s = alife_object(squad_id)
            if not s then
                cleanup_companion()
                return true
            end
            return false
        end)

        return true
    end)
end

function spawn_native_courier(item_sec)
    local fac = normalize_faction(get_actor_true_community() or "stalker")
    local sec = find_squad_section(fac)
    local sender = game.translate_string("st_pda_ic_outcome_sender")
    local courier_title = game.translate_string("st_pda_ic_courier_title")

    if PANDA.get_config("show_courier_notifications") then
        dynamic_news_helper.send_tip(
            game.translate_string("st_pda_ic_outcome_courier_warn"),
            sender, 2, 10, FALLBACK_NPC_ICON, "beep_1", "gr"
        )
    end

    local min, max = get_spawn_distance_range("companion_spawn_min", "companion_spawn_max", 20, 50)
    local pos, l, g = find_spawn_point_near_player(min, max)

    local sq = create_squad_safely(sec, pos, l, g)
    if not sq or sq:clsid() ~= clsid.online_offline_group_s then return end

    sq.scripted_target = "actor"
    -- IMPROVEMENT 1: Make them actually jog/sprint to the player instead of casually walking
    sq.rush_to_target = true 
    
    local squad_id = sq.id
    local check_interval = 2
    -- IMPROVEMENT 2: Give them 2 full minutes (60 checks) to navigate anomalies/mutants
    local max_checks = 60 
    local check_count = 0

    -- Helper function to make the courier become a normal stalker instead of deleting them
    local function release_to_alife(squad)
        squad.scripted_target = nil
        squad.rush_to_target = false
        -- Give them back to the Zone's simulation board so they wander off to a camp
        if SIMBOARD then
            SIMBOARD:assign_squad_to_smart(squad, nil)
        end
    end

    local function monitor_courier()
        if not db.actor then return true end
        local s = alife_object(squad_id)
        
        -- Squad was wiped out or deleted by engine
        if not s then return true end

        local commander = level.object_by_id(s:commander_id())
        
        -- IMPROVEMENT 3: Handle Courier Death! Adds immersion.
        if not commander or not commander:alive() then
            if PANDA.get_config("show_courier_notifications") then
                dynamic_news_helper.send_tip(
                    game.translate_string("st_pda_ic_courier_died") or "PDA signal lost... the courier didn't make it.", 
                    "System", 0, 10, FALLBACK_NPC_ICON, "danger", "gr"
                )
            end
            return true 
        end

        local dist = commander:position():distance_to(db.actor:position())

        if dist < 15 then -- Closer threshold for better interaction feel
            local name = commander:character_name() or courier_title
            
            if PANDA.get_config("show_courier_notifications") then
                dynamic_news_helper.send_tip(
                    game.translate_string("st_pda_ic_courier_arrived"),
                    name, 0, 10,
                    commander:character_icon() or FALLBACK_NPC_ICON,
                    "news", "npc"
                )
            end

            -- IMPROVEMENT 4: Guaranteed delivery once they arrive. No failing because the player stepped backward.
            local courier_deliver_event = "deliver_"..squad_id
            track_panda_ic_event("pda_ic_courier", courier_deliver_event)
            CreateTimeEvent("pda_ic_courier", courier_deliver_event, 2, function()
                if not db.actor then return true end
                
                if ini_sys:section_exist(item_sec) then
                    alife_create_item(item_sec, db.actor)
                end
                
                local msg = utils_data.parse_string_keys(
                    game.translate_string("st_pda_ic_outcome_item_gain"),
                    {["what"] = ui_item.get_sec_name(item_sec)}
                )
                
                if PANDA.get_config("show_courier_notifications") then
                    dynamic_news_helper.send_tip(
                        msg,
                        name, 0, 12,
                        commander:character_icon() or FALLBACK_NPC_ICON,
                        "beep_1", "npc"
                    )
                end
                
                -- IMPROVEMENT 5: Release to A-Life instead of deleting them in front of the player
                local final_sq = alife_object(squad_id)
                if final_sq then release_to_alife(final_sq) end
                
                return true
            end)
            
            return true -- End monitoring
        else
            -- Still approaching, handle timeout
            check_count = check_count + 1
            if check_count > max_checks then
                if PANDA.get_config("show_courier_notifications") then
                    dynamic_news_helper.send_tip(
                        game.translate_string("st_pda_ic_courier_timeout"),
                        courier_title, 0, 10, FALLBACK_NPC_ICON, "attention", "gr"
                    )
                end
                -- Player ran too far away / ignored them. Release them to A-Life.
                release_to_alife(s)
                return true
            end
            return false
        end
    end

    local courier_check_event = "check_"..squad_id
    track_panda_ic_event("pda_ic_courier", courier_check_event)
    CreateTimeEvent("pda_ic_courier", courier_check_event, check_interval, monitor_courier)
end

-- ============================================================
-- TELEPORT NPC TO SMART TERRAIN
-- ============================================================
function teleport_npc_to_smart_terrain(npc_id, smart_ref, npc_name, delay)
    delay = delay or 0
    local sender = game.translate_string("st_pda_ic_outcome_sender")

    local function do_teleport()
        if not db.actor then return true end

        local smart, smart_name = resolve_smart_from_reference(smart_ref)
        if not smart then
            printf("PANDA_IC: teleport_npc_to_smart failed — smart terrain '%s' not found", tostring(smart_ref))
            return true
        end

        local se_npc = alife_object(npc_id)
        if not se_npc then
            printf("PANDA_IC: teleport_npc_to_smart — NPC %d no longer exists", npc_id)
            return true
        end

        -- Get the smart terrain position and vertex data
        local smart_pos = smart.position
        local smart_gvid = smart.m_game_vertex_id
        local smart_lvid = smart.m_level_vertex_id

        -- Get the NPC's squad (if any) and teleport the whole squad
        local squad = get_object_squad(se_npc)
        if squad then
            -- Use the vanilla TeleportSquad approach
            local sim = alife()
            sim:teleport_object(squad.id, smart_gvid, smart_lvid, smart_pos)
            for k in squad:squad_members() do
                if db.offline_objects[k.id] then
                    db.offline_objects[k.id].level_vertex_id = nil
                end
                db.spawned_vertex_by_id[k.id] = nil
                sim:teleport_object(k.id, smart_gvid, smart_lvid, smart_pos)
            end

            -- Assign the squad to the target smart terrain
            if SIMBOARD and SIMBOARD.assign_squad_to_smart then
                SIMBOARD:assign_squad_to_smart(squad, smart.id)
            end
        else
            -- Solo NPC (no squad), teleport directly
            local npc_obj = level.object_by_id(npc_id)
            if npc_obj then
                npc_obj:set_npc_position(smart_pos)
            else
                se_npc.position = smart_pos
            end
        end

        local display_name = get_location_display_name(smart_ref)
        local name = npc_name or (se_npc:character_name()) or "Unknown"

        dynamic_news_helper.send_tip(
            utils_data.parse_string_keys(
                game.translate_string("st_pda_ic_outcome_npc_teleport_smart"),
                { ["name"] = name, ["location"] = display_name }
            ),
            sender, 0, 10, FALLBACK_NPC_ICON, "beep_2", "npc"
        )

        return true
    end

    if delay > 0 then
        local tp_smart_event = "tp_smart_" .. tostring(npc_id) .. "_" .. math.random(100000)
        track_panda_ic_event("pda_ic_tp", tp_smart_event)
        CreateTimeEvent("pda_ic_tp", tp_smart_event, delay, do_teleport)
    else
        do_teleport()
    end
end

-- ============================================================
-- TELEPORT NPC NEAR PLAYER
-- ============================================================
function teleport_npc_near_player(npc_id, npc_name, delay)
    delay = delay or 0
    local sender = game.translate_string("st_pda_ic_outcome_sender")

    local function do_teleport()
        if not db.actor then return true end

        local se_npc = alife_object(npc_id)
        if not se_npc then
            printf("PANDA_IC: teleport_npc_to_player — NPC %d no longer exists", npc_id)
            return true
        end

        -- Respect MCM companion/courier spawn range settings.
        local min_dist, max_dist = get_spawn_distance_range("companion_spawn_min", "companion_spawn_max", 20, 50)
        local pos, lvid, gvid = find_spawn_point_near_player(min_dist, max_dist)

        -- Get the NPC's squad (if any) and teleport the whole squad
        local squad = get_object_squad(se_npc)
        if squad then
            local sim = alife()
            sim:teleport_object(squad.id, gvid, lvid, pos)
            for k in squad:squad_members() do
                if db.offline_objects[k.id] then
                    db.offline_objects[k.id].level_vertex_id = nil
                end
                db.spawned_vertex_by_id[k.id] = nil
                sim:teleport_object(k.id, gvid, lvid, pos)
            end

            -- Clear any smart terrain assignment so they stay where teleported
            if SIMBOARD and SIMBOARD.assign_squad_to_smart then
                SIMBOARD:assign_squad_to_smart(squad, nil)
            end
        else
            -- Solo NPC
            local npc_obj = level.object_by_id(npc_id)
            if npc_obj then
                npc_obj:set_npc_position(pos)
            else
                se_npc.position = pos
            end
        end

        local name = npc_name or (se_npc:character_name()) or "Unknown"

        dynamic_news_helper.send_tip(
            utils_data.parse_string_keys(
                game.translate_string("st_pda_ic_outcome_npc_teleport_player"),
                { ["name"] = name }
            ),
            sender, 0, 10, FALLBACK_NPC_ICON, "beep_1", "npc"
        )

        return true
    end

    if delay > 0 then
        local tp_player_event = "tp_player_" .. tostring(npc_id) .. "_" .. math.random(100000)
        track_panda_ic_event("pda_ic_tp", tp_player_event)
        CreateTimeEvent("pda_ic_tp", tp_player_event, delay, do_teleport)
    else
        do_teleport()
    end
end

-- ============================================================
-- RECRUIT NPC AS COMPANION
-- ============================================================
function recruit_npc_as_companion(npc_id, npc_name, cannot_dismiss)
    if not axr_companions then
        printf("PANDA_IC: recruit_companion failed — axr_companions not available")
        return
    end

    -- Check companion limit
    local comps = 0
    if axr_companions.companion_squads then
        for _ in pairs(axr_companions.companion_squads) do
            comps = comps + 1
        end
    end
    local max_comps = PANDA.get_config("companion_limit") or 4
    if comps >= max_comps then
        printf("PANDA_IC: recruit_companion — companion limit reached (%d/%d)", comps, max_comps)
        dynamic_news_helper.send_tip(
            game.translate_string("st_pda_ic_outcome_recruit_limit"),
            game.translate_string("st_pda_ic_outcome_sender"), 0, 8,
            FALLBACK_NPC_ICON, "beep_1", "npc"
        )
        return
    end

    local npc_obj = level.object_by_id(npc_id)
    if not npc_obj or not npc_obj:alive() then
        printf("PANDA_IC: recruit_companion — NPC %d not online or dead", npc_id)
        return
    end

    local se_npc = alife_object(npc_id)
    if not se_npc then
        printf("PANDA_IC: recruit_companion — server object for NPC %d not found", npc_id)
        return
    end

    -- Get the NPC's squad
    local squad = get_object_squad(npc_obj) or get_object_squad(se_npc)

    if squad then
        -- Register the squad as a companion squad (vanilla pattern from dialogs_axr_companion)
        axr_companions.companion_squads[squad.id] = squad

        -- Unassign from current smart terrain
        if SIMBOARD and SIMBOARD.assign_squad_to_smart then
            SIMBOARD:assign_squad_to_smart(squad, nil)
        end

        -- Set up each squad member as a companion
        for k in squad:squad_members() do
            local member = db.storage[k.id] and db.storage[k.id].object
            if member and member:alive() then
                se_save_var(k.id, member:name(), "companion", true)
                if cannot_dismiss then
                    se_save_var(k.id, member:name(), "companion_cannot_dismiss", true)
                end
                axr_companions.add_to_actor_squad(member)
            end
        end
    else
        -- Solo NPC without a squad — still mark and add as companion
        se_save_var(npc_id, npc_obj:name(), "companion", true)
        if cannot_dismiss then
            se_save_var(npc_id, npc_obj:name(), "companion_cannot_dismiss", true)
        end
        axr_companions.add_to_actor_squad(npc_obj)
    end

    local name = npc_name or npc_obj:character_name() or "Unknown"
    local icon = npc_obj:character_icon() or FALLBACK_NPC_ICON

    if PANDA.get_config("show_companion_notifications") then
        dynamic_news_helper.send_tip(
            utils_data.parse_string_keys(
                game.translate_string("st_pda_ic_outcome_recruit_success"),
                { ["name"] = name }
            ),
            game.translate_string("st_pda_ic_outcome_sender"), 0, 10,
            icon, "beep_2", "npc"
        )
    end
end

-- ============================================================
-- CONVERSATION FLOW (State Machine)
-- ============================================================

function load_choices_for_turn(prefix, faction, conv_id, turn, npc_name, contact_id, npc_se)
    local base_key
    if prefix == "task" or not prefix then
        base_key = "st_pda_ic_"..faction.."_"..tostring(conv_id)
    else
        base_key = "st_pda_ic_"..prefix.."_"..faction.."_"..tostring(conv_id)
    end

    local p = base_key
    if turn > 1 then
        p = p.."_t"..tostring(turn)
    end
    local choices, count = {}, 0

    local function normalize_choice_channel(value)
        if not value then
            return "pda"
        end

        local normalized = tostring(value):lower():gsub("^%s+", ""):gsub("%s+$", "")
        if normalized == "f2f" then
            return "f2f"
        end

        return "pda"
    end

    local function load_registry_continue_channel(choice_idx)
        local registry_key = base_key .. "_panda_f2f_registry"
        local raw = game.translate_string(registry_key)
        if not raw or raw == registry_key then
            return nil
        end

        raw = tostring(raw):gsub("&quot;", "\"")
        local turn_block = raw:match("\"turnNumber\"%s*:%s*" .. tostring(turn) .. ".-\"choices\"%s*:%s*%[(.-)%]")
        if not turn_block then
            return nil
        end

        for choice_block in turn_block:gmatch("{(.-)}") do
            local found_idx = tonumber(choice_block:match("\"index\"%s*:%s*(%d+)"))
            if found_idx == choice_idx then
                return choice_block:match("\"continueChannel\"%s*:%s*\"([%w_%-]+)\"")
            end
        end

        return nil
    end

    -- Get relationship score for reply variant selection
    local rel = contact_id and get_npc_relationship(contact_id) or 0

    for i = 1, 4 do
        local key = p.."_choice_"..i
        local text = game.translate_string(key)
        if text == key then break end

        local reply_key = p.."_reply_"..i
        local reply_text = game.translate_string(reply_key)
        if reply_text == reply_key then reply_text = "" end

        -- Check for relationship-conditional reply variants
        if reply_text ~= "" and contact_id then
            if rel >= 300 then
                local high_key = p.."_reply_"..i.."_rel_high"
                local high_text = game.translate_string(high_key)
                if high_text ~= high_key then
                    reply_text = high_text
                end
            elseif rel <= -300 then
                local low_key = p.."_reply_"..i.."_rel_low"
                local low_text = game.translate_string(low_key)
                if low_text ~= low_key then
                    reply_text = low_text
                end
            end
        end

        local cont_channel = game.translate_string(p.."_cont_channel_"..i)
        if cont_channel == p.."_cont_channel_"..i then
            cont_channel = game.translate_string(p.."_channel_"..i)
            if cont_channel == p.."_channel_"..i then
                cont_channel = load_registry_continue_channel(i)
            end
        end

        choices[i] = {
            text = sub_placeholders(text, npc_name, faction, npc_se, contact_id),
            reply = sub_placeholders(reply_text, npc_name, faction, npc_se, contact_id),
            outcome = game.translate_string(p.."_outcome_"..i),
            next_turn = tonumber(game.translate_string(p.."_cont_"..i)) or nil,
            next_channel = normalize_choice_channel(cont_channel)
        }
        if choices[i].outcome == p.."_outcome_"..i then choices[i].outcome = "none" end
        count = i
    end
    return choices, count
end



function on_player_choice(idx, contact_id)
    -- Resolve which conversation to act on: use contact_id if given, else fall back to CONV
    local c
    if contact_id and active_conversations[contact_id] then
        c = active_conversations[contact_id]
    elseif CONV then
        c = CONV
    end

    if not c or not c.choices or not c.choices[idx] then return end

    local ch = c.choices[idx]
    local continuation_channel = (ch.next_channel == "f2f") and "f2f" or "pda"
    local npc_name = c.npc_name
    local cid = c.contact_id

    -- Add player choice to log, NO global tip
    pda_private_add_message(cid, npc_name, db.actor:character_name(), ch.text, db.actor:character_icon(), true, "sent")

    -- Remove from active table to prevent button-mashing abuse
    active_conversations[cid] = nil
    if CONV and CONV.contact_id == cid then CONV = nil end

    -- Check if outcome has already been triggered in this conversation
    local outcome_key = tostring(c.turn) .. "_" .. tostring(idx)
    local has_outcome = ch.outcome and ch.outcome ~= "none"
    local should_apply_outcome = false

    if has_outcome then
        c.applied_outcomes = c.applied_outcomes or {}
        if not c.applied_outcomes[outcome_key] then
            should_apply_outcome = true
            c.applied_outcomes[outcome_key] = true
        else
            printf("Outcome already applied for choice %s, skipping to prevent farming.", outcome_key)
        end
    end

    -- Mark reply chain as active so UI doesn't prematurely clear typing
    c.reply_pending = true
    pda_reply_pending = true

    -- Estimate typing duration based on reply length (roughly 1s per 20 chars, min 2s, max 8s)
    local reply_text = ch.reply or ""
    local reply_len = string.len(reply_text)
    local typing_duration = math.max(2, math.min(8, math.floor(reply_len / 20) + 1))

    -- Use per-conversation event IDs so multiple conversations don't clobber each other
    local ev_prefix = "pda_ic_" .. tostring(c.npc_id)

    -- Stage 2: After a short delay, mark as "delivered" (message reaches NPC's PDA)
    local delivered_delay = math.random(1, 2)
    CreateTimeEvent(ev_prefix, "delivery_ack", delivered_delay, function()
        set_last_player_message_state(cid, "delivered")

        -- Stage 3: NPC reads the message
        local player_msg_len = string.len(ch.text or "")
        local read_delay = math.max(1, math.min(4, math.floor(player_msg_len / 30) + 1))
        CreateTimeEvent(ev_prefix, "npc_read", read_delay, function()
            set_last_player_message_state(cid, "read")

            -- Stage 4: NPC thinks before typing
            local think_delay = math.random(1, 3)
            CreateTimeEvent(ev_prefix, "npc_thinking", think_delay, function()

                -- Stage 5: NPC starts typing
                upsert_npc_typing_message(cid, npc_name, c.npc_icon)
                CreateTimeEvent(ev_prefix, "npc_reply", typing_duration, function()
                    clear_npc_typing_message(cid)

                    if ch.reply and ch.reply ~= "" then
                        if is_private_tab_visible and is_private_tab_visible() then
                            -- Tab is open and visible, no global alert
                        else
                            printf("Global alert: New message from %s", npc_name)
                        end
                        pda_private_add_message(cid, npc_name, npc_name, ch.reply, c.npc_icon, false)
                        set_last_player_message_state(cid, "read")
                    end

                    if should_apply_outcome then
                        local outcome_delay_min = PANDA.get_config("outcome_delay_min") or 1
                        local outcome_delay_max = PANDA.get_config("outcome_delay_max") or 2
                        CreateTimeEvent(ev_prefix, "outcome", math.random(outcome_delay_min, outcome_delay_max), function()
                            apply_outcome(ch.outcome, npc_name, c.faction, c.npc_id, c.task_id, cid, c)
                            return true
                        end)
                    end

                    if ch.next_turn and continuation_channel == "pda" then
                        local next_choices, num = load_choices_for_turn(c.prefix, c.faction, c.conv_id, ch.next_turn, npc_name, cid)
                        if num > 0 then
                            c.turn = ch.next_turn
                            c.choices = next_choices
                            c.num_choices = num
                            c.reply_pending = false
                            -- Re-register in multi-conv table
                            active_conversations[cid] = c
                            CONV = c
                        end
                    elseif ch.next_turn and continuation_channel == "f2f" then
                        c.pending_in_person_continuation = true
                        c.pending_in_person_turn = ch.next_turn
                        c.pending_in_person_target = "panda_f2f_hub_dialog"
                        c.pending_in_person_set_at = time_global and time_global() or 0
                        local npc_se = c.npc_id and alife_object(c.npc_id) or nil
                        local handoff_identity = build_f2f_handoff_identity(npc_se, c.npc_id)
                        local handoff_token = make_f2f_handoff_token(c.npc_id, c.conv_id, ch.next_turn, c.pending_in_person_set_at)
                        c.pending_in_person_token = handoff_token
                        c.pending_in_person_story_id = handoff_identity.story_id
                        c.pending_in_person_canonical_id = handoff_identity.canonical_id
                        local handoff_target_name = tostring(c.npc_name or "Unknown")
                        local handoff_target_id = tostring(c.npc_id or "Unknown")
                        pda_private_add_message(
                            cid,
                            npc_name,
                            "PDA System",
                            string.format("Meet %s (ID: %s) to continue this conversation.", handoff_target_name, handoff_target_id),
                            c.npc_icon,
                            false,
                            nil,
                            nil,
                            nil,
                            { skip_personality = true }
                        )
                        local handoff_story_id = tostring(handoff_identity.story_id or "n/a")

                        printf("TRACE f2f-handoff npc_sid=%s story_id=%s canonical_id=%s conv_id=%s next_turn=%s channel=%s token=%s",
                            tostring(tonumber(c.npc_id) or 0),
                            tostring(handoff_story_id),
                            tostring(handoff_identity.canonical_id or "n/a"),
                            tostring(tonumber(c.conv_id) or 0),
                            tostring(tonumber(ch.next_turn) or 0),
                            tostring(continuation_channel),
                            tostring(handoff_token))

                        local handoff_row = {
                            contact_id = cid,
                            npc_id = c.npc_id,
                            conv_id = c.conv_id,
                            turn = ch.next_turn,
                            faction = c.faction,
                            prefix = c.prefix,
                            channel = "f2f",
                            dialog = "panda_f2f_hub_dialog",
                            set_at = c.pending_in_person_set_at,
                            token = handoff_token,
                            story_id = handoff_identity.story_id,
                            canonical_id = handoff_identity.canonical_id,
                            fallback_name = handoff_identity.fallback_name,
                            route_owner = nil,
                            route_dialog = "panda_f2f_hub_dialog",
                            route_status = "pending",
                        }
                        register_pending_f2f_handoff(cid, handoff_row)

                        local handoff_route = "no-route"
                        local bridge = ensure_panda_f2f_bridge()
                        local owner_tag = string.format("pda_handoff_%s_%s_%s", tostring(cid), tostring(c.conv_id), tostring(ch.next_turn))
                        if bridge and type(bridge.hard_route_branch) == "function" then
                            local ok_route_call, route_applied = pcall(bridge.hard_route_branch, c.npc_id, owner_tag)
                            if ok_route_call and route_applied == true then
                                handoff_route = "bridge route"
                            end
                        end

                        if handoff_route ~= "bridge route" and xr_meet and type(xr_meet.override_dialog) == "function" then
                            local ok_override_call = pcall(xr_meet.override_dialog, c.npc_id, "panda_f2f_hub_dialog")
                            if ok_override_call and has_xr_meet_dialog_override(c.npc_id, "panda_f2f_hub_dialog") then
                                handoff_route = "xr_meet fallback"
                            end
                        end

                        handoff_row.route_owner = owner_tag
                        handoff_row.route_status = handoff_route
                        handoff_row.route_set_at = time_global and time_global() or c.pending_in_person_set_at

                        printf("PANDA_IC: f2f handoff registered npc_id=%s conv_id=%s turn=%s dialog=%s route=%s",
                            tostring(c.npc_id), tostring(c.conv_id), tostring(ch.next_turn), "panda_f2f_hub_dialog", handoff_route)

                        -- Re-register in active_conversations so the pending_in_person
                        -- markers are trackable by consume_pending_f2f_handoff_internal
                        -- and sweep_expired_f2f_pending_markers. Without this, the conv
                        -- object is orphaned after on_player_choice removes it (line 5921).
                        active_conversations[cid] = c
                        CONV = c
                        -- Clear PDA choices: conversation has moved to f2f stage,
                        -- player should not be able to reply via PDA anymore.
                        c.choices = nil
                        c.num_choices = 0
                    end

                    if get_ui then
                        get_ui():Reset()
                    end

                    c.reply_pending = false
                    pda_reply_pending = false
                    return true
                end)
                return true
            end)
            return true
        end)
        return true
    end)

    -- Record cooldown only for terminal branches (no continuation turn)
    if not ch.next_turn then
        local composite_key = (c.prefix or "task") .. "_" .. c.faction .. "_" .. c.conv_id
        conv_last_played[composite_key] = game.get_game_time()
    end
end

local function resolve_conversation_context_internal(npc_id, conversation_id, turn_number, channel)
    local resolved_channel = channel or "pda"
    local matched = nil

    if npc_id ~= nil then
        for _, conv in pairs(active_conversations) do
            if conv and conv.npc_id == npc_id then
                matched = conv
                break
            end
        end
    elseif CONV then
        matched = CONV
    end

    if not matched then
        return nil
    end

    if conversation_id ~= nil and matched.conv_id ~= conversation_id then
        return nil
    end

    if turn_number ~= nil and matched.turn ~= turn_number then
        return nil
    end

    if matched.channel == nil then
        matched.channel = resolved_channel
    end

    return matched
end

local function apply_choice_internal(conversation_context, choice_index, channel)
    if not conversation_context then
        return false
    end

    conversation_context.channel = channel or conversation_context.channel or "pda"
    on_player_choice(choice_index, conversation_context.contact_id)
    return true
end

has_xr_meet_dialog_override = function(npc_id, dialog_name)
    local sid = tonumber(npc_id)
    if not sid or sid <= 0 or not xr_meet then
        return false
    end

    if type(xr_meet.has_dialog_override) == "function" then
        local ok_override, has_override = pcall(function()
            return xr_meet.has_dialog_override(sid)
        end)
        if ok_override and has_override == true then
            return true
        end
    end

    local table_candidates = {
        "dialog_override",
        "dialog_overrides",
        "override_dialogs",
    }

    for _, field in ipairs(table_candidates) do
        local overrides = rawget(xr_meet, field)
        if type(overrides) == "table" then
            local rec = overrides[sid] or overrides[tostring(sid)]
            if rec == dialog_name then
                return true
            end
            if type(rec) == "table" then
                local rec_dialog = rec.dialog or rec.dialog_id or rec.id or rec.override or rec.dialog_name
                if rec_dialog == dialog_name then
                    return true
                end
            end
        end
    end

    return false
end

local function sync_pda_f2f_handoff_globals()
    if pda_f2f_handoffs then
        _G.pda_f2f_handoffs = pda_f2f_handoffs
    else
        _G.pda_f2f_handoffs = nil
    end
end

local function clear_pending_in_person_marker(conv)
    if type(conv) ~= "table" then
        return
    end

    conv.pending_in_person_continuation = false
    conv.pending_in_person_turn = nil
    conv.pending_in_person_target = nil
    conv.pending_in_person_set_at = nil
    conv.pending_in_person_token = nil
    conv.pending_in_person_story_id = nil
    conv.pending_in_person_canonical_id = nil
end

abort_contact_f2f_state = function(contact_id, reason, options)
    local contact_key = tostring(contact_id or "")
    if contact_key == "" then
        return false, 0
    end

    options = type(options) == "table" and options or {}

    local convo = active_conversations and active_conversations[contact_key] or nil
    local handoff = pda_f2f_handoffs and pda_f2f_handoffs[contact_key] or nil
    local npc_sid = tonumber(handoff and handoff.npc_id or convo and convo.npc_id)
    local conv_id = tonumber(handoff and handoff.conv_id or convo and convo.conv_id)
    local turn = tonumber(handoff and handoff.turn or convo and convo.pending_in_person_turn)
    local token = handoff and handoff.token or convo and convo.pending_in_person_token or nil
    local set_at = tonumber(handoff and handoff.set_at or convo and convo.pending_in_person_set_at) or nil
    local route_owner = handoff and handoff.route_owner or nil
    local route_status = handoff and handoff.route_status or nil
    local any_cleanup = type(convo) == "table" or type(handoff) == "table"
    local removed_threads = 0

    if options.cancel_events == true then
        pda_reply_pending = false
        safe_remove_time_event("pda_ic", "delivery_ack")
        safe_remove_time_event("pda_ic", "npc_typing_start")
        safe_remove_time_event("pda_ic", "npc_reply")
        if npc_sid then
            local ev_prefix = "pda_ic_" .. tostring(npc_sid)
            safe_remove_time_event(ev_prefix, "delivery_ack")
            safe_remove_time_event(ev_prefix, "npc_read")
            safe_remove_time_event(ev_prefix, "npc_thinking")
            safe_remove_time_event(ev_prefix, "npc_reply")
            safe_remove_time_event(ev_prefix, "outcome")
        end
    end

    if npc_sid then
        local bridge = ensure_panda_f2f_bridge()
        local bridge_aborted = false
        if bridge and type(bridge.abort_session) == "function" then
            local ok_abort, abort_result = pcall(bridge.abort_session, npc_sid, route_owner, tostring(reason or "unspecified"), token)
            bridge_aborted = ok_abort and abort_result == true
        elseif bridge and type(bridge.restore_branch_route) == "function" then
            pcall(bridge.restore_branch_route, npc_sid, route_owner)
        end

        if xr_meet and type(xr_meet.restore_dialog) == "function" then
            pcall(xr_meet.restore_dialog, npc_sid)
        end

        if type(consume_pending_f2f_handoff_internal) == "function" then
            any_cleanup = consume_pending_f2f_handoff_internal(npc_sid, conv_id, turn, token, set_at) == true or any_cleanup
        elseif type(handoff) == "table" and type(pda_f2f_handoffs) == "table" then
            pda_f2f_handoffs[contact_key] = nil
            sync_pda_f2f_handoff_globals()
            any_cleanup = true
        end
        printf(
            "PANDA_IC: abort_contact_f2f_state contact_id=%s reason=%s npc_id=%s conv_id=%s turn=%s token=%s route_status=%s bridge_aborted=%s",
            tostring(contact_key),
            tostring(reason or "unspecified"),
            tostring(npc_sid),
            tostring(conv_id or "nil"),
            tostring(turn or "nil"),
            tostring(token or "nil"),
            tostring(route_status or "nil"),
            tostring(bridge_aborted)
        )
    elseif type(handoff) == "table" and type(pda_f2f_handoffs) == "table" then
        pda_f2f_handoffs[contact_key] = nil
        sync_pda_f2f_handoff_globals()
    end

    if type(convo) == "table" then
        clear_pending_in_person_marker(convo)
    end

    if options.remove_conversation ~= false and active_conversations and active_conversations[contact_key] then
        any_cleanup = true
        active_conversations[contact_key] = nil
    end
    if options.remove_conversation ~= false and CONV and CONV.contact_id == contact_key then
        CONV = nil
    end

    if options.remove_thread == true then
        removed_threads = delete_contact_thread(contact_key)
        if removed_threads > 0 then
            any_cleanup = true
        end
    end

    return any_cleanup, removed_threads
end

local function normalize_pending_f2f_candidate(raw_handoff, source, match_mode)
    if type(raw_handoff) ~= "table" then
        return nil
    end

    local npc_sid = tonumber(raw_handoff.npc_id)
    local conv_id = tonumber(raw_handoff.conv_id)
    local turn = tonumber(raw_handoff.turn)
    if not npc_sid or npc_sid <= 0 or not conv_id or conv_id <= 0 or not turn or turn <= 0 then
        return nil
    end

    local set_at = tonumber(raw_handoff.set_at)
    if not set_at then
        return nil
    end

    local now = time_global and time_global() or nil
    if now and (now - set_at) > F2F_HANDOFF_ACTIONABLE_GRACE_MS then
        return nil
    end

    return {
        source = source or "unknown",
        match_mode = match_mode or "exact_id",
        contact_id = raw_handoff.contact_id,
        npc_id = npc_sid,
        conv_id = conv_id,
        turn = turn,
        faction = raw_handoff.faction,
        prefix = raw_handoff.prefix,
        channel = raw_handoff.channel or "f2f",
        dialog = raw_handoff.dialog,
        set_at = set_at,
        token = raw_handoff.token and tostring(raw_handoff.token) or nil,
        story_id = raw_handoff.story_id,
        canonical_id = raw_handoff.canonical_id,
        fallback_name = raw_handoff.fallback_name,
        route_owner = raw_handoff.route_owner,
        route_dialog = raw_handoff.route_dialog,
        route_status = raw_handoff.route_status,
    }
end

select_preferred_pending_f2f_candidate = function(candidates)
    if type(candidates) ~= "table" or #candidates == 0 then
        return nil
    end

    table.sort(candidates, function(a, b)
        local a_exact = a and a.match_mode == "exact_id" and 1 or 0
        local b_exact = b and b.match_mode == "exact_id" and 1 or 0
        if a_exact ~= b_exact then
            return a_exact > b_exact
        end

        local a_set_at = tonumber(a and a.set_at) or 0
        local b_set_at = tonumber(b and b.set_at) or 0
        if a_set_at ~= b_set_at then
            return a_set_at > b_set_at
        end

        local a_token = tostring(a and a.token or "")
        local b_token = tostring(b and b.token or "")
        if a_token ~= b_token then
            return a_token > b_token
        end

        return tostring(a and a.source or "") < tostring(b and b.source or "")
    end)

    local exact_candidates = {}
    local fallback_candidates = {}
    for _, candidate in ipairs(candidates) do
        if candidate.match_mode == "exact_id" then
            exact_candidates[#exact_candidates + 1] = candidate
        else
            fallback_candidates[#fallback_candidates + 1] = candidate
        end
    end

    if #exact_candidates > 0 then
        return exact_candidates[1]
    end

    if #fallback_candidates == 1 then
        return fallback_candidates[1]
    end

    return nil
end

register_pending_f2f_handoff = function(contact_id, handoff_row)
    if type(handoff_row) ~= "table" then
        return false
    end

    local contact_key = tostring(contact_id or handoff_row.contact_id or "")
    local npc_sid = tonumber(handoff_row.npc_id)
    if contact_key == "" or not npc_sid or npc_sid <= 0 then
        return false
    end

    pda_f2f_handoffs = pda_f2f_handoffs or {}

    local existing = pda_f2f_handoffs[contact_key]
    if type(existing) == "table"
        and tonumber(existing.npc_id) == npc_sid
        and tostring(existing.token or "") ~= tostring(handoff_row.token or "")
    then
        printf(
            "PANDA_IC: superseding pending f2f handoff key=%s npc_id=%s old_conv_id=%s old_turn=%s old_token=%s new_conv_id=%s new_turn=%s new_token=%s",
            tostring(contact_key),
            tostring(npc_sid),
            tostring(existing.conv_id or "nil"),
            tostring(existing.turn or "nil"),
            tostring(existing.token or "nil"),
            tostring(handoff_row.conv_id or "nil"),
            tostring(handoff_row.turn or "nil"),
            tostring(handoff_row.token or "nil")
        )
    end

    for key, existing_row in pairs(pda_f2f_handoffs) do
        if key ~= contact_key and type(existing_row) == "table" and tonumber(existing_row.npc_id) == npc_sid then
            printf(
                "PANDA_IC: superseding pending f2f handoff key=%s npc_id=%s old_conv_id=%s old_turn=%s old_token=%s new_conv_id=%s new_turn=%s new_token=%s",
                tostring(key),
                tostring(npc_sid),
                tostring(existing_row.conv_id or "nil"),
                tostring(existing_row.turn or "nil"),
                tostring(existing_row.token or "nil"),
                tostring(handoff_row.conv_id or "nil"),
                tostring(handoff_row.turn or "nil"),
                tostring(handoff_row.token or "nil")
            )
            pda_f2f_handoffs[key] = nil
        end
    end

    for key, conv in pairs(active_conversations or {}) do
        if key ~= contact_key and type(conv) == "table" and tonumber(conv.npc_id) == npc_sid and conv.pending_in_person_continuation == true then
            clear_pending_in_person_marker(conv)
        end
    end

    handoff_row.contact_id = contact_key
    pda_f2f_handoffs[contact_key] = handoff_row
    sync_pda_f2f_handoff_globals()
    return true
end

local function get_pending_f2f_handoff_internal(npc_id)
    local npc_sid = tonumber(npc_id)
    if not npc_sid then
        return nil
    end

    local runtime_story_id = nil
    local runtime_canonical_id = nil
    if type(get_object_story_id) == "function" then
        local ok_story, story_id = pcall(function() return get_object_story_id(npc_sid) end)
        if ok_story and story_id and story_id ~= "" then
            runtime_story_id = tostring(story_id)
            runtime_canonical_id = tostring(story_id):lower()
        end
    end

    local function get_match_mode(handoff)
        if type(handoff) ~= "table" then
            return nil
        end

        if tonumber(handoff.npc_id) == npc_sid then
            return "exact_id"
        end

        local handoff_story_id = handoff.story_id and tostring(handoff.story_id) or nil
        local handoff_canonical_id = handoff.canonical_id and tostring(handoff.canonical_id):lower() or nil
        local handoff_fallback_name = handoff.fallback_name and tostring(handoff.fallback_name):lower() or nil

        if runtime_story_id and handoff_story_id and handoff_story_id == runtime_story_id then
            return "story_id"
        end
        if runtime_canonical_id and handoff_canonical_id and handoff_canonical_id == runtime_canonical_id then
            return "canonical_id"
        end
        if runtime_canonical_id and handoff_fallback_name and handoff_fallback_name == runtime_canonical_id then
            return "fallback_name"
        end

        return nil
    end

    local candidates = {}
    local seen = {}

    local function push_candidate(source, raw_handoff, match_mode, contact_id)
        if not match_mode then
            return
        end

        local normalized = normalize_pending_f2f_candidate(raw_handoff, source, match_mode)
        if not normalized then
            return
        end

        if contact_id ~= nil and normalized.contact_id == nil then
            normalized.contact_id = contact_id
        end

        local signature = table.concat({
            tostring(normalized.npc_id or "0"),
            tostring(normalized.conv_id or "0"),
            tostring(normalized.turn or "0"),
            tostring(normalized.token or ""),
            tostring(normalized.set_at or 0),
            tostring(normalized.match_mode or "unknown"),
        }, ":")
        if seen[signature] then
            return
        end

        seen[signature] = true
        candidates[#candidates + 1] = normalized
    end

    if pda_f2f_handoffs then
        for contact_id, handoff in pairs(pda_f2f_handoffs) do
            push_candidate("pda_f2f_handoffs", handoff, get_match_mode(handoff), contact_id)
        end
    end

    for contact_id, conv in pairs(active_conversations) do
        if type(conv) == "table" and conv.pending_in_person_continuation == true and conv.pending_in_person_turn then
            local raw_conv_handoff = {
                contact_id = contact_id,
                npc_id = conv.npc_id,
                conv_id = conv.conv_id,
                turn = conv.pending_in_person_turn,
                faction = conv.faction,
                prefix = conv.prefix,
                channel = "f2f",
                dialog = conv.pending_in_person_target or "panda_f2f_hub_dialog",
                set_at = conv.pending_in_person_set_at,
                token = conv.pending_in_person_token,
                story_id = conv.pending_in_person_story_id or conv.story_id,
                canonical_id = conv.pending_in_person_canonical_id or conv.canonical_id,
                fallback_name = conv.fallback_name,
            }
            push_candidate("active_conversations", raw_conv_handoff, get_match_mode(raw_conv_handoff), contact_id)
        end
    end

    return select_preferred_pending_f2f_candidate(candidates)
end

consume_pending_f2f_handoff_internal = function(npc_id, conv_id, turn, token, set_at)
    local npc_sid = tonumber(npc_id)
    if not npc_sid then
        return false
    end

    local target_conv_id = tonumber(conv_id)
    local target_turn = tonumber(turn)
    local target_set_at = tonumber(set_at)
    local target_token = token and tostring(token) or nil

    local function handoff_matches_target(handoff)
        if type(handoff) ~= "table" then
            return false
        end

        if tonumber(handoff.npc_id) ~= npc_sid then
            return false
        end

        if target_token then
            return tostring(handoff.token or "") == target_token
        end

        if target_set_at then
            local handoff_set_at = tonumber(handoff.set_at)
            return handoff_set_at ~= nil and handoff_set_at == target_set_at
        end

        if target_conv_id and tonumber(handoff.conv_id) ~= target_conv_id then
            return false
        end

        if target_turn and tonumber(handoff.turn) ~= target_turn then
            return false
        end

        return true
    end

    local function conv_matches_target(conv)
        if type(conv) ~= "table" then
            return false
        end

        if tonumber(conv.npc_id) ~= npc_sid or conv.pending_in_person_continuation ~= true then
            return false
        end

        if target_token then
            return tostring(conv.pending_in_person_token or "") == target_token
        end

        if target_set_at then
            local pending_set_at = tonumber(conv.pending_in_person_set_at)
            return pending_set_at ~= nil and pending_set_at == target_set_at
        end

        if target_conv_id and tonumber(conv.conv_id) ~= target_conv_id then
            return false
        end

        if target_turn and tonumber(conv.pending_in_person_turn) ~= target_turn then
            return false
        end

        return true
    end

    local consumed = false

    if pda_f2f_handoffs then
        for key, handoff in pairs(pda_f2f_handoffs) do
            if handoff_matches_target(handoff) then
                pda_f2f_handoffs[key] = nil
                consumed = true
            elseif tonumber(handoff.npc_id) == npc_sid
                and (not target_conv_id or tonumber(handoff.conv_id) == target_conv_id)
                and (not target_turn or tonumber(handoff.turn) == target_turn)
            then
                printf(
                    "PANDA_IC: preserving newer f2f handoff key=%s npc_id=%s conv_id=%s turn=%s token=%s requested_token=%s set_at=%s requested_set_at=%s",
                    tostring(key),
                    tostring(handoff.npc_id),
                    tostring(handoff.conv_id),
                    tostring(handoff.turn),
                    tostring(handoff.token or "nil"),
                    tostring(target_token or "nil"),
                    tostring(handoff.set_at or "nil"),
                    tostring(target_set_at or "nil")
                )
            end
        end

        local has_remaining_handoffs = false
        for _ in pairs(pda_f2f_handoffs) do
            has_remaining_handoffs = true
            break
        end

        if has_remaining_handoffs then
            _G.pda_f2f_handoffs = pda_f2f_handoffs
        else
            pda_f2f_handoffs = nil
            _G.pda_f2f_handoffs = nil
        end
    end

    for contact_id, conv in pairs(active_conversations) do
        if conv_matches_target(conv) then
            clear_pending_in_person_marker(conv)
            -- Remove completed conversation so new ones can trigger for this NPC
            active_conversations[contact_id] = nil
            if CONV and CONV.contact_id == contact_id then
                CONV = nil
            end
            consumed = true
        elseif tonumber(conv.npc_id) == npc_sid
            and conv.pending_in_person_continuation == true
            and (not target_conv_id or tonumber(conv.conv_id) == target_conv_id)
            and (not target_turn or tonumber(conv.pending_in_person_turn) == target_turn)
        then
            printf(
                "PANDA_IC: preserving newer pending_in_person marker npc_id=%s conv_id=%s turn=%s token=%s requested_token=%s set_at=%s requested_set_at=%s",
                tostring(conv.npc_id),
                tostring(conv.conv_id),
                tostring(conv.pending_in_person_turn),
                tostring(conv.pending_in_person_token or "nil"),
                tostring(target_token or "nil"),
                tostring(conv.pending_in_person_set_at or "nil"),
                tostring(target_set_at or "nil")
            )
        end
    end

    return consumed
end

build_savable_f2f_handoffs = function()
    if type(pda_f2f_handoffs) ~= "table" then
        return nil
    end

    local now = time_global and time_global() or nil
    local out = {}
    local saved_any = false

    for key, handoff in pairs(pda_f2f_handoffs) do
        if type(handoff) == "table" then
            local contact_key = tostring(handoff.contact_id or key)
            local actionable = is_handoff_actionable(handoff, now)
            if not is_contact_blocked(contact_key) and actionable == true then
                local cloned = {}
                for field_name, field_value in pairs(handoff) do
                    cloned[field_name] = field_value
                end
                cloned.contact_id = contact_key
                out[contact_key] = cloned
                saved_any = true
            end
        end
    end

    if saved_any then
        return out
    end

    return nil
end

local function sweep_expired_f2f_pending_markers(reason)
    local now = time_global and time_global() or nil
    if not now then
        return {
            stale_pending_cleared = 0,
            handoff_rows_removed = 0,
            source_reason = tostring(reason or "unspecified"),
        }
    end

    local stale_pending_cleared = 0
    local handoff_rows_removed = 0
    local stale_entries = {}

    for contact_id, conv in pairs(active_conversations or {}) do
        if type(conv) == "table" and conv.pending_in_person_continuation == true then
            local set_at = tonumber(conv.pending_in_person_set_at)
            local age_ms = set_at and (now - set_at) or nil
            if not set_at or age_ms > F2F_HANDOFF_ACTIONABLE_GRACE_MS then
                table.insert(stale_entries, {
                    contact_id = contact_id,
                    npc_id = tonumber(conv.npc_id),
                    conv_id = tonumber(conv.conv_id),
                    turn = tonumber(conv.pending_in_person_turn),
                    set_at = set_at,
                    age_ms = age_ms,
                })
                conv.pending_in_person_continuation = false
                conv.pending_in_person_turn = nil
                conv.pending_in_person_target = nil
                conv.pending_in_person_set_at = nil
                conv.pending_in_person_token = nil
                conv.pending_in_person_story_id = nil
                conv.pending_in_person_canonical_id = nil
                -- Remove the zombie conversation so new ones can trigger
                active_conversations[contact_id] = nil
                if CONV and CONV.contact_id == contact_id then
                    CONV = nil
                end
                stale_pending_cleared = stale_pending_cleared + 1
            end
        end
    end

    if #stale_entries > 0 and type(pda_f2f_handoffs) == "table" then
        for key, handoff in pairs(pda_f2f_handoffs) do
            if type(handoff) == "table" then
                local handoff_npc = tonumber(handoff.npc_id)
                local handoff_conv = tonumber(handoff.conv_id)
                local handoff_turn = tonumber(handoff.turn)
                for _, stale in ipairs(stale_entries) do
                    local npc_match = stale.npc_id and handoff_npc and stale.npc_id == handoff_npc
                    local conv_match = stale.conv_id and handoff_conv and stale.conv_id == handoff_conv
                    local turn_match = stale.turn and handoff_turn and stale.turn == handoff_turn
                    if npc_match and (conv_match or turn_match or (not stale.conv_id and not stale.turn)) then
                        pda_f2f_handoffs[key] = nil
                        handoff_rows_removed = handoff_rows_removed + 1
                        break
                    end
                end
            end
        end

        local has_remaining_handoffs = false
        for _ in pairs(pda_f2f_handoffs) do
            has_remaining_handoffs = true
            break
        end

        if has_remaining_handoffs then
            _G.pda_f2f_handoffs = pda_f2f_handoffs
        else
            pda_f2f_handoffs = nil
            _G.pda_f2f_handoffs = nil
        end
    end

    if stale_pending_cleared > 0 or handoff_rows_removed > 0 then
        printf(
            "PANDA_IC: f2f marker safety sweep reason=%s stale_pending_cleared=%s handoff_rows_removed=%s",
            tostring(reason or "unspecified"),
            tostring(stale_pending_cleared),
            tostring(handoff_rows_removed)
        )
    end

    return {
        stale_pending_cleared = stale_pending_cleared,
        handoff_rows_removed = handoff_rows_removed,
        source_reason = tostring(reason or "unspecified"),
    }
end

local function resolve_npc_server_id(npc_se)
    if not npc_se then
        return nil
    end

    local sid = tonumber(npc_se.id)
    if not sid and type(npc_se.id) == "function" then
        local ok, from_fn = pcall(function() return npc_se:id() end)
        if ok then
            sid = tonumber(from_fn)
        end
    end

    if not sid or sid <= 0 then
        return nil
    end

    return math.floor(sid)
end

local function get_npc_story_or_name_id(npc_se)
    local sid = resolve_npc_server_id(npc_se)
    if sid and type(get_object_story_id) == "function" then
        local ok_story, story_id = pcall(function() return get_object_story_id(sid) end)
        if ok_story and story_id and story_id ~= "" then
            return tostring(story_id), "story"
        end
    end

    if npc_se and npc_se.name then
        local ok_name, fallback_name = pcall(function() return npc_se:name() end)
        if ok_name and fallback_name and fallback_name ~= "" then
            return tostring(fallback_name), "name"
        end
    end

    return nil, nil
end

build_f2f_handoff_identity = function(npc_se, fallback_npc_id)
    local out = {
        npc_id = resolve_npc_server_id(npc_se) or tonumber(fallback_npc_id) or nil,
        story_id = nil,
        canonical_id = nil,
        fallback_name = nil,
    }

    if out.npc_id and type(get_object_story_id) == "function" then
        local ok_story, story_id = pcall(function() return get_object_story_id(out.npc_id) end)
        if ok_story and story_id and story_id ~= "" then
            out.story_id = tostring(story_id)
        end
    end

    if PANDA_CONV_API and type(PANDA_CONV_API.get_npc_canonical_id) == "function" and npc_se then
        local ok_canonical, canonical_id = pcall(function()
            return PANDA_CONV_API.get_npc_canonical_id(npc_se)
        end)
        if ok_canonical and canonical_id and canonical_id ~= "" then
            out.canonical_id = tostring(canonical_id):lower()
        end
    end

    if npc_se and npc_se.name then
        local ok_name, fallback_name = pcall(function() return npc_se:name() end)
        if ok_name and fallback_name and fallback_name ~= "" then
            out.fallback_name = tostring(fallback_name)
        end
    end

    if not out.canonical_id then
        if out.story_id and out.story_id ~= "" then
            out.canonical_id = tostring(out.story_id):lower()
        elseif out.fallback_name and out.fallback_name ~= "" then
            out.canonical_id = tostring(out.fallback_name):lower()
        end
    end

    return out
end

make_f2f_handoff_token = function(npc_id, conv_id, turn, set_at)
    local rand = math.random(100000, 999999)
    return string.format(
        "f2f_%s_%s_%s_%s_%s",
        tostring(tonumber(npc_id) or 0),
        tostring(tonumber(conv_id) or 0),
        tostring(tonumber(turn) or 0),
        tostring(tonumber(set_at) or 0),
        tostring(rand)
    )
end

PANDA_CONV_API = PANDA_CONV_API or {}

function PANDA_CONV_API.resolve_conversation_context(npc_id, conversation_id, turn_number, channel)
    return resolve_conversation_context_internal(npc_id, conversation_id, turn_number, channel or "pda")
end

function PANDA_CONV_API.check_preconditions(precond_key, npc_se, channel, context)
    local resolved_channel = channel or "pda"
    if type(context) == "table" and context.channel == nil then
        context.channel = resolved_channel
    end
    return check_preconditions_generic(precond_key, npc_se)
end

function PANDA_CONV_API.apply_choice(conversation_context, choice_index, channel)
    return apply_choice_internal(conversation_context, choice_index, channel or "pda")
end

function PANDA_CONV_API.apply_outcome(outcome_str, sender_npc_name, sender_faction, sender_npc_id, task_id, contact_id, conv_data, channel)
    return apply_outcome(
        outcome_str,
        sender_npc_name,
        sender_faction,
        sender_npc_id,
        task_id,
        contact_id,
        conv_data,
        channel or "pda"
    )
end

function PANDA_CONV_API.get_pending_f2f_handoff(npc_id)
    return get_pending_f2f_handoff_internal(npc_id)
end

function PANDA_CONV_API.consume_pending_f2f_handoff(npc_id, conv_id, turn, token, set_at)
    return consume_pending_f2f_handoff_internal(npc_id, conv_id, turn, token, set_at)
end

function PANDA_CONV_API.sweep_expired_f2f_markers(reason)
    return sweep_expired_f2f_pending_markers(reason)
end

function PANDA_CONV_API.get_npc_canonical_id(npc_se)
    local raw_id = get_npc_story_or_name_id(npc_se)
    if not raw_id then
        return nil
    end
    return tostring(raw_id):lower()
end

function start_interactive_conv(npc_se, conv_id, prefix, faction, task_id, category)
    local name = npc_se:character_name()
    local contact_id = make_contact_id(npc_se)
    local identity = build_f2f_handoff_identity(npc_se)

    if is_contact_blocked(contact_id) then
        return false
    end

    -- Block if this specific NPC already has an active conversation
    if active_conversations[contact_id] then return false end

    -- Initialize relationship score for hostile NPCs on first contact
    if not npc_relationship_scores[contact_id] then
        local npc_obj = level.object_by_id(npc_se.id)
        if npc_obj and npc_obj:relation(db.actor) == game_object.enemy then
            npc_relationship_scores[contact_id] = -200  -- Wary default for hostile NPCs
        end
    end

    -- Clear smart terrain placeholder cache for fresh resolution this conversation
    clear_st_resolve_cache()

    local key
    if prefix == "task" or not prefix then
        key = "st_pda_ic_"..faction.."_"..tostring(conv_id).."_open"
    else
        key = "st_pda_ic_"..prefix.."_"..faction.."_"..tostring(conv_id).."_open"
    end

    local msg = game.translate_string(key)
    if msg == key then return false end

    local choices, num = load_choices_for_turn(prefix, faction, conv_id, 1, name, contact_id, npc_se)
    if num == 0 then return false end

    local conv_data = {
        npc_id = identity.npc_id or npc_se.id,
        contact_id = contact_id,
        npc_name = name,
        npc_icon = npc_se:character_icon() or FALLBACK_NPC_ICON,
        faction = faction,
        prefix = prefix,
        conv_id = conv_id,
        turn = 1,
        choices = choices,
        num_choices = num,
        task_id = task_id,
        category = category,
        applied_outcomes = {}, -- Track applied outcomes to prevent farming during UI loops
        started_at = time_global(),  -- Track when conversation started (for timeout)
        reply_pending = false,  -- Per-conversation reply pending flag
        story_id = identity.story_id,
        canonical_id = identity.canonical_id,
        fallback_name = identity.fallback_name,
    }

    -- Store in multi-conversation table keyed by contact_id
    active_conversations[contact_id] = conv_data
    -- Keep CONV pointing to the latest conversation for backward compatibility
    CONV = conv_data

    last_conv_npc_id = npc_se.id
    record_npc_use(npc_se.id)

    -- Register NPC metadata for typing personality transforms
    if pda_typing_personality and pda_typing_personality.register_npc then
        local rank_name = get_npc_rank_name(npc_se) or "experienced"
        pda_typing_personality.register_npc(contact_id, faction, rank_name)
    end

    -- Send ONLY the Generic Global Chat Alert
    dynamic_news_helper.send_tip(
        "You've received a Private Message from " .. name,
        "PDA Alert", 0, 10, conv_data.npc_icon, "news", "npc"
    )

    -- Add the actual message directly into the custom Private PDA Log
    pda_private_add_message(contact_id, name, name, sub_placeholders(msg, name, faction, npc_se, contact_id), conv_data.npc_icon, false)

    -- Force refresh of UI if PDA is actively open so the message pops up immediately
    if get_ui then
        get_ui():Reset()
    end

    return true
end

-- ============================================================
-- STORY NPC CONVERSATION SCANNING
-- ============================================================
-- Extracts req_story_npc:<id> from a precondition string.
-- Returns the story_id or nil if not present.
local function extract_story_npc_id(precond_str)
    if not precond_str or precond_str == "" then return nil end
    return string.match(precond_str, "req_story_npc:([%w_%-]+)")
end

-- Scans all conversations for a faction and finds those that require a specific
-- story NPC.  For each, looks up the story NPC in alife and checks whether all
-- preconditions pass.  Returns a list of {npc_se, conv_id} tables.
local function collect_story_npc_conversations(xml_fac)
    local results = {}
    local base = "st_pda_ic_"
    local mode = PANDA.get_config("cooldown_mode")
    local penalty = PANDA.get_config("cooldown_penalty") / 100
    local hard_min = PANDA.get_config("cooldown_hard_min") * 60

    -- Discover max_id using the same scan as pick_random_conv_id_generic
    local max_id = 0
    while true do
        local p = base .. xml_fac .. "_" .. tostring(max_id + 1) .. "_open"
        if game.translate_string(p) == p then break end
        max_id = max_id + 1
    end
    if max_id == 0 then return results end

    for cid = 1, max_id do
        local precond_key = base .. xml_fac .. "_" .. tostring(cid) .. "_precond"
        local precond_val = game.translate_string(precond_key)
        if precond_val == precond_key then precond_val = "" end

        local story_id = extract_story_npc_id(precond_val)
        if story_id then
            local npc_se = get_story_se_object(story_id)
            if npc_se and npc_se:alive() then
                -- NPC cooldown
                if not is_npc_on_cooldown(npc_se.id) then
                    -- Conversation cooldown
                    local cooldown_key = "task_" .. xml_fac .. "_" .. cid
                    local last = conv_last_played[cooldown_key]
                    local skip = false
                    local weight = 100

                    if last then
                        local seconds_since = game.get_game_time():diffSec(last)
                        local on_cooldown = seconds_since < (PANDA.get_config("default_cooldown") * 60)
                        if on_cooldown then
                            if mode == 1 then
                                skip = true
                            elseif seconds_since < hard_min then
                                skip = true
                            else
                                weight = penalty * 100
                            end
                        end
                    end

                    if not skip then
                        -- Full precondition check (including req_story_npc itself)
                        if check_preconditions_generic(precond_key, npc_se) then
                            table.insert(results, {npc_se = npc_se, conv_id = cid, weight = weight})
                            printf("Story NPC conv %s matched — NPC %s (story_id=%s, weight=%s)",
                                tostring(tonumber(cid) or 0),
                                tostring(npc_se:character_name()),
                                tostring(story_id),
                                tostring(tonumber(weight) or 0))
                            printf("TRACE story-match npc_sid=%s story_id=%s conv_id=%s next_turn=%s channel=%s",
                                tostring(tonumber(npc_se.id) or 0),
                                tostring(story_id),
                                tostring(tonumber(cid) or 0),
                                tostring("n/a"),
                                tostring("pda"))
                        end
                    end
                end
            end
        end
    end

    return results
end

-- ============================================================
-- INTERACTIVE CONVERSATION ATTEMPT (merged system — no prefix)
-- Preconditions on each conversation handle NPC filtering
-- (friendly/hostile, faction, rank, etc.) via goodwill checks.
-- Story NPC conversations are mixed into the same pool as
-- simulated NPC conversations for equal selection chance.
-- ============================================================
local function attempt_interactive_conversation()
    printf("Attempting interactive conversation (merged system)")

    local player_comm = get_actor_true_community() or "stalker"
    local xml_fac = (player_comm == "stalker") and "loner" or player_comm

    -- Phase 1: Collect story NPC conversation candidates
    local story_matches = collect_story_npc_conversations(xml_fac)
    printf(string.format("Found %d story NPC conversation candidates", #story_matches))

    -- Phase 2: Collect simulated NPC conversation candidates (existing flow)
    local sim_matches = {}
    local npc_list = get_all_eligible_npcs()
    printf(string.format("Found %d eligible simulated NPCs", #npc_list))

    local pool = {}
    for i = 1, #npc_list do pool[i] = npc_list[i] end

    while #pool > 0 do
        local idx = math.random(#pool)
        local candidate = table.remove(pool, idx)
        local candidate_conv = pick_random_conv_id_generic(nil, xml_fac, nil, candidate)
        if candidate_conv then
            table.insert(sim_matches, {npc_se = candidate, conv_id = candidate_conv, weight = 100})
            -- Stop after finding one simulated match (preserves existing behavior
            -- where one random NPC is selected from the pool)
            break
        end
    end

    -- Phase 3: Merge both pools and do weighted random selection
    local all_matches = {}
    for _, m in ipairs(story_matches) do
        if m.npc_se and not is_contact_blocked(make_contact_id(m.npc_se)) then
            table.insert(all_matches, m)
        end
    end
    for _, m in ipairs(sim_matches) do
        if m.npc_se and not is_contact_blocked(make_contact_id(m.npc_se)) then
            table.insert(all_matches, m)
        end
    end

    if #all_matches == 0 then
        printf("No interactive conversation found for faction %s (no story or simulated NPC matches).", xml_fac)
        return false
    end

    -- Weighted random pick from merged pool
    local total_weight = 0
    for _, m in ipairs(all_matches) do total_weight = total_weight + m.weight end

    local r = math.random(total_weight)
    local accum = 0
    local pick = all_matches[1]
    for _, m in ipairs(all_matches) do
        accum = accum + m.weight
        if r <= accum then
            pick = m
            break
        end
    end

    printf("Picked NPC: %s (ID %s)",
        tostring(pick.npc_se:character_name()),
        tostring(tonumber(pick.npc_se.id) or 0))
    printf("Selected conv_id = %s", tostring(tonumber(pick.conv_id) or 0))

    return start_interactive_conv(pick.npc_se, pick.conv_id, nil, xml_fac, nil, nil)
end

-- ============================================================
-- CONVERSATION TIMEOUT SYSTEM
-- ============================================================
-- Each conversation can define a timeout (in real seconds) and an annoyed
-- message that gets sent when the player ignores the NPC.  Timeouts are
-- read from XML: st_pda_ic_<prefix>_<fac>_<id>_timeout  (seconds, e.g. "120")
--                 st_pda_ic_<prefix>_<fac>_<id>_timeout_msg (annoyed text)
-- If no XML timeout is found, a random default between 90-300 seconds is used.

local CONV_TIMEOUT_DEFAULT_MIN = 90   -- seconds (real-time)
local CONV_TIMEOUT_DEFAULT_MAX = 300

local function get_conv_timeout_config(prefix, faction, conv_id)
    local base
    if prefix == "task" or not prefix then
        base = "st_pda_ic_" .. faction .. "_" .. tostring(conv_id)
    else
        base = "st_pda_ic_" .. prefix .. "_" .. faction .. "_" .. tostring(conv_id)
    end

    local timeout_key = base .. "_timeout"
    local timeout_msg_key = base .. "_timeout_msg"

    local timeout_val = game.translate_string(timeout_key)
    local timeout_secs = nil
    if timeout_val ~= timeout_key then
        timeout_secs = tonumber(timeout_val)
    end
    if not timeout_secs then
        timeout_secs = math.random(CONV_TIMEOUT_DEFAULT_MIN, CONV_TIMEOUT_DEFAULT_MAX)
    end

    local timeout_msg = game.translate_string(timeout_msg_key)
    if timeout_msg == timeout_msg_key then
        timeout_msg = nil  -- Will use a generic fallback
    end

    return timeout_secs, timeout_msg
end

local GENERIC_TIMEOUT_MESSAGES = {
    "You know what, forget it. I don't have time for this.",
    "Still there? No? Fine, I'll find someone else.",
    "Guess you're not interested. Signal lost.",
    "I waited long enough. Don't bother replying.",
    "Typical. Can't even get a straight answer in this place.",
}

function check_conversation_timeouts()
    if not active_conversations then return end
    local now = time_global()

    local expired = {}
    for cid, conv in pairs(active_conversations) do
        -- Skip conversations that have a pending job (they are "paused")
        if conv.started_at and not conv.reply_pending and not has_pending_job(cid) then
            local timeout_secs, timeout_msg = get_conv_timeout_config(
                conv.prefix, conv.faction, conv.conv_id
            )
            -- time_global returns milliseconds
            local elapsed_ms = now - conv.started_at
            local elapsed_secs = elapsed_ms / 1000

            if elapsed_secs >= timeout_secs then
                table.insert(expired, { contact_id = cid, conv = conv, msg = timeout_msg })
            end
        end
    end

    for _, exp in ipairs(expired) do
        local conv = exp.conv
        local annoyed_msg = exp.msg
            or GENERIC_TIMEOUT_MESSAGES[math.random(#GENERIC_TIMEOUT_MESSAGES)]

        -- Substitute placeholders in the annoyed message
        annoyed_msg = sub_placeholders(annoyed_msg, conv.npc_name, conv.faction, conv.npc_id and alife_object(conv.npc_id) or nil, exp.contact_id)

        -- Add the annoyed message to the chat log
        pda_private_add_message(exp.contact_id, conv.npc_name, conv.npc_name, annoyed_msg, conv.npc_icon, false)

        abort_contact_f2f_state(exp.contact_id, "conversation_timeout", {
            remove_conversation = true,
            cancel_events = true,
        })

        -- Record cooldown
        local composite_key = (conv.prefix or "task") .. "_" .. conv.faction .. "_" .. conv.conv_id
        conv_last_played[composite_key] = game.get_game_time()

        printf("Conversation with %s timed out after %.0f seconds", conv.npc_name,
            (now - conv.started_at) / 1000)
    end

    -- Refresh UI if any expired
    if #expired > 0 and pda_private_tab and pda_private_tab.get_ui then
        pda_private_tab.get_ui():Reset()
    end
end

-- ============================================================
-- MAIN TRIGGER & SCHEDULING
-- ============================================================

local function is_actor_currently_in_dialog()
    if not (db and db.actor) then
        return false
    end

    if db.actor_dialog then
        return true
    end

    if db.actor.is_talking then
        local ok, talking = pcall(function()
            return db.actor:is_talking()
        end)
        if ok and talking then
            return true
        end
    end

    return false
end

is_handoff_actionable = function(handoff, now_ms)
    if type(handoff) ~= "table" then
        return false, "invalid_type"
    end

    local npc_id = tonumber(handoff.npc_id)
    local conv_id = tonumber(handoff.conv_id)
    local turn = tonumber(handoff.turn)

    if not npc_id or npc_id <= 0 then
        return false, "invalid_npc_id"
    end

    if not conv_id or conv_id <= 0 then
        return false, "invalid_conv_id"
    end

    if not turn or turn <= 0 then
        return false, "invalid_turn"
    end

    if now_ms then
        local set_at = tonumber(handoff.set_at)
        if not set_at then
            return false, "missing_set_at"
        end

        local age_ms = now_ms - set_at
        if age_ms > F2F_HANDOFF_ACTIONABLE_GRACE_MS then
            return false, string.format("stale_age age_ms=%s grace_ms=%s", tostring(age_ms), tostring(F2F_HANDOFF_ACTIONABLE_GRACE_MS))
        end
    end

    return true, nil
end

local function has_pending_f2f_handoff_entries()
    if type(pda_f2f_handoffs) ~= "table" then
        return false
    end

    local now = time_global and time_global() or nil
    local has_actionable = false
    local pruned_any = false

    for key, handoff in pairs(pda_f2f_handoffs) do
        local contact_key = tostring(handoff and handoff.contact_id or key)
        local actionable, reason = is_handoff_actionable(handoff, now)
        if actionable and is_contact_blocked(contact_key) then
            actionable = false
            reason = "blocked_contact"
        end
        if actionable then
            has_actionable = true
        else
            pda_f2f_handoffs[key] = nil
            pruned_any = true
            printf(
                "PANDA_IC: purged stale f2f handoff key=%s reason=%s npc_id=%s conv_id=%s turn=%s set_at=%s",
                tostring(key),
                tostring(reason or "invalid"),
                tostring(handoff and handoff.npc_id),
                tostring(handoff and handoff.conv_id),
                tostring(handoff and handoff.turn),
                tostring(handoff and handoff.set_at)
            )
        end
    end

    if pruned_any then
        local has_remaining = false
        for _ in pairs(pda_f2f_handoffs) do
            has_remaining = true
            break
        end

        if has_remaining then
            _G.pda_f2f_handoffs = pda_f2f_handoffs
        else
            pda_f2f_handoffs = nil
            _G.pda_f2f_handoffs = nil
        end
    end

    return has_actionable
end

local function bridge_reports_active_f2f_session()
    local bridge = ensure_panda_f2f_bridge()
    if not bridge then
        return false, nil
    end

    local probes = {
        "is_session_active",
        "has_active_session",
        "is_active_for_actor",
        "session_active_for_actor",
    }

    for _, fn_name in ipairs(probes) do
        local fn = bridge[fn_name]
        if type(fn) == "function" then
            local ok, active = pcall(fn, db and db.actor or nil)
            if ok and active == true then
                return true, fn_name
            end
        end
    end

    return false, nil
end

local function is_f2f_session_active_for_actor()
    if has_pending_f2f_handoff_entries() then
        return true, "handoff_table"
    end

    for _, conv in pairs(active_conversations or {}) do
        if type(conv) == "table" and conv.pending_in_person_continuation == true then
            return true, "pending_in_person_continuation"
        end
    end

    local bridge_active, bridge_probe = bridge_reports_active_f2f_session()
    if bridge_active then
        return true, "bridge_runtime:" .. tostring(bridge_probe)
    end

    return false, nil
end

local function log_f2f_scanner_suppression_once(source_reason)
    local source = tostring(source_reason or "unknown")
    local source_changed = source ~= _f2f_scanner_suppress_last_source
    local now = time_global and time_global() or nil
    if (not source_changed)
        and now
        and _f2f_scanner_suppress_last_log_at
        and (now - _f2f_scanner_suppress_last_log_at) < F2F_SCANNER_SUPPRESS_LOG_WINDOW_MS
    then
        return
    end

    _f2f_scanner_suppress_last_source = source

    if now then
        _f2f_scanner_suppress_last_log_at = now
    end

    printf(
        "PANDA_IC: scanner suppressed reason=f2f_session_active source=%s",
        source
    )
end

function try_trigger_interactive_conv()
    if not PANDA.get_config("enabled") then
        printf("Trigger skipped: disabled")
        return false
    end
    if not is_player_chat_online() then
        printf("Trigger skipped: player chat is offline")
        return false
    end
    sweep_expired_f2f_pending_markers("periodic_scanner_gate")
    local f2f_active, f2f_source = is_f2f_session_active_for_actor()
    if f2f_active then
        -- Guard: while an F2F handoff/session is active, skip scanner selection and
        -- precondition evaluation so we do not overwrite shared conversation context.
        log_f2f_scanner_suppression_once(f2f_source)
        return false
    end
    -- Allow up to 3 simultaneous conversations (configurable)
    local max_active = 3
    if count_active_conversations() >= max_active then
        printf("Trigger skipped: %d active conversations (max %d)", count_active_conversations(), max_active)
        return false
    end
    if not db.actor then
        printf("Trigger skipped: no actor")
        return false
    end
    if is_actor_currently_in_dialog() then
        printf("Trigger skipped: actor currently in dialog")
        return false
    end
    if PANDA.get_config("require_pda_equipped") and not db.actor:item_in_slot(8) then
        printf("Trigger skipped: PDA not equipped")
        return false
    end

    -- Merged system: all conversations are interactive.
    -- Preconditions on each conversation handle NPC filtering
    -- (friendly/hostile via goodwill, faction, rank, etc.)
    return attempt_interactive_conversation()
end

local function schedule_next_trigger(interval_min)
    local tf = level.get_time_factor() or 10
    if tf <= 0 then tf = 10 end
    interval_min = math.max(1, tonumber(interval_min) or 1)
    -- Convert in-game minutes to real seconds
    local delay = (interval_min * 60) / tf
    CreateTimeEvent("pda_ic_trigger", "tick", delay, function()
        -- Check for timed-out conversations before triggering new ones
        check_conversation_timeouts()
        try_trigger_interactive_conv()
        schedule_next_trigger(math.random(PANDA.get_config("trigger_min"), PANDA.get_config("trigger_max")))
        return true
    end)
end

-- Also run timeout checks more frequently (every 10 real seconds)
local function schedule_timeout_checker()
    CreateTimeEvent("pda_ic_timeout", "check", 10, function()
        check_conversation_timeouts()
        sweep_expired_f2f_pending_markers("periodic_timeout_checker")
        return false  -- Keep repeating
    end)
end

local function schedule_location_ref_checker()
    local interval = tonumber(PANDA.get_config("location_check_interval")) or 5
    if interval < 1 then interval = 1 end

    CreateTimeEvent("pda_ic_location", "check", interval, function()
        check_location_references()
        return false
    end)
end

local function schedule_job_checker()
    CreateTimeEvent("pda_ic_jobs", "check", 5, function()
        check_pending_jobs()
        return false -- Keep repeating
    end)
end


-- ============================================================
-- KEYBOARD CALLBACKS
-- ============================================================
function on_key_press_cb(key)
    -- debug trigger if enabled. All choice interactions are in the PDA UI now.
    if key == DIK_SPACE and not CONV and PANDA.get_config("debug_trigger") then
        try_trigger_interactive_conv()
    end
end

-- ============================================================
-- SAVE / LOAD (cooldowns)
-- ============================================================
function save_state(m)
    m.pda_ic_cooldowns = conv_last_played
    m.pda_ic_npc_cooldowns = npc_last_used
    m.pda_private_log = pda_private_log -- SAVE TO FILE
    m.pda_private_blocked_contacts = pda_private_blocked_contacts
    m.pda_player_chat_online = pda_player_chat_online
    m.pda_npc_relationship_scores = npc_relationship_scores
    -- Save active conversations (strip non-serializable fields)
    local save_convs = {}
    for cid, c in pairs(active_conversations) do
        if not is_contact_blocked(cid) then
            save_convs[cid] = {
                npc_id = c.npc_id, contact_id = c.contact_id,
                npc_name = c.npc_name, npc_icon = c.npc_icon,
                faction = c.faction, prefix = c.prefix, conv_id = c.conv_id,
                turn = c.turn, task_id = c.task_id, category = c.category,
                applied_outcomes = c.applied_outcomes, started_at = c.started_at,
                story_id = c.story_id, canonical_id = c.canonical_id, fallback_name = c.fallback_name,
                pending_in_person_continuation = c.pending_in_person_continuation,
                pending_in_person_turn = c.pending_in_person_turn,
                pending_in_person_target = c.pending_in_person_target,
                pending_in_person_set_at = c.pending_in_person_set_at,
                pending_in_person_token = c.pending_in_person_token,
                pending_in_person_story_id = c.pending_in_person_story_id,
                pending_in_person_canonical_id = c.pending_in_person_canonical_id,
            }
        end
    end
    m.pda_active_conversations = save_convs
    m.pda_f2f_handoffs = build_savable_f2f_handoffs()
    m.pda_pending_location_refs = pending_location_refs
    m.pda_next_location_ref_id = next_location_ref_id
    m.pda_pending_jobs = pending_jobs
    m.pda_next_job_id = next_job_id

    local adapter = get_anomaly_artifact_adapter()
    if adapter and adapter.save_state then
        adapter.save_state(m)
    end
end

function load_state(m)
    if m.pda_ic_cooldowns then conv_last_played = m.pda_ic_cooldowns end
    if m.pda_ic_npc_cooldowns then npc_last_used = m.pda_ic_npc_cooldowns end
    if m.pda_npc_relationship_scores then npc_relationship_scores = m.pda_npc_relationship_scores end
    active_conversations = {}
    CONV = nil
    pda_reply_pending = false
    pending_location_refs = {}
    next_location_ref_id = 1
    pending_jobs = {}
    next_job_id = 1
    if m.pda_private_log then
        pda_private_log = m.pda_private_log -- LOAD FROM FILE
        local i = #pda_private_log
        while i >= 1 do
            local entry = pda_private_log[i]
            if entry and entry.is_typing then
                table.remove(pda_private_log, i)
            elseif entry and entry.is_player then
                entry.delivery_state = normalize_delivery_state(entry.delivery_state)
                if entry.delivery_timestamp == nil then
                    entry.delivery_timestamp = get_delivery_time_marker()
                end
            end
            -- Migration: old saves have contact_name but no contact_id
            if entry and not entry.contact_id then
                entry.contact_id = entry.contact_name
            end
            i = i - 1
        end
    end

    if m.pda_private_blocked_contacts then
        pda_private_blocked_contacts = m.pda_private_blocked_contacts
    end

    if m.pda_player_chat_online ~= nil then
        pda_player_chat_online = m.pda_player_chat_online
    end

    if m.pda_pending_location_refs then
        pending_location_refs = m.pda_pending_location_refs
    end

    if m.pda_next_location_ref_id then
        next_location_ref_id = m.pda_next_location_ref_id
    end

    if m.pda_pending_jobs then
        pending_jobs = m.pda_pending_jobs
        -- Reset started_at to now so timeout counting restarts from load
        -- (prevents instant timeout after load)
        for _, job in pairs(pending_jobs) do
            job.started_at = time_global()
        end
    end

    if m.pda_next_job_id then
        next_job_id = m.pda_next_job_id
    end

    -- Restore explicit f2f handoff table before any bridge-dependent post-load logic runs.
    pda_f2f_handoffs = nil
    if type(m.pda_f2f_handoffs) == "table" then
        local now = time_global and time_global() or nil
        local restored_handoffs = {}
        for key, handoff in pairs(m.pda_f2f_handoffs) do
            if type(handoff) == "table" then
                local contact_key = tostring(handoff.contact_id or key)
                local actionable = is_handoff_actionable(handoff, now)
                if not is_contact_blocked(contact_key) and actionable == true then
                    local cloned = {}
                    for field_name, field_value in pairs(handoff) do
                        cloned[field_name] = field_value
                    end
                    cloned.contact_id = contact_key
                    restored_handoffs[contact_key] = cloned
                end
            end
        end
        if next(restored_handoffs) ~= nil then
            pda_f2f_handoffs = restored_handoffs
        end
    end
    if pda_f2f_handoffs then
        _G.pda_f2f_handoffs = pda_f2f_handoffs
    else
        _G.pda_f2f_handoffs = nil
    end

    local adapter = get_anomaly_artifact_adapter()
    if adapter and adapter.load_state then
        adapter.load_state(m)
    end

    -- Restore active conversations and rebuild their choices
    if m.pda_active_conversations then
        for key, saved in pairs(m.pda_active_conversations) do
            -- Migration: old saves keyed by npc_name; re-key using npc_id if available
            local cid = saved.contact_id or (saved.npc_id and tostring(saved.npc_id)) or key
            saved.contact_id = cid
            if not is_contact_blocked(cid) then
                local choices, num = load_choices_for_turn(
                    saved.prefix, saved.faction, saved.conv_id, saved.turn, saved.npc_name, cid
                )
                if num > 0 then
                    saved.choices = choices
                    saved.num_choices = num
                    saved.reply_pending = false
                    saved.pending_in_person_continuation = saved.pending_in_person_continuation == true
                    saved.pending_in_person_turn = saved.pending_in_person_turn
                    saved.pending_in_person_target = saved.pending_in_person_target
                    saved.pending_in_person_set_at = saved.pending_in_person_set_at
                    saved.pending_in_person_token = saved.pending_in_person_token
                    saved.pending_in_person_story_id = saved.pending_in_person_story_id or saved.story_id
                    saved.pending_in_person_canonical_id = saved.pending_in_person_canonical_id or saved.canonical_id
                    active_conversations[cid] = saved
                    CONV = saved  -- last one loaded becomes CONV for compat
                end
            end
        end
    end

    local recovered_handoffs = 0
    if pda_f2f_handoffs then
        for _, handoff in pairs(pda_f2f_handoffs) do
            if type(handoff) == "table" then
                recovered_handoffs = recovered_handoffs + 1
            end
        end
    end

    local pending_contacts = {}
    for cid, conv in pairs(active_conversations) do
        if conv and conv.pending_in_person_continuation == true then
            table.insert(pending_contacts, tostring(cid))
        end
    end
    local pending_contacts_str = (#pending_contacts > 0) and table.concat(pending_contacts, ",") or "none"
    printf("PANDA_IC: load_state recovered f2f_handoffs=%d pending_in_person_contacts=%s",
        recovered_handoffs, pending_contacts_str)

    sweep_expired_f2f_pending_markers("load_state")
end

-- ============================================================
-- INITIALIZATION
-- ============================================================
function on_game_start()
    -- Ensure this function runs only once
    if _callbacks_registered then return end

    -- Wire optional f2f bridge integration early at startup
    ensure_panda_f2f_bridge()

    -- Add the private tab to the PDA via mac_mcm
    if mac_mcm then
        mac_mcm.add_app("pda_private", {
            name = "st_pda_private_tab",        -- unlocalized string; define in your XML
            texture = "ui_pda_private_app",    -- texture name (create or reuse)
            tab = "eptPrivate",                  -- must match the button id in pda.xml
            func = pda_private_tab.get_ui        -- the getter function
        })
    else
        printf("PANDA_IC: MAC not found, private tab not registered.")
    end

    -- Register essential callbacks
    RegisterScriptCallback("actor_on_first_update", setup_engine_overrides)
    RegisterScriptCallback("on_key_press", on_key_press_cb)
    RegisterScriptCallback("save_state", save_state)
    RegisterScriptCallback("load_state", load_state)
    RegisterScriptCallback("on_game_end", on_game_shutdown_cb)
    RegisterScriptCallback("npc_on_before_hit", panda_npc_invulnerability_check)

    -- Schedule the first trigger
    schedule_next_trigger(1)
    -- Schedule conversation timeout checker
    schedule_timeout_checker()
    -- Schedule smart-location reference checker
    schedule_location_ref_checker()
    -- Schedule pending job checker (kill tracking)
    schedule_job_checker()

    _callbacks_registered = true
end
