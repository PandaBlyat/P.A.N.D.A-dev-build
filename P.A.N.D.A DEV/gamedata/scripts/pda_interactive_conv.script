function set_pda_private_tab_open(state)
    pda_private_tab_open = state == true
end

pda_private_log = {} -- Initialize the table
pda_private_blocked_contacts = {}
npc_relationship_scores = {} -- Per-NPC relationship scores, keyed by contact_id (-1000 to 1000)

function make_contact_id(npc_se)
    return tostring(npc_se.id)
end

function get_npc_relationship(contact_id)
    return npc_relationship_scores[contact_id] or 0
end

function change_npc_relationship(contact_id, delta)
    local current = npc_relationship_scores[contact_id] or 0
    npc_relationship_scores[contact_id] = math.max(-1000, math.min(1000, current + delta))
end

local function get_delivery_time_marker()
    if time_global then
        return time_global()
    end

    return nil
end

local function normalize_delivery_state(state)
    if state == "delivered" or state == "read" then
        return state
    end

    return "sent"
end

-- Function to add messages to the log
function pda_private_add_message(contact_id, contact_name, sender_name, text, icon, is_player, delivery_state, delivery_timestamp, notification_icon, extra_fields)
    if contact_id and pda_private_blocked_contacts[contact_id] then
        return false
    end

    -- Apply NPC typing personality transforms (faction/rank-based typos, slang, etc.)
    if not is_player
        and pda_typing_personality and pda_typing_personality.transform
        and not (type(extra_fields) == "table" and extra_fields.skip_personality)
    then
        text = pda_typing_personality.transform(text, tostring(contact_id))
    end

    -- Grab the current game time
    local game_time = game.get_game_time()
    local Y, M, D, h, m, s, ms = 0, 0, 0, 0, 0, 0, 0
    Y, M, D, h, m, s, ms = game_time:get(Y, M, D, h, m, s, ms)

    -- Format it into a string (DD/MM/YYYY HH:MM) for display
    local current_time = string.format("%02d/%02d/%04d %02d:%02d", D, M, Y, h, m)

    -- Store raw time data for accurate relative time calculations
    local raw_time = {
        year = Y, month = M, day = D,
        hour = h, minute = m, second = s
    }

    local entry = {
        contact_id = contact_id,       -- Unique NPC ID for grouping threads
        contact_name = contact_name,   -- Display name for UI
        sender = sender_name,
        text = text,
        sender_icon = icon or "ui_inGame2_neutral_1",
        timestamp = current_time,
        raw_time = raw_time,  -- Store raw time for calculations
        is_player = is_player or false,
        delivery_state = (is_player and normalize_delivery_state(delivery_state)) or nil,
        delivery_timestamp = (is_player and (delivery_timestamp or get_delivery_time_marker())) or nil,
        notification_icon = notification_icon
    }

    -- Merge any extra fields (e.g. msg_type, map_spot_id, location_ref for map attachments)
    if type(extra_fields) == "table" then
        for k, v in pairs(extra_fields) do
            entry[k] = v
        end
    end

    table.insert(pda_private_log, 1, entry) -- Insert at index 1 so newest are first

    -- Optional: Limit log to 100 messages to prevent save bloat (increased from 50)
    if #pda_private_log > 100 then
        table.remove(pda_private_log)
    end

    return true
end

-- Returns the server-side smart terrain ID for a location reference string.
-- Used by pda_private_tab to resolve map navigation targets at click time.
function get_smart_id_for_location_ref(location_ref)
    if not location_ref then return nil end
    local smart, smart_name = resolve_smart_from_reference(location_ref)
    if not smart and smart_name and SIMBOARD and SIMBOARD.smarts_by_names then
        smart = SIMBOARD.smarts_by_names[smart_name]
    end
    return smart and smart.id or nil
end

function delete_contact_thread(contact_id)
    if not contact_id then
        return 0
    end

    local removed = 0
    local i = #pda_private_log
    while i >= 1 do
        local entry = pda_private_log[i]
        if entry and entry.contact_id == contact_id then
            table.remove(pda_private_log, i)
            removed = removed + 1
        end
        i = i - 1
    end

    return removed
end

function is_contact_blocked(contact_id)
    return contact_id ~= nil and pda_private_blocked_contacts[contact_id] == true
end

function block_contact(contact_id)
    if not contact_id then
        return false, 0
    end

    pda_private_blocked_contacts[contact_id] = true
    local _, removed = abort_contact_f2f_state(contact_id, "block_contact", {
        remove_conversation = true,
        cancel_events = true,
        remove_thread = true,
    })

    clear_npc_typing_message(contact_id)

    return true, tonumber(removed) or 0
end

function unblock_contact(contact_id)
    if not contact_id then
        return false
    end

    pda_private_blocked_contacts[contact_id] = nil
    return true
end

function set_last_player_message_state(contact_id, state)
    local normalized_state = normalize_delivery_state(state)
    for i = 1, #pda_private_log do
        local entry = pda_private_log[i]
        if entry and entry.is_player and entry.contact_id == contact_id then
            entry.delivery_state = normalized_state
            entry.delivery_timestamp = get_delivery_time_marker()
            return true
        end
    end

    return false
end
function upsert_npc_typing_message(contact_id, sender_name, icon)
    if not contact_id then
        return false
    end

    for i = 1, #pda_private_log do
        local entry = pda_private_log[i]
        if entry and entry.contact_id == contact_id and entry.is_typing then
            entry.sender = sender_name or entry.contact_name or "Unknown"
            entry.sender_icon = icon or entry.sender_icon or FALLBACK_NPC_ICON
            entry.timestamp = entry.timestamp or ""
            return true
        end
    end

    pda_private_add_message(contact_id, nil, sender_name or "Unknown", "Typing...", icon or FALLBACK_NPC_ICON, false, nil, nil, nil, { skip_personality = true })
    local latest = pda_private_log[1]
    if latest then
        latest.is_typing = true
    end

    return true
end

function clear_npc_typing_message(contact_id)
    if not contact_id then
        return false
    end

    local removed = false
    local i = #pda_private_log
    while i >= 1 do
        local entry = pda_private_log[i]
        if entry and entry.contact_id == contact_id and entry.is_typing then
            table.remove(pda_private_log, i)
            removed = true
        end
        i = i - 1
    end

    return removed
end


