local function ensure_panda_f2f_bridge()
    if _panda_state.f2f_bridge_checked then
        return panda_f2f_bridge
    end

    _panda_state.f2f_bridge_checked = true

    if not panda_f2f_bridge then
        local ok = pcall(function()
            if require then
                require("panda_f2f_bridge")
            end
        end)

        if not ok then
            pcall(function()
                dofile("gamedata\\scripts\\panda_f2f_bridge.script")
            end)
        end
    end

    if not panda_f2f_bridge then
        printf("PANDA_IC: warning: panda_f2f_bridge unavailable after module load")
        return nil
    end

    return panda_f2f_bridge
end

local function ensure_panda_npc_creator()
    if panda_npc_creator and type(panda_npc_creator.install_engine_guards) == "function" then
        _panda_state.npc_creator_checked = true
        pcall(panda_npc_creator.install_engine_guards)
        return panda_npc_creator
    end

    if _panda_state.npc_creator_checked then
        return panda_npc_creator
    end

    _panda_state.npc_creator_checked = true

    if not panda_npc_creator then
        local ok = pcall(function()
            if require then
                require("panda_npc_creator")
            end
        end)

        if not ok then
            pcall(function()
                dofile("gamedata\\scripts\\panda_npc_creator.script")
            end)
        end
    end

    if panda_npc_creator and type(panda_npc_creator.install_engine_guards) == "function" then
        pcall(panda_npc_creator.install_engine_guards)
    end

    if not panda_npc_creator then
        printf("PANDA_IC: warning: panda_npc_creator unavailable after module load")
        return nil
    end

    return panda_npc_creator
end

ensure_panda_npc_creator()

local function get_anomaly_artifact_adapter()
    if panda_anomaly_artifact_adapter and panda_anomaly_artifact_adapter.ensure_state then
        return panda_anomaly_artifact_adapter
    end

    local ok = pcall(function()
        if require then
            require("panda_anomaly_artifact_adapter")
        end
    end)

    if not ok then
        pcall(function()
            dofile("gamedata\\scripts\\panda_anomaly_artifact_adapter.script")
        end)
    end

    if panda_anomaly_artifact_adapter and panda_anomaly_artifact_adapter.ensure_state then
        return panda_anomaly_artifact_adapter
    end

    return nil
end

local function make_panda_runtime_task_id(family, conv_data)
    local conv_name = conv_data and (conv_data.conv_id or conv_data.prefix) or nil
    if not conv_name or conv_name == "" then
        conv_name = "conversation"
    end

    conv_name = tostring(conv_name)
        :gsub("%W+", "_")
        :gsub("^_+", "")
        :gsub("_+$", "")

    if conv_name == "" then
        conv_name = "conversation"
    end

    local family_name = tostring(family or "task")
        :gsub("%W+", "_")
        :gsub("^_+", "")
        :gsub("_+$", "")

    if family_name == "" then
        family_name = "task"
    end

    return string.format("panda_%s_%s_%d", family_name, conv_name, math.random(100000, 999999))
end

local function make_artifact_runtime_task_id(conv_data)
    return make_panda_runtime_task_id("artifact", conv_data)
end


