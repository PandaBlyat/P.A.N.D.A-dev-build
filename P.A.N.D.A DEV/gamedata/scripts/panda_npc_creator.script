local function normalize_visual_community(faction)
    local fac = string.lower(tostring(faction or "stalker"))
    return FACTION_VISUAL_COMMUNITY[fac] or fac
end

local function get_xr_visual_ini()
    if xr_visual_ini_cache ~= false then
        return xr_visual_ini_cache
    end

    xr_visual_ini_cache = nil
    if ini_file then
        local ok, ini = pcall(ini_file, "ai_tweaks\\xr_visual.ltx")
        if ok and ini then
            xr_visual_ini_cache = ini
        end
    end

    return xr_visual_ini_cache
end

local function get_death_outfits_ini()
    if death_outfits_ini_cache ~= false then
        return death_outfits_ini_cache
    end

    death_outfits_ini_cache = nil
    if ini_file then
        local ok, ini = pcall(ini_file, "items\\settings\\death_outfits.ltx")
        if ok and ini then
            death_outfits_ini_cache = ini
        end
    end

    return death_outfits_ini_cache
end

local VISUAL_BASE_PREFIXES = {
    { "^stalker_dolg",      "actors\\stalker_dolg\\" },
    { "^light_dolg",        "actors\\stalker_dolg\\" },
    { "^stalker_freedom",   "actors\\stalker_freedom\\" },
    { "^light_free",        "actors\\stalker_freedom\\" },
    { "^stalker_merc",      "actors\\stalker_merc\\" },
    { "^stalker_ki",        "actors\\stalker_merc\\" },
    { "^light_merc",        "actors\\stalker_merc\\" },
    { "^stalker_monolith",  "actors\\stalker_monolith\\" },
    { "^light_mono",        "actors\\stalker_monolith\\" },
    { "^stalker_soldier",   "actors\\stalker_soldier\\" },
    { "^soldier_",          "actors\\stalker_soldier\\" },
    { "^light_voen",        "actors\\stalker_soldier\\" },
    { "^stalker_military",  "actors\\stalker_soldier\\" },
    { "^stalker_bandit",    "actors\\stalker_bandit\\" },
    { "^light_bandit",      "actors\\stalker_bandit\\" },
    { "^stalker_neutral",   "actors\\stalker_neutral\\" },
    { "^light_neutral",     "actors\\stalker_neutral\\" },
    { "^stalker_nebo",      "actors\\stalker_nebo\\" },
    { "^stalker_radexo",    "actors\\stalker_nebo\\" },
    { "^stalker_ecolog",    "actors\\stalker_ecologist\\" },
    { "^stalker_nauchniy",  "actors\\stalker_ecologist\\" },
    { "^stalker_greh",      "actors\\stalker_greh\\" },
    { "^stalker_isg",       "actors\\stalker_isg\\" },
    { "^light_isg",         "actors\\stalker_isg\\" },
    { "^stalker_renegade",  "actors\\stalker_renegade\\" },
}

local function infer_visual_path_from_base(visual_base)
    if not visual_base or visual_base == "" then
        return nil
    end
    if string.find(visual_base, "\\") then
        return visual_base
    end

    local lower = string.lower(tostring(visual_base))
    for _, entry in ipairs(VISUAL_BASE_PREFIXES) do
        if string.find(lower, entry[1]) then
            return entry[2] .. tostring(visual_base)
        end
    end

    return nil
end

local function resolve_visual_from_death_outfits(outfit_section)
    if not outfit_section or outfit_section == "" then
        return nil
    end

    local ini = get_death_outfits_ini()
    if not ini or not ini.section_exist or not ini.line_count or not ini.r_line then
        return nil
    end
    if not ini:section_exist("outfit_by_visual") then
        return nil
    end

    local line_count = ini:line_count("outfit_by_visual") or 0
    for line_index = 0, line_count - 1 do
        local ok, _, visual_base, value = pcall(function()
            return ini:r_line("outfit_by_visual", line_index, "", "")
        end)
        if ok and visual_base and value then
            local mapped_outfit = string.match(tostring(value), "^%s*([^,%s]+)")
            if mapped_outfit == outfit_section then
                return infer_visual_path_from_base(visual_base)
            end
        end
    end

    return nil
end

local function infer_outfit_visual_community(faction, outfit_section)
    local lower = string.lower(tostring(outfit_section or ""))
    if string.find(lower, "dolg") or string.find(lower, "duty") then return "dolg" end
    if string.find(lower, "svoboda") or string.find(lower, "freedom") then return "freedom" end
    if string.find(lower, "merc") or string.find(lower, "killer") then return "killer" end
    if string.find(lower, "monolith") then return "monolith" end
    if string.find(lower, "army") or string.find(lower, "military") or string.find(lower, "specops") then return "army" end
    if string.find(lower, "ecolog") or string.find(lower, "scientific") or string.find(lower, "ssp") then return "ecolog" end
    if string.find(lower, "bandit") or string.find(lower, "renegade") then return "bandit" end
    if string.find(lower, "isg") then return "killer" end
    return normalize_visual_community(faction)
end

local function normalize_outfit_visual_key(outfit_section)
    local lower = string.lower(tostring(outfit_section or ""))
    if lower == "" then
        return nil
    end
    if lower == "novice_outfit" or string.find(lower, "novice") then
        return "novice_outfit"
    end
    if string.find(lower, "exo") or string.find(lower, "nosorog") then
        return "exo_outfit"
    end
    if string.find(lower, "seva") or string.find(lower, "scientific") or string.find(lower, "ssp")
        or string.find(lower, "proto") or string.find(lower, "nbc") or string.find(lower, "radiation") then
        return "scientific_outfit"
    end
    if string.find(lower, "clearsky") or string.find(lower, "csky") or string.find(lower, "cs_")
        or string.find(lower, "nebo") then
        return "cs_heavy_outfit"
    end
    if string.find(lower, "army") or string.find(lower, "military") or string.find(lower, "specops") then
        return "military_outfit"
    end
    if string.find(lower, "dolg") or string.find(lower, "duty") then
        return string.find(lower, "heavy") and "dolg_heavy_outfit" or "dolg_outfit"
    end
    if string.find(lower, "svoboda") or string.find(lower, "freedom") then
        return string.find(lower, "heavy") and "svoboda_heavy_outfit" or "svoboda_light_outfit"
    end
    if string.find(lower, "stalker") or string.find(lower, "loner") or string.find(lower, "neutral") then
        return "stalker_outfit"
    end
    return nil
end

local function resolve_outfit_visual(faction, outfit_section)
    if not outfit_section or outfit_section == "" then
        return nil
    end

    local cache_key = tostring(faction or "stalker") .. "|" .. tostring(outfit_section)
    if xr_visual_lookup_cache[cache_key] ~= nil then
        return xr_visual_lookup_cache[cache_key] ~= false and xr_visual_lookup_cache[cache_key] or nil
    end

    local death_visual = resolve_visual_from_death_outfits(outfit_section)
    if death_visual and death_visual ~= "" then
        xr_visual_lookup_cache[cache_key] = death_visual
        return death_visual
    end

    local ini = get_xr_visual_ini()
    if not ini or not ini.section_exist then
        xr_visual_lookup_cache[cache_key] = false
        return nil
    end

    local tried = {}
    local function try_section(section, outfit_key)
        if not section or section == "" or tried[section] then
            return nil
        end
        tried[section] = true
        if ini:section_exist(section) then
            local ok, visual = pcall(function()
                return ini:r_string_ex(section, outfit_key)
            end)
            if ok and visual and visual ~= "" then
                return visual
            end
        end
        return nil
    end

    local fallback_key = normalize_outfit_visual_key(outfit_section)
    local preferred_community = infer_outfit_visual_community(faction, outfit_section)

    local function try_common_sections(outfit_key)
        return try_section(preferred_community, outfit_key)
            or try_section(normalize_visual_community(faction), outfit_key)
            or try_section("stalker", outfit_key)
            or try_section("bandit", outfit_key)
            or try_section("killer", outfit_key)
            or try_section("army", outfit_key)
            or try_section("dolg", outfit_key)
            or try_section("freedom", outfit_key)
            or try_section("ecolog", outfit_key)
            or try_section("monolith", outfit_key)
    end

    local visual = try_common_sections(outfit_section)
    if (not visual) and fallback_key and fallback_key ~= outfit_section then
        tried = {}
        visual = try_common_sections(fallback_key)
    end

    xr_visual_lookup_cache[cache_key] = visual or false
    return visual
end

-- ============================================================
-- TEMPLATE PARSING
-- ============================================================

local function parse_template(template_id)
    if npc_templates[template_id] then
        return npc_templates[template_id]
    end

    local key = "st_panda_npc_template_" .. tostring(template_id)
    local raw = game.translate_string(key)

    if not raw or raw == key or raw == "" then
        printf("PANDA_NPC: template '%s' not found (key=%s)", tostring(template_id), key)
        return nil
    end

    local tpl = {
        faction      = "stalker",
        rank         = "veteran",
        name         = nil,
        primary      = nil,
        secondary    = nil,
        outfit       = nil,
        items        = {},
        relation     = "default",
        spawn_dist   = 50,
        trader       = false,
        allow_roam   = true,
        trade_preset = nil,
        buy          = nil,
        sell         = nil,
    }

    for pair in string.gmatch(raw, "[^|]+") do
        local k, v = string.match(pair, "^%s*([^=%s]+)%s*=%s*(.-)%s*$")
        if k and v then
            local key = string.lower(tostring(k))
            local lower_v = string.lower(tostring(v))

            if     key == "name"         then tpl.name         = (v ~= "") and v or nil
            elseif key == "faction"      then tpl.faction      = v
            elseif key == "rank"         then tpl.rank         = v
            elseif key == "primary"      then tpl.primary      = (v ~= "") and v or nil
            elseif key == "secondary"    then tpl.secondary    = (v ~= "") and v or nil
            elseif key == "outfit"       then tpl.outfit       = (v ~= "") and v or nil
            elseif key == "relation"     then tpl.relation     = v
            elseif key == "count"        then -- deprecated: custom NPC templates now always spawn one character
            elseif key == "spawn_dist"   then tpl.spawn_dist   = math.max(10, tonumber(v) or 50)
            elseif key == "trader"       then tpl.trader       = (lower_v == "1" or lower_v == "true")
            elseif key == "roam" or key == "allow_roam" or key == "allowroam" then
                tpl.allow_roam = not (lower_v == "0" or lower_v == "false")
            elseif key == "stay_put" or key == "stayput" then
                tpl.allow_roam = not (lower_v == "1" or lower_v == "true")
            elseif key == "trade_preset" then tpl.trade_preset = v
            elseif key == "buy"          then tpl.buy          = tonumber(v)
            elseif key == "sell"         then tpl.sell         = tonumber(v)
            elseif key == "items" then
                tpl.items = {}
                for item_entry in string.gmatch(v, "[^,]+") do
                    local sec, cnt = string.match(item_entry, "^%s*([^:%s]+)%s*:?%s*(%d*)%s*$")
                    if sec and sec ~= "" then
                        table.insert(tpl.items, {
                            section = sec,
                            count   = math.max(1, tonumber(cnt) or 1),
                        })
                    end
                end
            end
        end
    end

    npc_templates[template_id] = tpl
    return tpl
end

local function normalize_rank_name(rank_name)
    if not rank_name then
        return nil
    end

    local normalized = string.lower(tostring(rank_name))
    normalized = string.gsub(normalized, "^%s+", "")
    normalized = string.gsub(normalized, "%s+$", "")
    if normalized == "" then
        return nil
    end

    return normalized
end

local function resolve_rank_points(rank_name)
    local normalized = normalize_rank_name(rank_name)
    if not normalized then
        return nil
    end

    local rank_module = rawget(_G, "ranks") or ensure_script_global("ranks")
    if rank_module and type(rank_module.get_rank_interval) == "function" then
        local ok_interval, interval = pcall(rank_module.get_rank_interval, normalized)
        if ok_interval and type(interval) == "table" then
            local min_rank = tonumber(interval[1] or interval.min or interval.low or interval.from)
            local max_rank = tonumber(interval[2] or interval.max or interval.high or interval.to)
            if min_rank then
                if max_rank and max_rank > min_rank then
                    return math.floor((min_rank + max_rank) * 0.5)
                end
                return min_rank
            end
        end
    end

    return FALLBACK_RANK_POINTS[normalized]
end

local function apply_rank_to_server_object(se_obj, rank_name)
    local rank_points = resolve_rank_points(rank_name)
    if not se_obj or not rank_points or not se_obj.set_rank then
        return false, rank_points
    end

    local ok = pcall(function()
        se_obj:set_rank(rank_points)
    end)
    return ok, rank_points
end

local function apply_rank_to_game_object(obj, rank_name)
    local rank_points = resolve_rank_points(rank_name)
    if not obj or not rank_points or not obj.set_character_rank then
        return false, rank_points
    end

    local ok = pcall(function()
        obj:set_character_rank(rank_points)
    end)
    return ok, rank_points
end

-- ============================================================
-- WEAPON / ITEM HELPERS (adapted from A.R.C.H.)
-- ============================================================

local function resolve_addon_flags(section, attachment_str)
    if not attachment_str or attachment_str == "0" or attachment_str == "" then
        return 0
    end
    if attachment_str == "r" then
        local flag = 0
        if ini_sys and ini_sys:section_exist(section) then
            if ini_sys:r_string_ex(section, "scope_status")             then flag = flag + 1 end
            if ini_sys:r_string_ex(section, "grenade_launcher_status")  then flag = flag + 2 end
            if ini_sys:r_string_ex(section, "silencer_status")          then flag = flag + 4 end
        end
        return (flag > 0) and math.random(0, flag) or 0
    end
    return tonumber(attachment_str) or 0
end

local function resolve_ammo_type(section, ammo_str)
    if not ammo_str or ammo_str == "0" or ammo_str == "" then return 0 end
    if ammo_str == "r" then
        if ini_sys and ini_sys:section_exist(section) then
            local ammo_class = ini_sys:r_string_ex(section, "ammo_class") or ""
            local count = 0
            for _ in string.gmatch(ammo_class, "[^,]+") do count = count + 1 end
            return (count > 1) and math.random(0, count - 1) or 0
        end
        return 0
    end
    return math.max(0, (tonumber(ammo_str) or 1) - 1)
end

local function parse_weapon_tokens(weapon_str)
    if not weapon_str or weapon_str == "" then
        return nil, nil, nil
    end

    local parts = {}
    for token in string.gmatch(weapon_str, "[^:]+") do
        parts[#parts + 1] = token
    end

    return parts[1], parts[2] or "0", parts[3] or "0"
end

local function resolve_weapon_ammo_section(section, ammo_str)
    if not section or not ini_sys or not ini_sys:section_exist(section) then
        return nil
    end

    local ammo_class = ini_sys:r_string_ex(section, "ammo_class") or ""
    if ammo_class == "" then
        return nil
    end

    local ammo_sections = {}
    for ammo_sec in string.gmatch(ammo_class, "[^,%s]+") do
        ammo_sections[#ammo_sections + 1] = ammo_sec
    end

    if #ammo_sections == 0 then
        return nil
    end

    local ammo_index = resolve_ammo_type(section, ammo_str) + 1
    return ammo_sections[ammo_index] or ammo_sections[1]
end

local function give_weapon(se_obj, weapon_str)
    if not weapon_str or weapon_str == "" then return end
    local section, attach_str, ammo_str = parse_weapon_tokens(weapon_str)
    if not section or not ini_sys or not ini_sys:section_exist(section) then
        if section then printf("PANDA_NPC: weapon section '%s' not found, skipping", section) end
        return
    end
    local ok, se_wpn = pcall(alife_create_item, section, se_obj)
    if not ok or not se_wpn then
        printf("PANDA_NPC: failed to create weapon '%s'", tostring(section))
        return
    end
    if utils_stpk and utils_stpk.get_weapon_data and utils_stpk.set_weapon_data then
        local data = utils_stpk.get_weapon_data(se_wpn)
        if data then
            data.addon_flags = resolve_addon_flags(section, attach_str)
            data.ammo_type   = resolve_ammo_type(section, ammo_str)
            utils_stpk.set_weapon_data(data, se_wpn)
        end
    end

    local ammo_section = resolve_weapon_ammo_section(section, ammo_str)
    if ammo_section and ini_sys:section_exist(ammo_section) then
        for _ = 1, 2 do
            pcall(alife_create_item, ammo_section, se_obj)
        end
    end
end

local function give_outfit(se_obj, outfit_section)
    if not outfit_section or outfit_section == "" then return end
    if not ini_sys or not ini_sys:section_exist(outfit_section) then
        printf("PANDA_NPC: outfit section '%s' not found, skipping", tostring(outfit_section))
        return
    end
    local ok = pcall(alife_create_item, outfit_section, se_obj)
    if not ok then printf("PANDA_NPC: failed to create outfit '%s'", tostring(outfit_section)) end
end

local function give_items(se_obj, items_list)
    for _, entry in ipairs(items_list) do
        if ini_sys and ini_sys:section_exist(entry.section) then
            for i = 1, entry.count do
                local ok = pcall(alife_create_item, entry.section, se_obj)
                if not ok then
                    printf("PANDA_NPC: failed to create item '%s' (copy %d)", tostring(entry.section), i)
                end
            end
        else
            printf("PANDA_NPC: item section '%s' not found, skipping", tostring(entry.section))
        end
    end
end

-- ============================================================
-- RELATION / COMPANION APPLICATION
-- ============================================================

local function apply_squad_relation(squad_obj, relation)
    if not squad_obj then return end
    relation = tostring(relation or "default"):lower()

    if relation == "hostile" then
        squad_obj:set_squad_relation("enemy")
        squad_obj.scripted_target = "actor"
        squad_obj.rush_to_target  = true
    elseif relation == "friendly" or relation == "companion" then
        squad_obj:set_squad_relation("friend")
        squad_obj.scripted_target = nil
        squad_obj.rush_to_target  = false
    end
end

local function register_as_companion(squad_obj, squad_id)
    if axr_companions then
        if axr_companions.companion_squads then
            axr_companions.companion_squads[squad_id] = squad_obj
        end
        if axr_companions.add_companion_squad then
            pcall(axr_companions.add_companion_squad, squad_id)
        end
    end
    for m in squad_obj:squad_members() do
        local se = alife_object(m.id)
        if se then
            pcall(se_save_var, se.id, se:name(), "companion",               true)
            pcall(se_save_var, se.id, se:name(), "companion_cannot_dismiss", true)
        end
    end
    if squad_obj.set_follow_distance then
        squad_obj:set_follow_distance(10)
    end
end

local function get_callback_npc_id(obj, se_obj)
    if se_obj and se_obj.id then
        return tonumber(se_obj.id)
    end
    if obj then
        local ok, npc_id = pcall(function() return obj:id() end)
        if ok then
            return tonumber(npc_id)
        end
    end
    return nil
end

local function apply_pending_actor_relation(obj, relation)
    local actor = db and db.actor
    if not obj or not actor then
        return false
    end

    relation = tostring(relation or "default"):lower()
    if relation == "hostile" then
        obj:set_relation(game_object.enemy, actor)
        obj:force_set_goodwill(-5000, actor)
        return true
    elseif relation == "friendly" or relation == "companion" then
        obj:set_relation(game_object.friend, actor)
        obj:force_set_goodwill(5000, actor)
        return true
    end

    return false
end

local function release_server_object(se_obj, reason)
    if not se_obj then
        return false
    end

    if alife_release then
        return alife_release(se_obj, reason)
    end

    local sim = alife()
    if sim and sim.release then
        sim:release(se_obj, true)
        return true
    end

    return false
end

local function collect_squad_member_ids(squad_obj)
    local ids = {}
    if not squad_obj then
        return ids
    end

    for k in squad_obj:squad_members() do
        ids[#ids + 1] = k.id
    end

    table.sort(ids)
    return ids
end

local function prune_squad_to_single_member(squad_obj, template_id)
    local member_ids = collect_squad_member_ids(squad_obj)
    if #member_ids <= 1 then
        return member_ids
    end

    for i = 2, #member_ids do
        local member_id = member_ids[i]
        if squad_obj and squad_obj.remove_npc then
            pcall(function()
                squad_obj:remove_npc(member_id, true)
            end)
        else
            local se_member = alife_object(member_id)
            if se_member then
                if squad_obj and squad_obj.unregister_member then
                    pcall(function()
                        squad_obj:unregister_member(member_id)
                    end)
                end
                release_server_object(se_member, "PANDA_NPC extra squad member for " .. tostring(template_id))
            end
        end
    end

    printf("PANDA_NPC: pruned template '%s' squad_id=%s from %s members down to 1",
        tostring(template_id), tostring(squad_obj and squad_obj.id), tostring(#member_ids))

    local remaining_ids = collect_squad_member_ids(squad_obj)
    if #remaining_ids > 0 then
        return { remaining_ids[1] }
    end

    return { member_ids[1] }
end

local function clear_npc_generated_loadout(se_npc, tpl)
    local sim = alife()
    if not sim or not se_npc then
        return
    end

    local replace_weapons = (tpl.primary and tpl.primary ~= "") or (tpl.secondary and tpl.secondary ~= "")
    local replace_outfit = tpl.outfit and tpl.outfit ~= ""
    if not replace_weapons and not replace_outfit then
        return
    end

    local release_ids = {}
    for child_id in sim:get_children(se_npc) do
        local se_item = alife_object(child_id)
        if se_item then
            local cls = se_item:clsid()
            if (replace_weapons and (IsWeapon(nil, cls) or IsAmmo(nil, cls) or IsGrenade(nil, cls)))
                or (replace_outfit and IsOutfit(nil, cls)) then
                release_ids[#release_ids + 1] = child_id
            end
        end
    end

    for _, child_id in ipairs(release_ids) do
        local se_item = alife_object(child_id)
        if se_item then
            release_server_object(se_item, "PANDA_NPC replacing generated loadout for " .. tostring(se_npc.id))
        end
    end
end

local function get_server_section_name(se_obj)
    if not se_obj or not se_obj.section_name then
        return nil
    end

    local ok, section = pcall(function()
        return se_obj:section_name()
    end)

    return ok and section or nil
end

local function clear_conflicting_outfits(se_npc, desired_outfit)
    local sim = alife()
    if not sim or not se_npc or not desired_outfit or desired_outfit == "" then
        return
    end

    local release_ids = {}
    for child_id in sim:get_children(se_npc) do
        local se_item = alife_object(child_id)
        if se_item and IsOutfit(nil, se_item:clsid()) then
            local section = get_server_section_name(se_item)
            if section and section ~= desired_outfit then
                release_ids[#release_ids + 1] = child_id
            end
        end
    end

    for _, child_id in ipairs(release_ids) do
        local se_item = alife_object(child_id)
        if se_item then
            release_server_object(se_item, "PANDA_NPC removing conflicting outfit for " .. tostring(se_npc.id))
        end
    end
end

local function apply_server_visual_override(se_obj, visual_name)
    if not se_obj or not visual_name or visual_name == "" then
        return false
    end
    if not utils_stpk or not utils_stpk.get_stalker_data or not utils_stpk.set_stalker_data then
        return false
    end

    local ok_data, data = pcall(utils_stpk.get_stalker_data, se_obj)
    if not ok_data or not data then
        return false
    end

    if data.visual_name == visual_name then
        return true
    end

    data.visual_name = visual_name
    local ok_set = pcall(utils_stpk.set_stalker_data, data, se_obj)
    return ok_set
end

local function apply_online_visual_override(obj, visual_name)
    if not obj or not visual_name or visual_name == "" or not obj.set_visual_name then
        return false
    end

    local ok = pcall(function()
        obj:set_visual_name(visual_name)
    end)

    return ok
end

local function normalize_visual_name(value)
    local normalized = string.lower(tostring(value or ""))
    normalized = string.gsub(normalized, "%.ogf$", "")
    return normalized
end

local function is_visual_applied(obj, desired_visual)
    if not obj or not desired_visual or desired_visual == "" then
        return true
    end
    if not obj.get_visual_name then
        return false
    end

    local ok, current_visual = pcall(function()
        return obj:get_visual_name()
    end)
    if not ok or not current_visual or current_visual == "" then
        return false
    end

    return normalize_visual_name(current_visual) == normalize_visual_name(desired_visual)
end

local function find_inventory_item_by_section(obj, section)
    if not obj or not section or not obj.iterate_inventory then
        return nil
    end

    local found = nil
    obj:iterate_inventory(function(_, item)
        if not found and item and item:section() == section then
            found = item
        end
    end, obj)

    return found
end

local function is_outfit_equipped(obj, desired_outfit)
    if not obj or not desired_outfit or desired_outfit == "" then
        return true
    end

    if obj.get_current_outfit then
        local ok_outfit, outfit = pcall(function()
            return obj:get_current_outfit()
        end)
        if ok_outfit and outfit and outfit.section and outfit:section() == desired_outfit then
            return true
        end
    end

    if obj.item_in_slot then
        local ok_slot, outfit = pcall(function()
            return obj:item_in_slot(7)
        end)
        if ok_slot and outfit and outfit.section and outfit:section() == desired_outfit then
            return true
        end
    end

    return false
end

local function vector_to_table(pos)
    if not pos then
        return nil
    end

    return {
        x = pos.x,
        y = pos.y,
        z = pos.z,
    }
end

local function table_to_vector(tbl)
    if not tbl then
        return nil
    end

    return vector():set(tbl.x or 0, tbl.y or 0, tbl.z or 0)
end

local function get_runtime_position(obj)
    if not obj then
        return nil
    end

    local ok, pos = pcall(function()
        if type(obj.position) == "function" then
            return obj:position()
        end
        return obj.position
    end)

    return ok and pos or nil
end

local function get_live_npc_object(npc_id)
    if db and db.storage and db.storage[npc_id] and db.storage[npc_id].object then
        return db.storage[npc_id].object
    end

    if level and level.object_by_id then
        return level.object_by_id(npc_id)
    end

    return nil
end

local function apply_stationary_npc_runtime_lock(npc, anchor, _reason, force_idle_reset)
    if not npc then
        return false
    end

    local desired_pos = anchor and table_to_vector(anchor.pos) or nil
    local path_type = game_object and game_object.no_path or nil
    local move_enum = rawget(_G, "move")

    if npc.set_path_type and path_type ~= nil then
        pcall(function()
            npc:set_path_type(path_type)
        end)
    end
    if anchor and anchor.lvid and npc.set_dest_level_vertex_id then
        pcall(function()
            npc:set_dest_level_vertex_id(anchor.lvid)
        end)
    end
    if anchor and anchor.gvid and npc.set_dest_game_vertex_id then
        pcall(function()
            npc:set_dest_game_vertex_id(anchor.gvid)
        end)
    end
    if desired_pos and npc.set_desired_position then
        pcall(function()
            npc:set_desired_position(desired_pos)
        end)
    end
    if move_enum and move_enum.stand and npc.set_movement_type then
        pcall(function()
            npc:set_movement_type(move_enum.stand)
        end)
    end

    return true
end

local function get_server_object_smart_id(se_obj)
    if not se_obj then
        return nil
    end

    local smart_id = se_obj.m_smart_terrain_id
    if smart_id == nil and se_obj.smart_terrain_id then
        local ok, resolved_id = pcall(function()
            return se_obj:smart_terrain_id()
        end)
        if ok then
            smart_id = resolved_id
        end
    end

    if smart_id == 65535 then
        return nil
    end

    return smart_id
end

local function get_stationary_entry_mode(entry)
    if not entry or entry.mode == nil or entry.mode == "" then
        if entry and (entry.smart_id == nil or entry.smart_id == "") and entry.squad_id then
            local squad_obj = alife_object(entry.squad_id)
            local inferred_smart_id = squad_obj and squad_obj.smart_id or nil
            if inferred_smart_id and inferred_smart_id ~= 65535 then
                entry.smart_id = inferred_smart_id
            end
        end

        return (entry and entry.smart_id) and "smart_job" or "anchor"
    end

    return tostring(entry.mode)
end

local function get_stationary_smart_object(entry, npc_id)
    local smart_id = entry and (tonumber(entry.smart_id) or entry.smart_id) or nil
    if not smart_id and npc_id then
        smart_id = get_server_object_smart_id(alife_object(npc_id))
    end

    if not smart_id or smart_id == 65535 then
        return nil
    end

    local smart_obj = alife_object(smart_id)
    if not smart_obj or (smart_obj.clsid and smart_obj:clsid() ~= clsid.smart_terrain) then
        return nil
    end

    if entry then
        entry.smart_id = smart_id
    end

    return smart_obj
end

local function get_stationary_job_ltx(job, smart_obj)
    if job and job.ltx then
        return job.ltx
    end

    if smart_obj then
        return smart_obj.ltx
    end

    return nil
end

local function get_stationary_job_active_section(job, smart_obj)
    local ltx = get_stationary_job_ltx(job, smart_obj)
    if not ltx or not job or not job.section or not ltx.r_string_ex then
        return nil
    end

    if ltx.section_exist then
        local ok_exist, exists = pcall(function()
            return ltx:section_exist(job.section)
        end)
        if ok_exist and not exists then
            return nil
        end
    end

    local ok_active, active_section = pcall(function()
        return ltx:r_string_ex(job.section, "active")
    end)

    if ok_active and active_section and active_section ~= "" and active_section ~= "nil" then
        return active_section
    end

    return nil
end

local function get_stationary_job_scheme(job, smart_obj)
    local active_section = get_stationary_job_active_section(job, smart_obj)
    if not active_section then
        return nil
    end

    if utils_data and utils_data.get_scheme_by_section then
        local ok_scheme, scheme = pcall(function()
            return utils_data.get_scheme_by_section(active_section)
        end)
        if ok_scheme and scheme and scheme ~= "" and scheme ~= "nil" then
            return scheme
        end
    end

    return string.match(tostring(active_section), "^(%w+)@")
end

local function get_stationary_job_priority(job)
    if not job then
        return nil
    end

    if gulag_general and gulag_general.get_job_prior then
        local ok_priority, priority = pcall(function()
            return gulag_general.get_job_prior(job)
        end)
        if ok_priority then
            return tonumber(priority) or priority
        end
    end

    return tonumber(job.prior) or job.prior
end

local function get_stationary_job_type(job)
    if not job then
        return nil
    end

    if job.job_type then
        return job.job_type
    end

    if gulag_general and gulag_general.get_job_type then
        local ok_type, job_type = pcall(function()
            return gulag_general.get_job_type(job)
        end)
        if ok_type then
            return job_type
        end
    end

    return nil
end

local function get_stationary_job_precondition(job)
    if not job then
        return nil
    end

    if job.precondition_function then
        return job.precondition_function
    end

    if gulag_general and gulag_general.get_job_precondition then
        local ok_precond, precond = pcall(function()
            return gulag_general.get_job_precondition(job)
        end)
        if ok_precond then
            return precond
        end
    end

    return nil
end

local function get_stationary_job_prefix(job)
    if not job then
        return nil
    end

    if job.prefix_name then
        return job.prefix_name
    end

    if gulag_general and gulag_general.get_job_prefix_name then
        local ok_prefix, prefix = pcall(function()
            return gulag_general.get_job_prefix_name(job)
        end)
        if ok_prefix then
            return prefix
        end
    end

    return nil
end

local function is_stationary_story_job_scheme(scheme)
    return scheme ~= nil and STATIONARY_JOB_SCHEME_PRIORITY[scheme] ~= nil
end

local function get_stationary_custom_job_name(smart_obj, npc_id)
    return STATIONARY_CUSTOM_JOB_PREFIX .. tostring(smart_obj and smart_obj.id or "smart") .. "_" .. tostring(npc_id)
end

local function get_stationary_custom_job_section(smart_obj, npc_id)
    return "logic@" .. get_stationary_custom_job_name(smart_obj, npc_id)
end

local function is_stationary_custom_job_section(section)
    return type(section) == "string" and string.find(section, "^logic@" .. STATIONARY_CUSTOM_JOB_PREFIX) ~= nil
end

local function stationary_reserved_job_precondition(se_obj, _smart, job)
    return se_obj ~= nil and job ~= nil and job._panda_reserved_npc_id == se_obj.id
end

local function build_stationary_custom_job_ltx(smart_obj, npc_id)
    local smart_name = smart_obj and smart_obj.name and smart_obj:name() or nil
    if not smart_name or smart_name == "" then
        return nil, nil
    end

    local job_name = get_stationary_custom_job_name(smart_obj, npc_id)
    local lines = {
        "[logic@" .. job_name .. "]",
        "prior = " .. tostring(STATIONARY_JOB_PRIORITY_BOOST),
        "active = cover@" .. job_name,
        "",
        "[cover@" .. job_name .. "]",
        "smart = " .. smart_name,
        "radius_min = 0",
        "radius_max = 0",
        "use_attack_direction = false",
        "anim = guard",
        "meet = meet",
        "gather_items_enabled = false",
        "help_wounded_enabled = false",
        "corpse_detection_enabled = false",
    }

    if smart_obj.def_restr then
        lines[#lines + 1] = "out_restr = " .. tostring(smart_obj.def_restr)
    end

    if smart_obj.ignore_zone then
        lines[#lines + 1] = "combat_ignore_cond = {=npc_in_zone(" .. tostring(smart_obj.ignore_zone) .. ")} true"
        lines[#lines + 1] = "combat_ignore_keep_when_attacked = true"
    end

    lines[#lines + 1] = ""
    lines[#lines + 1] = "[meet]"
    lines[#lines + 1] = "close_anim = nil"
    lines[#lines + 1] = "close_victim = nil"
    lines[#lines + 1] = "far_anim = nil"
    lines[#lines + 1] = "far_victim = nil"
    lines[#lines + 1] = "close_distance = 0"
    lines[#lines + 1] = "far_distance = 0"
    lines[#lines + 1] = "close_snd_distance = 3"
    lines[#lines + 1] = "abuse = false"
    lines[#lines + 1] = "use = {=actor_enemy} false, true"
    lines[#lines + 1] = "allow_break = false"
    lines[#lines + 1] = "meet_on_talking = false"
    lines[#lines + 1] = "trade_enable = false"

    return table.concat(lines, "\n"), job_name
end

local function ensure_stationary_custom_job_task(smart_obj, job)
    if not smart_obj or not job then
        return nil
    end

    if not job.alife_task then
        if smart_obj.smart_alife_task then
            job.alife_task = smart_obj.smart_alife_task
        elseif CALifeSmartTerrainTask then
            local ok_task, task = pcall(function()
                return CALifeSmartTerrainTask(smart_obj.m_game_vertex_id, smart_obj.m_level_vertex_id)
            end)
            if ok_task then
                job.alife_task = task
            end
        end
    end

    if job.alife_task then
        local ok_gvid, game_vertex_id = pcall(function()
            return job.alife_task:game_vertex_id()
        end)
        local ok_pos, position = pcall(function()
            return job.alife_task:position()
        end)
        local gg = game_graph and game_graph() or nil

        if ok_gvid and game_vertex_id then
            job.game_vertex_id = game_vertex_id
            if gg and gg.vertex then
                local ok_level, level_vertex = pcall(function()
                    return gg:vertex(game_vertex_id)
                end)
                if ok_level and level_vertex and level_vertex.level_id then
                    job.level_id = level_vertex:level_id()
                end
            end
        end
        if ok_pos and position then
            job.position = position
        end
    end

    return job
end

local function insert_stationary_custom_job(smart_obj, job)
    if not smart_obj or not job then
        return nil
    end

    smart_obj.stalker_jobs = smart_obj.stalker_jobs or {}
    for _, existing in ipairs(smart_obj.stalker_jobs) do
        if existing == job or existing.section == job.section then
            return ensure_stationary_custom_job_task(smart_obj, existing)
        end
    end

    smart_obj.stalker_jobs[#smart_obj.stalker_jobs + 1] = job
    table.sort(smart_obj.stalker_jobs, function(a, b)
        return (tonumber(get_stationary_job_priority(a)) or 0) > (tonumber(get_stationary_job_priority(b)) or 0)
    end)

    return ensure_stationary_custom_job_task(smart_obj, job)
end

local function remove_stationary_custom_job(smart_obj, job)
    if not smart_obj or not job or not job._panda_dynamic then
        return false
    end

    if smart_obj.stalker_jobs then
        for index = #smart_obj.stalker_jobs, 1, -1 do
            local existing = smart_obj.stalker_jobs[index]
            if existing == job or existing.section == job.section then
                table.remove(smart_obj.stalker_jobs, index)
            end
        end
    end

    if db and db.dynamic_ltx and job._panda_dynamic_key then
        db.dynamic_ltx[job._panda_dynamic_key] = nil
    end

    return true
end

local function ensure_stationary_custom_job(smart_obj, npc_id, entry)
    if not smart_obj or not npc_id or not create_ini_file or not db then
        return nil
    end

    local logic_section = get_stationary_custom_job_section(smart_obj, npc_id)
    if smart_obj.find_job_by_section then
        local ok_existing, existing_job = pcall(function()
            return smart_obj:find_job_by_section(logic_section)
        end)
        if ok_existing and existing_job then
            existing_job._panda_dynamic = true
            existing_job._panda_dynamic_key = get_stationary_custom_job_name(smart_obj, npc_id)
            existing_job._panda_stationary_story_job = true
            existing_job._panda_reserved_npc_id = npc_id
            return ensure_stationary_custom_job_task(smart_obj, existing_job)
        end
    end

    local ltx_text, job_name = build_stationary_custom_job_ltx(smart_obj, npc_id)
    if not ltx_text or not job_name then
        return nil
    end

    db.dynamic_ltx = db.dynamic_ltx or {}
    db.dynamic_ltx[job_name] = create_ini_file(ltx_text)

    local job = {
        section = logic_section,
        ini_path = "*" .. job_name,
        ltx = db.dynamic_ltx[job_name],
        job_type = "point_job",
        prior = STATIONARY_JOB_PRIORITY_BOOST,
        prefix_name = "",
        exclusive = true,
        precondition_function = stationary_reserved_job_precondition,
        _panda_dynamic = true,
        _panda_dynamic_key = job_name,
        _panda_reserved_npc_id = npc_id,
        _panda_stationary_story_job = true,
    }

    if entry then
        entry.job_section = logic_section
    end

    printf(
        "PANDA_NPC: created stationary fallback smart job npc_id=%s smart_id=%s section=%s",
        tostring(npc_id),
        tostring(smart_obj.id or "nil"),
        tostring(logic_section)
    )

    return insert_stationary_custom_job(smart_obj, job)
end

local function score_stationary_smart_job(job, smart_obj)
    if not job or job._panda_dynamic or is_stationary_custom_job_section(job.section) then
        return nil
    end

    if smart_obj then
        job = ensure_stationary_custom_job_task(smart_obj, job) or job
    end

    if not job or not job.section or not job.alife_task then
        return nil
    end

    local scheme = get_stationary_job_scheme(job, smart_obj)
    if not is_stationary_story_job_scheme(scheme) then
        return nil
    end

    local score = scheme and STATIONARY_JOB_SCHEME_PRIORITY[scheme] or nil
    if not score then
        return nil
    end

    local priority = get_stationary_job_priority(job)
    if priority then
        score = score + math.min(tonumber(priority) or 0, 40)
    end
    if job.exclusive then
        score = score + 35
    end

    return score
end

local function stationary_job_available_to_npc(smart_obj, npc_info, job)
    if not smart_obj or not npc_info or not npc_info.se_obj or not job then
        return false
    end

    local precondition = get_stationary_job_precondition(job)
    if not precondition then
        return true
    end

    local ok_available, available = pcall(precondition, npc_info.se_obj, smart_obj, job, npc_info)
    return ok_available and available == true
end

local function count_authored_stationary_smart_jobs(smart_obj)
    local jobs = smart_obj and smart_obj.stalker_jobs
    if type(jobs) ~= "table" then
        return nil
    end

    local count = 0
    for _, job in ipairs(jobs) do
        if score_stationary_smart_job(job, smart_obj) then
            count = count + 1
        end
    end

    return count
end

local function find_stationary_smart_job_for_npc(smart_obj, npc_info, preferred_section, entry)
    local jobs = smart_obj and smart_obj.stalker_jobs
    if type(jobs) ~= "table" then
        return nil
    end

    if preferred_section and preferred_section ~= "" and not is_stationary_custom_job_section(preferred_section) and smart_obj.find_job_by_section then
        local ok_preferred, preferred_job = pcall(function()
            return smart_obj:find_job_by_section(preferred_section)
        end)
        if ok_preferred and preferred_job and preferred_job.section then
            local preferred_owner = smart_obj.npc_by_job_section and smart_obj.npc_by_job_section[preferred_job.section] or nil
            if (preferred_owner == nil or preferred_owner == npc_info.se_obj.id)
                and stationary_job_available_to_npc(smart_obj, npc_info, preferred_job)
                and score_stationary_smart_job(preferred_job, smart_obj) then
                return preferred_job
            end
        end
    end

    local best_job = nil
    local best_score = nil
    for _, job in ipairs(jobs) do
        local section = job and job.section
        local owner = section and smart_obj.npc_by_job_section and smart_obj.npc_by_job_section[section] or nil
        local score = score_stationary_smart_job(job, smart_obj)
        if section and score and (owner == nil or owner == npc_info.se_obj.id)
            and stationary_job_available_to_npc(smart_obj, npc_info, job) then
            if not best_job or score > best_score then
                best_job = job
                best_score = score
            end
        end
    end

    if best_job then
        return best_job
    end

    return nil
end

local function promote_stationary_smart_job(job, npc_id)
    if not job then
        return false
    end

    if job._panda_dynamic then
        job._panda_reserved_npc_id = npc_id
        job.prior = math.max(tonumber(job.prior) or 0, STATIONARY_JOB_PRIORITY_BOOST)
        return true
    end

    if job._panda_reserved_npc_id and job._panda_reserved_npc_id ~= npc_id then
        return false
    end

    if job._panda_reserved_npc_id ~= npc_id then
        job._panda_original_exclusive = job.exclusive
        job._panda_original_prior = job.prior
        job._panda_original_job_type = job.job_type
        job._panda_original_precondition_function = job.precondition_function
        job._panda_original_prefix_name = job.prefix_name
    end

    local current_priority = tonumber(job.prior) or tonumber(get_stationary_job_priority(job)) or 0
    job._panda_reserved_npc_id = npc_id
    job.exclusive = true
    job.prior = math.max(current_priority, STATIONARY_JOB_PRIORITY_BOOST)

    local job_type = get_stationary_job_type(job)
    if job_type then
        job.job_type = job_type
    end

    local precondition = get_stationary_job_precondition(job)
    if precondition then
        job.precondition_function = precondition
    end

    local prefix_name = get_stationary_job_prefix(job)
    if prefix_name then
        job.prefix_name = prefix_name
    end

    return true
end

local function restore_stationary_smart_job(job, npc_id)
    if not job or job._panda_reserved_npc_id ~= npc_id then
        return false
    end

    if job._panda_dynamic then
        job._panda_reserved_npc_id = nil
        return true
    end

    job.exclusive = job._panda_original_exclusive
    job.prior = job._panda_original_prior
    job.job_type = job._panda_original_job_type
    job.precondition_function = job._panda_original_precondition_function
    job.prefix_name = job._panda_original_prefix_name
    job._panda_reserved_npc_id = nil
    job._panda_original_exclusive = nil
    job._panda_original_prior = nil
    job._panda_original_job_type = nil
    job._panda_original_precondition_function = nil
    job._panda_original_prefix_name = nil

    return true
end

local function move_server_object_to_stationary_job(se_obj, _squad_obj, job, entry)
    if not se_obj or not job or not job.alife_task then
        return false
    end

    local task = job.alife_task
    local ok_pos, position = pcall(function()
        return task:position()
    end)
    if not ok_pos or not position then
        return false
    end

    local ok_lvid, lvid = pcall(function()
        return task:level_vertex_id()
    end)
    local ok_gvid, gvid = pcall(function()
        return task:game_vertex_id()
    end)

    -- Vanilla smart terrain setup does not force-move squads here; it only hints the
    -- spawn vertex and lets smart/job logic place the NPC when the object comes online.
    if ok_lvid and lvid and db and db.spawned_vertex_by_id then
        db.spawned_vertex_by_id[se_obj.id] = lvid
    end

    if entry then
        if ok_pos and position then
            entry.pos = vector_to_table(position)
        elseif not entry.pos and se_obj.position then
            entry.pos = vector_to_table(se_obj.position)
        end
        entry.lvid = ok_lvid and lvid or entry.lvid
        entry.gvid = ok_gvid and gvid or entry.gvid
    end

    return true
end

local function configure_story_style_squad_target(squad_obj, smart_obj)
    if not squad_obj or not smart_obj then
        return false
    end

    stationary_custom_squads[squad_obj.id] = nil
    squad_obj.panda_stationary = nil
    attach_stationary_squad_to_smart(squad_obj, { smart_id = smart_obj.id })
    squad_obj.always_arrived = true
    squad_obj.scripted_target = tostring(smart_obj.id)
    squad_obj.assigned_target_id = smart_obj.id
    squad_obj.current_target_id = smart_obj.id
    squad_obj.current_action = 1
    squad_obj.task_target_id = nil
    squad_obj.rush_to_target = false
    if (tonumber(squad_obj.idle_time) or 0) < STORY_SQUAD_IDLE_TIME then
        squad_obj.idle_time = STORY_SQUAD_IDLE_TIME
    end
    if game and game.get_game_time then
        squad_obj.stay_time = game.get_game_time()
    end

    return true
end

local function release_stationary_smart_job(npc_id)
    local entry = stationary_custom_npcs[npc_id]
    if not entry or get_stationary_entry_mode(entry) ~= "smart_job" then
        return false
    end

    local smart_obj = get_stationary_smart_object(entry, npc_id)
    if not smart_obj then
        return false
    end

    local job = nil
    if entry.job_section and smart_obj.find_job_by_section then
        local ok_job, resolved_job = pcall(function()
            return smart_obj:find_job_by_section(entry.job_section)
        end)
        if ok_job then
            job = resolved_job
        end
    end

    if smart_obj.npc_by_job_section and entry.job_section and smart_obj.npc_by_job_section[entry.job_section] == npc_id then
        smart_obj.npc_by_job_section[entry.job_section] = nil
    end

    if smart_obj.npc_info and smart_obj.npc_info[npc_id] and smart_obj.npc_info[npc_id].job
        and entry.job_section and smart_obj.npc_info[npc_id].job.section == entry.job_section then
        smart_obj.npc_info[npc_id].job = nil
        smart_obj.npc_info[npc_id].begin_job = false
    end

    if job then
        if job._panda_dynamic then
            remove_stationary_custom_job(smart_obj, job)
        else
            restore_stationary_smart_job(job, npc_id)
        end
    end

    entry.job_section = nil

    return true
end

local function ensure_stationary_smart_job_binding(npc_id, live_npc, reason)
    local entry = stationary_custom_npcs[npc_id]
    if not entry or get_stationary_entry_mode(entry) ~= "smart_job" then
        return false
    end

    local se_obj = alife_object(npc_id)
    local smart_obj = get_stationary_smart_object(entry, npc_id)
    if not se_obj or not smart_obj then
        return false
    end

    local squad_obj = entry.squad_id and alife_object(entry.squad_id) or nil
    if not squad_obj and se_obj.group_id and se_obj.group_id ~= 65535 then
        squad_obj = alife_object(se_obj.group_id)
        if squad_obj then
            entry.squad_id = squad_obj.id
        end
    end

    if squad_obj then
        configure_story_style_squad_target(squad_obj, smart_obj)
    end

    if smart_obj.register_npc and (not smart_obj.npc_info or not smart_obj.npc_info[npc_id]) then
        pcall(function()
            smart_obj:register_npc(se_obj)
        end)
    end

    local npc_info = smart_obj.npc_info and smart_obj.npc_info[npc_id] or nil
    if not npc_info and smart_obj.fill_npc_info then
        local ok_info, filled_info = pcall(function()
            return smart_obj:fill_npc_info(se_obj)
        end)
        if ok_info and filled_info then
            smart_obj.npc_info = smart_obj.npc_info or {}
            smart_obj.npc_info[npc_id] = filled_info
            npc_info = filled_info
        end
    end

    if not npc_info then
        printf(
            "PANDA_NPC: stationary smart job bind postponed npc_id=%s reason=%s smart_id=%s (npc_info missing)",
            tostring(npc_id),
            tostring(reason or "unspecified"),
            tostring(entry.smart_id or "nil")
        )
        return false
    end

    local job = find_stationary_smart_job_for_npc(smart_obj, npc_info, entry.job_section, entry)
    if not job then
        printf(
            "PANDA_NPC: no free stationary smart job for npc_id=%s smart=%s reason=%s",
            tostring(npc_id),
            tostring(smart_obj.name and smart_obj:name() or entry.smart_id or "nil"),
            tostring(reason or "unspecified")
        )
        return false
    end

    promote_stationary_smart_job(job, npc_id)
    if smart_obj.npc_by_job_section then
        for section, owner_id in pairs(smart_obj.npc_by_job_section) do
            if owner_id == npc_id and section ~= job.section then
                smart_obj.npc_by_job_section[section] = nil
            end
        end
        smart_obj.npc_by_job_section[job.section] = npc_id
    end

    npc_info.need_job = "nil"
    npc_info.job = job
    npc_info.current_index = 1
    npc_info.begin_job = false

    entry.mode = "smart_job"
    entry.smart_id = smart_obj.id
    entry.job_section = job.section
    move_server_object_to_stationary_job(se_obj, squad_obj, job, entry)

    if live_npc and smart_obj.setup_logic then
        npc_info.begin_job = true
        if db and db.offline_objects and db.offline_objects[npc_id] and empty_table then
            pcall(function()
                empty_table(db.offline_objects[npc_id])
            end)
        end
        pcall(function()
            smart_obj:setup_logic(live_npc)
        end)
    end

    printf(
        "PANDA_NPC: stationary smart job bound npc_id=%s squad_id=%s smart_id=%s job=%s reason=%s",
        tostring(npc_id),
        tostring(entry.squad_id or "nil"),
        tostring(entry.smart_id or "nil"),
        tostring(entry.job_section or "nil"),
        tostring(reason or "unspecified")
    )

    return true
end

local function get_stationary_anchor_for_squad(squad_obj)
    if not squad_obj then
        return nil
    end

    for member in squad_obj:squad_members() do
        local anchor = stationary_custom_npcs[member.id]
        if anchor and get_stationary_entry_mode(anchor) == "anchor" then
            return anchor
        end
    end

    return nil
end

local function resolve_stationary_anchor_smart_id(anchor, squad_obj)
    local smart_id = anchor and (tonumber(anchor.smart_id) or anchor.smart_id) or nil
    if smart_id then
        return smart_id
    end

    if squad_obj and squad_obj.smart_id then
        return squad_obj.smart_id
    end

    if not squad_obj then
        return nil
    end

    for member in squad_obj:squad_members() do
        local member_smart_id = get_server_object_smart_id(alife_object(member.id))
        if member_smart_id then
            return member_smart_id
        end
    end

    return nil
end

attach_stationary_squad_to_smart = function(squad_obj, anchor)
    if not squad_obj then
        return nil
    end

    local smart_id = resolve_stationary_anchor_smart_id(anchor, squad_obj)
    if not smart_id then
        return nil
    end

    if anchor then
        anchor.smart_id = smart_id
    end

    if squad_obj.smart_id ~= smart_id then
        if SIMBOARD and type(SIMBOARD.assign_squad_to_smart) == "function" then
            pcall(function()
                SIMBOARD:assign_squad_to_smart(squad_obj, smart_id)
            end)
        else
            local smart_obj = alife_object(smart_id)
            if smart_obj and squad_obj.assign_smart then
                pcall(function()
                    squad_obj:assign_smart(smart_obj, squad_obj.smart_id)
                end)
            end
        end
    end

    squad_obj.smart_id = smart_id
    return smart_id
end

local function detach_stationary_squad_from_simboard(squad_obj, old_smart_id)
    if not squad_obj then
        return false
    end

    local detached_via_api = false
    if SIMBOARD and type(SIMBOARD.assign_squad_to_smart) == "function" then
        detached_via_api = pcall(function()
            SIMBOARD:assign_squad_to_smart(squad_obj, nil)
        end) == true
    end

    local squad_id = squad_obj.id
    if old_smart_id and SIMBOARD and SIMBOARD.smarts and SIMBOARD.smarts[old_smart_id] then
        local board_entry = SIMBOARD.smarts[old_smart_id]
        if board_entry.squads and board_entry.squads[squad_id] then
            board_entry.squads[squad_id] = nil
            if smart_terrain and smart_terrain.smart_terrain_squad_count then
                local ok_population, population = pcall(function()
                    return smart_terrain.smart_terrain_squad_count(board_entry.squads)
                end)
                if ok_population then
                    board_entry.population = population
                end
            end
        end
    end

    return detached_via_api
end

configure_stationary_squad = function(squad_obj, reason)
    if not squad_obj then
        return false
    end

    local squad_id = squad_obj.id
    local anchor = get_stationary_anchor_for_squad(squad_obj)
    local target_smart_id = resolve_stationary_anchor_smart_id(anchor, squad_obj)
    stationary_custom_squads[squad_id] = true
    squad_obj.panda_stationary = true
    local reason_text = tostring(reason or "unspecified")
    local old_smart_id = squad_obj.smart_id
    local expected_target_id = target_smart_id or squad_id
    local expected_scripted_target = tostring(expected_target_id)
    local expected_current_action = target_smart_id and 1 or 0

    if old_smart_id ~= target_smart_id or squad_obj.task_target_id ~= nil
        or tostring(squad_obj.scripted_target or "") ~= expected_scripted_target
        or squad_obj.assigned_target_id ~= expected_target_id
        or squad_obj.current_target_id ~= expected_target_id
        or squad_obj.current_action ~= expected_current_action
        or squad_obj.rush_to_target ~= false then
        printf(
            "PANDA_NPC: stationary squad reassert squad_id=%s reason=%s smart_id=%s scripted_target=%s assigned_target_id=%s current_target_id=%s current_action=%s rush_to_target=%s task_target_id=%s",
            tostring(squad_id),
            reason_text,
            tostring(old_smart_id or "nil"),
            tostring(squad_obj.scripted_target or "nil"),
            tostring(squad_obj.assigned_target_id or "nil"),
            tostring(squad_obj.current_target_id or "nil"),
            tostring(squad_obj.current_action or "nil"),
            tostring(squad_obj.rush_to_target),
            tostring(squad_obj.task_target_id or "nil")
        )
    end

    if target_smart_id then
        attach_stationary_squad_to_smart(squad_obj, anchor)
        squad_obj.task_target_id = nil
        squad_obj.scripted_target = expected_scripted_target
        squad_obj.assigned_target_id = expected_target_id
        squad_obj.current_target_id = expected_target_id
        squad_obj.current_action = 1
        squad_obj.rush_to_target = false
        if game and game.get_game_time then
            squad_obj.stay_time = game.get_game_time()
        end
        return true
    end

    detach_stationary_squad_from_simboard(squad_obj, old_smart_id)
    squad_obj.smart_id = nil
    squad_obj.task_target_id = nil
    squad_obj.scripted_target = expected_scripted_target
    squad_obj.assigned_target_id = expected_target_id
    squad_obj.current_target_id = expected_target_id
    squad_obj.current_action = expected_current_action
    squad_obj.rush_to_target = false

    for member in squad_obj:squad_members() do
        local se_member = alife_object(member.id)
        if se_member then
            local member_smart_id = nil
            if se_member.smart_terrain_id then
                local ok_member_smart, resolved_member_smart = pcall(function()
                    return se_member:smart_terrain_id()
                end)
                if ok_member_smart then
                    member_smart_id = resolved_member_smart
                end
            end

            if member_smart_id == nil then
                member_smart_id = se_member.m_smart_terrain_id
            end

            if member_smart_id and member_smart_id ~= 65535 then
                printf(
                    "PANDA_NPC: stationary member scrub npc_id=%s squad_id=%s reason=%s smart_id=%s",
                    tostring(member.id),
                    tostring(squad_id),
                    reason_text,
                    tostring(member_smart_id)
                )
            end

            if se_member.clear_smart_terrain then
                pcall(function()
                    se_member:clear_smart_terrain()
                end)
            end
            se_member.m_smart_terrain_id = 65535
        end
    end

    return true
end

local function enforce_stationary_npc_anchor(npc_id, reason)
    local anchor = stationary_custom_npcs[npc_id]
    if not anchor then
        return false
    end

    if get_stationary_entry_mode(anchor) == "smart_job" then
        return ensure_stationary_smart_job_binding(npc_id, get_live_npc_object(npc_id), reason or "smart_job_runtime")
    end

    local reason_text = tostring(reason or "unspecified")
    local squad_obj = nil
    if anchor.squad_id then
        squad_obj = alife_object(anchor.squad_id)
        if squad_obj then
            configure_stationary_squad(squad_obj, reason_text)
        else
            printf(
                "PANDA_NPC: stationary anchor missing squad npc_id=%s squad_id=%s reason=%s",
                tostring(npc_id),
                tostring(anchor.squad_id),
                reason_text
            )
        end
    end

    local npc = get_live_npc_object(npc_id)
    local desired_pos = table_to_vector(anchor.pos)
    if not npc or not desired_pos or not npc.alive or not npc:alive() then
        return false
    end

    local force_idle_reset = reason_text == "spawn_custom_npc"
        or reason_text == "npc_on_net_spawn"
        or reason_text == "on_game_start_restore"
        or reason_text == "squad_on_first_update"

    apply_stationary_npc_runtime_lock(npc, anchor, reason_text, force_idle_reset)

    local current_pos = get_runtime_position(npc)
    if current_pos and current_pos.distance_to and npc.set_npc_position then
        local ok_dist, dist = pcall(function()
            return current_pos:distance_to(desired_pos)
        end)
        if ok_dist and dist and dist > STATIONARY_TELEPORT_THRESHOLD and reason_text ~= "npc_on_net_spawn" then
            printf(
                "PANDA_NPC: stationary anchor drift npc_id=%s squad_id=%s reason=%s dist=%s threshold=%s",
                tostring(npc_id),
                tostring(anchor.squad_id or "nil"),
                reason_text,
                tostring(dist),
                tostring(STATIONARY_TELEPORT_THRESHOLD)
            )

            local snapped_with_squad = false
            if squad_obj and squad_obj.set_squad_position then
                local ok_snap = pcall(function()
                    squad_obj:set_squad_position(desired_pos)
                end)
                snapped_with_squad = ok_snap == true
            end
            if not snapped_with_squad then
                pcall(function()
                    npc:set_npc_position(desired_pos)
                end)
            end

            apply_stationary_npc_runtime_lock(npc, anchor, reason_text, true)
        end
    end

    return true
end

local function schedule_stationary_anchor_enforcement(npc_id)
    local anchor = stationary_custom_npcs[npc_id]
    if not anchor or get_stationary_entry_mode(anchor) ~= "anchor" or not CreateTimeEvent or stationary_anchor_scheduled[npc_id] then
        return
    end

    stationary_anchor_scheduled[npc_id] = true
    CreateTimeEvent("panda_npc_anchor", tostring(npc_id), STATIONARY_ANCHOR_INTERVAL, function()
        stationary_anchor_scheduled[npc_id] = nil

        local current = stationary_custom_npcs[npc_id]
        if not current then
            return true
        end

        enforce_stationary_npc_anchor(npc_id, "anchor_timer")

        schedule_stationary_anchor_enforcement(npc_id)
        return true
    end)
end

local function schedule_online_loadout_activation(npc_id)
    local pending = pending_loadout_overrides[npc_id]
    if not pending or not CreateTimeEvent then
        return
    end

    CreateTimeEvent("panda_npc_loadout", tostring(npc_id), LOADOUT_RETRY_INTERVAL, function()
        local override = pending_loadout_overrides[npc_id]
        if not override then
            return true
        end

        local sim = alife()
        local se_npc = sim and sim:object(npc_id)
        if se_npc then
            if override.outfit and override.outfit ~= "" then
                clear_conflicting_outfits(se_npc, override.outfit)
            end
            if override.visual and override.visual ~= "" then
                apply_server_visual_override(se_npc, override.visual)
            end
        end

        local npc = level.object_by_id(npc_id)
        if not npc then
            override.tries = (override.tries or 0) + 1
            if override.tries < LOADOUT_RETRY_LIMIT then
                schedule_online_loadout_activation(npc_id)
            end
            return true
        end

        local outfit_applied = not (override.outfit and override.outfit ~= "")
        if override.outfit and override.outfit ~= "" then
            local outfit = find_inventory_item_by_section(npc, override.outfit)
            if outfit then
                pcall(function() npc:move_to_slot(outfit, 7) end)
            end
            outfit_applied = is_outfit_equipped(npc, override.outfit)
        end

        local visual_applied = not (override.visual and override.visual ~= "")
        if override.visual and override.visual ~= "" then
            apply_online_visual_override(npc, override.visual)
            visual_applied = is_visual_applied(npc, override.visual)
        end

        local weapon_applied = not ((override.primary and override.primary ~= "") or (override.secondary and override.secondary ~= ""))
        local active_weapon = nil
        if override.primary and override.primary ~= "" then
            active_weapon = find_inventory_item_by_section(npc, override.primary)
        end
        if not active_weapon and override.secondary and override.secondary ~= "" then
            active_weapon = find_inventory_item_by_section(npc, override.secondary)
        end
        if not active_weapon and npc.best_weapon then
            local ok_best, best = pcall(function() return npc:best_weapon() end)
            if ok_best then
                active_weapon = best
            end
        end
        if active_weapon then
            pcall(function() npc:make_item_active(active_weapon) end)
            weapon_applied = true
        end

        if outfit_applied and weapon_applied and visual_applied then
            pending_loadout_overrides[npc_id] = nil
        else
            override.tries = (override.tries or 0) + 1
            if override.tries < LOADOUT_RETRY_LIMIT then
                schedule_online_loadout_activation(npc_id)
            else
                printf("PANDA_NPC: timed out applying custom loadout to npc_id=%d (primary=%s secondary=%s outfit=%s visual=%s)",
                    npc_id, tostring(override.primary), tostring(override.secondary), tostring(override.outfit), tostring(override.visual))
                pending_loadout_overrides[npc_id] = nil
            end
        end
        return true
    end)
end

-- ============================================================
-- SMART TERRAIN RESOLUTION (inlined to avoid local-function deps)
-- ============================================================

local function resolve_smart_terrain(smart_ref)
    if not smart_ref or smart_ref == "" then return nil end
    if not SIMBOARD or not SIMBOARD.get_smart_by_name then return nil end
    
    local name = smart_ref
    
    -- 1. Strip "panda_st_" prefix if present (PANDA smart reference convention)
    local stripped = string.match(name, "_panda_st_(.+)$")
    if stripped then name = stripped end

    -- 2. Strip "st_" prefix (Common STALKER localization prefix)
    -- "^st_" means "st_" at the very beginning of the string
    name = string.gsub(name, "^st_", "")

    -- 3. Strip "_name" suffix (Common STALKER localization suffix)
    -- "_name$" means "_name" at the very end of the string
    name = string.gsub(name, "_name$", "")

    -- Try to get the smart terrain with the cleaned up name
    local smart = SIMBOARD:get_smart_by_name(name)
    
    -- Fallback: If it didn't find it, try the original unedited string just in case
    if not smart and name ~= smart_ref then
        smart = SIMBOARD:get_smart_by_name(smart_ref)
    end
    
    return smart
end

local function get_obj_position(obj)
    if not obj then return nil end
    if type(obj.position) == "function" then return obj:position() end
    return obj.position
end

local function get_obj_level_vertex_id(obj)
    if not obj then
        return nil
    end
    if obj.m_level_vertex_id ~= nil then
        return obj.m_level_vertex_id
    end
    if obj.m_tNodeID ~= nil then
        return obj.m_tNodeID
    end
    if type(obj.level_vertex_id) == "function" then
        local ok, value = pcall(function()
            return obj:level_vertex_id()
        end)
        if ok then
            return value
        end
    end
    return nil
end

local function get_obj_game_vertex_id(obj)
    if not obj then
        return nil
    end
    if obj.m_game_vertex_id ~= nil then
        return obj.m_game_vertex_id
    end
    if obj.m_tGraphID ~= nil then
        return obj.m_tGraphID
    end
    if type(obj.game_vertex_id) == "function" then
        local ok, value = pcall(function()
            return obj:game_vertex_id()
        end)
        if ok then
            return value
        end
    end
    return nil
end

local function get_smart_spawn_anchor(smart_obj)
    local pos = get_obj_position(smart_obj)
    local lvid = get_obj_level_vertex_id(smart_obj)
    local gvid = get_obj_game_vertex_id(smart_obj)
    if not pos or not lvid or not gvid then
        return nil, nil, nil
    end
    return pos, lvid, gvid
end

local function find_spawn_point_near_smart_local(min, max, smart_pos, smart_lvid, smart_gvid)
    if not smart_pos or not smart_lvid or not smart_gvid then
        return nil, nil, nil
    end

    min = tonumber(min) or 10
    max = tonumber(max) or min
    if min > max then
        min, max = max, min
    end

    for _ = 1, 20 do
        local d = math.random(min, max)
        local dir = vector():set(math.random(-100,100), 0, math.random(-100,100)):normalize()
        local n = level.vertex_in_direction(smart_lvid, dir, d)
        if n and n < 4294967295 then
            return level.vertex_position(n), n, smart_gvid
        end
    end

    return smart_pos, smart_lvid, smart_gvid
end

local function find_spawn_point_near_player_local(min, max)
    local actor = db and db.actor
    if not actor then
        return nil, nil, nil
    end

    local p = actor:position()
    local l = actor:level_vertex_id()
    local g = actor:game_vertex_id()

    min = tonumber(min) or 10
    max = tonumber(max) or min
    if min > max then
        min, max = max, min
    end

    for _ = 1, 20 do
        local d = math.random(min, max)
        local dir = vector():set(math.random(-100,100), 0, math.random(-100,100)):normalize()
        local n = level.vertex_in_direction(l, dir, d)
        if n and n < 4294967295 then
            return level.vertex_position(n), n, g
        end
    end

    return p, l, g
end

local function create_squad_safely_local(sec, pos, lvid, gvid, spawn_smart, single_member_section)
    local sim = alife()
    if not sim or not sim.create or not sec or not pos or not lvid or not gvid then
        return nil
    end

    local obj = sim:create(sec, pos, lvid, gvid)
    if obj and obj:clsid() == clsid.online_offline_group_s then
        if spawn_smart and spawn_smart.id then
            obj.smart_id = spawn_smart.id
        end

        local spawned_single_member = false
        local added_member_id = nil
        if single_member_section and obj.add_squad_member then
            local ok_add, new_member_id = pcall(function()
                return obj:add_squad_member(single_member_section, pos, lvid, gvid)
            end)
            added_member_id = ok_add and new_member_id or nil
            spawned_single_member = added_member_id ~= nil
            if not spawned_single_member then
                printf(
                    "PANDA_NPC: failed to add single member '%s' to squad section '%s'; falling back to create_npc",
                    tostring(single_member_section),
                    tostring(sec)
                )
            end
        end

        if not spawned_single_member and obj.create_npc then
            obj:create_npc(spawn_smart, pos, lvid, gvid)
        end

        if spawned_single_member and spawn_smart and spawn_smart.register_npc and added_member_id then
            local added_member = sim:object(added_member_id)
            if added_member then
                pcall(function()
                    spawn_smart:register_npc(added_member)
                end)
            end
        end

        if SIMBOARD and SIMBOARD.setup_squad_and_group then
            for k in obj:squad_members() do
                local se = k.object or (k.id and sim:object(k.id))
                if se then
                    SIMBOARD:setup_squad_and_group(se)
                end
            end
        end
    end

    return obj
end

local function create_single_npc_safely_local(sec, pos, lvid, gvid, spawn_smart)
    local sim = alife()
    if not sim or not sim.create or not sec or not pos or not lvid or not gvid then
        return nil
    end

    local obj = sim:create(sec, pos, lvid, gvid)
    if not obj then
        return nil
    end

    if spawn_smart and spawn_smart.register_npc then
        pcall(function()
            spawn_smart:register_npc(obj)
        end)
    end

    if SIMBOARD and SIMBOARD.setup_squad_and_group then
        pcall(function()
            SIMBOARD:setup_squad_and_group(obj)
        end)
    end

    return obj
end

local function cleanup_failed_stationary_spawn(template_id, se_obj, squad_obj, smart_obj, npc_id, reason)
    if npc_id then
        pending_name_overrides[npc_id] = nil
        pending_rank_overrides[npc_id] = nil
        pending_relation_overrides[npc_id] = nil
        pending_loadout_overrides[npc_id] = nil
        stationary_custom_npcs[npc_id] = nil
        stationary_anchor_scheduled[npc_id] = nil
    end

    if squad_obj then
        stationary_custom_squads[squad_obj.id] = nil
        if SIMBOARD and SIMBOARD.remove_squad then
            pcall(function()
                SIMBOARD:remove_squad(squad_obj)
            end)
        elseif squad_obj.remove_squad then
            pcall(function()
                squad_obj:remove_squad()
            end)
        end

        printf(
            "PANDA_NPC: aborted stationary template '%s'; cleaned up squad_id=%s reason=%s",
            tostring(template_id),
            tostring(squad_obj.id or "nil"),
            tostring(reason or "unknown")
        )
        return
    end

    if se_obj then
        local smart_id = get_server_object_smart_id(se_obj) or (smart_obj and smart_obj.id) or nil
        if smart_id and smart_id ~= 65535 then
            safe_unregister_from_smart(alife_object(smart_id), se_obj, "PANDA_NPC stationary spawn cleanup", smart_id)
        end
        release_server_object(se_obj, "PANDA_NPC stationary spawn cleanup for " .. tostring(template_id))
        printf(
            "PANDA_NPC: aborted stationary template '%s'; released npc_id=%s reason=%s",
            tostring(template_id),
            tostring(se_obj.id or npc_id or "nil"),
            tostring(reason or "unknown")
        )
    end
end

-- ============================================================
-- CORE SPAWN FUNCTION
-- ============================================================

function spawn_custom_npc(template_id, context)
    context = context or {}
    local tpl = parse_template(template_id)
    local needs_smart = context.smart_ref and context.smart_ref ~= ""
    local wants_stationary_anchor = tpl and needs_smart and tpl.allow_roam == false
    local allow_roam = tpl and not wants_stationary_anchor
    if not tpl then
        printf("PANDA_NPC: spawn_custom_npc aborted — template '%s' missing", tostring(template_id))
        return
    end
    if not (db and db.actor) and not needs_smart then
        printf("PANDA_NPC: spawn_custom_npc aborted — no actor")
        return
    end
    if not needs_smart and tpl.allow_roam == false then
        printf(
            "PANDA_NPC: template '%s' requested a fixed position, but near-player spawns always roam; ignoring stationary flag",
            tostring(template_id)
        )
    end

    -- Resolve spawn position
    local pos, lvid, gvid
    local smart_obj = nil
    if needs_smart then
        smart_obj = resolve_smart_terrain(context.smart_ref)
        if smart_obj then
            pos, lvid, gvid = get_smart_spawn_anchor(smart_obj)
        end
        if not pos then
            printf("PANDA_NPC: smart terrain '%s' not ready for template '%s'",
                tostring(context.smart_ref), tostring(template_id))
        end
    end
    if needs_smart and not pos then
        return
    end
    if wants_stationary_anchor and smart_obj then
        local authored_stationary_jobs = count_authored_stationary_smart_jobs(smart_obj)
        if authored_stationary_jobs == 0 then
            printf(
                "PANDA_NPC: stationary template '%s' requires a smart terrain with an authored stalker idle job; smart '%s' has none, aborting fixed-position spawn",
                tostring(template_id),
                tostring(smart_obj.name and smart_obj:name() or context.smart_ref or "nil")
            )
            return
        end
    end
    if not pos and not needs_smart then
        local dist = tpl.spawn_dist or 50
        pos, lvid, gvid = find_spawn_point_near_player_local(dist, dist)
    end

    -- Create squad
    local sec = get_squad_section(tpl.faction)
    local single_member_section = get_single_member_spawn_section(sec)
    local squad = nil
    local squad_id = nil
    local member_ids = {}
    local spawned_single_npc = nil

    if wants_stationary_anchor and single_member_section then
        spawned_single_npc = create_single_npc_safely_local(single_member_section, pos, lvid, gvid, smart_obj)
        if not spawned_single_npc then
            printf(
                "PANDA_NPC: failed to create direct stationary npc '%s' from section '%s'; falling back to squad spawn",
                tostring(template_id),
                tostring(single_member_section)
            )
        end
    end

    if spawned_single_npc then
        member_ids = { spawned_single_npc.id }
    else
        squad = create_squad_safely_local(sec, pos, lvid, gvid, smart_obj, single_member_section)
        if not squad or squad:clsid() ~= clsid.online_offline_group_s then
            printf("PANDA_NPC: create_squad_safely failed for template '%s' (section=%s)", tostring(template_id), tostring(sec))
            return
        end
        squad_id = squad.id
        member_ids = prune_squad_to_single_member(squad, template_id)
    end

    -- Assign to smart terrain
    if squad and smart_obj and SIMBOARD and SIMBOARD.assign_squad_to_smart then
        SIMBOARD:assign_squad_to_smart(squad, smart_obj.id)
    end

    -- Apply relation
    if squad then
        apply_squad_relation(squad, tpl.relation)
    end

    if wants_stationary_anchor and squad then
        configure_story_style_squad_target(squad, smart_obj)
    end

    -- Companion integration
    if string.lower(tpl.relation or "") == "companion" then
        if squad then
            register_as_companion(squad, squad_id)
        elseif wants_stationary_anchor then
            printf(
                "PANDA_NPC: stationary template '%s' was spawned as a single npc; companion squad integration was skipped",
                tostring(template_id)
            )
        end
    end

    -- Apply loadout + name to each member
    local member_count = 0
    local outfit_visual = resolve_outfit_visual(tpl.faction, tpl.outfit)
    for _, member_id in ipairs(member_ids) do
        member_count = member_count + 1
        local se_obj = alife_object(member_id)
        local anchor_pos = pos
        local anchor_lvid = lvid
        local anchor_gvid = gvid
        if se_obj then
            if wants_stationary_anchor then
                anchor_pos = get_obj_position(se_obj) or anchor_pos
                anchor_lvid = get_obj_level_vertex_id(se_obj) or anchor_lvid
                anchor_gvid = get_obj_game_vertex_id(se_obj) or anchor_gvid

                local anchor_smart_id = smart_obj and smart_obj.id or get_server_object_smart_id(se_obj)
                stationary_custom_npcs[member_id] = {
                    mode = "smart_job",
                    pos = vector_to_table(anchor_pos),
                    lvid = anchor_lvid,
                    gvid = anchor_gvid,
                    squad_id = squad_id,
                    smart_id = anchor_smart_id,
                    job_section = nil,
                }
                if not ensure_stationary_smart_job_binding(member_id, nil, "spawn_custom_npc") then
                    cleanup_failed_stationary_spawn(
                        template_id,
                        spawned_single_npc or se_obj,
                        squad,
                        smart_obj,
                        member_id,
                        "no compatible authored stationary smart job"
                    )
                    return
                end
            else
                stationary_custom_npcs[member_id] = nil
            end

            local primary_section = parse_weapon_tokens(tpl.primary)
            local secondary_section = parse_weapon_tokens(tpl.secondary)
            clear_npc_generated_loadout(se_obj, tpl)
            give_weapon(se_obj, tpl.primary)
            give_weapon(se_obj, tpl.secondary)
            give_outfit(se_obj, tpl.outfit)
            if outfit_visual then
                apply_server_visual_override(se_obj, outfit_visual)
            end
            give_items(se_obj, tpl.items)

            -- Apply name: try directly on server object first
            if tpl.name and tpl.name ~= "" then
                if se_obj.set_character_name then
                    pcall(function() se_obj:set_character_name(tpl.name) end)
                end
                -- Register as fallback for when NPC goes online
                pending_name_overrides[member_id] = tpl.name
            end

            if tpl.rank and tpl.rank ~= "" then
                local applied_server, rank_points = apply_rank_to_server_object(se_obj, tpl.rank)
                local online_obj = level and level.object_by_id and level.object_by_id(member_id) or nil
                local applied_online = false
                if online_obj then
                    applied_online = select(1, apply_rank_to_game_object(online_obj, tpl.rank))
                end
                pending_rank_overrides[member_id] = tpl.rank
                printf(
                    "PANDA_NPC: queued rank '%s' for npc_id=%d points=%s server=%s online=%s",
                    tostring(tpl.rank),
                    member_id,
                    tostring(rank_points or "nil"),
                    tostring(applied_server),
                    tostring(applied_online)
                )
            else
                pending_rank_overrides[member_id] = nil
            end

            if tpl.relation and tpl.relation ~= "" then
                pending_relation_overrides[member_id] = string.lower(tostring(tpl.relation))
            end

            if primary_section or secondary_section or (tpl.outfit and tpl.outfit ~= "") then
                pending_loadout_overrides[member_id] = {
                    primary = primary_section,
                    secondary = secondary_section,
                    outfit = tpl.outfit,
                    visual = outfit_visual,
                    tries = 0,
                }
            else
                pending_loadout_overrides[member_id] = nil
            end
        end

        -- Track NPC
        if not active_custom_npcs[template_id] then
            active_custom_npcs[template_id] = {}
        end
        table.insert(active_custom_npcs[template_id], {
            npc_id     = member_id,
            squad_id   = squad_id,
            alive      = true,
            spawned_at = time_global and time_global() or 0,
        })
    end

    printf("PANDA_NPC: spawned template '%s' squad_id=%s section=%s relation=%s members=%s member_section=%s spawn_mode=%s",
        tostring(template_id), tostring(squad_id), tostring(sec), tostring(tpl.relation), tostring(member_count), tostring(single_member_section or "fallback"),
        spawned_single_npc and "single_npc" or "squad")
    return spawned_single_npc or squad
end

-- ============================================================
-- PRECONDITION HELPERS
-- ============================================================

local function get_alive_entries(template_id)
    local entries = active_custom_npcs[template_id]
    if not entries then return {} end
    local alive = {}
    for _, e in ipairs(entries) do
        if e.alive then
            -- Validate against alife
            local se = alife_object(e.npc_id)
            if not se then
                e.alive = false
            else
                alive[#alive + 1] = e
            end
        end
    end
    return alive
end

function is_template_npc_alive(template_id)
    return #get_alive_entries(template_id) > 0
end

function is_template_npc_dead(template_id)
    return not is_template_npc_alive(template_id)
end

function is_template_npc_near(template_id, dist)
    if not db.actor then return false end
    dist = tonumber(dist) or 50
    local actor_pos = db.actor:position()
    for _, e in ipairs(get_alive_entries(template_id)) do
        local obj = level.object_by_id(e.npc_id)
        if obj and obj:alive() then
            if obj:position():distance_to(actor_pos) <= dist then
                return true
            end
        end
    end
    return false
end

-- Returns the first alive NPC id for this template (used for F2F target resolution).
function get_active_npc_id(template_id)
    local entries = get_alive_entries(template_id)
    if #entries > 0 then return entries[1].npc_id end
    return nil
end

-- Returns the alife server object for the first alive NPC of this template.
function get_active_npc_se(template_id)
    local id = get_active_npc_id(template_id)
    if id then return alife_object(id) end
    return nil
end

local function normalize_faction_key(faction)
    if not faction then
        return "loner"
    end

    local fac = string.lower(tostring(faction))
    fac = string.gsub(fac, "^actor_", "")
    if fac == "stalker" then
        return "loner"
    end

    return fac
end

local function actor_faction_key()
    if db and db.actor and db.actor.character_community then
        local fac = db.actor:character_community()
        if fac and fac ~= "" then
            return normalize_faction_key(fac)
        end
    end
    return "loner"
end

local function extract_custom_story_target(precond_str)
    if not precond_str or precond_str == "" then
        return nil, nil
    end
    return string.match(precond_str, "req_custom_story_npc:([%w_%-]+):([^,%)]+)")
end

local function has_spawn_record(template_id)
    local entries = active_custom_npcs[template_id]
    return entries ~= nil and #entries > 0
end

local function queue_story_target_spawn(template_id, smart_ref, reason)
    if not template_id or template_id == "" or not smart_ref or smart_ref == "" then
        return nil
    end

    local req = pending_story_targets[template_id]
    if not req then
        req = { attempts = 0 }
        pending_story_targets[template_id] = req
    end

    req.smart_ref = smart_ref
    req.last_reason = reason or req.last_reason
    return req
end

local function pending_story_target_count()
    local count = 0
    for _ in pairs(pending_story_targets) do
        count = count + 1
    end
    return count
end

local process_pending_story_targets

local function schedule_story_target_retry(delay)
    if story_target_retry_scheduled or pending_story_target_count() == 0 or not CreateTimeEvent then
        return
    end

    story_target_retry_scheduled = true
    CreateTimeEvent("panda_story_target_spawn", "retry", delay or 5, function()
        story_target_retry_scheduled = false
        if process_pending_story_targets then
            process_pending_story_targets("timer")
        end
        return true
    end)
end

function ensure_story_target_spawned(template_id, smart_ref, context)
    context = context or {}

    if not template_id or template_id == "" then
        return nil
    end

    local existing = get_active_npc_se(template_id)
    if existing then
        pending_story_targets[template_id] = nil
        return existing
    end

    if has_spawn_record(template_id) then
        pending_story_targets[template_id] = nil
        return nil
    end

    if not smart_ref or smart_ref == "" then
        printf("PANDA_NPC: story target '%s' missing smart_ref", tostring(template_id))
        return nil
    end

    local squad = spawn_custom_npc(template_id, {
        smart_ref = smart_ref,
        conv_data = context.conv_data,
    })

    local spawned = get_active_npc_se(template_id)
    if spawned then
        pending_story_targets[template_id] = nil
        return spawned
    end

    if not squad then
        queue_story_target_spawn(template_id, smart_ref, "spawn_deferred")
        schedule_story_target_retry(5)
    end

    return nil
end

process_pending_story_targets = function(reason)
    if pending_story_target_count() == 0 then
        return
    end

    local remaining = 0
    for template_id, req in pairs(pending_story_targets) do
        if get_active_npc_se(template_id) or has_spawn_record(template_id) then
            pending_story_targets[template_id] = nil
        else
            ensure_story_target_spawned(template_id, req.smart_ref, { source = reason })
            if get_active_npc_se(template_id) or has_spawn_record(template_id) then
                pending_story_targets[template_id] = nil
            else
                req.attempts = (req.attempts or 0) + 1
                remaining = remaining + 1
                printf("PANDA_NPC: deferred story target '%s' still waiting (attempt=%d, smart=%s, trigger=%s, last_reason=%s)",
                    tostring(template_id),
                    tonumber(req.attempts) or 0,
                    tostring(req.smart_ref),
                    tostring(reason),
                    tostring(req.last_reason))
            end
        end
    end

    if remaining > 0 then
        schedule_story_target_retry(5)
    end
end

local function spawn_story_target_templates_for_faction(xml_fac, reason)
    if not xml_fac or xml_fac == "" then
        return
    end

    local cid = 1
    while true do
        local stem = "st_pda_ic_" .. tostring(xml_fac) .. "_" .. tostring(cid)
        local open_key = stem .. "_open"
        if game.translate_string(open_key) == open_key then
            break
        end

        local precond_key = stem .. "_precond"
        local precond_val = game.translate_string(precond_key)
        if precond_val ~= precond_key then
            local tpl_id, smart_ref = extract_custom_story_target(precond_val)
            if tpl_id and smart_ref then
                queue_story_target_spawn(tpl_id, smart_ref, reason or ("scan:" .. tostring(xml_fac)))
            end
        end

        cid = cid + 1
    end

    process_pending_story_targets(reason or ("scan:" .. tostring(xml_fac)))
end

-- ============================================================
-- SAVE / LOAD
-- ============================================================

function save_state(m)
    local save_npcs = {}
    for tpl_id, entries in pairs(active_custom_npcs) do
        local valid = {}
        for _, e in ipairs(entries) do
            if e.alive then
                valid[#valid + 1] = {
                    npc_id     = e.npc_id,
                    squad_id   = e.squad_id,
                    alive      = true,
                    spawned_at = e.spawned_at,
                }
            end
        end
        if #valid > 0 then
            save_npcs[tpl_id] = valid
        end
    end
    m.panda_custom_npcs          = save_npcs
    m.panda_npc_name_overrides   = pending_name_overrides
    m.panda_npc_rank_overrides   = pending_rank_overrides
    m.panda_npc_relation_overrides = pending_relation_overrides
    m.panda_npc_loadout_overrides = pending_loadout_overrides
    m.panda_npc_stationary_anchors = stationary_custom_npcs
end

function load_state(m)
    active_custom_npcs    = m.panda_custom_npcs        or {}
    pending_name_overrides = m.panda_npc_name_overrides or {}
    pending_rank_overrides = m.panda_npc_rank_overrides or {}
    pending_relation_overrides = m.panda_npc_relation_overrides or {}
    pending_loadout_overrides = m.panda_npc_loadout_overrides or {}
    stationary_custom_npcs = {}
    stationary_custom_squads = {}
    if type(m.panda_npc_stationary_anchors) == "table" then
        for raw_npc_id, anchor in pairs(m.panda_npc_stationary_anchors) do
            local npc_id = tonumber(raw_npc_id)
            if npc_id and type(anchor) == "table" then
                local squad_id = tonumber(anchor.squad_id) or anchor.squad_id
                local smart_id = tonumber(anchor.smart_id) or anchor.smart_id
                if not smart_id and squad_id then
                    local squad_obj = alife_object(squad_id)
                    local inferred_smart_id = squad_obj and squad_obj.smart_id or nil
                    if inferred_smart_id and inferred_smart_id ~= 65535 then
                        smart_id = inferred_smart_id
                    end
                end
                local mode = anchor.mode
                if not mode or mode == "" then
                    mode = smart_id and "smart_job" or "anchor"
                end
                stationary_custom_npcs[npc_id] = {
                    mode = tostring(mode),
                    pos = anchor.pos,
                    lvid = tonumber(anchor.lvid) or anchor.lvid,
                    gvid = tonumber(anchor.gvid) or anchor.gvid,
                    squad_id = squad_id,
                    smart_id = smart_id,
                    job_section = anchor.job_section,
                }
                if squad_id and tostring(mode) == "anchor" then
                    stationary_custom_squads[squad_id] = true
                end
            end
        end
    end
    stationary_anchor_scheduled = {}
    pending_story_targets = {}
    story_target_retry_scheduled = false
end

-- ============================================================
-- CALLBACKS
-- ============================================================

local function on_npc_net_spawn(obj, se_obj)
    local npc_id = get_callback_npc_id(obj, se_obj)
    if not npc_id then
        return
    end

    if pending_name_overrides[npc_id] then
        local name = pending_name_overrides[npc_id]
        local sim  = alife()
        local se   = se_obj or (sim and sim:object(npc_id))
        if se and se.set_character_name then
            pcall(function() se:set_character_name(name) end)
        end
        pending_name_overrides[npc_id] = nil
        printf("PANDA_NPC: applied name '%s' to npc_id=%d (deferred)", tostring(name), npc_id)
    end

    if pending_rank_overrides[npc_id] then
        local rank_name = pending_rank_overrides[npc_id]
        local sim = alife()
        local se = se_obj or (sim and sim:object(npc_id))
        local applied_server, rank_points = apply_rank_to_server_object(se, rank_name)
        local applied_online = false
        if obj then
            applied_online = select(1, apply_rank_to_game_object(obj, rank_name))
        end
        if applied_server or applied_online then
            pending_rank_overrides[npc_id] = nil
        end
        printf(
            "PANDA_NPC: applied deferred rank '%s' to npc_id=%d points=%s server=%s online=%s",
            tostring(rank_name),
            npc_id,
            tostring(rank_points or "nil"),
            tostring(applied_server),
            tostring(applied_online)
        )
    end

    if pending_relation_overrides[npc_id] then
        if apply_pending_actor_relation(obj, pending_relation_overrides[npc_id]) then
            pending_relation_overrides[npc_id] = nil
        end
    end

    if pending_loadout_overrides[npc_id] then
        schedule_online_loadout_activation(npc_id)
    end

    if stationary_custom_npcs[npc_id] then
        local anchor = stationary_custom_npcs[npc_id]
        if get_stationary_entry_mode(anchor) == "smart_job" then
            ensure_stationary_smart_job_binding(npc_id, obj, "npc_on_net_spawn")
        elseif anchor and anchor.squad_id then
            local squad_obj = alife_object(anchor.squad_id)
            if squad_obj then
                configure_stationary_squad(squad_obj, "npc_on_net_spawn")
            end
            schedule_stationary_anchor_enforcement(npc_id)
        end
    end
end

local function on_npc_death(obj, killer)
    local npc_id = get_callback_npc_id(obj)
    if not npc_id then
        return
    end

    local stationary_anchor = stationary_custom_npcs[npc_id]
    release_stationary_smart_job(npc_id)

    pending_name_overrides[npc_id] = nil
    pending_rank_overrides[npc_id] = nil
    pending_relation_overrides[npc_id] = nil
    pending_loadout_overrides[npc_id] = nil
    stationary_custom_npcs[npc_id] = nil
    stationary_anchor_scheduled[npc_id] = nil
    if stationary_anchor and stationary_anchor.squad_id then
        stationary_custom_squads[stationary_anchor.squad_id] = nil
    end
    for tpl_id, entries in pairs(active_custom_npcs) do
        for _, e in ipairs(entries) do
            if e.npc_id == npc_id and e.alive then
                e.alive = false
                printf("PANDA_NPC: npc_id=%d (template '%s') marked dead", npc_id, tostring(tpl_id))
            end
        end
    end
end

local function enforce_stationary_squad_runtime(squad_obj, reason)
    if not squad_obj or not stationary_custom_squads[squad_obj.id] then
        return
    end

    local anchored_member = false
    local smart_job_member = false
    for member in squad_obj:squad_members() do
        local entry = stationary_custom_npcs[member.id]
        if entry then
            if get_stationary_entry_mode(entry) == "anchor" then
                anchored_member = true
                enforce_stationary_npc_anchor(member.id, reason)
            else
                smart_job_member = true
            end
        end
    end

    if smart_job_member and not anchored_member then
        stationary_custom_squads[squad_obj.id] = nil
        squad_obj.panda_stationary = nil
        return
    end

    if not anchored_member then
        configure_stationary_squad(squad_obj, reason or "squad_runtime")
    end
end

local function on_stationary_squad_first_update(squad_obj)
    enforce_stationary_squad_runtime(squad_obj, "squad_on_first_update")
end

local function on_stationary_squad_update(squad_obj)
    enforce_stationary_squad_runtime(squad_obj, "squad_on_update")
end

local function on_actor_first_update()
    spawn_story_target_templates_for_faction(actor_faction_key(), "actor_on_first_update")
end

-- ============================================================
-- INITIALIZATION
-- ============================================================

function on_game_start()
    if initialized then return end
    initialized = true
    RegisterScriptCallback("npc_on_net_spawn",       on_npc_net_spawn)
    RegisterScriptCallback("npc_on_death_callback",  on_npc_death)
    RegisterScriptCallback("squad_on_first_update",  on_stationary_squad_first_update)
    RegisterScriptCallback("squad_on_update",        on_stationary_squad_update)
    RegisterScriptCallback("actor_on_first_update",  on_actor_first_update)
    if db and db.actor then
        spawn_story_target_templates_for_faction(actor_faction_key(), "on_game_start")
    end
    for npc_id in pairs(pending_loadout_overrides) do
        schedule_online_loadout_activation(npc_id)
    end
    for npc_id, entry in pairs(stationary_custom_npcs) do
        if get_stationary_entry_mode(entry) == "smart_job" then
            ensure_stationary_smart_job_binding(npc_id, get_live_npc_object(npc_id), "on_game_start_restore")
        else
            enforce_stationary_npc_anchor(npc_id, "on_game_start_restore")
            schedule_stationary_anchor_enforcement(npc_id)
        end
    end
    printf("PANDA_NPC: initialized")
end

panda_npc_creator.install_engine_guards = install_engine_guards
panda_npc_creator.spawn_custom_npc = spawn_custom_npc
panda_npc_creator.ensure_story_target_spawned = ensure_story_target_spawned
panda_npc_creator.save_state = save_state
panda_npc_creator.load_state = load_state
panda_npc_creator.on_game_start = on_game_start
