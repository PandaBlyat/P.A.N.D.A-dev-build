-- ============================================================
-- pda_interactive_conv_mcm.script (Fixed Version)
-- ============================================================

local ROOT_ID = "pda_interactive_conv"

-- Helper functions for preconditions
local function isInteractiveEnabled() return ui_mcm.get(ROOT_ID.."/interactive/enabled") end
local function isFlexibleMode()       return ui_mcm.get(ROOT_ID.."/interactive/cooldown_mode") == 2 end
local function isStrictMode()         return ui_mcm.get(ROOT_ID.."/interactive/cooldown_mode") == 1 end
local function isBackgroundEnabled()  return ui_mcm.get(ROOT_ID.."/background/npc_conv_enabled") end
local function isBackgroundStrict()   return ui_mcm.get(ROOT_ID.."/background/npc_conv_strict_cooldown") end
local function isDynamicNewsEnabled() return ui_mcm.get(ROOT_ID.."/dynamic_news/dn_enabled") end

-- ============================================================
-- Main MCM options table
-- ============================================================
function on_mcm_load()
    return {
        id = ROOT_ID,
        gr = {
            -- ================================================
            -- MOD INFO (Title Banner & Credits)
            -- ================================================
            {
                id   = "mod_info",
                text = "pda_interactive_conv_menu_mod_info",
                clr  = {255, 255, 255, 255},  -- white
                sh   = true,
                gr   = {
                    -- Main banner with mod title/subtitle
                    { id = "slide_mod_info", type = "slide",
                      link = "banner_panda_n1_icon.dds",
                      text = "", size = {512, 50}, spacing = 10, stretch = true },
                    -- Brief description / credits
                    { id = "desc_mod_info", type = "desc",
                      text = "pda_interactive_conv_desc_mod_info",
                      clr = {255, 200, 200, 200} },
                }
            },

            -- ================================================
            -- INTERACTIVE CONVERSATIONS
            -- ================================================
            {
                id   = "interactive",
                text = "pda_interactive_conv_menu_interactive",
                clr  = {255, 100, 200, 255},  -- Light purple
                sh   = true,
                gr   = {
                    -- Section banner
                    { id = "slide_interactive", type = "slide",
                      link = "banner_panda_interactive_conv_icon.dds",
                      text = "", size = {512, 50}, spacing = 10, stretch = true },

                    -- Master enable/disable
                    { id = "enabled", type = "check", val = 1, def = true },

                    -- Brief description
                    { id = "desc_interactive", type = "desc",
                      text = "pda_interactive_conv_desc_interactive",
                      clr = {255, 200, 200, 200} },

                    -- TIMING (only shown if enabled)
                    { id = "title_timing", type = "title",
                      text = "pda_interactive_conv_title_timing",
                      clr = {255, 200, 220, 100},
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "line_timing", type = "line",
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "trigger_min", type = "track", val = 2, min = 1, max = 60, step = 1, def = 8,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "trigger_max", type = "track", val = 2, min = 1, max = 120, step = 1, def = 15,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "default_cooldown", type = "track", val = 2, min = 5, max = 300, step = 5, def = 60,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "choice_tip_duration", type = "track", val = 2, min = 10, max = 120, step = 5, def = 40,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "pda_retry_delay", type = "track", val = 2, min = 1, max = 10, step = 1, def = 2,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "npc_reply_delay_min", type = "track", val = 2, min = 1, max = 10, step = 1, def = 2,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "npc_reply_delay_max", type = "track", val = 2, min = 1, max = 10, step = 1, def = 4,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "outcome_delay_min", type = "track", val = 2, min = 0, max = 5, step = 1, def = 1,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "outcome_delay_max", type = "track", val = 2, min = 0, max = 5, step = 1, def = 2,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "branch_delay_min", type = "track", val = 2, min = 1, max = 10, step = 1, def = 2,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "branch_delay_max", type = "track", val = 2, min = 1, max = 10, step = 1, def = 4,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "intro_delay", type = "track", val = 2, min = 1, max = 10, step = 1, def = 2,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "no_intro_delay", type = "track", val = 2, min = 0, max = 5, step = 1, def = 1,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "line_timing_end", type = "line",
                      precondition = { isInteractiveEnabled, {} } },

                    -- COOLDOWN BEHAVIOUR (only shown if enabled)
                    { id = "title_cooldown", type = "title",
                      text = "pda_interactive_conv_title_cooldown",
                      clr = {255, 150, 200, 150},
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "line_cooldown", type = "line",
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "cooldown_mode", type = "radio_h", val = 2, def = 2, no_str = true,
                      content = { {1, "Strict (hard block)"}, {2, "Flexible (reduced chance)"} },
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "cooldown_penalty", type = "track", val = 2, min = 5, max = 75, step = 5, def = 25,
                      precondition = { function() return isInteractiveEnabled() and isFlexibleMode() end, {} } },
                    { id = "cooldown_hard_min", type = "track", val = 2, min = 0, max = 30, step = 1, def = 5,
                      precondition = { function() return isInteractiveEnabled() and isStrictMode() end, {} } },
                    { id = "allow_cross_faction", type = "check", val = 1, def = false,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "line_cooldown_end", type = "line",
                      precondition = { isInteractiveEnabled, {} } },

                    -- GAMEPLAY (only shown if enabled)
                    { id = "title_gameplay", type = "title",
                      text = "pda_interactive_conv_title_gameplay",
                      clr = {255, 100, 200, 255},
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "line_gameplay", type = "line",
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "spawn_chance_mult", type = "track", val = 2, min = 0, max = 200, step = 5, def = 100,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "require_pda_equipped", type = "check", val = 1, def = true,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "companion_limit", type = "track", val = 2, min = 1, max = 10, step = 1, def = 4,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "max_npcs_per_trigger", type = "track", val = 2, min = 5, max = 100, step = 5, def = 20,
                      precondition = { isInteractiveEnabled, {} } },
                    { id = "npc_cooldown", type = "track", val = 2, min = 1, max = 120, step = 5, def = 10,
