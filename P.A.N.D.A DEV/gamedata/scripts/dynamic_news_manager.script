------------------------------------------------------------
-- Helpers
------------------------------------------------------------
function DynamicNewsManager:BuildSentenceStalkerEnemy(victim,who,mn,mx)
	local comm_victim = victim:character_community()
	local comm_who = who:character_community()
	local comm, dist
	local c = 0
	for i=1, #db.OnlineStalkers do
		if (db.OnlineStalkers[i] ~= who_id) then
			local st = db.storage[db.OnlineStalkers[i]]
			local npc = st and st.object or level.object_by_id(db.OnlineStalkers[i])
			if (npc and IsStalker(npc,npc:clsid()) and npc:alive() and not get_object_story_id(db.OnlineStalkers[i])) then
				comm = npc:character_community()	-- remove local
				if (comm == comm_who) then
					dist = victim:position():distance_to(npc:position())
					if (dist < mx) or (dist > mn) then 
						c = c + 1
					end
				end
			end 
		end
		if (c >= 2) then 
			break 
		end
	end

	local sentences = {}
	local string_count = 1
	while true do 
		local tr_s = game.translate_string("st_dyn_news_builder_attacked_"..string_count)
		if (tr_s == "st_dyn_news_builder_attacked_"..string_count) then 
			break
		else 
			table.insert(sentences,tr_s)
		end
		string_count = string_count + 1
	end
	
	if (#sentences == 0) then 	
		return false
	end

	if (c >= 2) then 
		return sentences[math.random(#sentences)], dynamic_news_helper.GetCommunityDescription(who,math.random(9,10))
	end

	return sentences[math.random(#sentences)], dynamic_news_helper.GetCommunityDescription(who,math.random(7,8))
end

function DynamicNewsManager:BuildSentenceStalkerEnemy_Offline(comm_w)
	local index = math.random(7,8)
	if (math.random(100) < 50) then 
		index = math.random(9,10)
	end

	local sentences = utils_data.collect_translations("st_dyn_news_builder_attacked_",true)
	if (not sentences) then return false end

	local comm_w_desc = game.translate_string("st_dyn_news_comm_" .. comm_w .. "_" .. index)

	return sentences[math.random(#sentences)], comm_w_desc
end

function DynamicNewsManager:IsSpecialNPC(npc)
	if (not npc) then return true end
	
	if string.find(npc:section(),"sim_default") then
		return false
	end
	
	return true
end

function DynamicNewsManager:IsMonoCommunity(npc)
	if (not npc) then return true end
	
	local comm = character_community(npc)
	if (npc:id() == AC_ID and comm ~= "actor") then 
		comm = comm:sub(7)
	end 
	
	if self.mono[comm] then
		return true
	end
	
	return false
end

function DynamicNewsManager:IsUnknownCommunity(npc)
	if (not npc) then return true end
	
	local comm = character_community(npc)
	if (npc:id() == AC_ID and comm ~= "actor") then 
		comm = comm:sub(7)
	end 
	
	if self.unknown[comm] then
		return true
	end
	
	return false
end



function get_story_npc_info(section)
	if not (section and section ~= "") then
		return
	end
	
	local se_npc = get_story_se_object(section)
	if se_npc then
		local name = se_npc:character_name()
		local icon = se_npc:character_icon()
		return { name = name , icon = icon }
	end
	return
end

--=========================================================================
-- NPC Conversations Logic
--=========================================================================

function DynamicNewsManager:TickConversation()
    ResetTimeEvent("DynamicNewsManager", "TickConversation", self.conv_timer)

    -- Global toggle
    if not self.conv_enabled then return false end
    if self.conv_active then return false end

    -- Random chance to run at all (global percentage)
    if math.random(100) > self.conv_chance then return false end

    -- Surge or dead PDA blocks everything
    if self:NewsToggle() or (not item_device.is_pda_charged(true)) then return false end

    -- Interactive conversation system (external)
    if pda_interactive_conv and pda_interactive_conv.try_trigger_interactive_conv then
        if pda_interactive_conv.try_trigger_interactive_conv(self) then
            return false   -- interactive conv took over this tick
        end
    end

    -- Player reputation gossip: configurable chance to replace normal dialog
    if self.rep_gossip_chance > 0 and math.random(100) <= self.rep_gossip_chance then
        if self:ShouldFirePlayerRepGossip() then
            return self:GossipAboutPlayer()
        end
    end

    local player_comm  = get_actor_true_community()
    local current_time = game.get_game_time()
    local current_lvl  = level.name()
    local actor_pos    = db.actor:position()
    local MIN_DIST     = 150

    -- Build candidate pool (NPCs of same faction, far enough, not traders, not dead)
    local candidates = {}
    local sim = alife()
    local gg  = game_graph()

    for i = 1, 65534 do
        local se_obj = sim:object(i)
        if se_obj and se_obj.id ~= AC_ID
        and IsStalker(nil, se_obj:clsid())
        and se_obj:alive()
        and se_obj:community() == player_comm
        and se_obj:community() ~= "trader"
        and se_obj.group_id ~= 65535 then

            local npc_rank = ranks.get_obj_rank_name(se_obj)
            local is_valid_rank = (npc_rank == "novice") or (npc_rank == "trainee") or (npc_rank == "experienced")

            if is_valid_rank then
                local npc_lvl = sim:level_name(gg:vertex(se_obj.m_game_vertex_id):level_id())
                local is_far  = false

                if npc_lvl ~= current_lvl then
                    is_far = true
                elseif se_obj.position:distance_to(actor_pos) >= MIN_DIST then
                    is_far = true
                end

                if is_far then
                    local last_t   = self.last_speaker_time[se_obj.id]
                    local idle_min = last_t and current_time:diffSec(last_t) / 60 or 9999
                    table.insert(candidates, { se = se_obj, idle_time = idle_min })
                end
            end
        end
    end

    if #candidates < 2 then return false end

    table.sort(candidates, function(a, b) return a.idle_time > b.idle_time end)

    local xml_fac_name = (player_comm == "stalker") and "loner" or player_comm

    -- Decide group vs classic dialog using configurable group_chance
    local try_group = (math.random(100) <= self.group_chance) and (#candidates >= 3)

    if try_group then
        local group_max = self:CountGroupConvs(xml_fac_name)
        if group_max > 0 then
            return self:StartGroupConversation(xml_fac_name, candidates, group_max)
        end
    end

    -- Classic 2‑NPC faction dialog with meta cooldown
    local max_id = 0
    while true do
        local probe = "st_dyn_news_conversation_faction_" .. xml_fac_name .. "_" .. (max_id + 1) .. "_turn_1"
        if game.translate_string(probe) == probe then break end
        max_id = max_id + 1
    end

    if max_id == 0 then return false end

    local conv_id = self:PickFreshConvId(xml_fac_name, max_id)

    local top_pool = math.max(2, math.floor(#candidates * 0.5))
    local idx1 = math.random(1, top_pool)
    local idx2 = math.random(1, top_pool)
    while idx1 == idx2 do idx2 = math.random(1, top_pool) end

    local se_1 = candidates[idx1].se
    local se_2 = candidates[idx2].se
    self.last_speaker_time[se_1.id] = game.get_game_time()
    self.last_speaker_time[se_2.id] = game.get_game_time()

    self.conv_active = true
    self:ProcessConversationTurn(xml_fac_name, conv_id, 1, se_1, se_2)

    return false
end



function DynamicNewsManager:ProcessConversationTurn(faction, conv_id, turn, npc_1, npc_2)
    if not (npc_1 and npc_1:alive() and npc_2 and npc_2:alive()) then
        self.conv_active = false
        return
    end

    local str_id  = "st_dyn_news_conversation_faction_" .. faction .. "_" .. conv_id .. "_turn_" .. turn
    local message = game.translate_string(str_id)

    if (message == str_id) then
        self.conv_active = false
        return
    end

    -- Record topics on the very first turn (conversation is now committed)
    if turn == 1 then
        self:MarkConvTopics(faction, conv_id)
    end

    local active_speaker = (turn % 2 ~= 0) and npc_1 or npc_2
    local npc1_first     = str_explode(npc_1:character_name(), " ")[1] or npc_1:character_name()
    local npc2_first     = str_explode(npc_2:character_name(), " ")[1] or npc_2:character_name()

    message = string.gsub(message, "%%speaker_name%%",       active_speaker:character_name())
    message = string.gsub(message, "%%speaker_first_name%%", npc1_first)
    message = string.gsub(message, "%%other_first_name%%",   npc2_first)

    local display_fac = (faction == "loner") and "stalker" or faction
    local header = strformat("%s, %s", active_speaker:character_name(), game.translate_string("st_faction_" .. display_fac))

    dynamic_news_helper.send_tip(message, header, 0, 10, active_speaker:character_icon(), "news", "npc")

    local next_turn = turn + 1
    local delay     = math.random(4, 8)
    local event_key = "ConvTurn_" .. npc_1.id .. "_" .. conv_id .. "_" .. turn
    self.active_conv_events[#self.active_conv_events + 1] = event_key

    CreateTimeEvent(event_key, "Next", delay, function()
        for i = #self.active_conv_events, 1, -1 do
            if self.active_conv_events[i] == event_key then
                table.remove(self.active_conv_events, i)
                break
            end
        end
        self:ProcessConversationTurn(faction, conv_id, next_turn, npc_1, npc_2)
        return true
    end)
end



-- ================================================================
-- NEW: CountGroupConvs
--   Probes the XML to find how many group conversations exist for
--   a given faction name (e.g. "loner", "freedom", "army").
--   Returns the highest valid conv ID found (0 = none).
-- ================================================================
function DynamicNewsManager:CountGroupConvs(faction)
	local max_id = 0
	while true do
		local probe = "st_dyn_news_" .. faction .. "_conversation_msg_" .. (max_id + 1)
		if game.translate_string(probe) == probe then break end
		max_id = max_id + 1
	end
	return max_id
end


-- ================================================================
-- NEW: StartGroupConversation
--   Picks a random group conv, assigns a unique NPC to the opener
--   and to each response turn, then fires them with staggered delays.
--
--   XML naming convention expected:
--     st_dyn_news_{faction}_conversation_msg_{id}        ← 1 opener
--     st_dyn_news_{faction}_conversation_resp_{id}_{n}   ← n responders
-- ================================================================
function DynamicNewsManager:StartGroupConversation(faction, candidates, max_id)
	local conv_id = math.random(1, max_id)

	-- Count how many response turns this conversation has
	local resp_count = 0
	while true do
		local probe = "st_dyn_news_" .. faction .. "_conversation_resp_" .. conv_id .. "_" .. (resp_count + 1)
		if game.translate_string(probe) == probe then break end
		resp_count = resp_count + 1
	end

	-- We need 1 opener + resp_count speakers, all unique.
	-- Total speakers needed: 1 + resp_count (capped at available candidates).
	local speakers_needed = 1 + math.min(resp_count, #candidates - 1)
	if #candidates < speakers_needed then
		-- Not enough NPCs; silently bail (TickConversation will retry next cycle)
		return false
	end

	-- Pick unique speakers from the top half of the idle-sorted candidate pool
	local top_pool   = math.max(speakers_needed, math.floor(#candidates * 0.5))
	top_pool         = math.min(top_pool, #candidates)
	local used_idx   = {}
	local speakers   = {}   -- indexed: [1] = opener, [2..] = responders

	for _ = 1, speakers_needed do
		local idx
		local attempts = 0
		repeat
			idx = math.random(1, top_pool)
			attempts = attempts + 1
		until not used_idx[idx] or attempts > 20
		used_idx[idx] = true
		table.insert(speakers, candidates[idx].se)
		self.last_speaker_time[candidates[idx].se.id] = game.get_game_time()
	end

	-- ── Send the opener ──────────────────────────────────────────
	local opener_npc = speakers[1]
	local opener_key = "st_dyn_news_" .. faction .. "_conversation_msg_" .. conv_id
	local opener_msg = game.translate_string(opener_key)

	if opener_msg == opener_key then return false end   -- XML entry missing

	local display_fac    = (faction == "loner") and "stalker" or faction
	local faction_label  = game.translate_string("st_faction_" .. display_fac)
	local opener_header  = strformat("%s, %s", opener_npc:character_name(), faction_label)

	dynamic_news_helper.send_tip(opener_msg, opener_header, 0, 10, opener_npc:character_icon(), "news", "npc")

	self.conv_active = true

	-- ── Schedule each responder ──────────────────────────────────
	--   Delay accumulates so responses are staggered naturally.
	local cum_delay = 0

	for r = 1, math.min(resp_count, #speakers - 1) do
		local resp_npc = speakers[r + 1]
		local resp_key = "st_dyn_news_" .. faction .. "_conversation_resp_" .. conv_id .. "_" .. r
		local resp_msg = game.translate_string(resp_key)

		if resp_msg == resp_key then
			-- No more valid responses; mark conversation done on next gap
			break
		end

		cum_delay = cum_delay + math.random(5, 10)

		local event_key = "GroupConv_" .. conv_id .. "_resp_" .. r .. "_" .. opener_npc.id
		self.active_conv_events[#self.active_conv_events + 1] = event_key

		-- Capture loop variables for the closure
		local captured_npc    = resp_npc
		local captured_msg    = resp_msg
		local captured_fac    = faction_label
		local captured_key    = event_key
		local is_last         = (r == math.min(resp_count, #speakers - 1))

		CreateTimeEvent(event_key, "Next", cum_delay, function()
			-- Clean up tracking entry
			for i = #self.active_conv_events, 1, -1 do
				if self.active_conv_events[i] == captured_key then
					table.remove(self.active_conv_events, i)
					break
				end
			end

			-- Verify speaker still alive
			if captured_npc and captured_npc:alive() then
				local resp_header = strformat("%s, %s", captured_npc:character_name(), captured_fac)
				dynamic_news_helper.send_tip(captured_msg, resp_header, 0, 10, captured_npc:character_icon(), "news", "npc")
			end

			-- Last response: unlock the conversation gate
			if is_last then
				self.conv_active = false
			end

			return true
		end)
	end

	-- Edge case: if resp_count was 0, unlock immediately
	if resp_count == 0 then
		self.conv_active = false
	end

	return false
end


-- ============================================================
-- META COOLDOWN HELPERS
-- ============================================================

-- Returns true if any tag in this conversation's _meta string
-- was played within the cooldown window.
function DynamicNewsManager:IsConvOnCooldown(faction, conv_id)
    local meta_key = "st_dyn_news_conversation_faction_" .. faction .. "_" .. conv_id .. "_meta"
    local meta_str = game.translate_string(meta_key)
    if meta_str == meta_key then return false end   -- no meta tag = never blocked

    local faction_topics = self.recent_conv_topics[faction]
    if not faction_topics then return false end

    local now = game.get_game_time()
    for tag in string.gmatch(meta_str, "([^,]+)") do
        tag = tag:match("^%s*(.-)%s*$")            -- trim whitespace
        local played_time = faction_topics[tag]
        if played_time then
            local mins_ago = now:diffSec(played_time) / 60
            if mins_ago < self.topic_cooldown_min then
                return true
            end
        end
    end
    return false
end

-- Stamps all tags from this conversation's _meta with the current
-- game time so they enter cooldown.
function DynamicNewsManager:MarkConvTopics(faction, conv_id)
    local meta_key = "st_dyn_news_conversation_faction_" .. faction .. "_" .. conv_id .. "_meta"
    local meta_str = game.translate_string(meta_key)
    if meta_str == meta_key then return end

    if not self.recent_conv_topics[faction] then
        self.recent_conv_topics[faction] = {}
    end

    local now = game.get_game_time()
    for tag in string.gmatch(meta_str, "([^,]+)") do
        tag = tag:match("^%s*(.-)%s*$")
        self.recent_conv_topics[faction][tag] = now
    end
end

-- Tries up to 5 times to find a conversation not on cooldown.
-- Falls back to the last rolled ID so it never blocks entirely.
function DynamicNewsManager:PickFreshConvId(faction, max_id)
    local conv_id
    for _ = 1, 5 do
        conv_id = math.random(1, max_id)
        if not self:IsConvOnCooldown(faction, conv_id) then
            return conv_id
        end
    end
    return conv_id  -- graceful fallback
end

-- Same logic wired for group conversations.
function DynamicNewsManager:PickFreshGroupConvId(faction, max_id)
    local conv_id
    for _ = 1, 5 do
        conv_id = math.random(1, max_id)
        -- Group convs use the same meta format on the faction XML
        if not self:IsConvOnCooldown(faction, conv_id) then
            return conv_id
        end
    end
    return conv_id
end


-- ============================================================
-- PLAYER REP GOSSIP
-- ============================================================

-- Returns true when enough time has passed and the 10% dice rolls.
function DynamicNewsManager:ShouldFirePlayerRepGossip()
    if math.random(100) > 10 then return false end

    if self.player_rep_gossip_time then
        local now = game.get_game_time()
        local mins = now:diffSec(self.player_rep_gossip_time) / 60
        if mins < self.player_rep_gossip_interval then return false end
    end

    return true
end

-- Sends a 2-NPC burst on the faction channel gossiping about the player.
-- Message shape depends on rep AND rank tier, player name is injected.
function DynamicNewsManager:GossipAboutPlayer()
    local player_comm = get_actor_true_community()
    local xml_fac     = (player_comm == "stalker") and "loner" or player_comm

    -- Need 2 speakers from the faction
    local sim      = alife()
    local gg       = game_graph()
    local speakers = {}

    for i = 1, 65534 do
        local se = sim:object(i)
        if se and se.id ~= AC_ID
        and IsStalker(nil, se:clsid())
        and se:alive()
        and se:community() == player_comm
        and se:community() ~= "trader"
        and se.group_id ~= 65535 then
            table.insert(speakers, se)
            if #speakers >= 6 then break end    -- collect a small pool, pick from it
        end
    end

    if #speakers < 2 then return false end

    -- Shuffle-pick 2 unique speakers
    local i1 = math.random(1, #speakers)
    local i2 = math.random(1, #speakers)
    while i2 == i1 do i2 = math.random(1, #speakers) end
    local sp1 = speakers[i1]
    local sp2 = speakers[i2]

    -- ── Determine rep tier ────────────────────────────────────
    local rep_tbl  = {"terrible","really_bad","very_bad","bad","neutral","good","very_good","really_good","excellent"}
    local rank_tbl = {"novice","trainee","experienced","professional","veteran","expert","master","legend"}
    local actor_rep   = utils_obj.get_reputation_name(db.actor:character_reputation())
    local actor_rank  = ranks.get_obj_rank_name(db.actor)
    local rep_tier, rank_tier = 2, 2

    for i = 1, #rep_tbl do
        if string.match(actor_rep, rep_tbl[i]) then
            if i <= 4 then rep_tier = 1
            elseif i <= 6 then rep_tier = 2
            else rep_tier = 3
            end
            break
        end
    end
    for i = 1, #rank_tbl do
        if string.match(actor_rank, rank_tbl[i]) then
            if i <= 2 then rank_tier = 1
            elseif i <= 4 then rank_tier = 2
            elseif i <= 6 then rank_tier = 3
            else rank_tier = 4
            end
            break
        end
    end

    -- Determine the conversation prefix
    local prefix = (math.random(2) == 1) and ("rep_" .. rep_tier) or ("rank_" .. rank_tier)
    local base_id = "st_dyn_news_player_gossip_" .. prefix .. "_conv_"

    -- Find how many structured conversations exist for this tier
    local max_conv = 0
    while true do
        local probe = base_id .. (max_conv + 1) .. "_1"
        if game.translate_string(probe) == probe then break end
        max_conv = max_conv + 1
    end

    if max_conv == 0 then return false end

    local conv_id = math.random(1, max_conv)
    
    -- Count turns for the selected conversation
    local max_turns = 0
    while true do
        local probe = base_id .. conv_id .. "_" .. (max_turns + 1)
        if game.translate_string(probe) == probe then break end
        max_turns = max_turns + 1
    end

    local player_name = alife():actor():character_name()
    local display_fac = (xml_fac == "loner") and "stalker" or xml_fac
    local fac_label   = game.translate_string("st_faction_" .. display_fac)

    -- Local recursive callback to play conversation back and forth
    local function send_gossip_turn(turn)
        if turn > max_turns then return end

        local sp = (turn % 2 == 1) and sp1 or sp2
        local msg_key = base_id .. conv_id .. "_" .. turn
        local msg = game.translate_string(msg_key)

        if msg == msg_key then return end

        msg = string.gsub(msg, "%%player_name%%", player_name)

        local hdr = strformat("%s, %s", sp:character_name(), fac_label)
        local icon = sp:character_icon()
        
        if turn == 1 then
            dynamic_news_helper.send_tip(msg, hdr, 0, 10, icon, "news", "npc")
            -- Schedule next turn
            send_gossip_turn(turn + 1)
        else
            local event_key = "PlayerRepGossip_" .. sp1.id .. "_" .. turn
            self.active_conv_events[#self.active_conv_events + 1] = event_key
            
            CreateTimeEvent(event_key, "Next", math.random(5, 9), function()
                for i = #self.active_conv_events, 1, -1 do
                    if self.active_conv_events[i] == event_key then
                        table.remove(self.active_conv_events, i)
                        break
                    end
                end
                
                if sp and sp:alive() then
                    dynamic_news_helper.send_tip(msg, hdr, 0, 10, icon, "news", "npc")
                end
                send_gossip_turn(turn + 1)
                return true
            end)
        end
    end

    send_gossip_turn(1)

    -- Stamp cooldown
    self.player_rep_gossip_time = game.get_game_time()

    return false
end


-- ============================================================
-- FACTION JOIN REACTIONS
-- ============================================================

-- Call from actor_on_update (global function) to detect faction changes.
-- Add this line to the global actor_on_update:
--   local inst = get_dynamic_news()
--   if inst then inst:CheckFactionChange() end
function DynamicNewsManager:CheckFactionChange()
    local current_comm = get_actor_true_community()
    if current_comm == self.player_faction then return end

    local old_faction = self.player_faction
    self.player_faction = current_comm

    -- Instantly update channel visibility for restricted factions mid-game 
    -- so we can actually see their news messages once we join them.
    self.channel_status["monolith"] = (current_comm == "monolith")
    self.channel_status["army"]     = (current_comm == "army")
    self.channel_status["greh"]     = (current_comm == "greh")
    self.channel_status["isg"]      = (current_comm == "isg")

    self:GossipPlayerJoinedFaction(current_comm, old_faction)
end


-- Fires a 2-3 message burst from the new faction welcoming the player.
function DynamicNewsManager:GossipPlayerJoinedFaction(new_comm, old_comm)
    local xml_fac = (new_comm == "stalker") and "loner" or new_comm

    -- Determine the conversation prefix
    local base_id = "st_dyn_news_faction_join_" .. xml_fac .. "_conv_"

    -- Find how many structured conversations exist for this faction
    local max_conv = 0
    while true do
        local probe = base_id .. (max_conv + 1) .. "_1"
        if game.translate_string(probe) == probe then break end
        max_conv = max_conv + 1
    end

    if max_conv == 0 then return end   -- no strings for this faction yet

    local conv_id = math.random(1, max_conv)

    -- Count turns for the selected conversation
    local max_turns = 0
    while true do
        local probe = base_id .. conv_id .. "_" .. (max_turns + 1)
        if game.translate_string(probe) == probe then break end
        max_turns = max_turns + 1
    end

    if max_turns == 0 then return end

    -- Gather speakers from the new faction
    local sim      = alife()
    local speakers = {}

    for i = 1, 65534 do
        local se = sim:object(i)
        if se and se.id ~= AC_ID
        and IsStalker(nil, se:clsid())
        and se:alive()
        and se:community() == new_comm
        and se:community() ~= "trader"
        and se.group_id ~= 65535 then
            table.insert(speakers, se)
            if #speakers >= 6 then break end
        end
    end

    if #speakers < 1 then return end

    -- Shuffle speakers to get random distinct NPCs
    for i = #speakers, 2, -1 do
        local j = math.random(1, i)
        speakers[i], speakers[j] = speakers[j], speakers[i]
    end

    local sp1 = speakers[1]
    local sp2 = speakers[2] or speakers[1] -- Fallback to same NPC if only 1 exists in the entire Zone

    local player_name = alife():actor():character_name()
    local display_fac = (xml_fac == "loner") and "stalker" or xml_fac
    local fac_label   = game.translate_string("st_faction_" .. display_fac)

    local q = self.queue[new_comm]
    if not q then return end

    -- Insert turns sequentially. 
    -- We insert at index 1 so that the engine's TickNews (which reads from the END of the array)
    -- pops them out in the correct 1 -> 2 -> 3 chronological order over time.
    for turn = 1, max_turns do
        local sp = (turn % 2 == 1) and sp1 or sp2
        
        local msg_key = base_id .. conv_id .. "_" .. turn
        local msg     = game.translate_string(msg_key)
        
        if msg ~= msg_key then
            msg = string.gsub(msg, "%%player_name%%", player_name)
            local header = strformat("%s, %s", sp:character_name(), fac_label)
            
            table.insert(q, 1, {Mg=msg, Ic=sp:character_icon(), Snd="news", Se=header, It="npc"})
            self.counter = self.counter + 1
        end
    end
end


function on_key_press(key)
    -- Route to interactive conv handler if it's loaded
    if pda_interactive_conv and pda_interactive_conv.on_key_press_cb then
        pda_interactive_conv.on_key_press_cb(key)
    end
end
