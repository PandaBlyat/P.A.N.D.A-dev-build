--[[
    P.A.N.D.A Face-to-Face conversation bridge.
    Dynamically builds a dialogue tree from interactive-conversation string tables
    and routes branch logic through PANDA_CONV_API with channel="f2f".
--]]

panda_f2f_bridge = panda_f2f_bridge or {}

local MAX_CONV_SCAN = 256
local MAX_CHOICE_SCAN = 12
local MAX_TREE_DEPTH = 12
local MISSING_STOP = 20
local HUB_DIALOG_ID = "panda_f2f_hub_dialog"
local BRANCH_HARD_ROUTE_SUFFIX = "_f2f_hard_route"
local SAVE_KEY_OVERRIDE_OWNERS = "panda_f2f_bridge_override_owners"
local RECENT_HANDOFF_GRACE_MS = 2 * 60 * 1000
local WATCHDOG_INIT_GRACE_MS = 1500
local WATCHDOG_FORCE_TIMEOUT_MS = 5000
local ROOT_ENTRY_PHRASE_ID = "st_panda_f2f_root_entry"
local ACTOR_PARITY_SHIM_PHRASE_ID = "st_panda_f2f_actor_parity_shim"
local ACTOR_PARITY_SHIM_FALLBACK_LITERAL = "[PANDA parity shim]"
local bridge_debug
local bridge_warn
local cleanup_noncommit_exit
local cleanup_state_handlers
local resolve_server_npc_id
local resolve_server_entity_from_id
local normalize_lookup_id
local resolve_partner_runtime_ids
local handoff_matches_talker_identity
local build_callback_resolution_context
local get_unique_actionable_pending_handoff

local runtime = {
    state_by_id = {},
    latest_state = nil,
    pending_state = nil,
    active_token = nil,
    override_owners = {},
    callbacks_registered = false,
}

local function make_state_id_from_values(npc_id, conv_id, turn)
    return string.format("%s:%s:%s", tostring(npc_id or "unknown"), tostring(conv_id or 0), tostring(turn or 1))
end

local function make_state_id(state)
    if type(state) ~= "table" then
        return make_state_id_from_values("unknown", 0, 1)
    end
    local npc_id = state.npc_se and state.npc_se.id or "unknown"
    return make_state_id_from_values(npc_id, state.conv_id, state.turn)
end

local function register_active_state(state)
    if type(state) ~= "table" then
        return nil
    end
    state.teardown_in_progress = false
    if runtime.active_token and state.active_token and runtime.active_token ~= tostring(state.active_token) then
        local previous_token_key = "token:" .. tostring(runtime.active_token)
        local previous_state = runtime.state_by_id[previous_token_key]
        runtime.state_by_id[previous_token_key] = nil
        if previous_state and previous_state.runtime_state_id then
            runtime.state_by_id[previous_state.runtime_state_id] = nil
        end
        -- Clean up handler functions from the replaced session to prevent
        -- stale closures holding references to destroyed engine objects
        if type(previous_state) == "table" then
            cleanup_state_handlers(previous_state)
        end
    end
    local state_id = make_state_id(state)
    state.runtime_state_id = state_id
    runtime.state_by_id[state_id] = state
    if state.active_token then
        runtime.state_by_id["token:" .. tostring(state.active_token)] = state
        runtime.active_token = tostring(state.active_token)
    end
    runtime.latest_state = state
    return state_id
end

local function unregister_active_state(state)
    if type(state) ~= "table" then
        return
    end
    local state_id = state.runtime_state_id or make_state_id(state)
    runtime.state_by_id[state_id] = nil
    if state.active_token then
        local token_key = "token:" .. tostring(state.active_token)
        if runtime.state_by_id[token_key] == state then
            runtime.state_by_id[token_key] = nil
        end
        if runtime.active_token == tostring(state.active_token) then
            runtime.active_token = nil
        end
    end
    if runtime.latest_state == state then
        runtime.latest_state = nil
    end
end


local function resolve_runtime_state_for_npc(npc_id)
    local sid = normalize_lookup_id(npc_id)
    if not sid then
        local latest = runtime.latest_state
        if type(latest) == "table" and latest.teardown_in_progress ~= true then
            return latest
        end
        return nil
    end

    local active_token = runtime.active_token
    if active_token then
        local token_state = runtime.state_by_id["token:" .. tostring(active_token)]
        if type(token_state) == "table" and token_state.teardown_in_progress ~= true then
            local token_npc_id = resolve_server_npc_id(token_state.npc_se, "resolve_runtime_state_for_npc:token")
            if token_npc_id == sid then
                return token_state
            end
        end
    end

    for _, candidate in pairs(runtime.state_by_id) do
        if type(candidate) == "table" and candidate.teardown_in_progress ~= true then
            local candidate_npc_id = resolve_server_npc_id(candidate.npc_se, "resolve_runtime_state_for_npc:scan")
            if candidate_npc_id == sid then
                return candidate
            end
        end
    end

    local latest = runtime.latest_state
    if type(latest) == "table" and latest.teardown_in_progress ~= true then
        local latest_npc_id = resolve_server_npc_id(latest.npc_se, "resolve_runtime_state_for_npc:latest")
        if latest_npc_id == sid then
            return latest
        end
    end

    return nil
end

local function get_conv_api()
    if PANDA_CONV_API then
        return PANDA_CONV_API
    end
    if pda_interactive_conv and pda_interactive_conv.PANDA_CONV_API then
        return pda_interactive_conv.PANDA_CONV_API
    end
    return nil
end

local function get_dialog_manager_iface()
    local dm = rawget(_G, "dialog_manager")
    if type(dm) == "table" then
        return dm
    end
    return _G
end

function normalize_lookup_id(id)
    local sid = tonumber(id)
    if not sid or sid <= 0 then
        return nil
    end
    return math.floor(sid)
end

local function resolve_actor_sid()
    local actor = db and db.actor or nil
    if not actor then
        return nil
    end

    local sid = normalize_lookup_id(actor.id)
    if sid then
        return sid
    end

    if type(actor.id) == "function" then
        local ok_sid, resolved_sid = pcall(function()
            return actor:id()
        end)
        if ok_sid then
            return normalize_lookup_id(resolved_sid)
        end
    end

    return nil
end

local function resolve_unique_active_runtime_state()
    local unique_state = nil
    local seen = {}

    for _, candidate in pairs(runtime.state_by_id) do
        if type(candidate) == "table" and candidate.teardown_in_progress ~= true and not seen[candidate] then
            if unique_state and unique_state ~= candidate then
                return nil
            end
            seen[candidate] = true
            unique_state = candidate
        end
    end

    if type(unique_state) == "table" then
        return unique_state
    end

    local latest = runtime.latest_state
    if type(latest) == "table" and latest.teardown_in_progress ~= true then
        return latest
    end

    return nil
end

local function resolve_lookup_id_from_value(value)
    local sid = normalize_lookup_id(value)
    if sid then
        return sid
    end

    local value_type = type(value)
    if value_type ~= "table" and value_type ~= "userdata" then
        return nil
    end

    local ok_field, raw_id = pcall(function()
        return value.id
    end)
    if ok_field then
        if type(raw_id) == "function" then
            local ok_call, resolved_id = pcall(function()
                return value:id()
            end)
            if ok_call then
                sid = normalize_lookup_id(resolved_id)
            end
        else
            sid = normalize_lookup_id(raw_id)
        end
        if sid then
            return sid
        end
    end

    for _, field_name in ipairs({
        "npc_id",
        "object_id",
        "speaker_id",
        "talker_id",
        "partner_id",
    }) do
        local ok_nested, nested_value = pcall(function()
            return value[field_name]
        end)
        if ok_nested then
            sid = normalize_lookup_id(nested_value)
            if sid then
                return sid
            end
        end
    end

    return nil
end

resolve_server_entity_from_id = function(id, source_tag)
    local sid = normalize_lookup_id(id)
    if not sid then
        return nil
    end

    local sim = alife and alife()
    if not sim then
        bridge_debug(
            "resolve_server_entity_from_id: failed source=%s npc_id=%s detail=%s",
            tostring(source_tag or "unknown"),
            tostring(sid),
            "missing_alife"
        )
        return nil
    end

    local se = sim:object(sid)
    if se then
        return se
    end

    bridge_debug(
        "resolve_server_entity_from_id: failed source=%s npc_id=%s detail=%s",
        tostring(source_tag or "unknown"),
        tostring(sid),
        "sim_object_nil"
    )
    return nil
end

build_callback_resolution_context = function(...)
    local out = {
        npc_id = nil,
        npc_se = nil,
        talker_id = nil,
        source = "none",
        candidate_ids = {},
    }

    local actor_sid = resolve_actor_sid()
    local seen = {}

    local function consider_value(source_tag, value)
        local sid = resolve_lookup_id_from_value(value)
        if not sid or (actor_sid and sid == actor_sid) or seen[sid] then
            return
        end

        seen[sid] = true
        out.candidate_ids[#out.candidate_ids + 1] = sid
        if not out.npc_id then
            out.npc_id = sid
            out.source = tostring(source_tag or "callback")
        end
        if not out.npc_se then
            out.npc_se = resolve_server_entity_from_id(sid, source_tag)
        end
    end

    for idx = 1, select("#", ...) do
        local arg = select(idx, ...)
        local source_tag = "callback_arg_" .. tostring(idx)
        if type(arg) == "table" or type(arg) == "userdata" or idx <= 2 then
            consider_value(source_tag, arg)
        end

        if type(arg) == "table" or type(arg) == "userdata" then
            for _, field_name in ipairs({
                "npc",
                "speaker",
                "object",
                "talker",
                "partner",
                "other",
            }) do
                local ok_nested, nested_value = pcall(function()
                    return arg[field_name]
                end)
                if ok_nested then
                    consider_value(source_tag .. "." .. tostring(field_name), nested_value)
                end
            end
        end
    end

    out.talker_id = out.npc_id
    return out
end

local function compare_pending_handoff_priority(a, b)
    local a_set_at = tonumber(a and a.set_at) or 0
    local b_set_at = tonumber(b and b.set_at) or 0
    if a_set_at ~= b_set_at then
        return a_set_at > b_set_at
    end

    local a_token = tostring(a and a.token or "")
    local b_token = tostring(b and b.token or "")
    if a_token ~= b_token then
        return a_token > b_token
    end

    return tostring(a and a.key or "") < tostring(b and b.key or "")
end

get_unique_actionable_pending_handoff = function()
    local handoffs = rawget(_G, "pda_f2f_handoffs")
    if type(handoffs) ~= "table" then
        return nil
    end

    local now = tonumber(time_global and time_global() or 0) or 0
    local newest_by_npc = {}
    for key, raw_handoff in pairs(handoffs) do
        if type(raw_handoff) == "table" then
            local npc_id = normalize_lookup_id(raw_handoff.npc_id)
            local conv_id = normalize_lookup_id(raw_handoff.conv_id)
            local turn = normalize_lookup_id(raw_handoff.turn)
            local set_at = tonumber(raw_handoff.set_at)
            local age_ok = true
            if set_at then
                local age = now - set_at
                if age < 0 then
                    age = 0
                end
                age_ok = age <= RECENT_HANDOFF_GRACE_MS
            end

            if npc_id and conv_id and turn and set_at and age_ok then
                local candidate = {
                    key = key,
                    npc_id = npc_id,
                    conv_id = conv_id,
                    turn = turn,
                    set_at = set_at,
                    token = raw_handoff.token and tostring(raw_handoff.token) or nil,
                    source_path = "unique_pending_handoff",
                }
                local existing = newest_by_npc[npc_id]
                if not existing or compare_pending_handoff_priority(candidate, existing) then
                    newest_by_npc[npc_id] = candidate
                end
            end
        end
    end

    local candidates = {}
    for _, candidate in pairs(newest_by_npc) do
        candidates[#candidates + 1] = candidate
    end

    if #candidates ~= 1 then
        return nil
    end

    return candidates[1]
end

local function resolve_current_talker_id()
    if mob_trade and type(mob_trade.GetTalkingNpc) == "function" then
        local ok_talker, talker = pcall(function() return mob_trade.GetTalkingNpc() end)
        if ok_talker and talker then
            local talker_id = talker.id
            if type(talker.id) == "function" then
                local ok_id, id_from_fn = pcall(function() return talker:id() end)
                if ok_id then
                    talker_id = id_from_fn
                end
            end
            talker_id = normalize_lookup_id(talker_id)
            if talker_id then
                return talker_id
            end
        end
    end

    if type(get_speaker) == "function" then
        local ok_speaker, speaker = pcall(function() return get_speaker() end)
        if ok_speaker and speaker then
            local speaker_id = speaker.id
            if type(speaker.id) == "function" then
                local ok_id, id_from_fn = pcall(function() return speaker:id() end)
                if ok_id then
                    speaker_id = id_from_fn
                end
            end
            speaker_id = normalize_lookup_id(speaker_id)
            if speaker_id then
                return speaker_id
            end
        end
    end

    return nil
end

local function resolve_story_id_for_sid(sid)
    if type(get_object_story_id) ~= "function" then
        return nil
    end
    local ok_story, resolved_story_id = pcall(function() return get_object_story_id(sid) end)
    if ok_story and resolved_story_id and resolved_story_id ~= "" then
        return tostring(resolved_story_id)
    end
    return nil
end

local function build_identity_candidate_list(raw_values)
    local out = {}
    local seen = {}
    for _, value in ipairs(raw_values or {}) do
        if value ~= nil then
            local normalized = tostring(value):lower()
            if normalized ~= "" and not seen[normalized] then
                seen[normalized] = true
                out[#out + 1] = normalized
            end
        end
    end
    return out
end

local function build_runtime_identity_candidates(npc_se, talker_sid)
    local runtime_ids = resolve_partner_runtime_ids(npc_se)
    local raw_values = {}

    for _, candidate in ipairs(runtime_ids.canonical_candidates or {}) do
        raw_values[#raw_values + 1] = candidate
    end
    raw_values[#raw_values + 1] = runtime_ids.story_id
    raw_values[#raw_values + 1] = runtime_ids.canonical_id
    raw_values[#raw_values + 1] = runtime_ids.fallback_name
    raw_values[#raw_values + 1] = runtime_ids.character_name

    if talker_sid then
        raw_values[#raw_values + 1] = resolve_story_id_for_sid(talker_sid)
    end

    return build_identity_candidate_list(raw_values), runtime_ids
end

local function build_handoff_identity_candidates(raw_handoff)
    local raw_values = {
        raw_handoff and raw_handoff.canonical_id,
        raw_handoff and raw_handoff.story_id,
        raw_handoff and raw_handoff.story_npc_id,
        raw_handoff and raw_handoff.req_story_npc,
        raw_handoff and raw_handoff.fallback_name,
    }

    local raw_npc_id = normalize_lookup_id(raw_handoff and raw_handoff.npc_id)
    if raw_npc_id then
        raw_values[#raw_values + 1] = resolve_story_id_for_sid(raw_npc_id)
    end

    return build_identity_candidate_list(raw_values)
end

local function match_handoff_identity(raw_handoff, runtime_candidate_map, talker_sid)
    local raw_npc_id = normalize_lookup_id(raw_handoff and raw_handoff.npc_id)
    if talker_sid and raw_npc_id and handoff_matches_talker_identity(raw_npc_id, talker_sid) then
        return true, "exact_id", build_handoff_identity_candidates(raw_handoff)
    end

    local handoff_candidates = build_handoff_identity_candidates(raw_handoff)
    for _, candidate in ipairs(handoff_candidates) do
        if runtime_candidate_map[candidate] then
            local match_mode = "canonical_id"
            if raw_handoff and raw_handoff.story_id and tostring(raw_handoff.story_id):lower() == candidate then
                match_mode = "story_id"
            end
            return true, match_mode, handoff_candidates
        end
    end

    return false, nil, handoff_candidates
end

handoff_matches_talker_identity = function(handoff_npc_sid, talker_sid)
    if not handoff_npc_sid or not talker_sid then
        return false
    end
    if handoff_npc_sid == talker_sid then
        return true
    end
    local handoff_story_id = resolve_story_id_for_sid(handoff_npc_sid)
    local talker_story_id = resolve_story_id_for_sid(talker_sid)
    if handoff_story_id and talker_story_id and handoff_story_id == talker_story_id then
        return true
    end
    return false
end

local function get_partner_npc_se(context)
    local sim = alife and alife()
    if not sim then
        bridge_debug("get_partner_npc_se: pending_conv_id=%s partner_id=%s server_entity_resolved=%s", "nil", "nil", "false")
        return nil
    end

    context = type(context) == "table" and context or {}
    local pending_conv_id = nil
    local partner_id = nil

    local function resolve_from_id(path, id)
        local sid = normalize_lookup_id(id)
        if not sid then
            return nil
        end

        partner_id = sid
        local se = sim:object(sid)
        if se then
            local story_id = nil
            if type(get_object_story_id) == "function" then
                local ok_story, resolved_story_id = pcall(function() return get_object_story_id(sid) end)
                if ok_story and resolved_story_id and resolved_story_id ~= "" then
                    story_id = tostring(resolved_story_id)
                end
            end
            bridge_debug(
                "get_partner_npc_se: path=%s pending_conv_id=%s partner_id=%s story_id=%s server_entity_resolved=%s",
                tostring(path),
                tostring(pending_conv_id),
                tostring(partner_id),
                tostring(story_id),
                "true"
            )
            return se
        end

        bridge_debug("get_partner_npc_se: path=%s sim:object(id) returned nil for partner_id=%s", tostring(path), tostring(partner_id))
        return nil
    end

    local callback_npc_id = context.npc_id or resolve_server_npc_id(context.npc_se, "get_partner_npc_se:callback")
    if callback_npc_id then
        local se = resolve_from_id(context.source or "callback_context", callback_npc_id)
        if se then
            bridge_debug(
                "get_partner_npc_se: path=%s pending_conv_id=%s partner_id=%s source=%s server_entity_resolved=%s",
                tostring(context.source or "callback_context"),
                tostring(pending_conv_id),
                tostring(partner_id),
                tostring(context.source or "callback_context"),
                "true"
            )
            return se
        end
    end

    local live_talker_id = context.talker_id or resolve_current_talker_id()
    if live_talker_id then
        local se = resolve_from_id("live_talker", live_talker_id)
        if se then
            return se
        end
    end

    if db and db.actor_dialog then
        local sid = normalize_lookup_id(db.actor_dialog:id())
        if sid then
            local se = resolve_from_id("db.actor_dialog:id()", sid)
            if se then
                return se
            end
        end
        if sid and level and level.object_by_id then
            local obj = level.object_by_id(sid)
            if obj and obj.id then
                local obj_sid = normalize_lookup_id(obj:id())
                if obj_sid then
                    local se = resolve_from_id("db.actor_dialog -> level.object_by_id", obj_sid)
                    if se then
                        return se
                    end
                end
            end
        end
    end

    if level and level.get_target_obj then
        local obj = level.get_target_obj()
        if obj and obj:id() then
            local sid = normalize_lookup_id(obj:id())
            if sid then
                local se = resolve_from_id("level.get_target_obj", sid)
                if se then
                    return se
                end
            end
        end
    end

    local unique_handoff = get_unique_actionable_pending_handoff()
    if unique_handoff then
        pending_conv_id = unique_handoff.conv_id
        local se = resolve_from_id(unique_handoff.source_path or "unique_pending_handoff", unique_handoff.npc_id)
        if se then
            bridge_debug(
                "get_partner_npc_se: path=%s pending_conv_id=%s partner_id=%s handoff_turn=%s token=%s server_entity_resolved=%s",
                tostring(unique_handoff.source_path or "unique_pending_handoff"),
                tostring(pending_conv_id),
                tostring(partner_id),
                tostring(unique_handoff.turn or "nil"),
                tostring(unique_handoff.token or "nil"),
                "true"
            )
            return se
        end
    end

    bridge_debug(
        "get_partner_npc_se: path=%s pending_conv_id=%s partner_id=%s story_id=%s server_entity_resolved=%s",
        "none",
        tostring(pending_conv_id),
        tostring(partner_id),
        "nil",
        "false"
    )
    return nil
end

local function normalize_faction_key(faction)
    local fac = tostring(faction or ""):lower()
    if fac == "" then
        return nil
    end

    fac = string.gsub(fac, "^actor_", "")
    if fac == "stalker" then
        return "loner"
    end

    return fac
end

local function actor_faction_key()
    if db and db.actor and db.actor.character_community then
        local fac = db.actor:character_community()
        if fac and fac ~= "" then
            return normalize_faction_key(fac) or "loner"
        end
    end
    return "loner"
end

local function make_allocator(start_id)
    local next_id = tonumber(start_id)
    if not next_id then
        next_id = 0
    end
    next_id = math.max(0, math.floor(next_id))

    return function()
        local out = next_id
        next_id = next_id + 1
        return out
    end
end

local function tr(key)
    if not key or key == "" then
        return key
    end
    return game.translate_string(key)
end

local function parse_bool_flag(value)
    if value == nil then
        return false
    end

    local s = tostring(value):lower()
    if s == "0" or s == "false" or s == "off" or s == "no" then
        return false
    end

    return true
end

local function normalize_npc_id(npc_id)
    local out = tonumber(npc_id)
    if not out or out <= 0 then
        return nil
    end
    return math.floor(out)
end

local function restore_override_owners(owners)
    if type(owners) ~= "table" then
        return false
    end

    local restored_any = false
    for npc_id, _ in pairs(owners) do
        local sid = normalize_npc_id(npc_id)
        if sid and xr_meet and type(xr_meet.restore_dialog) == "function" then
            local ok_restore = pcall(xr_meet.restore_dialog, sid)
            restored_any = ok_restore or restored_any
        end
    end

    return restored_any
end

local function clear_runtime_transient_state()
    runtime.state_by_id = {}
    runtime.latest_state = nil
    runtime.pending_state = nil
    runtime.active_token = nil
end

local function discard_runtime_state_for_npc(npc_id, token)
    local sid = normalize_npc_id(npc_id)
    local token_s = token and tostring(token) or nil
    local removed = false

    local pending_state = runtime.pending_state
    if type(pending_state) == "table" then
        local pending_sid = pending_state.resolved_npc_id or resolve_server_npc_id(pending_state.npc_se, "discard_runtime_state_for_npc:pending")
        local pending_token = pending_state.active_token and tostring(pending_state.active_token) or nil
        local pending_handoff_token = pending_state.handoff_token and tostring(pending_state.handoff_token) or nil
        if (sid and pending_sid == sid)
            or (token_s and (pending_token == token_s or pending_handoff_token == token_s))
        then
            runtime.pending_state = nil
            removed = true
        end
    end

    local matched_states = {}
    local seen = {}
    for _, candidate in pairs(runtime.state_by_id) do
        if type(candidate) == "table" and not seen[candidate] then
            local candidate_sid = candidate.resolved_npc_id or resolve_server_npc_id(candidate.npc_se, "discard_runtime_state_for_npc:active")
            local candidate_active_token = candidate.active_token and tostring(candidate.active_token) or nil
            local candidate_handoff_token = candidate.handoff_token and tostring(candidate.handoff_token) or nil
            if (sid and candidate_sid == sid)
                or (token_s and (candidate_active_token == token_s or candidate_handoff_token == token_s))
            then
                matched_states[#matched_states + 1] = candidate
                seen[candidate] = true
            end
        end
    end

    for _, candidate in ipairs(matched_states) do
        unregister_active_state(candidate)
        removed = true
    end

    return removed
end

resolve_server_npc_id = function(npc_se, source_tag)
    local sid = normalize_npc_id(npc_se and npc_se.id)
    if sid then
        return sid
    end

    if npc_se and type(npc_se.id) == "function" then
        local ok_sid, resolved_sid = pcall(function() return npc_se:id() end)
        if ok_sid then
            sid = normalize_npc_id(resolved_sid)
            if sid then
                return sid
            end
        end
    end

    bridge_debug(
        "resolve_server_npc_id: failed source=%s npc_se_present=%s raw_id=%s id_field_type=%s",
        tostring(source_tag or "unknown"),
        tostring(npc_se ~= nil),
        tostring(npc_se and npc_se.id),
        tostring(npc_se and type(npc_se.id) or "nil")
    )
    return nil
end

local function make_override_owner_tag(state, branch)
    return string.format(
        "f2f:%s:%s:%s:%s",
        tostring(state and state.faction or "loner"),
        tostring(state and state.conv_id or 0),
        tostring((branch and branch.turn) or (state and state.turn) or 0),
        tostring(branch and branch.index or 0)
    )
end

local function save_state_cb(m)
    m[SAVE_KEY_OVERRIDE_OWNERS] = runtime.override_owners
end

local function load_state_cb(m)
    local saved_override_owners = m[SAVE_KEY_OVERRIDE_OWNERS] or {}
    restore_override_owners(saved_override_owners)
    clear_runtime_transient_state()
    runtime.override_owners = {}
end

local function is_actor_dialog_active()
    if db and db.actor_dialog then
        return true
    end

    local actor = db and db.actor or nil
    if actor and actor.is_talking then
        local ok, talking = pcall(function()
            return actor:is_talking()
        end)
        if ok and talking == true then
            return true
        end
    end

    if mob_trade and type(mob_trade.GetTalkingNpc) == "function" then
        local ok, talker = pcall(function()
            return mob_trade.GetTalkingNpc()
        end)
        if ok and talker then
            return true
        end
    end

    return false
end

local function actor_on_update_cb()
    local state = runtime.latest_state
    if type(state) ~= "table" then
        return
    end

    -- Only watchdog the state that matches the current active token.
    -- If a newer session has been registered (e.g. a second f2f conversation
    -- started while this state's teardown was deferred), this state is orphaned.
    -- Clean it up directly without going through on_dialog_closed, which would
    -- resolve the NPC ID and potentially tear down the NEW session's state instead.
    if state.active_token and runtime.active_token
        and tostring(state.active_token) ~= tostring(runtime.active_token) then
        bridge_warn(
            "teardown watchdog stale_session_cleanup token=%s active_token=%s",
            tostring(state.active_token),
            tostring(runtime.active_token)
        )
        cleanup_state_handlers(state)
        unregister_active_state(state)
        return
    end

    local active_npc_id = resolve_server_npc_id(state.npc_se, "actor_on_update_cb")
    if not active_npc_id then
        return
    end

    local now_ms = time_global and time_global() or 0
    local watchdog_started_at = tonumber(state.watchdog_started_at) or now_ms
    local watchdog_age_ms = now_ms - watchdog_started_at
    local talker_id = resolve_current_talker_id()
    if talker_id and handoff_matches_talker_identity(active_npc_id, talker_id) then
        state.watchdog_talker_seen = true
        return
    end
    if is_actor_dialog_active() then
        -- During active dialog frames, talker resolution can briefly return nil.
        -- Treat this as transient and keep the handoff/session alive.
        state.watchdog_dialog_seen = true
        return
    end

    if watchdog_age_ms < WATCHDOG_INIT_GRACE_MS then
        return
    end

    if state.watchdog_talker_seen ~= true and state.watchdog_dialog_seen ~= true and watchdog_age_ms < WATCHDOG_FORCE_TIMEOUT_MS then
        return
    end

    bridge_warn(
        "teardown watchdog fallback npc_id=%s reason=%s age_ms=%s talker_seen=%s dialog_seen=%s",
        tostring(active_npc_id or "nil"),
        "actor_on_update_watchdog",
        tostring(watchdog_age_ms),
        tostring(state.watchdog_talker_seen == true),
        tostring(state.watchdog_dialog_seen == true)
    )
    panda_f2f_bridge.on_dialog_closed(active_npc_id, "actor_on_update_watchdog")
end

local function ensure_callbacks_registered()
    if runtime.callbacks_registered then
        return
    end
    if type(RegisterScriptCallback) ~= "function" then
        return
    end

    local function register_callback_safe(name, fn)
        local ok, err = pcall(RegisterScriptCallback, name, fn)
        if not ok then
            bridge_warn("teardown callback_register_failed name=%s error=%s", tostring(name), tostring(err))
        end
        return ok
    end

    register_callback_safe("save_state", save_state_cb)
    register_callback_safe("load_state", load_state_cb)
    register_callback_safe("actor_on_update", actor_on_update_cb)

    -- Prefer explicit dialog-close callbacks where available; actor_on_update remains fallback watchdog.
    register_callback_safe("dialog_close", panda_f2f_bridge.on_dialog_closed)
    register_callback_safe("dialog_closed", panda_f2f_bridge.on_dialog_closed)
    register_callback_safe("on_dialog_close", panda_f2f_bridge.on_dialog_closed)

    runtime.callbacks_registered = true
end

function bridge_debug(fmt, ...)
    local panda = rawget(_G, "PANDA")
    local debug_enabled = panda and type(panda.get_config) == "function" and panda.get_config("debug_logging")
    if not debug_enabled then
        return
    end

    local msg = string.format("PANDA_F2F_BRIDGE: " .. tostring(fmt), ...)
    if type(rawget(_G, "printf")) == "function" then
        _G.printf("%s", msg)
    elseif type(rawget(_G, "log1")) == "function" then
        _G.log1(msg)
    end
end

function bridge_warn(fmt, ...)
    local msg = string.format("PANDA_F2F_BRIDGE: " .. tostring(fmt), ...)
    if type(rawget(_G, "printf")) == "function" then
        _G.printf("%s", msg)
    elseif type(rawget(_G, "log1")) == "function" then
        _G.log1(msg)
    end
end

local function key_exists(key)
    if type(key) ~= "string" then
        return false
    end

    key = key:gsub("^%s*(.-)%s*$", "%1")
    if key == "" then
        return false
    end

    local val = tr(key)
    if type(val) ~= "string" then
        return false
    end

    val = val:gsub("^%s*(.-)%s*$", "%1")
    if val == "" then
        return false
    end

    if val == key then
        return false
    end

    return true
end

local function evaluate_shared_precondition(precond_key, npc_se, context)
    if not precond_key or precond_key == "" then
        return true, "no-precondition-key"
    end

    local api = get_conv_api()
    if not api or type(api.check_preconditions) ~= "function" then
        return true, "no-shared-api"
    end

    local ctx = context or {}
    local ok = api.check_preconditions(precond_key, npc_se, "f2f", ctx) == true
    local reason = nil

    -- Optional richer reason plumbing if shared API grows detailed helpers.
    if type(api.check_preconditions_with_reason) == "function" then
        local detailed_ok, detailed_res = pcall(function()
            return api.check_preconditions_with_reason(precond_key, npc_se, "f2f", ctx)
        end)
        if detailed_ok then
            if type(detailed_res) == "table" then
                if detailed_res.ok ~= nil then
                    ok = detailed_res.ok == true
                end
                if detailed_res.reason ~= nil then
                    reason = tostring(detailed_res.reason)
                end
            elseif type(detailed_res) == "boolean" then
                ok = detailed_res
            elseif detailed_res ~= nil then
                reason = tostring(detailed_res)
            end
        end
    elseif type(api.get_last_precondition_reason) == "function" then
        local reason_ok, reason_res = pcall(function()
            return api.get_last_precondition_reason(precond_key, npc_se, "f2f", ctx)
        end)
        if reason_ok and reason_res ~= nil then
            reason = tostring(reason_res)
        end
    end

    return ok, reason
end

local function extract_req_story_npc_id_from_key(precond_key)
    if not precond_key or precond_key == "" then
        return nil
    end
    local raw = tr(precond_key)
    if raw == precond_key then
        return nil
    end
    return raw:match("req_story_npc:([%w_%-]+)")
end

local function decode_registry_json(raw)
    if not raw or raw == "" then
        return nil
    end
    return tostring(raw):gsub("&quot;", "\"")
end

local function get_registry_raw(stem)
    local key = stem .. "_panda_f2f_registry"
    local raw = tr(key)
    if raw == key then
        return nil
    end
    return decode_registry_json(raw)
end

resolve_partner_runtime_ids = function(npc_se)
    local out = {
        story_id = nil,
        fallback_name = nil,
        character_name = nil,
        canonical_id = nil,
        canonical_candidates = {},
    }

    if not npc_se then
        return out
    end

    local seen_candidates = {}
    local function push_candidate(value)
        if value == nil then
            return
        end
        local normalized = tostring(value):lower()
        if normalized == "" or seen_candidates[normalized] then
            return
        end
        seen_candidates[normalized] = true
        out.canonical_candidates[#out.canonical_candidates + 1] = normalized
    end

    local conv_api = get_conv_api()
    if conv_api and type(conv_api.get_npc_canonical_id) == "function" then
        out.canonical_id = conv_api.get_npc_canonical_id(npc_se)
    end
    push_candidate(out.canonical_id)

    local sid = tonumber(npc_se.id)
    if not sid and type(npc_se.id) == "function" then
        local ok_sid, sid_from_fn = pcall(function() return npc_se:id() end)
        if ok_sid then
            sid = tonumber(sid_from_fn)
        end
    end
    if sid and sid > 0 and type(get_object_story_id) == "function" then
        local ok_story, story_id = pcall(function() return get_object_story_id(math.floor(sid)) end)
        if ok_story and story_id and story_id ~= "" then
            out.story_id = tostring(story_id)
        end
    end
    push_candidate(out.story_id)

    if npc_se.name then
        local ok_name, fallback_name = pcall(function() return npc_se:name() end)
        if ok_name and fallback_name and fallback_name ~= "" then
            out.fallback_name = tostring(fallback_name)
        end
    end
    push_candidate(out.fallback_name)

    if npc_se.character_name then
        local ok_character, character_name = pcall(function() return npc_se:character_name() end)
        if ok_character and character_name and character_name ~= "" then
            out.character_name = tostring(character_name)
        end
    end
    push_candidate(out.character_name)

    if not out.canonical_id then
        out.canonical_id = out.canonical_candidates[1]
    end
    if out.canonical_id then
        out.canonical_id = tostring(out.canonical_id):lower()
    end

    return out
end

local function collect_registry_f2f_turns(registry_raw)
    local out = {}
    if not registry_raw or registry_raw == "" then
        return out
    end
    if not registry_raw:find("\"schema\"%s*:%s*\"panda_f2f_bridge_registry_v1\"") then
        return out
    end

    local entry_nodes = registry_raw:match("\"entryNodes\"%s*:%s*{(.-)}")
    if not entry_nodes then
        return out
    end

    local f2f_list = entry_nodes:match("\"f2f\"%s*:%s*%[(.-)%]")
    if not f2f_list then
        return out
    end

    for n in f2f_list:gmatch("(%d+)") do
        out[#out + 1] = tonumber(n)
    end

    return out
end

local function collect_turn_story_ids(registry_raw, turn)
    local ids = {}
    if not registry_raw or not turn then
        return ids
    end

    local turn_block = registry_raw:match("\"turnNumber\"%s*:%s*" .. tostring(turn) .. "%s*,(.-)%}%s*[,%]]")
    if not turn_block then
        return ids
    end

    for story_id in turn_block:gmatch("\"storyNpcId\"%s*:%s*\"([%w_%-]+)\"") do
        ids[#ids + 1] = story_id
    end

    return ids
end

local function collect_registry_continuation(registry_raw, turn, choice_index)
    if not registry_raw or not turn or not choice_index then
        return nil, nil
    end

    local turn_pattern = "\"turnNumber\"%s*:%s*" .. tostring(turn) .. "%s*,(.-)%}%s*[,%]]"
    local turn_block = registry_raw:match(turn_pattern)
    if not turn_block then
        return nil, nil
    end

    local choice_patterns = {
        "\"choiceIndex\"%s*:%s*" .. tostring(choice_index) .. "%s*,(.-)%}%s*[,%]]",
        "\"choiceNumber\"%s*:%s*" .. tostring(choice_index) .. "%s*,(.-)%}%s*[,%]]",
        "\"index\"%s*:%s*" .. tostring(choice_index) .. "%s*,(.-)%}%s*[,%]]",
    }

    local choice_block = nil
    for _, pattern in ipairs(choice_patterns) do
        choice_block = turn_block:match(pattern)
        if choice_block then
            break
        end
    end
    if not choice_block then
        return nil, nil
    end

    local next_turn =
        choice_block:match("\"nextTurn\"%s*:%s*(%d+)") or
        choice_block:match("\"contTurn\"%s*:%s*(%d+)") or
        choice_block:match("\"continuationTurn\"%s*:%s*(%d+)")
    local next_channel =
        choice_block:match("\"nextChannel\"%s*:%s*\"([%w_%-]+)\"") or
        choice_block:match("\"contChannel\"%s*:%s*\"([%w_%-]+)\"") or
        choice_block:match("\"continuationChannel\"%s*:%s*\"([%w_%-]+)\"")

    if next_turn then
        next_turn = tonumber(next_turn)
    end

    return next_turn, next_channel
end

local function extract_registry_string_override(registry_raw, key_name)
    if not registry_raw or registry_raw == "" or not key_name or key_name == "" then
        return nil
    end
    local escaped_key = tostring(key_name):gsub("(%W)", "%%%1")
    local raw_value = registry_raw:match("\"" .. escaped_key .. "\"%s*:%s*\"([^\"]+)\"")
    if not raw_value then
        return nil
    end
    local trimmed = tostring(raw_value):gsub("^%s*(.-)%s*$", "%1")
    if trimmed == "" then
        return nil
    end
    return trimmed
end

local function collect_registry_bridge_text_overrides(registry_raw)
    return {
        f2fRootActorLineKey = extract_registry_string_override(registry_raw, "f2fRootActorLineKey"),
        f2fParityShimKey = extract_registry_string_override(registry_raw, "f2fParityShimKey"),
    }
end

local function resolve_bool_flag_override(flag_key, default_value)
    if type(flag_key) ~= "string" or flag_key == "" then
        return default_value == true
    end
    if key_exists(flag_key) then
        return parse_bool_flag(tr(flag_key))
    end
    return default_value == true
end

local function select_f2f_turn(stem, npc_se)
    local registry_raw = get_registry_raw(stem)
    local entry_turns = collect_registry_f2f_turns(registry_raw)
    if #entry_turns == 0 then
        return 1
    end

    local runtime_ids = resolve_partner_runtime_ids(npc_se)
    bridge_debug(
        "select_f2f_turn stem=%s runtime_story_id=%s runtime_fallback_name=%s runtime_character_name=%s runtime_canonical_id=%s runtime_candidates=%s entry_turns=%s",
        tostring(stem),
        tostring(runtime_ids.story_id),
        tostring(runtime_ids.fallback_name),
        tostring(runtime_ids.character_name),
        tostring(runtime_ids.canonical_id),
        (#runtime_ids.canonical_candidates > 0 and table.concat(runtime_ids.canonical_candidates, "|") or "<none>"),
        table.concat(entry_turns, ",")
    )

    for _, turn in ipairs(entry_turns) do
        local ids = collect_turn_story_ids(registry_raw, turn)
        bridge_debug(
            "select_f2f_turn turn=%s candidate_storyNpcIds=%s runtime_canonical_id=%s",
            tostring(turn),
            (#ids > 0 and table.concat(ids, ",") or "<none>"),
            tostring(runtime_ids.canonical_id)
        )

        if #ids == 0 then
            return turn
        end

        if #runtime_ids.canonical_candidates > 0 then
            for _, id in ipairs(ids) do
                local canonical_registry_id = tostring(id):lower()
                local matched = false
                for _, candidate in ipairs(runtime_ids.canonical_candidates) do
                    if candidate == canonical_registry_id then
                        matched = true
                        break
                    end
                end
                bridge_debug(
                    "select_f2f_turn compare runtime_candidates=%s xml_storyNpcId=%s match=%s",
                    table.concat(runtime_ids.canonical_candidates, "|"),
                    tostring(canonical_registry_id),
                    tostring(matched)
                )
                if matched then
                    return turn
                end
            end
        end
    end

    bridge_debug(
        "select_f2f_turn no-match stem=%s runtime_candidates=%s entry_turns=%s reason=%s",
        tostring(stem),
        (#runtime_ids.canonical_candidates > 0 and table.concat(runtime_ids.canonical_candidates, "|") or "<none>"),
        table.concat(entry_turns, ","),
        "no turn storyNpcId matched runtime canonical candidates"
    )
    return nil
end

local function execute_shared_outcome(branch, state)
    local api = get_conv_api()
    if not api or type(api.apply_outcome) ~= "function" then
        return false
    end

    local npc = state.npc_se
    local npc_name = npc and npc:character_name() or "Unknown"
    local npc_faction = (npc and npc.community and npc:community()) or state.faction
    local npc_id = resolve_server_npc_id(npc, "execute_shared_outcome")
    local contact_id = npc_id and tostring(npc_id) or nil

    local conv_data = {
        channel = "f2f",
        faction = state.faction,
        conv_id = state.conv_id,
        prefix = state.prefix,
        turn = state.turn or 1,
    }

    return api.apply_outcome(
        branch.outcome or "none",
        npc_name,
        npc_faction,
        npc_id,
        nil,
        contact_id,
        conv_data,
        "f2f"
    ) == true
end

local function get_pending_handoff_for_npc(npc_se)
    local function normalize_positive_int(value)
        return normalize_npc_id(value)
    end

    local partner_id = resolve_server_npc_id(npc_se, "get_pending_handoff_for_npc")

    local runtime_ids = resolve_partner_runtime_ids(npc_se)
    local runtime_candidate_map = {}
    for _, candidate in ipairs(runtime_ids.canonical_candidates or {}) do
        runtime_candidate_map[tostring(candidate):lower()] = true
    end

    bridge_debug(
        "get_pending_handoff_for_npc: resolved partner_id=%s npc_se_present=%s runtime_story_id=%s runtime_canonical_id=%s runtime_candidates=%s",
        tostring(partner_id),
        tostring(npc_se ~= nil),
        tostring(runtime_ids.story_id),
        tostring(runtime_ids.canonical_id),
        (#runtime_ids.canonical_candidates > 0 and table.concat(runtime_ids.canonical_candidates, "|") or "<none>")
    )
    if not partner_id and #runtime_ids.canonical_candidates == 0 then
        bridge_debug("get_pending_handoff_for_npc: reject reason=bad_ids partner_id=nil runtime_candidates=<none>")
        return nil
    end

    local function collect_handoff_identity_candidates(raw_handoff)
        local out = {}
        local seen = {}
        local function push_candidate(value)
            if value == nil then
                return
            end
            local normalized = tostring(value):lower()
            if normalized == "" or seen[normalized] then
                return
            end
            seen[normalized] = true
            out[#out + 1] = normalized
        end

        push_candidate(raw_handoff and raw_handoff.canonical_id)
        push_candidate(raw_handoff and raw_handoff.story_id)
        push_candidate(raw_handoff and raw_handoff.story_npc_id)
        push_candidate(raw_handoff and raw_handoff.req_story_npc)
        push_candidate(raw_handoff and raw_handoff.fallback_name)

        local raw_npc_id = normalize_positive_int(raw_handoff and raw_handoff.npc_id)
        if raw_npc_id and type(get_object_story_id) == "function" then
            local ok_story, resolved_story = pcall(function() return get_object_story_id(raw_npc_id) end)
            if ok_story and resolved_story and resolved_story ~= "" then
                push_candidate(resolved_story)
            end
        end

        return out
    end

    local function normalize_handoff(raw_handoff, source_path, match_mode)
        if type(raw_handoff) ~= "table" then
            return nil
        end

        local conv_id = normalize_positive_int(raw_handoff.conv_id)
        local turn = normalize_positive_int(raw_handoff.turn)
        local npc_id = normalize_positive_int(raw_handoff.npc_id)
        if not conv_id or not turn or not npc_id then
            return nil
        end

        local set_at = tonumber(raw_handoff.set_at)
        if not set_at then
            return nil
        end

        local now = tonumber(time_global and time_global() or 0) or 0
        local age = now - set_at
        if age < 0 then
            age = 0
        end
        if age > RECENT_HANDOFF_GRACE_MS then
            return nil
        end

        local normalized = {
            npc_id = npc_id,
            conv_id = conv_id,
            turn = turn,
            faction = raw_handoff.faction,
            prefix = raw_handoff.prefix,
            channel = "f2f",
            source_path = source_path or "unknown",
            source = raw_handoff,
            match_mode = match_mode or "exact_id",
            contact_id = raw_handoff.contact_id,
            set_at = set_at,
            token = raw_handoff.token and tostring(raw_handoff.token) or nil,
            story_id = raw_handoff.story_id,
            canonical_id = raw_handoff.canonical_id,
            fallback_name = raw_handoff.fallback_name,
            route_owner = raw_handoff.route_owner,
            route_dialog = raw_handoff.route_dialog,
            route_status = raw_handoff.route_status,
        }

        return normalized
    end

    local function choose_preferred_candidate(candidates)
        if type(candidates) ~= "table" or #candidates == 0 then
            return nil
        end

        table.sort(candidates, function(a, b)
            local a_exact = a and a.match_mode == "exact_id" and 1 or 0
            local b_exact = b and b.match_mode == "exact_id" and 1 or 0
            if a_exact ~= b_exact then
                return a_exact > b_exact
            end

            if compare_pending_handoff_priority(a, b) then
                return true
            end
            if compare_pending_handoff_priority(b, a) then
                return false
            end

            return tostring(a and a.source_path or "") < tostring(b and b.source_path or "")
        end)

        if candidates[1].match_mode == "exact_id" then
            return candidates[1]
        end

        if #candidates == 1 then
            return candidates[1]
        end

        return nil
    end

    local function handoff_matches_identity(raw_handoff)
        local candidates = collect_handoff_identity_candidates(raw_handoff)
        if #candidates == 0 then
            return false, "<none>"
        end
        for _, candidate in ipairs(candidates) do
            if runtime_candidate_map[candidate] then
                return true, table.concat(candidates, "|")
            end
        end
        return false, table.concat(candidates, "|")
    end

    local function evaluate_handoff_candidate(raw_handoff, source_path)
        if type(raw_handoff) ~= "table" then
            bridge_debug(
                "get_pending_handoff_for_npc: reject source=%s reason=bad_ids handoff_type=%s",
                tostring(source_path),
                tostring(type(raw_handoff))
            )
            return nil
        end

        local raw_npc_id = normalize_positive_int(raw_handoff.npc_id)
        local conv_id = normalize_positive_int(raw_handoff.conv_id)
        local turn = normalize_positive_int(raw_handoff.turn)
        if not conv_id or not turn then
            bridge_debug(
                "get_pending_handoff_for_npc: reject source=%s reason=missing_conv_or_turn raw_npc_id=%s conv_id=%s turn=%s",
                tostring(source_path),
                tostring(raw_handoff.npc_id),
                tostring(conv_id),
                tostring(turn)
            )
            return nil
        end

        if not raw_npc_id then
            bridge_debug(
                "get_pending_handoff_for_npc: reject source=%s reason=bad_ids raw_npc_id=%s conv_id=%s turn=%s",
                tostring(source_path),
                tostring(raw_handoff.npc_id),
                tostring(conv_id),
                tostring(turn)
            )
            return nil
        end

        if partner_id and raw_npc_id == partner_id then
            bridge_debug(
                "get_pending_handoff_for_npc: exact_match source=%s partner_id=%s handoff_npc_id=%s",
                tostring(source_path),
                tostring(partner_id),
                tostring(raw_npc_id)
            )
            return normalize_handoff(raw_handoff, source_path, "exact_id")
        end

        local identity_match, handoff_candidates = handoff_matches_identity(raw_handoff)
        if identity_match then
            local match_mode = "canonical_id"
            if raw_handoff.story_id and runtime_candidate_map[tostring(raw_handoff.story_id):lower()] then
                match_mode = "story_id"
            end
            bridge_debug(
                "get_pending_handoff_for_npc: canonical_match source=%s partner_id=%s handoff_npc_id=%s match=%s handoff_candidates=%s",
                tostring(source_path),
                tostring(partner_id),
                tostring(raw_npc_id),
                tostring(match_mode),
                tostring(handoff_candidates)
            )
            return normalize_handoff(raw_handoff, source_path, match_mode)
        end

        bridge_debug(
            "get_pending_handoff_for_npc: reject source=%s reason=npc_mismatch partner_id=%s handoff_npc_id=%s handoff_candidates=%s",
            tostring(source_path),
            tostring(partner_id),
            tostring(raw_npc_id),
            tostring(handoff_candidates)
        )
        return nil
    end

    local function fallback_from_global_handoffs()
        local handoffs = rawget(_G, "pda_f2f_handoffs")
        local handoff_count = 0
        if type(handoffs) == "table" then
            for _ in pairs(handoffs) do
                handoff_count = handoff_count + 1
            end
        end
        bridge_debug(
            "get_pending_handoff_for_npc: _G.pda_f2f_handoffs exists=%s count=%s",
            tostring(type(handoffs) == "table"),
            tostring(handoff_count)
        )
        if type(handoffs) ~= "table" then
            return nil
        end

        local candidates = {}
        for _, raw_handoff in pairs(handoffs) do
            local normalized = evaluate_handoff_candidate(raw_handoff, "fallback:pda_f2f_handoffs")
            if normalized then
                candidates[#candidates + 1] = normalized
            end
        end

        return choose_preferred_candidate(candidates)
    end

    local function fallback_from_active_conversations()
        local conversations = nil
        if pda_interactive_conv and type(pda_interactive_conv.active_conversations) == "table" then
            conversations = pda_interactive_conv.active_conversations
        elseif type(rawget(_G, "active_conversations")) == "table" then
            conversations = active_conversations
        end

        if type(conversations) ~= "table" then
            return nil
        end

        local candidates = {}
        for contact_id, conv in pairs(conversations) do
            if type(conv) == "table" and conv.pending_in_person_continuation == true then
                local raw_handoff = {
                    npc_id = conv.npc_id,
                    conv_id = conv.conv_id,
                    turn = conv.pending_in_person_turn or conv.turn,
                    faction = conv.faction,
                    prefix = conv.prefix,
                    contact_id = contact_id,
                    set_at = conv.pending_in_person_set_at,
                    token = conv.pending_in_person_token,
                    story_id = conv.pending_in_person_story_id or conv.story_id,
                    canonical_id = conv.pending_in_person_canonical_id or conv.canonical_id,
                    fallback_name = conv.fallback_name,
                }
                local normalized = evaluate_handoff_candidate(raw_handoff, "fallback:active_conversations")
                if normalized then
                    candidates[#candidates + 1] = normalized
                end
            end
        end

        return choose_preferred_candidate(candidates)
    end

    local function fallback_recent_canonical_within_grace_window(grace_ms)
        local handoffs = rawget(_G, "pda_f2f_handoffs")
        if type(handoffs) ~= "table" or #runtime_ids.canonical_candidates == 0 then
            return nil
        end

        local candidates = {}
        local now = tonumber(time_global and time_global() or 0) or 0
        local allowed_age = tonumber(grace_ms) or RECENT_HANDOFF_GRACE_MS

        for _, raw_handoff in pairs(handoffs) do
            local set_at = tonumber(raw_handoff and raw_handoff.set_at)
            if not set_at then
                bridge_debug("get_pending_handoff_for_npc: reject source=recent_canonical reason=stale_age missing_set_at=true")
            else
                local age = now - set_at
                if age < 0 then
                    age = 0
                end
                if age > allowed_age then
                    bridge_debug(
                        "get_pending_handoff_for_npc: reject source=recent_canonical reason=stale_age raw_npc_id=%s age_ms=%s grace_ms=%s",
                        tostring(raw_handoff and raw_handoff.npc_id),
                        tostring(age),
                        tostring(allowed_age)
                    )
                else
                    local identity_match = handoff_matches_identity(raw_handoff)
                    local conv_id = normalize_positive_int(raw_handoff and raw_handoff.conv_id)
                    local turn = normalize_positive_int(raw_handoff and raw_handoff.turn)
                    local raw_npc_id = normalize_positive_int(raw_handoff and raw_handoff.npc_id)
                    if not conv_id or not turn then
                        bridge_debug(
                            "get_pending_handoff_for_npc: reject source=recent_canonical reason=missing_conv_or_turn raw_npc_id=%s conv_id=%s turn=%s",
                            tostring(raw_handoff and raw_handoff.npc_id),
                            tostring(conv_id),
                            tostring(turn)
                        )
                    elseif not raw_npc_id then
                        bridge_debug(
                            "get_pending_handoff_for_npc: reject source=recent_canonical reason=bad_ids raw_npc_id=%s",
                            tostring(raw_handoff and raw_handoff.npc_id)
                        )
                    elseif not identity_match then
                        local _, handoff_candidates = handoff_matches_identity(raw_handoff)
                        bridge_debug(
                            "get_pending_handoff_for_npc: reject source=recent_canonical reason=npc_mismatch partner_id=%s handoff_npc_id=%s handoff_candidates=%s",
                            tostring(partner_id),
                            tostring(raw_npc_id),
                            tostring(handoff_candidates)
                        )
                    else
                        local normalized = normalize_handoff(raw_handoff, "recent_canonical_match", "canonical_id")
                        if normalized then
                            candidates[#candidates + 1] = normalized
                        end
                    end
                end
            end
        end

        return choose_preferred_candidate(candidates)
    end

    local api = get_conv_api()
    local handoff = nil
    if not api then
        bridge_debug("get_pending_handoff_for_npc: get_conv_api returned nil")
    else
        bridge_debug("get_pending_handoff_for_npc: get_conv_api returned table")
    end

    if api and type(api.get_pending_f2f_handoff) == "function" and partner_id then
        local ok_handoff, api_handoff = pcall(function()
            return api.get_pending_f2f_handoff(partner_id)
        end)
        if ok_handoff then
            bridge_debug(
                "get_pending_handoff_for_npc: api.get_pending_f2f_handoff(partner_id=%s) returned=%s",
                tostring(partner_id),
                tostring(type(api_handoff))
            )
            handoff = evaluate_handoff_candidate(api_handoff, "api:get_pending_f2f_handoff")
        else
            bridge_debug(
                "get_pending_handoff_for_npc: api.get_pending_f2f_handoff(partner_id=%s) call_failed",
                tostring(partner_id)
            )
        end
    elseif api then
        bridge_debug("get_pending_handoff_for_npc: api.get_pending_f2f_handoff missing or not callable")
    end

    if not handoff then
        handoff = fallback_from_global_handoffs()
        if handoff then
            bridge_debug("get_pending_handoff_for_npc: winner path=fallback:pda_f2f_handoffs partner_id=%s", tostring(partner_id))
        else
            handoff = fallback_from_active_conversations()
            if handoff then
                bridge_debug("get_pending_handoff_for_npc: winner path=fallback:active_conversations partner_id=%s", tostring(partner_id))
            else
                handoff = fallback_recent_canonical_within_grace_window(RECENT_HANDOFF_GRACE_MS)
                if handoff then
                    bridge_debug("get_pending_handoff_for_npc: winner path=recent_canonical_match partner_id=%s", tostring(partner_id))
                end
            end
        end
    else
        bridge_debug("get_pending_handoff_for_npc: winner path=api:get_pending_f2f_handoff partner_id=%s", tostring(partner_id))
    end

    if not handoff then
        bridge_debug("get_pending_handoff_for_npc: handoff source=none partner_id=%s", tostring(partner_id))
        return nil
    end

    bridge_debug(
        "get_pending_handoff_for_npc: handoff source=%s partner_id=%s conv_id=%s turn=%s",
        tostring(handoff.source_path),
        tostring(partner_id),
        tostring(handoff.conv_id),
        tostring(handoff.turn)
    )

    return handoff
end

local function has_actionable_handoff_marker_for_npc(npc_se)
    local function normalize_positive_int(value)
        return normalize_npc_id(value)
    end

    local partner_id = resolve_server_npc_id(npc_se, "has_actionable_handoff_marker_for_npc")
    if not partner_id then
        return false, "no_partner_id"
    end

    local handoffs = rawget(_G, "pda_f2f_handoffs")
    if type(handoffs) == "table" then
        for _, raw_handoff in pairs(handoffs) do
            if type(raw_handoff) == "table" then
                local raw_npc_id = normalize_positive_int(raw_handoff.npc_id)
                local conv_id = normalize_positive_int(raw_handoff.conv_id)
                local turn = normalize_positive_int(raw_handoff.turn)
                if raw_npc_id == partner_id and conv_id and turn then
                    return true, "global_handoff_entry_present"
                end
            end
        end
    end

    local conversations = nil
    if pda_interactive_conv and type(pda_interactive_conv.active_conversations) == "table" then
        conversations = pda_interactive_conv.active_conversations
    elseif type(rawget(_G, "active_conversations")) == "table" then
        conversations = active_conversations
    end

    if type(conversations) == "table" then
        for _, conv in pairs(conversations) do
            if type(conv) == "table" and conv.pending_in_person_continuation == true then
                local conv_npc_id = normalize_positive_int(conv.npc_id)
                if conv_npc_id == partner_id then
                    return true, "active_conversation_pending_in_person"
                end
            end
        end
    end

    return false, "recent_fallback_blocked_no_actionable_marker"
end

local function consume_pending_handoff_for_npc(npc_se, conv_id, turn, token, set_at)
    local api = get_conv_api()
    if not api or type(api.consume_pending_f2f_handoff) ~= "function" then
        return false
    end

    local partner_id = resolve_server_npc_id(npc_se, "consume_pending_handoff_for_npc")
    if not partner_id then
        bridge_debug("consume_pending_handoff_for_npc: reject reason=bad_ids")
        return false
    end

    return api.consume_pending_f2f_handoff(partner_id, conv_id, turn, token, set_at) == true
end

cleanup_state_handlers = function(state)
    if type(state) ~= "table" then
        return
    end
    -- Remove _G handler functions to prevent stale closure leaks.
    -- Each f2f dialog session registers precondition/action callbacks in _G
    -- via register_dispatcher(). These closures capture state.dialog (CPhraseDialog
    -- userdata) and state.npc_se (server entity). If not cleaned up, stale
    -- references to destroyed engine objects can cause freezes during save/load/GC.
    if type(state.handlers) == "table" then
        for _, handler in ipairs(state.handlers) do
            if handler.cond_name then
                _G[handler.cond_name] = nil
            end
            if handler.act_name then
                _G[handler.act_name] = nil
            end
        end
        state.handlers = {}
    end
    -- Break references to engine userdata to prevent stale access
    state.dialog = nil
    state.npc_se = nil
end

cleanup_noncommit_exit = function(state, exit_reason)
    if type(state) ~= "table" then
        return false
    end
    if state.branch_committed == true then
        return false
    end

    local active_npc_id = resolve_server_npc_id(state.npc_se, "cleanup_noncommit_exit")
    local consumed_handoff = consume_pending_handoff_for_npc(
        state.npc_se,
        state.handoff_conv_id or state.conv_id,
        state.handoff_turn or state.turn,
        state.handoff_token,
        state.handoff_set_at
    )
    if consumed_handoff then
        bridge_warn(
            "cleanup_noncommit_exit handoff_consume removed=true npc_id=%s conv_id=%s turn=%s reason=%s",
            tostring(active_npc_id or state.npc_se and state.npc_se.id or "nil"),
            tostring(state.conv_id or "nil"),
            tostring(state.turn or "nil"),
            tostring(exit_reason or "unknown")
        )
    else
        bridge_warn(
            "cleanup_noncommit_exit handoff_consume removed=false npc_id=%s conv_id=%s turn=%s reason=%s detail=consume_miss",
            tostring(active_npc_id or state.npc_se and state.npc_se.id or "nil"),
            tostring(state.conv_id or "nil"),
            tostring(state.turn or "nil"),
            tostring(exit_reason or "unknown")
        )
    end
    bridge_warn(
        "handoff_cleared_on_abort npc_id=%s conv_id=%s turn=%s reason=%s",
        tostring(active_npc_id or state.npc_se and state.npc_se.id or "nil"),
        tostring(state.conv_id or "nil"),
        tostring(state.turn or "nil"),
        tostring(exit_reason or "unknown")
    )
    cleanup_state_handlers(state)
    return true
end

local function get_recent_handoff_match_for_npc(npc_se, grace_ms)
    local function normalize_positive_int(value)
        return normalize_npc_id(value)
    end

    local partner_id = resolve_server_npc_id(npc_se, "get_recent_handoff_match_for_npc")

    local handoffs = rawget(_G, "pda_f2f_handoffs")
    if not partner_id or type(handoffs) ~= "table" then
        return nil
    end

    local latest = nil
    local latest_set_at = nil
    for _, raw_handoff in pairs(handoffs) do
        if type(raw_handoff) == "table" and normalize_positive_int(raw_handoff.npc_id) == partner_id then
            local conv_id = normalize_positive_int(raw_handoff.conv_id)
            local turn = normalize_positive_int(raw_handoff.turn)
            local set_at = tonumber(raw_handoff.set_at)
            if conv_id and turn and set_at and (not latest_set_at or set_at > latest_set_at) then
                latest_set_at = set_at
                latest = {
                    npc_id = partner_id,
                    conv_id = conv_id,
                    turn = turn,
                    faction = raw_handoff.faction,
                    prefix = raw_handoff.prefix,
                    channel = "f2f",
                    source_path = "recent_npc_match",
                    source = raw_handoff,
                }
            end
        end
    end

    if not latest then
        bridge_debug("get_recent_handoff_match_for_npc: handoff source=none partner_id=%s", tostring(partner_id))
        return nil
    end

    local now = tonumber(time_global and time_global() or 0) or 0
    local allowed_age = tonumber(grace_ms) or RECENT_HANDOFF_GRACE_MS
    local age = now - (latest_set_at or 0)
    if age < 0 then
        age = 0
    end
    if age > allowed_age then
        bridge_debug(
            "get_recent_handoff_match_for_npc: handoff source=recent_npc_match stale=true partner_id=%s conv_id=%s turn=%s age_ms=%s grace_ms=%s",
            tostring(partner_id),
            tostring(latest.conv_id),
            tostring(latest.turn),
            tostring(age),
            tostring(allowed_age)
        )
        return nil
    end

    bridge_debug(
        "get_recent_handoff_match_for_npc: handoff source=recent_npc_match partner_id=%s conv_id=%s turn=%s age_ms=%s grace_ms=%s",
        tostring(partner_id),
        tostring(latest.conv_id),
        tostring(latest.turn),
        tostring(age),
        tostring(allowed_age)
    )
    return latest
end

function panda_f2f_bridge.hard_route_branch(npc_id, owner_tag)
    ensure_callbacks_registered()

    local sid = normalize_npc_id(npc_id)
    if not sid then
        bridge_debug("hard_route_branch: reject reason=bad_ids npc_id=%s", tostring(npc_id))
        return false
    end
    if not xr_meet or type(xr_meet.override_dialog) ~= "function" then
        return false
    end

    local ok_override_call, override_result = pcall(xr_meet.override_dialog, sid, HUB_DIALOG_ID)
    if not ok_override_call then
        bridge_warn(
            "hard_route_branch warning: override_dialog call failed npc_id=%s dialog=%s",
            tostring(sid),
            tostring(HUB_DIALOG_ID)
        )
        return false
    end

    bridge_debug(
        "hard_route_branch: override_dialog invoked npc_id=%s dialog=%s result=%s",
        tostring(sid),
        tostring(HUB_DIALOG_ID),
        tostring(override_result)
    )

    local override_applied = false
    local detected_override_value = nil
    if type(xr_meet.has_dialog_override) == "function" then
        local ok_override, has_override = pcall(xr_meet.has_dialog_override, sid)
        if ok_override then
            detected_override_value = has_override
            if has_override == true then
                override_applied = true
            end
        end
    end
    if not override_applied then
        local table_candidates = {
            "dialog_override",
            "dialog_overrides",
            "override_dialogs",
        }
        for _, field in ipairs(table_candidates) do
            local overrides = rawget(xr_meet, field)
            if type(overrides) == "table" then
                local rec = overrides[sid] or overrides[tostring(sid)]
                if rec == HUB_DIALOG_ID then
                    detected_override_value = rec
                    override_applied = true
                    break
                end
                if type(rec) == "table" then
                    local rec_dialog = rec.dialog or rec.dialog_id or rec.id or rec.override
                    if rec_dialog == HUB_DIALOG_ID then
                        detected_override_value = rec_dialog
                        override_applied = true
                        break
                    end
                    if detected_override_value == nil then
                        detected_override_value = rec_dialog
                    end
                elseif detected_override_value == nil then
                    detected_override_value = rec
                end
            end
        end
    end
    bridge_debug(
        "hard_route_branch: override validation npc_id=%s expected=%s detected=%s detected_type=%s applied=%s",
        tostring(sid),
        tostring(HUB_DIALOG_ID),
        tostring(detected_override_value),
        type(detected_override_value),
        tostring(override_applied)
    )
    if not override_applied then
        bridge_debug(
            "hard_route_branch debug: dialog override reflection pending npc_id=%s dialog=%s",
            tostring(sid),
            tostring(HUB_DIALOG_ID)
        )
    end

    if override_applied then
        runtime.override_owners[tostring(sid)] = {
            owner = owner_tag or "f2f",
            dialog = HUB_DIALOG_ID,
            started_at = time_global and time_global() or 0,
        }
    end

    return override_applied == true
end

function panda_f2f_bridge.restore_branch_route(npc_id, owner_tag)
    ensure_callbacks_registered()

    local sid = normalize_npc_id(npc_id)
    if not sid then
        bridge_debug("restore_branch_route: reject reason=bad_ids npc_id=%s", tostring(npc_id))
        return false
    end

    local key = tostring(sid)
    local rec = runtime.override_owners[key]
    if rec and owner_tag and rec.owner ~= owner_tag then
        return false
    end

    if xr_meet and type(xr_meet.restore_dialog) == "function" then
        xr_meet.restore_dialog(sid)
    end
    runtime.override_owners[key] = nil
    return true
end

function panda_f2f_bridge.abort_session(npc_id, owner_tag, reason, token)
    ensure_callbacks_registered()

    local sid = normalize_npc_id(npc_id)
    if not sid then
        bridge_debug("abort_session: reject reason=bad_ids npc_id=%s", tostring(npc_id))
        return false
    end

    local restored = panda_f2f_bridge.restore_branch_route(sid, owner_tag)
    if restored ~= true and owner_tag ~= nil then
        restored = panda_f2f_bridge.restore_branch_route(sid, nil) or restored
    end

    local discarded = discard_runtime_state_for_npc(sid, token)
    bridge_warn(
        "abort_session npc_id=%s reason=%s restored=%s discarded=%s token=%s",
        tostring(sid),
        tostring(reason or "unknown"),
        tostring(restored == true),
        tostring(discarded == true),
        tostring(token or "nil")
    )
    return restored == true or discarded == true
end

function panda_f2f_bridge.reset_runtime(reason)
    ensure_callbacks_registered()

    local restored = restore_override_owners(runtime.override_owners)
    clear_runtime_transient_state()
    runtime.override_owners = {}
    bridge_warn(
        "reset_runtime reason=%s restored_overrides=%s",
        tostring(reason or "unknown"),
        tostring(restored == true)
    )
    return true
end

function panda_f2f_bridge.is_session_active(_actor)
    if type(runtime.pending_state) == "table" then
        return true
    end
    if type(runtime.latest_state) == "table" then
        return true
    end
    if runtime.active_token ~= nil then
        return true
    end
    return next(runtime.state_by_id or {}) ~= nil
end

function panda_f2f_bridge.on_branch_completed(npc_id, owner_tag)
    return panda_f2f_bridge.restore_branch_route(npc_id, owner_tag)
end

function panda_f2f_bridge.on_branch_failed(npc_id, owner_tag)
    return panda_f2f_bridge.restore_branch_route(npc_id, owner_tag)
end

function panda_f2f_bridge.on_branch_timeout(npc_id, owner_tag)
    return panda_f2f_bridge.restore_branch_route(npc_id, owner_tag)
end

local function collect_branches(npc_se, forced_context)
    local actor_faction = actor_faction_key()
    local faction = actor_faction
    local stem_prefix = nil
    local found = nil
    local missing = 0
    local last_resolved_stem = nil
    local first_missing_key = nil

    local function normalize_positive_int(value)
        local n = tonumber(value)
        if not n or n <= 0 then
            return nil
        end
        return math.floor(n)
    end

    local forced_conv_id = nil
    local forced_turn = nil
    local forced_handoff_active = false
    local forced_faction = nil
    local forced_faction_raw = nil
    local forced_prefix = nil
    if type(forced_context) == "table" then
        forced_conv_id = normalize_positive_int(forced_context.conv_id)
        forced_turn = normalize_positive_int(forced_context.turn)
        forced_handoff_active = (forced_conv_id ~= nil and forced_turn ~= nil)
        forced_faction_raw = tostring(forced_context.faction or "")
        forced_faction = normalize_faction_key(forced_context.faction)

        forced_prefix = tostring(forced_context.prefix or "")
        if forced_prefix == "" then
            forced_prefix = nil
        end

        if not forced_handoff_active then
            forced_conv_id = nil
            forced_turn = nil
            forced_faction = nil
            forced_prefix = nil
        else
            faction = forced_faction or actor_faction
            stem_prefix = forced_prefix
        end
    end

    local partner_runtime_ids = resolve_partner_runtime_ids(npc_se)
    local partner_npc_id = normalize_positive_int(npc_se and npc_se.id)
    if not partner_npc_id and npc_se and type(npc_se.id) == "function" then
        local ok_partner_id, resolved_partner_id = pcall(function() return npc_se:id() end)
        if ok_partner_id then
            partner_npc_id = normalize_positive_int(resolved_partner_id)
        end
    end
    local forced_npc_binding = forced_handoff_active and forced_context and forced_context.npc_id or nil

    local function forced_identity_matches_partner()
        if not forced_handoff_active or forced_npc_binding == nil then
            return false
        end

        local binding_raw = tostring(forced_npc_binding)
        if binding_raw == "" then
            return false
        end

        local binding_lower = binding_raw:lower()
        local binding_sid = normalize_positive_int(binding_raw)

        if binding_sid and partner_npc_id and binding_sid == partner_npc_id then
            return true
        end

        if partner_runtime_ids.canonical_id and binding_lower == tostring(partner_runtime_ids.canonical_id):lower() then
            return true
        end

        for _, candidate in ipairs(partner_runtime_ids.canonical_candidates or {}) do
            if binding_lower == tostring(candidate):lower() then
                return true
            end
        end

        return false
    end

    local forced_identity_matches = forced_identity_matches_partner()
    bridge_debug(
        "collect_branches: forced_context active=%s conv_id=%s turn=%s npc_id=%s faction=%s prefix=%s",
        tostring(forced_handoff_active),
        tostring(forced_conv_id),
        tostring(forced_turn),
        tostring(forced_npc_binding),
        tostring(forced_faction),
        tostring(forced_prefix)
    )
    bridge_debug(
        "collect_branches: forced_faction raw=%s normalized=%s",
        tostring(forced_faction_raw),
        tostring(forced_faction)
    )
    bridge_debug(
        "collect_branches: forced_identity forced_npc_binding=%s forced_identity_matches=%s",
        tostring(forced_npc_binding),
        tostring(forced_identity_matches)
    )

    local function resolve_turn_stem(stem, turn)
        if turn and turn > 1 then
            return stem .. "_t" .. tostring(turn)
        end
        return stem
    end

    local function collect_turn_branches(stem, cid, turn, conv_req_story_npc, out_state)
        if type(out_state.turns) ~= "table" then
            out_state.turns = {}
        end
        if out_state.turns[turn] then
            return out_state.turns[turn]
        end

        local turn_stem = resolve_turn_stem(stem, turn)
        local turn_open_preferred = turn_stem .. "_open"
        local turn_open_fallback = stem .. "_open"
        local turn_open_key = "__PANDA_F2F_MISSING_TURN_OPEN__"
        local missing_turn_open = true
        if key_exists(turn_open_preferred) then
            turn_open_key = turn_open_preferred
            missing_turn_open = false
        elseif key_exists(turn_open_fallback) then
            turn_open_key = turn_open_fallback
            missing_turn_open = false
        end

        local registry_raw = nil
        if key_exists(stem .. "_registry") then
            registry_raw = tr(stem .. "_registry")
        end

        local is_entry_turn = out_state and out_state.entry_turn and turn == out_state.entry_turn or false
        local registry_bridge_overrides = collect_registry_bridge_text_overrides(registry_raw)
        local turn_state = {
            turn = turn,
            turn_stem = turn_stem,
            is_entry_turn = is_entry_turn,
            open_key = turn_open_key,
            preferred_open_key = turn_open_preferred,
            fallback_open_key = turn_open_fallback,
            missing_turn_open = missing_turn_open,
            f2f_root_actor_line_key = registry_bridge_overrides.f2fRootActorLineKey,
            f2f_parity_shim_key = registry_bridge_overrides.f2fParityShimKey,
            branches = {},
        }
        out_state.turns[turn] = turn_state

        local missing_choices = 0
        local rejected_choice_keys = {}
        local total_choices_loaded = 0
        local choices_passing_preconditions = 0
        local choice_1_key = turn_stem .. "_choice_1"
        for idx = 1, MAX_CHOICE_SCAN do
            local choice_key = turn_stem .. "_choice_" .. idx
            if not key_exists(choice_key) then
                if idx == 1 and not first_missing_key then
                    first_missing_key = choice_1_key
                end
                missing_choices = missing_choices + 1
                if missing_choices >= 3 then
                    break
                end
            else
                missing_choices = 0
                total_choices_loaded = total_choices_loaded + 1
                local reply_key = turn_stem .. "_reply_" .. idx
                local outcome_key = turn_stem .. "_outcome_" .. idx
                local choice_precond_key = turn_stem .. "_choice_" .. idx .. "_precond"
                local hard_route_key = turn_stem .. "_choice_" .. idx .. BRANCH_HARD_ROUTE_SUFFIX
                local keep_hub_override_key = turn_stem .. "_choice_" .. idx .. "_keep_hub_override"
                local cont_turn_key = turn_stem .. "_cont_" .. idx
                local cont_channel_key = turn_stem .. "_cont_channel_" .. idx

                local show = true
                local choice_reason = nil
                if key_exists(choice_precond_key) then
                    show, choice_reason = evaluate_shared_precondition(choice_precond_key, npc_se, {
                        channel = "f2f",
                        conv_id = cid,
                        branch = idx,
                        faction = faction,
                        turn = turn,
                    })

                    local choice_req_story_npc = extract_req_story_npc_id_from_key(choice_precond_key)
                    if not show and conv_req_story_npc and choice_req_story_npc and conv_req_story_npc == choice_req_story_npc then
                        show = true
                        choice_reason = "relaxed-duplicate-req_story_npc:" .. tostring(choice_req_story_npc)
                    end
                    if not show and not first_missing_key and key_exists(choice_precond_key) then
                        first_missing_key = choice_precond_key
                    end
                end
                bridge_debug(
                    "collect_branches choice-precond key=%s result=%s reason=%s conv_id=%s turn=%s choice=%s",
                    tostring(key_exists(choice_precond_key) and choice_precond_key or "<none>"),
                    tostring(show),
                    tostring(choice_reason),
                    tostring(cid),
                    tostring(turn),
                    tostring(choice_key)
                )

                if show then
                    local choice_renderable = key_exists(choice_key)
                    local reply_renderable = key_exists(reply_key)
                    if not choice_renderable or not reply_renderable then
                        show = false
                        choice_reason = (not choice_renderable and "choice_not_renderable" or "reply_not_renderable")
                    end
                end

                if show then
                    choices_passing_preconditions = choices_passing_preconditions + 1
                    local hard_route = false
                    if key_exists(hard_route_key) then
                        hard_route = parse_bool_flag(tr(hard_route_key))
                    end
                    local keep_hub_override = false
                    if key_exists(keep_hub_override_key) then
                        keep_hub_override = parse_bool_flag(tr(keep_hub_override_key))
                    end

                    local next_turn = nil
                    local next_channel = nil
                    if key_exists(cont_turn_key) then
                        next_turn = normalize_positive_int(tr(cont_turn_key))
                    end
                    if key_exists(cont_channel_key) then
                        next_channel = tostring(tr(cont_channel_key) or ""):lower()
                        if next_channel == "" then
                            next_channel = nil
                        end
                    end
                    if (not next_turn or not next_channel) and registry_raw and registry_raw ~= "" then
                        local reg_turn, reg_channel = collect_registry_continuation(registry_raw, turn, idx)
                        if not next_turn then
                            next_turn = normalize_positive_int(reg_turn)
                        end
                        if not next_channel and reg_channel and reg_channel ~= "" then
                            next_channel = tostring(reg_channel):lower()
                        end
                    end
                    bridge_debug(
                        "collect_branches continuation conv_id=%s turn=%s choice=%s next_turn=%s next_channel=%s",
                        tostring(cid),
                        tostring(turn),
                        tostring(idx),
                        tostring(next_turn or "nil"),
                        tostring(next_channel or "nil")
                    )

                    table.insert(turn_state.branches, {
                        index = idx,
                        turn = turn,
                        choice_key = choice_key,
                        reply_key = key_exists(reply_key) and reply_key or nil,
                        outcome = key_exists(outcome_key) and tr(outcome_key) or "none",
                        precond_key = key_exists(choice_precond_key) and choice_precond_key or nil,
                        hard_route = hard_route,
                        keep_hub_override = keep_hub_override,
                        next_turn = next_turn,
                        next_channel = next_channel,
                    })
                else
                    rejected_choice_keys[#rejected_choice_keys + 1] = choice_key
                end
            end
        end

        turn_state.total_choices_loaded = total_choices_loaded
        turn_state.choices_passing_preconditions = choices_passing_preconditions
        if #turn_state.branches == 0 then
            bridge_warn(
                "collect_branches fail reason=no_branches stem=%s key=%s conv_id=%s turn=%s rejected=%s",
                tostring(turn_stem),
                tostring(first_missing_key or "nil"),
                tostring(cid),
                tostring(turn),
                (#rejected_choice_keys > 0 and table.concat(rejected_choice_keys, ",") or "<none>")
            )
        end
        return turn_state
    end

    for cid = 1, MAX_CONV_SCAN do
        if not forced_conv_id or cid == forced_conv_id then
            local stem
            if stem_prefix and stem_prefix ~= "task" then
                stem = string.format("st_pda_ic_%s_%s_%d", stem_prefix, faction, cid)
            else
                stem = string.format("st_pda_ic_%s_%d", faction, cid)
            end
            last_resolved_stem = stem
            local open_key = stem .. "_open"
            if not key_exists(open_key) and not forced_conv_id then
                if not first_missing_key then
                    first_missing_key = open_key
                end
                missing = missing + 1
                if missing >= MISSING_STOP then
                    break
                end
            else
                missing = 0
                local precond_key = stem .. "_precond"
                local conv_ok = true
                local conv_reason = nil
                local conv_req_story_npc = nil
                if key_exists(precond_key) then
                    conv_ok, conv_reason = evaluate_shared_precondition(precond_key, npc_se, {
                        channel = "f2f",
                        conv_id = cid,
                        faction = faction,
                        handoff_npc_id = forced_handoff_active and forced_npc_binding or nil,
                    })
                    conv_req_story_npc = extract_req_story_npc_id_from_key(precond_key)
                    if not conv_ok and forced_handoff_active and conv_req_story_npc and forced_identity_matches then
                        conv_ok = true
                        conv_reason = "forced-handoff-identity-match:" .. tostring(conv_req_story_npc)
                    end
                    if not conv_ok and not first_missing_key then
                        first_missing_key = precond_key
                    end
                end
                bridge_debug(
                    "collect_branches conv-precond key=%s result=%s reason=%s conv_id=%s",
                    tostring(key_exists(precond_key) and precond_key or "<none>"),
                    tostring(conv_ok),
                    tostring(conv_reason),
                    tostring(cid)
                )

                if conv_ok then
                    found = {
                        faction = faction,
                        conv_id = cid,
                        prefix = stem_prefix,
                        open_key = open_key,
                        precond_key = key_exists(precond_key) and precond_key or nil,
                        branches = {},
                        handoff = forced_handoff_active and forced_context and forced_context.source or nil,
                        handoff_source = forced_handoff_active and forced_context and (forced_context.source_path or forced_context.source) or nil,
                        handoff_present = forced_handoff_active,
                        handoff_conv_id = forced_handoff_active and forced_context and forced_context.conv_id or nil,
                        handoff_turn = forced_handoff_active and forced_context and forced_context.turn or nil,
                        handoff_token = forced_handoff_active and forced_context and forced_context.token or nil,
                        handoff_set_at = forced_handoff_active and forced_context and forced_context.set_at or nil,
                        stem = stem,
                        render_non_entry_openers = resolve_bool_flag_override("panda_f2f_render_non_entry_openers", false),
                    }

                    local f2f_turn = forced_turn or select_f2f_turn(stem, npc_se)
                    if not f2f_turn then
                        found = nil
                    else
                        found.turn = f2f_turn
                        found.entry_turn = f2f_turn
                        found.turns = {}
                        bridge_debug(
                            "collect_branches: resolved branch context conv_id=%s turn=%s forced_active=%s",
                            tostring(cid),
                            tostring(f2f_turn),
                            tostring(forced_handoff_active)
                        )
                        local root_turn = collect_turn_branches(stem, cid, f2f_turn, conv_req_story_npc, found)
                        found.turn_stem = root_turn.turn_stem
                        found.is_entry_turn = root_turn.is_entry_turn
                        found.preferred_open_key = root_turn.preferred_open_key
                        found.fallback_open_key = root_turn.fallback_open_key
                        found.open_key = root_turn.open_key
                        found.missing_turn_open = root_turn.missing_turn_open
                        found.f2f_root_actor_line_key = root_turn.f2f_root_actor_line_key
                        found.f2f_parity_shim_key = root_turn.f2f_parity_shim_key
                        found.branches = root_turn.branches
                        found.total_choices_loaded = root_turn.total_choices_loaded
                        found.choices_passing_preconditions = root_turn.choices_passing_preconditions

                        local expansion_seen = {}
                        local function expand_turns(turn, depth)
                            if not turn or depth > MAX_TREE_DEPTH then
                                return
                            end
                            local visit_key = tostring(cid) .. ":" .. tostring(turn)
                            if expansion_seen[visit_key] then
                                return
                            end
                            expansion_seen[visit_key] = true

                            local turn_state = collect_turn_branches(stem, cid, turn, conv_req_story_npc, found)
                            for _, branch in ipairs(turn_state.branches or {}) do
                                if branch.next_channel == "f2f" and branch.next_turn then
                                    expand_turns(branch.next_turn, depth + 1)
                                end
                            end
                        end
                        expand_turns(f2f_turn, 1)

                        break
                    end
                end
            end
        end
    end

    if not found then
        bridge_warn(
            "collect_branches fail reason=no_state stem=%s key=%s forced_conv_id=%s forced_turn=%s faction=%s prefix=%s",
            tostring(last_resolved_stem or "nil"),
            tostring(first_missing_key or "nil"),
            tostring(forced_conv_id or "nil"),
            tostring(forced_turn or "nil"),
            tostring(faction or "nil"),
            tostring(stem_prefix or "nil")
        )
    end

    return found
end

local function debug_resolve_snapshot(stage, npc_se, state, handoff)
    local npc_id = resolve_server_npc_id(npc_se, "debug_resolve_snapshot")
    bridge_debug(
        "resolve stage=%s npc_id=%s conv_id=%s forced_turn=%s resolved_faction=%s resolved_stem=%s handoff_present=%s handoff_source=%s turn_root_key=%s total_choices_loaded=%s choices_passing_preconditions=%s final_branch_count=%s",
        tostring(stage or "unknown"),
        tostring(npc_id or "nil"),
        tostring(state and state.conv_id or handoff and handoff.conv_id or "nil"),
        tostring(handoff and handoff.turn or state and state.turn or "nil"),
        tostring(state and state.faction or handoff and handoff.faction or "nil"),
        tostring(state and state.stem or "nil"),
        tostring((handoff ~= nil) or (state and state.handoff_present) or false),
        tostring(handoff and (handoff.source_path or handoff.source) or state and state.handoff_source or "none"),
        tostring(state and state.open_key or "nil"),
        tostring(state and state.total_choices_loaded or 0),
        tostring(state and state.choices_passing_preconditions or 0),
        tostring(state and state.branches and #state.branches or 0)
    )
end

local function dm_bind_saved_dialog(dm, state)
    if type(dm) ~= "table" or type(state) ~= "table" or state.dialog == nil then
        return false
    end

    dm.saved_dialog = state.dialog
    return dm.saved_dialog == state.dialog
end

local function dm_add_dialog(state, parent_id, id, phrase_id, cond, act, use_script_text)
    local dm = get_dialog_manager_iface()
    local phrase_text = tostring(phrase_id or "")
    local allow_script_text = use_script_text and phrase_text:find("^dialogs%.") ~= nil
    local parent_sid = tostring(parent_id)
    local node_sid = tostring(id)

    local phrase = nil
    if state and state.dialog and state.dialog.AddPhrase then
        phrase = state.dialog:AddPhrase(phrase_id, node_sid, parent_sid, -10000)
    end

    bridge_debug(
        "dm_add_dialog insert phrase_id=%s parent_id=%s node_id=%s add_phrase_ret=%s script_text_mode=%s",
        tostring(phrase_id or "nil"),
        tostring(parent_id or "nil"),
        tostring(id or "nil"),
        tostring(phrase ~= nil),
        tostring(allow_script_text == true)
    )

    if phrase then
        local script = phrase:GetPhraseScript()
        if script then
            if cond then script:AddPrecondition(cond) end
            if act then script:AddAction(act) end
            if allow_script_text and script.SetScriptText then
                script:SetScriptText(phrase_id)
            end
        end

        bridge_debug(
            "dm_add_dialog success phrase_id=%s parent_id=%s node_id=%s script_ret=%s",
            tostring(phrase_id or "nil"),
            tostring(parent_id or "nil"),
            tostring(id or "nil"),
            tostring(script ~= nil)
        )

        return script
    end

    local fallback_bound_dialog = dm_bind_saved_dialog(dm, state)
    bridge_warn(
        "dm_add_dialog hard_fail reason=add_phrase_failed phrase_id=%s parent_id=%s node_id=%s fallback_bound_dialog=%s",
        tostring(phrase_id or "nil"),
        tostring(parent_id or "nil"),
        tostring(id or "nil"),
        tostring(fallback_bound_dialog)
    )

    return nil
end

local function build_dialog_tree(dialog, state)
    local alloc = make_allocator(0)
    local token = tostring(time_global and time_global() or math.random(10000, 99999))
    local exit_phrase = "dm_universal_actor_exit"
    local exit_action = "dialogs.break_dialog"

    state.dialog = dialog
    state.alloc = alloc
    state.handlers = {}
    state.active_token = token
    state.branch_committed = false
    state.watchdog_started_at = time_global and time_global() or 0
    state.watchdog_dialog_seen = false
    state.watchdog_talker_seen = false
    register_active_state(state)

    local use_legacy_visible_root = resolve_bool_flag_override("panda_f2f_use_legacy_visible_root", true)
    local root_phrase_id = state.f2f_root_actor_line_key or ROOT_ENTRY_PHRASE_ID
    local root_use_script_text = false
    local parity_shim_phrase_id = state.f2f_parity_shim_key or ACTOR_PARITY_SHIM_PHRASE_ID
    local parity_shim_use_script_text = false
    local use_entry_direct_open = (state.is_entry_turn == true) and (use_legacy_visible_root ~= true)

    if not use_entry_direct_open then
        local root_phrase_text = tr(root_phrase_id)
        if root_phrase_text == root_phrase_id then
            bridge_warn(
                "build_dialog_tree root_key_unresolved root_phrase_id=%s conv_id=%s turn=%s",
                tostring(root_phrase_id),
                tostring(state.conv_id or "nil"),
                tostring(state.turn or "nil")
            )
        end
    end
    local npc_open_phrase_id = state.open_key
    local npc_open_use_script_text = false
    if state.is_entry_turn == false then
        npc_open_phrase_id = nil
        npc_open_use_script_text = false
    elseif state.missing_turn_open then
        npc_open_phrase_id = "[DEBUG] Missing conversation opening line."
        npc_open_use_script_text = false
        bridge_warn(
            "build_dialog_tree fallback reason=missing_turn_open conv_id=%s turn=%s preferred=%s fallback=%s",
            tostring(state.conv_id or "nil"),
            tostring(state.turn or "nil"),
            tostring(state.preferred_open_key or "nil"),
            tostring(state.fallback_open_key or "nil")
        )
    end
    if use_legacy_visible_root then
        local parity_shim_phrase_text = tr(parity_shim_phrase_id)
        local parity_shim_phrase_valid = type(parity_shim_phrase_text) == "string"
            and parity_shim_phrase_text ~= ""
            and parity_shim_phrase_text ~= parity_shim_phrase_id
        if not parity_shim_phrase_valid then
            parity_shim_phrase_id = ACTOR_PARITY_SHIM_FALLBACK_LITERAL
            bridge_warn(
                "build_dialog_tree fallback reason=actor_parity_shim_missing_text constant=ACTOR_PARITY_SHIM_PHRASE_ID phrase_id=%s fallback_literal=%s translated_text=%s conv_id=%s turn=%s",
                tostring(ACTOR_PARITY_SHIM_PHRASE_ID),
                tostring(parity_shim_phrase_id),
                tostring(parity_shim_phrase_text),
                tostring(state.conv_id or "nil"),
                tostring(state.turn or "nil")
            )
        end
    end

    bridge_debug(
        "build_dialog_tree root_mode legacy_visible_root=%s entry_direct_open=%s root_phrase_id=%s root_script_text_mode=%s parity_shim_phrase_id=%s parity_shim_script_text_mode=%s npc_open_phrase_id=%s npc_open_script_text_mode=%s conv_id=%s turn=%s",
        tostring(use_legacy_visible_root == true),
        tostring(use_entry_direct_open == true),
        tostring(root_phrase_id or "nil"),
        tostring(root_use_script_text == true),
        tostring(parity_shim_phrase_id or "nil"),
        tostring(parity_shim_use_script_text == true),
        tostring(npc_open_phrase_id or "nil"),
        tostring(npc_open_use_script_text == true),
        tostring(state.conv_id or "nil"),
        tostring(state.turn or "nil")
    )

    local root_id = nil
    if not use_entry_direct_open then
        root_id = alloc()
    end
    local npc_open_id = alloc()
    local generated_ids = {
        root = {},
        shim = {},
        open = { npc_open_id },
        choice = {},
        reply = {},
        exit = {},
    }
    local nodes_added = 0
    local root_ok = use_entry_direct_open == true
    local npc_open_ok = false
    local actor_choice_count_added = 0
    local npc_reply_count_added = 0
    local build_state = {
        node_speaker_role = {},
        node_parent = {},
        node_children = {},
        first_level_choices = {},
    }
    local function register_parent_child(parent_id, node_id)
        if node_id == nil then
            return
        end
        local node_key = tostring(node_id)
        local parent_key = tostring(parent_id or "")
        build_state.node_parent[node_key] = parent_key
        if build_state.node_children[parent_key] == nil then
            build_state.node_children[parent_key] = {}
        end
        build_state.node_children[parent_key][#build_state.node_children[parent_key] + 1] = node_key
    end

    local function log_parity_diagnostics(reason)
        local function children_csv(node_id)
            local node_key = tostring(node_id or "")
            local children = build_state.node_children[node_key] or {}
            if #children == 0 then
                return "<none>"
            end
            return table.concat(children, ",")
        end

        local function log_node(label, node_id)
            if node_id == nil then
                bridge_warn(
                    "build_dialog_tree parity_diag reason=%s label=%s node_id=nil",
                    tostring(reason or "unknown"),
                    tostring(label or "unknown")
                )
                return
            end
            local node_key = tostring(node_id)
            bridge_warn(
                "build_dialog_tree parity_diag reason=%s label=%s node_id=%s parent=%s children=%s speaker=%s",
                tostring(reason or "unknown"),
                tostring(label or "unknown"),
                tostring(node_key),
                tostring(build_state.node_parent[node_key] or "<none>"),
                tostring(children_csv(node_key)),
                tostring(build_state.node_speaker_role[node_key] or "unknown")
            )
        end

        log_node("root", root_id)
        for idx, node_id in ipairs(generated_ids.shim or {}) do
            log_node("shim_" .. tostring(idx), node_id)
        end
        log_node("opener", npc_open_id)
        for idx, node_id in ipairs(build_state.first_level_choices or {}) do
            log_node("choice_" .. tostring(idx), node_id)
        end
    end

    local function add_logged_node(parent_id, node_id, phrase_id, cond, act, allow_script_text, role, speaker_role)
        bridge_debug(
            "build_dialog_tree insert role=%s parent_id=%s node_id=%s phrase_id=%s cond=%s act=%s script_text=%s",
            tostring(role or "unknown"),
            tostring(parent_id or "nil"),
            tostring(node_id or "nil"),
            tostring(phrase_id or "nil"),
            tostring(cond or "nil"),
            tostring(act or "nil"),
            tostring(allow_script_text == true)
        )
        local ok = dm_add_dialog(state, parent_id, node_id, phrase_id, cond, act, allow_script_text)
        if ok then
            nodes_added = nodes_added + 1
            register_parent_child(parent_id, node_id)
            if speaker_role == "actor" or speaker_role == "npc" then
                build_state.node_speaker_role[tostring(node_id)] = speaker_role
            end
            if role == "root_actor_entry" then
                root_ok = true
            elseif role == "npc_open" then
                npc_open_ok = true
            elseif role == "actor_choice" then
                actor_choice_count_added = actor_choice_count_added + 1
            elseif role == "npc_reply" then
                npc_reply_count_added = npc_reply_count_added + 1
            end
        end
        return ok
    end
    local function add_logged_exit_node(parent_id, node_id, role)
        bridge_debug(
            "build_dialog_tree exit_insert role=%s parent_id=%s node_id=%s phrase_id=%s act=%s",
            tostring(role or "unknown"),
            tostring(parent_id or "nil"),
            tostring(node_id or "nil"),
            tostring(exit_phrase),
            tostring(exit_action)
        )
        return add_logged_node(parent_id, node_id, exit_phrase, nil, exit_action, false, role, "actor")
    end

    local function ensure_actor_parity(parent_node_id, context)
        context = context or {}
        local next_speaker_role = context.next_speaker_role
        local parent_speaker_role = context.parent_speaker_role
        if parent_speaker_role ~= "actor" and parent_speaker_role ~= "npc" then
            parent_speaker_role = build_state.node_speaker_role[tostring(parent_node_id)]
        end

        if parent_speaker_role == "npc" and next_speaker_role == "npc" then
            if use_legacy_visible_root ~= true then
                bridge_debug(
                    "build_dialog_tree parity_path mode=non_rendered_transition parent_id=%s context=%s",
                    tostring(parent_node_id or "nil"),
                    tostring(context.parity_context or "generic")
                )
                return parent_node_id, false
            end
            local shim_literal_phrase = type(parity_shim_phrase_id) == "string" and key_exists(parity_shim_phrase_id) ~= true
            local safe_one_way = context and context.safe_one_way_progression == true
            if shim_literal_phrase and not safe_one_way then
                bridge_warn(
                    "build_dialog_tree parity_path skip_literal_shim parent_id=%s context=%s phrase_id=%s",
                    tostring(parent_node_id or "nil"),
                    tostring(context.parity_context or "generic"),
                    tostring(parity_shim_phrase_id or "nil")
                )
                return parent_node_id, false
            end

            local parity_shim_id = alloc()
            generated_ids.shim[#generated_ids.shim + 1] = parity_shim_id
            add_logged_node(
                parent_node_id,
                parity_shim_id,
                parity_shim_phrase_id,
                nil,
                nil,
                parity_shim_use_script_text,
                "actor_parity_shim",
                "actor"
            )
            return parity_shim_id, true
        end

        return parent_node_id, false
    end

    local npc_open_parent_id = ""
    if not use_entry_direct_open then
        generated_ids.root[#generated_ids.root + 1] = root_id
        add_logged_node("", root_id, root_phrase_id, nil, nil, root_use_script_text, "root_actor_entry", "actor")
        -- NOTE:
        -- Anomaly's actor_dialog flow can present dynamic root nodes with reversed parity
        -- (root behaving as NPC in hub-style dialogs). Keep the legacy shim path only when
        -- explicitly enabled by panda_f2f_use_legacy_visible_root.
        npc_open_parent_id = ensure_actor_parity(root_id, {
            parent_speaker_role = "npc",
            next_speaker_role = "npc",
            parity_context = "root_open",
            safe_one_way_progression = false,
        })
    end
    add_logged_node(npc_open_parent_id, npc_open_id, npc_open_phrase_id, nil, nil, npc_open_use_script_text, "npc_open", "npc")

    local function has_renderable_authored_choice(turn_state)
        if type(turn_state) ~= "table" or type(turn_state.branches) ~= "table" then
            return false
        end
        for _, branch in ipairs(turn_state.branches) do
            if type(branch) == "table" and key_exists(branch.choice_key) then
                return true
            end
        end
        return false
    end

    local current_turn_state = state
    if type(state.turns) == "table" and state.turn ~= nil then
        current_turn_state = state.turns[state.turn] or state
    end

    local has_turn_choices = has_renderable_authored_choice(current_turn_state)
    if not has_turn_choices then
        bridge_warn(
            "build_dialog_tree short_circuit reason=no_renderable_turn_choices conv_id=%s turn=%s action=%s",
            tostring(state.conv_id or "nil"),
            tostring(state.turn or "nil"),
            tostring(exit_action)
        )
        local fallback_actor_id = alloc()
        generated_ids.exit[#generated_ids.exit + 1] = fallback_actor_id
        add_logged_exit_node(npc_open_id, fallback_actor_id, "fallback_actor_exit")
        log_parity_diagnostics("no_renderable_turn_choices")

        return {
            build_ok = false,
            nodes_added = nodes_added,
            root_ok = root_ok,
            npc_open_ok = npc_open_ok,
            actor_choice_count_added = actor_choice_count_added,
            npc_reply_count_added = npc_reply_count_added,
        }
    end

    local function should_log_parity_diagnostics()
        local only_shim_selectable = (#generated_ids.shim > 0) and (#build_state.first_level_choices == 0)
        return (actor_choice_count_added == 0) or only_shim_selectable
    end

    local function register_dispatcher(branch)
        local idx = branch.index
        local branch_turn = branch.turn or state.turn or 1
        local cond_name = string.format("panda_f2f_bridge_choice_precond_%s_%d_t%d", token, idx, branch_turn)
        local act_name = string.format("panda_f2f_bridge_choice_action_%s_%d_t%d", token, idx, branch_turn)
        local captured_state = state
        local captured_state_id = make_state_id(captured_state)
        local captured_token = tostring(token)

        local function resolve_callback_state()
            local token_key = "token:" .. captured_token
            local token_state = runtime.state_by_id[token_key]
            if token_state ~= captured_state then
                return nil, "token_invalid"
            end
            local indexed_state = runtime.state_by_id[captured_state_id]
            if indexed_state == captured_state then
                return indexed_state, "token_valid"
            end
            return captured_state, "token_valid_fallback"
        end

        _G[cond_name] = function()
            local active_state, status = resolve_callback_state()
            bridge_warn(
                "callback fired entry=choice_precondition name=%s branch=%s token=%s status=%s conv_id=%s turn=%s",
                tostring(cond_name),
                tostring(branch.index),
                tostring(captured_token),
                tostring(status or "nil"),
                tostring(active_state and active_state.conv_id or "nil"),
                tostring(branch_turn)
            )
            if not active_state then return false end
            if branch.precond_key and branch.precond_key ~= "" then
                local ok, reason = evaluate_shared_precondition(branch.precond_key, active_state.npc_se, {
                    channel = "f2f",
                    conv_id = active_state.conv_id,
                    branch = branch.index,
                    faction = active_state.faction,
                    turn = branch_turn,
                })
                bridge_debug(
                    "callback choice_precondition evaluated key=%s result=%s reason=%s token=%s conv_id=%s turn=%s branch=%s",
                    tostring(branch.precond_key),
                    tostring(ok),
                    tostring(reason),
                    tostring(captured_token),
                    tostring(active_state and active_state.conv_id or "nil"),
                    tostring(branch_turn),
                    tostring(branch.index)
                )
                return ok == true
            end
            return true
        end

        _G[act_name] = function()
            local active_state, status = resolve_callback_state()
            bridge_warn(
                "callback fired entry=answer name=%s branch=%s token=%s status=%s conv_id=%s turn=%s",
                tostring(act_name),
                tostring(branch.index),
                tostring(captured_token),
                tostring(status or "nil"),
                tostring(active_state and active_state.conv_id or "nil"),
                tostring(branch_turn)
            )
            if not active_state then return end

            -- Re-evaluate preconditions at dispatch time for deterministic safety.
            if branch.precond_key and branch.precond_key ~= "" then
                local ok = evaluate_shared_precondition(branch.precond_key, active_state.npc_se, {
                    channel = "f2f",
                    conv_id = active_state.conv_id,
                    branch = branch.index,
                    faction = active_state.faction,
                    turn = branch_turn,
                })
                if not ok then return end
            end

            local owner_tag = nil
            local routed = false
            local active_npc_id = resolve_server_npc_id(active_state.npc_se, "register_dispatcher:act")
            if branch.hard_route then
                owner_tag = make_override_owner_tag(active_state, branch)
                routed = panda_f2f_bridge.hard_route_branch(active_npc_id, owner_tag)
            end

            local branch_state = active_state
            if branch_turn ~= (active_state.turn or 1) then
                branch_state = {
                    conv_id = active_state.conv_id,
                    faction = active_state.faction,
                    npc_se = active_state.npc_se,
                    turn = branch_turn,
                }
            end
            local outcome_token = tostring(branch.outcome or ""):gsub("^%s*(.-)%s*$", "%1"):lower()
            local commit_mode = "outcome_applied"
            local ok = false
            if outcome_token == "" or outcome_token == "none" then
                ok = true
                commit_mode = "outcome_skipped_none"
            else
                ok = execute_shared_outcome(branch, branch_state)
            end
            bridge_debug(
                "register_dispatcher: branch commit branch=%s conv_id=%s turn=%s ok=%s commit_mode=%s outcome=%s",
                tostring(branch.index),
                tostring(active_state.conv_id or "nil"),
                tostring(branch_state.turn or "nil"),
                tostring(ok),
                tostring(commit_mode),
                tostring(branch.outcome or "none")
            )
            if ok then
                active_state.branch_committed = true
                -- Consume only after a player-selected branch is committed.
                consume_pending_handoff_for_npc(
                    active_state.npc_se,
                    active_state.handoff_conv_id or active_state.conv_id,
                    active_state.handoff_turn or active_state.turn,
                    active_state.handoff_token,
                    active_state.handoff_set_at
                )
            end
            if branch.hard_route and routed then
                local keep_hub_override = branch.keep_hub_override == true
                if not keep_hub_override then
                    local restored = panda_f2f_bridge.restore_branch_route(active_npc_id, owner_tag)
                    if ok and active_npc_id then
                        runtime.override_owners[tostring(active_npc_id)] = nil
                    end
                    bridge_debug(
                        "register_dispatcher: hard_route cleanup branch=%s conv_id=%s turn=%s ok=%s commit_mode=%s restored=%s",
                        tostring(branch.index),
                        tostring(active_state.conv_id or "nil"),
                        tostring(active_state.turn or "nil"),
                        tostring(ok),
                        tostring(commit_mode),
                        tostring(restored)
                    )
                else
                    bridge_debug(
                        "register_dispatcher: hard_route cleanup skipped keep_hub_override=true branch=%s conv_id=%s turn=%s ok=%s commit_mode=%s",
                        tostring(branch.index),
                        tostring(active_state.conv_id or "nil"),
                        tostring(active_state.turn or "nil"),
                        tostring(ok),
                        tostring(commit_mode)
                    )
                end
            end
        end

        state.handlers[#state.handlers + 1] = { cond_name = cond_name, act_name = act_name }
        return cond_name, act_name
    end

    if #state.branches == 0 then
        local fallback_actor_id = alloc()
        generated_ids.exit[#generated_ids.exit + 1] = fallback_actor_id

        bridge_warn(
            "build_dialog_tree fallback inserted reason=no_branches conv_id=%s turn=%s npc_open_phrase_id=%s",
            tostring(state.conv_id or "nil"),
            tostring(state.turn or "nil"),
            tostring(npc_open_phrase_id or "nil")
        )

        add_logged_exit_node(npc_open_id, fallback_actor_id, "fallback_actor_exit")
        local build_ok = (root_ok == true) and (npc_open_ok == true) and (actor_choice_count_added > 0)
        bridge_debug(
            "build_dialog_tree node_ids root=%s shim=%s open=%s choice=%s reply=%s exit=%s conv_id=%s turn=%s",
            table.concat(generated_ids.root, ","),
            table.concat(generated_ids.shim, ","),
            table.concat(generated_ids.open, ","),
            table.concat(generated_ids.choice, ","),
            table.concat(generated_ids.reply, ","),
            table.concat(generated_ids.exit, ","),
            tostring(state.conv_id or "nil"),
            tostring(state.turn or "nil")
        )
        if should_log_parity_diagnostics() then
            log_parity_diagnostics("no_branches")
        end
        bridge_debug(
            "build_dialog_tree summary build_ok=%s nodes_added=%s root_ok=%s npc_open_ok=%s actor_choice_count_added=%s npc_reply_count_added=%s conv_id=%s turn=%s",
            tostring(build_ok),
            tostring(nodes_added),
            tostring(root_ok),
            tostring(npc_open_ok),
            tostring(actor_choice_count_added),
            tostring(npc_reply_count_added),
            tostring(state.conv_id or "nil"),
            tostring(state.turn or "nil")
        )
        return {
            build_ok = build_ok,
            nodes_added = nodes_added,
            root_ok = root_ok,
            npc_open_ok = npc_open_ok,
            actor_choice_count_added = actor_choice_count_added,
            npc_reply_count_added = npc_reply_count_added,
        }
    end

    local function get_turn_state(turn)
        if type(state.turns) == "table" then
            return state.turns[turn]
        end
        if turn == state.turn then
            return state
        end
        return nil
    end

    local function build_turn(parent_open_id, turn, depth, visited_turns)
        if depth > MAX_TREE_DEPTH then
            bridge_warn(
                "build_dialog_tree max_depth_guard conv_id=%s turn=%s depth=%s",
                tostring(state.conv_id or "nil"),
                tostring(turn or "nil"),
                tostring(depth)
            )
            return
        end

        local turn_state = get_turn_state(turn)
        if type(turn_state) ~= "table" then
            bridge_warn(
                "build_dialog_tree missing_turn_state conv_id=%s turn=%s",
                tostring(state.conv_id or "nil"),
                tostring(turn or "nil")
            )
            return
        end

        local visit_key = tostring(state.conv_id or "nil") .. ":" .. tostring(turn)
        if visited_turns[visit_key] then
            bridge_warn(
                "build_dialog_tree loop_guard conv_id=%s turn=%s depth=%s",
                tostring(state.conv_id or "nil"),
                tostring(turn or "nil"),
                tostring(depth)
            )
            return
        end
        visited_turns[visit_key] = true

        for _, branch in ipairs(turn_state.branches or {}) do
            local actor_id = alloc()
            generated_ids.choice[#generated_ids.choice + 1] = actor_id
            local cond_name, act_name = register_dispatcher(branch)
            local actor_choice_added = add_logged_node(parent_open_id, actor_id, branch.choice_key, cond_name, act_name, false, "actor_choice", "actor")
            if actor_choice_added and depth == 1 then
                build_state.first_level_choices[#build_state.first_level_choices + 1] = actor_id
            end

            if branch.reply_key then
                local npc_id = alloc()
                generated_ids.reply[#generated_ids.reply + 1] = npc_id
                add_logged_node(actor_id, npc_id, branch.reply_key, nil, nil, false, "npc_reply", "npc")

                if branch.next_channel == "f2f" and branch.next_turn then
                    local next_turn_state = get_turn_state(branch.next_turn)
                    if next_turn_state then
                        local allow_next_turn_open = state.render_non_entry_openers ~= false
                        local should_insert_next_turn_open = allow_next_turn_open and (next_turn_state.missing_turn_open ~= true)
                        local continuation_parent_id = npc_id
                        local continuation_shim_inserted = false
                        local next_open_phrase_for_log = "nil"

                        if should_insert_next_turn_open then
                            local continuation_open_id = alloc()
                            generated_ids.open[#generated_ids.open + 1] = continuation_open_id
                            add_logged_node(
                                npc_id,
                                continuation_open_id,
                                next_turn_state.open_key,
                                nil,
                                nil,
                                false,
                                "npc_open",
                                "npc"
                            )
                            continuation_parent_id = continuation_open_id
                            continuation_shim_inserted = false
                            next_open_phrase_for_log = tostring(next_turn_state.open_key or "nil")
                        else
                            continuation_parent_id, continuation_shim_inserted = ensure_actor_parity(npc_id, {
                                next_speaker_role = "actor",
                            })
                            if allow_next_turn_open and next_turn_state.missing_turn_open == true then
                                bridge_warn(
                                    "build_dialog_tree continuation missing_next_turn_open conv_id=%s from_turn=%s to_turn=%s choice_key=%s action=direct_to_choices preferred=%s fallback=%s",
                                    tostring(state.conv_id or "nil"),
                                    tostring(turn or "nil"),
                                    tostring(branch.next_turn or "nil"),
                                    tostring(branch.choice_key or "nil"),
                                    tostring(next_turn_state.preferred_open_key or "nil"),
                                    tostring(next_turn_state.fallback_open_key or "nil")
                                )
                            end
                            if not allow_next_turn_open then
                                next_open_phrase_for_log = "render_disabled"
                            elseif next_turn_state.missing_turn_open == true then
                                next_open_phrase_for_log = "missing_turn_open"
                            end
                        end
                        bridge_debug(
                            "build_dialog_tree continuation conv_id=%s from_turn=%s to_turn=%s choice_key=%s direct_actor_next=%s npc_open_inserted=%s next_open_phrase=%s",
                            tostring(state.conv_id or "nil"),
                            tostring(turn or "nil"),
                            tostring(branch.next_turn or "nil"),
                            tostring(branch.choice_key or "nil"),
                            tostring(should_insert_next_turn_open ~= true),
                            tostring(continuation_shim_inserted == true),
                            tostring(next_open_phrase_for_log)
                        )
                        build_turn(continuation_parent_id, branch.next_turn, depth + 1, visited_turns)
                    else
                        bridge_warn(
                            "build_dialog_tree missing_next_turn_state conv_id=%s from_turn=%s to_turn=%s choice_key=%s action=exit_fallback",
                            tostring(state.conv_id or "nil"),
                            tostring(turn or "nil"),
                            tostring(branch.next_turn or "nil"),
                            tostring(branch.choice_key or "nil")
                        )
                        bridge_debug(
                            "build_dialog_tree continuation conv_id=%s from_turn=%s to_turn=%s choice_key=%s direct_actor_next=%s npc_open_inserted=%s next_open_phrase=%s",
                            tostring(state.conv_id or "nil"),
                            tostring(turn or "nil"),
                            tostring(branch.next_turn or "nil"),
                            tostring(branch.choice_key or "nil"),
                            "false",
                            "false",
                            "nil"
                        )
                        local exit_id = alloc()
                        generated_ids.exit[#generated_ids.exit + 1] = exit_id
                        add_logged_exit_node(npc_id, exit_id, "actor_exit")
                    end
                else
                    local exit_id = alloc()
                    generated_ids.exit[#generated_ids.exit + 1] = exit_id
                    add_logged_exit_node(npc_id, exit_id, "actor_exit")
                end
            else
                local exit_id = alloc()
                generated_ids.exit[#generated_ids.exit + 1] = exit_id
                add_logged_exit_node(actor_id, exit_id, "actor_exit")
            end
        end

        visited_turns[visit_key] = nil
    end

    build_turn(npc_open_id, state.turn, 1, {})

    local root_exit_id = alloc()
    generated_ids.exit[#generated_ids.exit + 1] = root_exit_id
    add_logged_exit_node(npc_open_id, root_exit_id, "actor_root_exit")

    local build_ok = (root_ok == true) and (npc_open_ok == true) and (actor_choice_count_added > 0)
    bridge_debug(
        "build_dialog_tree node_ids root=%s shim=%s open=%s choice=%s reply=%s exit=%s conv_id=%s turn=%s",
        table.concat(generated_ids.root, ","),
        table.concat(generated_ids.shim, ","),
        table.concat(generated_ids.open, ","),
        table.concat(generated_ids.choice, ","),
        table.concat(generated_ids.reply, ","),
        table.concat(generated_ids.exit, ","),
        tostring(state.conv_id or "nil"),
        tostring(state.turn or "nil")
    )
    if should_log_parity_diagnostics() then
        log_parity_diagnostics("final_tree")
    end
    bridge_debug(
        "build_dialog_tree summary build_ok=%s nodes_added=%s root_ok=%s npc_open_ok=%s actor_choice_count_added=%s npc_reply_count_added=%s conv_id=%s turn=%s",
        tostring(build_ok),
        tostring(nodes_added),
        tostring(root_ok),
        tostring(npc_open_ok),
        tostring(actor_choice_count_added),
        tostring(npc_reply_count_added),
        tostring(state.conv_id or "nil"),
        tostring(state.turn or "nil")
    )
    return {
        build_ok = build_ok,
        nodes_added = nodes_added,
        root_ok = root_ok,
        npc_open_ok = npc_open_ok,
        actor_choice_count_added = actor_choice_count_added,
        npc_reply_count_added = npc_reply_count_added,
    }
end

function panda_f2f_bridge.on_dialog_closed(npc_or_reason, reason, ...)
    ensure_callbacks_registered()

    local callback_context = build_callback_resolution_context(npc_or_reason, reason, ...)
    local close_reason = "dialog_closed"
    if type(reason) == "string" then
        close_reason = tostring(reason)
    elseif type(npc_or_reason) == "string" and not callback_context.npc_id then
        close_reason = tostring(npc_or_reason)
    end

    -- Some close callbacks arrive late or without stable NPC context.
    -- If another dialog is already active, let the watchdog own teardown so a
    -- stale close event cannot dismantle the new session's runtime token/tree.
    local dialog_still_active = is_actor_dialog_active()
    if close_reason ~= "actor_on_update_watchdog" and dialog_still_active then
        bridge_warn(
            "teardown deferred reason=%s detail=%s callback_npc_id=%s",
            tostring(close_reason),
            "dialog_still_active",
            tostring(callback_context.npc_id or normalize_lookup_id(npc_or_reason) or "nil")
        )
        return
    end

    local resolved_npc_id = callback_context.npc_id or normalize_lookup_id(npc_or_reason)
    local state = nil
    if resolved_npc_id then
        state = resolve_runtime_state_for_npc(resolved_npc_id)
    else
        state = resolve_unique_active_runtime_state()
    end

    if not resolved_npc_id and type(state) == "table" then
        resolved_npc_id = state.resolved_npc_id or resolve_server_npc_id(state.npc_se, "on_dialog_closed:state_fallback")
    end

    if type(state) == "table" and state.teardown_in_progress == true then
        bridge_warn(
            "teardown duplicate_skip npc_id=%s reason=%s",
            tostring(resolved_npc_id or "nil"),
            tostring(close_reason)
        )
        return
    end

    if type(state) == "table" then
        state.teardown_in_progress = true
    end

    bridge_warn(
        "teardown start npc_id=%s reason=%s state_present=%s branch_committed=%s",
        tostring(resolved_npc_id or "nil"),
        tostring(close_reason),
        tostring(type(state) == "table"),
        tostring(type(state) == "table" and state.branch_committed == true)
    )

    if type(state) == "table" and state.branch_committed ~= true and type(cleanup_noncommit_exit) == "function" then
        bridge_warn(
            "teardown cleanup_noncommit_exit npc_id=%s reason=%s",
            tostring(resolved_npc_id or "nil"),
            tostring(close_reason)
        )
        cleanup_noncommit_exit(state, close_reason)
    end

    local conv_api = get_conv_api()
    if conv_api and type(conv_api.sweep_expired_f2f_markers) == "function" then
        local ok_sweep, sweep_summary = pcall(conv_api.sweep_expired_f2f_markers, "bridge:on_dialog_closed:" .. close_reason)
        if ok_sweep and type(sweep_summary) == "table" then
            bridge_warn(
                "teardown f2f_marker_sweep reason=%s stale_pending_cleared=%s handoff_rows_removed=%s",
                tostring(close_reason),
                tostring(sweep_summary.stale_pending_cleared or 0),
                tostring(sweep_summary.handoff_rows_removed or 0)
            )
        else
            bridge_warn(
                "teardown f2f_marker_sweep reason=%s result=%s",
                tostring(close_reason),
                tostring(ok_sweep and "invalid_summary" or "call_failed")
            )
        end
    else
        bridge_warn(
            "teardown f2f_marker_sweep skipped reason=%s detail=%s",
            tostring(close_reason),
            "api_unavailable"
        )
    end

    if resolved_npc_id then
        local restored = panda_f2f_bridge.restore_branch_route(resolved_npc_id, nil)
        bridge_warn(
            "teardown restore_branch_route npc_id=%s reason=%s restored=%s",
            tostring(resolved_npc_id),
            tostring(close_reason),
            tostring(restored == true)
        )
    else
        bridge_warn(
            "teardown restore_branch_route skipped reason=%s detail=%s",
            tostring(close_reason),
            "missing_npc_id"
        )
    end

    if type(state) == "table" then
        local had_runtime_state_id = state.runtime_state_id ~= nil
        local had_active_token = state.active_token ~= nil
        unregister_active_state(state)
        cleanup_state_handlers(state)
        bridge_warn(
            "teardown unregister_state npc_id=%s reason=%s had_runtime_state_id=%s had_active_token=%s",
            tostring(resolved_npc_id or "nil"),
            tostring(close_reason),
            tostring(had_runtime_state_id),
            tostring(had_active_token)
        )
    else
        bridge_warn(
            "teardown unregister_state skipped npc_id=%s reason=%s detail=%s",
            tostring(resolved_npc_id or "nil"),
            tostring(close_reason),
            "state_missing"
        )
        if resolved_npc_id then
            local discarded = discard_runtime_state_for_npc(resolved_npc_id, nil)
            bridge_warn(
                "teardown discard_runtime_state npc_id=%s reason=%s discarded=%s",
                tostring(resolved_npc_id or "nil"),
                tostring(close_reason),
                tostring(discarded == true)
            )
        end
    end
end

function panda_f2f_bridge.precondition(...)
    ensure_callbacks_registered()
    bridge_warn("callback fired entry=hub_precondition name=%s", "panda_f2f_bridge.precondition")
    local callback_context = build_callback_resolution_context(...)

    local function reject_hub_activation(reason)
        runtime.pending_state = nil
        bridge_warn("hub activation reject reason=%s", tostring(reason or "unknown"))
        return false
    end

    local function has_renderable_authored_choice(state)
        if type(state) ~= "table" or type(state.branches) ~= "table" then
            return false
        end

        for _, branch in ipairs(state.branches) do
            if type(branch) == "table" and key_exists(branch.choice_key) then
                local precond_ok = true
                if branch.precond_key and branch.precond_key ~= "" then
                    precond_ok = evaluate_shared_precondition(branch.precond_key, state.npc_se, {
                        channel = "f2f",
                        conv_id = state.conv_id,
                        branch = branch.index,
                        faction = state.faction,
                        turn = state.turn,
                    }) == true
                end
                if precond_ok then
                    return true
                end
            end
        end

        return false
    end

    local npc_se = get_partner_npc_se(callback_context)
    local handoff = npc_se and get_pending_handoff_for_npc(npc_se) or nil
    if not handoff then
        local live_npc_se = get_partner_npc_se()
        local callback_npc_id = resolve_server_npc_id(npc_se, "precondition:callback_probe")
        local live_npc_id = resolve_server_npc_id(live_npc_se, "precondition:live_probe")
        if live_npc_se and live_npc_id and live_npc_id ~= callback_npc_id then
            bridge_debug(
                "precondition resolution retry: callback_npc_id=%s live_npc_id=%s",
                tostring(callback_npc_id or "nil"),
                tostring(live_npc_id)
            )
            npc_se = live_npc_se
            handoff = get_pending_handoff_for_npc(npc_se)
        end
    end
    if not npc_se then
        return reject_hub_activation("npc_unresolved")
    end

    local runtime_ids = resolve_partner_runtime_ids(npc_se)
    bridge_debug(
        "precondition partner ids: npc_id=%s runtime_story_id=%s runtime_fallback_name=%s runtime_character_name=%s runtime_canonical_id=%s canonical_candidates=%s",
        tostring(npc_se and npc_se.id),
        tostring(runtime_ids.story_id),
        tostring(runtime_ids.fallback_name),
        tostring(runtime_ids.character_name),
        tostring(runtime_ids.canonical_id),
        (#runtime_ids.canonical_candidates > 0 and table.concat(runtime_ids.canonical_candidates, "|") or "<none>")
    )

    bridge_debug(
        "precondition handoff check: runtime_partner_id=%s pending_handoff_npc_id=%s",
        tostring(npc_se and npc_se.id or "nil"),
        tostring(handoff and handoff.npc_id or "nil")
    )
    if not handoff then
        return reject_hub_activation("invalid_handoff_context")
    end

    local talker_id = callback_context.talker_id or resolve_current_talker_id() or resolve_server_npc_id(npc_se, "precondition:npc_fallback")
    if not talker_id then
        return reject_hub_activation("missing_talk_target")
    end
    if not handoff_matches_talker_identity(tonumber(handoff.npc_id), talker_id) then
        bridge_debug(
            "precondition reject: talk_target_mismatch talker_id=%s handoff_npc_id=%s",
            tostring(talker_id),
            tostring(handoff and handoff.npc_id or "nil")
        )
        return reject_hub_activation("talk_target_mismatch")
    end

    local state = collect_branches(npc_se, handoff)
    if not state then
        return reject_hub_activation("no_state")
    end

    if not key_exists(state.open_key) then
        return reject_hub_activation("missing_open_key")
    end

    if not has_renderable_authored_choice(state) then
        return reject_hub_activation("no_renderable_authored_choices")
    end

    state.npc_se = npc_se
    state.resolved_npc_id = resolve_server_npc_id(npc_se, "precondition:resolved")
    state.teardown_in_progress = false
    runtime.pending_state = state
    debug_resolve_snapshot("precondition", npc_se, state, handoff)
    bridge_debug(
        "precondition pass: npc_id=%s runtime_story_id=%s runtime_fallback_name=%s runtime_canonical_id=%s conv_id=%s turn=%s branches=%s",
        tostring(npc_se and npc_se.id),
        tostring(runtime_ids.story_id),
        tostring(runtime_ids.fallback_name),
        tostring(runtime_ids.canonical_id),
        tostring(state.conv_id),
        tostring(state.turn),
        tostring(#state.branches)
    )
    return true
end

function panda_f2f_bridge.init_dialog(dialog, ...)
    ensure_callbacks_registered()
    bridge_warn("callback fired entry=hub_init name=%s", "panda_f2f_bridge.init_dialog")
    local callback_context = build_callback_resolution_context(...)

    local state = runtime.pending_state
    local init_handoff = nil
    if not state then
        local npc_se = get_partner_npc_se(callback_context)
        local handoff = npc_se and get_pending_handoff_for_npc(npc_se) or nil
        if not handoff then
            local live_npc_se = get_partner_npc_se()
            local callback_npc_id = resolve_server_npc_id(npc_se, "init_dialog:callback_probe")
            local live_npc_id = resolve_server_npc_id(live_npc_se, "init_dialog:live_probe")
            if live_npc_se and live_npc_id and live_npc_id ~= callback_npc_id then
                bridge_debug(
                    "init_dialog resolution retry: callback_npc_id=%s live_npc_id=%s",
                    tostring(callback_npc_id or "nil"),
                    tostring(live_npc_id)
                )
                npc_se = live_npc_se
                handoff = get_pending_handoff_for_npc(npc_se)
            end
        end
        if not npc_se then
            return
        end
        if not handoff then
            local has_actionable_marker, marker_reason = has_actionable_handoff_marker_for_npc(npc_se)
            if has_actionable_marker then
                handoff = get_recent_handoff_match_for_npc(npc_se, RECENT_HANDOFF_GRACE_MS)
                if handoff then
                    bridge_debug(
                        "init_dialog recent_fallback_allowed npc_id=%s reason=%s",
                        tostring(npc_se and npc_se.id or "nil"),
                        tostring(marker_reason)
                    )
                end
            else
                bridge_debug(
                    "init_dialog recent_fallback_blocked npc_id=%s reason=%s",
                    tostring(npc_se and npc_se.id or "nil"),
                    tostring(marker_reason or "recent_fallback_blocked_no_actionable_marker")
                )
            end
        end
        if not handoff then
            bridge_warn(
                "init_dialog reject reason=missing_valid_handoff npc_id=%s",
                tostring(npc_se and npc_se.id or "nil")
            )
            return
        end

        local talker_id = callback_context.talker_id or resolve_current_talker_id() or resolve_server_npc_id(npc_se, "init_dialog:npc_fallback")
        if not talker_id or not handoff_matches_talker_identity(tonumber(handoff.npc_id), talker_id) then
            bridge_warn(
                "init_dialog reject reason=missing_valid_handoff npc_id=%s talker_id=%s handoff_npc_id=%s",
                tostring(npc_se and npc_se.id or "nil"),
                tostring(talker_id or "nil"),
                tostring(handoff and handoff.npc_id or "nil")
            )
            return
        end

        init_handoff = handoff
        state = collect_branches(npc_se, handoff)
        if not state then
            return
        end
        state.npc_se = npc_se
    end

    state.resolved_npc_id = state.resolved_npc_id or resolve_server_npc_id(state.npc_se, "init_dialog:resolved")
    state.teardown_in_progress = false
    runtime.pending_state = nil
    debug_resolve_snapshot("init", state.npc_se, state, init_handoff)

    local build_result = build_dialog_tree(dialog, state) or {}
    if build_result.build_ok ~= true then
        local active_npc_id = resolve_server_npc_id(state.npc_se, "init_dialog:build_failed")
        bridge_warn(
            "init_dialog build_failed npc_id=%s conv_id=%s turn=%s build_ok=%s nodes_added=%s root_ok=%s npc_open_ok=%s actor_choice_count_added=%s npc_reply_count_added=%s action=%s",
            tostring(active_npc_id or "nil"),
            tostring(state.conv_id or "nil"),
            tostring(state.turn or "nil"),
            tostring(build_result.build_ok == true),
            tostring(build_result.nodes_added or 0),
            tostring(build_result.root_ok == true),
            tostring(build_result.npc_open_ok == true),
            tostring(build_result.actor_choice_count_added or 0),
            tostring(build_result.npc_reply_count_added or 0),
            "restore_dialog_route"
        )
        if active_npc_id then
            panda_f2f_bridge.restore_branch_route(active_npc_id, nil)
        end
        unregister_active_state(state)
        return
    end
    bridge_warn(
        "init_dialog build_complete npc_id=%s conv_id=%s turn=%s open_key=%s branch_count=%s missing_turn_open=%s build_ok=%s nodes_added=%s root_ok=%s npc_open_ok=%s actor_choice_count_added=%s npc_reply_count_added=%s",
        tostring(state.npc_se and state.npc_se.id or "nil"),
        tostring(state.conv_id or "nil"),
        tostring(state.turn or "nil"),
        tostring(state.open_key or "nil"),
        tostring(state.branches and #state.branches or 0),
        tostring(state.missing_turn_open == true),
        tostring(build_result.build_ok == true),
        tostring(build_result.nodes_added or 0),
        tostring(build_result.root_ok == true),
        tostring(build_result.npc_open_ok == true),
        tostring(build_result.actor_choice_count_added or 0),
        tostring(build_result.npc_reply_count_added or 0)
    )
    debug_resolve_snapshot("build", state.npc_se, state, nil)
end

return panda_f2f_bridge
