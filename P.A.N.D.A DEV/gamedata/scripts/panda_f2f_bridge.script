--[[
    P.A.N.D.A Face-to-Face conversation bridge.
    Dynamically builds a dialogue tree from interactive-conversation string tables
    and routes branch logic through PANDA_CONV_API with channel="f2f".
--]]

panda_f2f_bridge = panda_f2f_bridge or {}

local MAX_CONV_SCAN = 256
local MAX_CHOICE_SCAN = 12
local MISSING_STOP = 20
local HUB_DIALOG_ID = "panda_f2f_hub_dialog"
local BRANCH_HARD_ROUTE_SUFFIX = "_f2f_hard_route"
local SAVE_KEY_OVERRIDE_OWNERS = "panda_f2f_bridge_override_owners"
local bridge_debug

local runtime = {
    state_by_id = {},
    latest_state = nil,
    override_owners = {},
    callbacks_registered = false,
}

local function get_conv_api()
    if PANDA_CONV_API then
        return PANDA_CONV_API
    end
    if pda_interactive_conv and pda_interactive_conv.PANDA_CONV_API then
        return pda_interactive_conv.PANDA_CONV_API
    end
    return nil
end

local function get_dialog_manager_iface()
    local dm = rawget(_G, "dialog_manager")
    if type(dm) == "table" then
        return dm
    end
    return _G
end

local function get_partner_npc_se()
    local sim = alife and alife()
    if not sim then
        bridge_debug("get_partner_npc_se: pending_conv_id=%s partner_id=%s server_entity_resolved=%s", "nil", "nil", "false")
        return nil
    end

    local pending_conv_id = nil
    local partner_id = nil

    if db and db.actor_dialog then
        local id = db.actor_dialog:id()
        local sid = tonumber(id)
        if sid and sid > 0 then
            sid = math.floor(sid)
            partner_id = sid
            local se = sim:object(sid)
            bridge_debug("get_partner_npc_se: pending_conv_id=%s partner_id=%s server_entity_resolved=%s", tostring(pending_conv_id), tostring(partner_id), tostring(se ~= nil))
            if se then
                return se
            end
            bridge_debug("get_partner_npc_se: sim:object(id) returned nil for partner_id=%s", tostring(partner_id))
        end
        if sid and sid > 0 and level and level.object_by_id then
            local obj = level.object_by_id(sid)
            if obj and obj.id then
                local obj_sid = tonumber(obj:id())
                if obj_sid and obj_sid > 0 then
                    obj_sid = math.floor(obj_sid)
                    partner_id = obj_sid
                    local se = sim:object(obj_sid)
                    bridge_debug("get_partner_npc_se: pending_conv_id=%s partner_id=%s server_entity_resolved=%s", tostring(pending_conv_id), tostring(partner_id), tostring(se ~= nil))
                    if se then
                        return se
                    end
                    bridge_debug("get_partner_npc_se: sim:object(id) returned nil for partner_id=%s", tostring(partner_id))
                end
            end
        end
    end

    if level and level.get_target_obj then
        local obj = level.get_target_obj()
        if obj and obj:id() then
            local sid = tonumber(obj:id())
            if sid and sid > 0 then
                sid = math.floor(sid)
                partner_id = sid
                local se = sim:object(sid)
                bridge_debug("get_partner_npc_se: pending_conv_id=%s partner_id=%s server_entity_resolved=%s", tostring(pending_conv_id), tostring(partner_id), tostring(se ~= nil))
                if se then
                    return se
                end
                bridge_debug("get_partner_npc_se: sim:object(id) returned nil for partner_id=%s", tostring(partner_id))
            end
        end
    end

    bridge_debug("get_partner_npc_se: pending_conv_id=%s partner_id=%s server_entity_resolved=%s", tostring(pending_conv_id), tostring(partner_id), "false")
    return nil
end

local function actor_faction_key()
    if db and db.actor and db.actor.character_community then
        local fac = db.actor:character_community()
        if fac and fac ~= "" then
            return (fac == "stalker") and "loner" or fac
        end
    end
    return "loner"
end

local function make_allocator(seed)
    local base = tonumber(seed) or 0
    base = math.abs(base) % 100000
    local next_id = base + 1000

    return function()
        local out = next_id
        next_id = next_id + 1
        return out
    end
end

local function make_seed(npc_id, conv_id, faction)
    local raw = string.format("%s|%s|%s", tostring(npc_id or 0), tostring(conv_id or 0), tostring(faction or "loner"))
    local acc = 0
    for i = 1, #raw do
        acc = (acc * 131 + raw:byte(i)) % 2147483647
    end
    return acc
end

local function tr(key)
    if not key or key == "" then
        return key
    end
    return game.translate_string(key)
end

local function parse_bool_flag(value)
    if value == nil then
        return false
    end

    local s = tostring(value):lower()
    if s == "0" or s == "false" or s == "off" or s == "no" then
        return false
    end

    return true
end

local function normalize_npc_id(npc_id)
    local out = tonumber(npc_id)
    if not out then
        return nil
    end
    return math.floor(out)
end

local function make_override_owner_tag(state, branch)
    return string.format(
        "f2f:%s:%s:%s",
        tostring(state and state.faction or "loner"),
        tostring(state and state.conv_id or 0),
        tostring(branch and branch.index or 0)
    )
end

local function save_state_cb(m)
    m[SAVE_KEY_OVERRIDE_OWNERS] = runtime.override_owners
end

local function load_state_cb(m)
    runtime.override_owners = m[SAVE_KEY_OVERRIDE_OWNERS] or {}
    for npc_id, _ in pairs(runtime.override_owners) do
        local sid = normalize_npc_id(npc_id)
        if sid and xr_meet and type(xr_meet.restore_dialog) == "function" then
            xr_meet.restore_dialog(sid)
        end
    end
    runtime.override_owners = {}
end

local function ensure_callbacks_registered()
    if runtime.callbacks_registered then
        return
    end
    if type(RegisterScriptCallback) ~= "function" then
        return
    end

    RegisterScriptCallback("save_state", save_state_cb)
    RegisterScriptCallback("load_state", load_state_cb)
    runtime.callbacks_registered = true
end

function bridge_debug(fmt, ...)
    local panda = rawget(_G, "PANDA")
    local debug_enabled = panda and type(panda.get_config) == "function" and panda.get_config("debug_logging")
    if not debug_enabled then
        return
    end

    local msg = string.format("PANDA_F2F_BRIDGE: " .. tostring(fmt), ...)
    if type(rawget(_G, "printf")) == "function" then
        _G.printf("%s", msg)
    elseif type(rawget(_G, "log1")) == "function" then
        _G.log1(msg)
    end
end

local function key_exists(key)
    local val = tr(key)
    return val ~= key
end

local function evaluate_shared_precondition(precond_key, npc_se, context)
    if not precond_key or precond_key == "" then
        return true
    end

    local api = get_conv_api()
    if not api or type(api.check_preconditions) ~= "function" then
        return true
    end

    return api.check_preconditions(precond_key, npc_se, "f2f", context or {}) == true
end

local function decode_registry_json(raw)
    if not raw or raw == "" then
        return nil
    end
    return tostring(raw):gsub("&quot;", "\"")
end

local function get_registry_raw(stem)
    local key = stem .. "_panda_f2f_registry"
    local raw = tr(key)
    if raw == key then
        return nil
    end
    return decode_registry_json(raw)
end

local function resolve_partner_runtime_ids(npc_se)
    local out = {
        story_id = nil,
        fallback_name = nil,
        canonical_id = nil,
    }

    if not npc_se then
        return out
    end

    local conv_api = get_conv_api()
    if conv_api and type(conv_api.get_npc_canonical_id) == "function" then
        out.canonical_id = conv_api.get_npc_canonical_id(npc_se)
    end

    local sid = tonumber(npc_se.id)
    if not sid and type(npc_se.id) == "function" then
        local ok_sid, sid_from_fn = pcall(function() return npc_se:id() end)
        if ok_sid then
            sid = tonumber(sid_from_fn)
        end
    end
    if sid and sid > 0 and type(get_object_story_id) == "function" then
        local ok_story, story_id = pcall(function() return get_object_story_id(math.floor(sid)) end)
        if ok_story and story_id and story_id ~= "" then
            out.story_id = tostring(story_id)
        end
    end

    if npc_se.name then
        local ok_name, fallback_name = pcall(function() return npc_se:name() end)
        if ok_name and fallback_name and fallback_name ~= "" then
            out.fallback_name = tostring(fallback_name)
        end
    end

    if not out.canonical_id then
        out.canonical_id = out.story_id or out.fallback_name
    end
    if out.canonical_id then
        out.canonical_id = tostring(out.canonical_id):lower()
    end

    return out
end

local function collect_registry_f2f_turns(registry_raw)
    local out = {}
    if not registry_raw or registry_raw == "" then
        return out
    end
    if not registry_raw:find("\"schema\"%s*:%s*\"panda_f2f_bridge_registry_v1\"") then
        return out
    end

    local entry_nodes = registry_raw:match("\"entryNodes\"%s*:%s*{(.-)}")
    if not entry_nodes then
        return out
    end

    local f2f_list = entry_nodes:match("\"f2f\"%s*:%s*%[(.-)%]")
    if not f2f_list then
        return out
    end

    for n in f2f_list:gmatch("(%d+)") do
        out[#out + 1] = tonumber(n)
    end

    return out
end

local function collect_turn_story_ids(registry_raw, turn)
    local ids = {}
    if not registry_raw or not turn then
        return ids
    end

    local turn_block = registry_raw:match("\"turnNumber\"%s*:%s*" .. tostring(turn) .. "%s*,(.-)%}%s*[,%]]")
    if not turn_block then
        return ids
    end

    for story_id in turn_block:gmatch("\"storyNpcId\"%s*:%s*\"([%w_%-]+)\"") do
        ids[#ids + 1] = story_id
    end

    return ids
end

local function select_f2f_turn(stem, npc_se)
    local registry_raw = get_registry_raw(stem)
    local entry_turns = collect_registry_f2f_turns(registry_raw)
    if #entry_turns == 0 then
        return 1
    end

    local runtime_ids = resolve_partner_runtime_ids(npc_se)
    bridge_debug(
        "select_f2f_turn stem=%s runtime_story_id=%s runtime_fallback_name=%s runtime_canonical_id=%s entry_turns=%s",
        tostring(stem),
        tostring(runtime_ids.story_id),
        tostring(runtime_ids.fallback_name),
        tostring(runtime_ids.canonical_id),
        table.concat(entry_turns, ",")
    )

    for _, turn in ipairs(entry_turns) do
        local ids = collect_turn_story_ids(registry_raw, turn)
        bridge_debug(
            "select_f2f_turn turn=%s candidate_storyNpcIds=%s runtime_canonical_id=%s",
            tostring(turn),
            (#ids > 0 and table.concat(ids, ",") or "<none>"),
            tostring(runtime_ids.canonical_id)
        )

        if #ids == 0 then
            return turn
        end

        if runtime_ids.canonical_id then
            for _, id in ipairs(ids) do
                local canonical_registry_id = tostring(id):lower()
                bridge_debug(
                    "select_f2f_turn compare runtime_canonical_id=%s xml_storyNpcId=%s match=%s",
                    tostring(runtime_ids.canonical_id),
                    tostring(canonical_registry_id),
                    tostring(canonical_registry_id == runtime_ids.canonical_id)
                )
                if canonical_registry_id == runtime_ids.canonical_id then
                    return turn
                end
            end
        end
    end

    return nil
end

local function execute_shared_outcome(branch, state)
    local api = get_conv_api()
    if not api or type(api.apply_outcome) ~= "function" then
        return false
    end

    local npc = state.npc_se
    local npc_name = npc and npc:character_name() or "Unknown"
    local npc_faction = (npc and npc.community and npc:community()) or state.faction
    local npc_id = npc and npc.id or nil
    local contact_id = npc_id and tostring(npc_id) or nil

    local conv_data = {
        channel = "f2f",
        faction = state.faction,
        conv_id = state.conv_id,
        prefix = state.prefix,
        turn = state.turn or 1,
    }

    return api.apply_outcome(
        branch.outcome or "none",
        npc_name,
        npc_faction,
        npc_id,
        nil,
        contact_id,
        conv_data,
        "f2f"
    ) == true
end

local function get_pending_handoff_for_npc(npc_se)
    local partner_id = npc_se and tonumber(npc_se.id) or nil
    if not partner_id or partner_id <= 0 then
        bridge_debug("get_pending_handoff_for_npc: pending_conv_id=%s partner_id=%s server_entity_resolved=%s", "nil", tostring(partner_id), tostring(npc_se ~= nil))
        return nil
    end
    partner_id = math.floor(partner_id)

    local api = get_conv_api()
    if not api or type(api.get_pending_f2f_handoff) ~= "function" then
        return nil
    end

    local handoff = api.get_pending_f2f_handoff(partner_id)
    if type(handoff) ~= "table" then
        bridge_debug("get_pending_handoff_for_npc: pending_conv_id=%s partner_id=%s server_entity_resolved=%s", "nil", tostring(partner_id), "true")
        return nil
    end

    local conv_id = tonumber(handoff.conv_id)
    local turn = tonumber(handoff.turn)
    if not conv_id or not turn then
        bridge_debug("get_pending_handoff_for_npc: pending_conv_id=%s partner_id=%s server_entity_resolved=%s", tostring(handoff and handoff.conv_id), tostring(partner_id), "true")
        return nil
    end
    conv_id = math.floor(conv_id)
    turn = math.floor(turn)
    if conv_id <= 0 or turn <= 0 then
        bridge_debug("get_pending_handoff_for_npc: pending_conv_id=%s partner_id=%s server_entity_resolved=%s", tostring(conv_id), tostring(partner_id), "true")
        return nil
    end

    bridge_debug("get_pending_handoff_for_npc: pending_conv_id=%s partner_id=%s server_entity_resolved=%s", tostring(conv_id), tostring(partner_id), "true")

    return {
        conv_id = conv_id,
        turn = turn,
        channel = "f2f",
        source = handoff,
    }
end

local function consume_pending_handoff_for_npc(npc_se)
    if not npc_se or not npc_se.id then
        return false
    end

    local api = get_conv_api()
    if not api or type(api.consume_pending_f2f_handoff) ~= "function" then
        return false
    end

    return api.consume_pending_f2f_handoff(npc_se.id) == true
end

function panda_f2f_bridge.hard_route_branch(npc_id, owner_tag)
    ensure_callbacks_registered()

    local sid = normalize_npc_id(npc_id)
    if not sid then
        return false
    end
    if not xr_meet or type(xr_meet.override_dialog) ~= "function" then
        return false
    end

    xr_meet.override_dialog(sid, HUB_DIALOG_ID)
    runtime.override_owners[tostring(sid)] = {
        owner = owner_tag or "f2f",
        dialog = HUB_DIALOG_ID,
        started_at = time_global and time_global() or 0,
    }

    return true
end

function panda_f2f_bridge.restore_branch_route(npc_id, owner_tag)
    ensure_callbacks_registered()

    local sid = normalize_npc_id(npc_id)
    if not sid then
        return false
    end

    local key = tostring(sid)
    local rec = runtime.override_owners[key]
    if rec and owner_tag and rec.owner ~= owner_tag then
        return false
    end

    if xr_meet and type(xr_meet.restore_dialog) == "function" then
        xr_meet.restore_dialog(sid)
    end
    runtime.override_owners[key] = nil
    return true
end

function panda_f2f_bridge.on_branch_completed(npc_id, owner_tag)
    return panda_f2f_bridge.restore_branch_route(npc_id, owner_tag)
end

function panda_f2f_bridge.on_branch_failed(npc_id, owner_tag)
    return panda_f2f_bridge.restore_branch_route(npc_id, owner_tag)
end

function panda_f2f_bridge.on_branch_timeout(npc_id, owner_tag)
    return panda_f2f_bridge.restore_branch_route(npc_id, owner_tag)
end

local function collect_branches(npc_se, forced_context)
    local faction = actor_faction_key()
    local found = nil
    local missing = 0
    local forced_conv_id = forced_context and tonumber(forced_context.conv_id) or nil
    local forced_turn = forced_context and tonumber(forced_context.turn) or nil

    for cid = 1, MAX_CONV_SCAN do
        if not forced_conv_id or cid == forced_conv_id then
            local stem = string.format("st_pda_ic_%s_%d", faction, cid)
            local open_key = stem .. "_open"
            if not key_exists(open_key) then
                missing = missing + 1
                if forced_conv_id then
                    break
                end
                if missing >= MISSING_STOP then
                    break
                end
            else
                missing = 0
                local precond_key = stem .. "_precond"
                local conv_ok = true
                if key_exists(precond_key) then
                    conv_ok = evaluate_shared_precondition(precond_key, npc_se, {
                        channel = "f2f",
                        conv_id = cid,
                        faction = faction,
                    })
                end

                if conv_ok then
                    found = {
                        faction = faction,
                        conv_id = cid,
                        prefix = nil,
                        open_key = open_key,
                        precond_key = key_exists(precond_key) and precond_key or nil,
                        branches = {},
                        handoff = forced_context and forced_context.source or nil,
                    }

                    local f2f_turn = forced_turn or select_f2f_turn(stem, npc_se)
                    if not f2f_turn then
                        found = nil
                    else
                        found.turn = f2f_turn

                        local turn_stem = stem
                        if f2f_turn > 1 then
                            turn_stem = stem .. "_t" .. tostring(f2f_turn)
                        end

                        local missing_choices = 0
                        for idx = 1, MAX_CHOICE_SCAN do
                            local choice_key = turn_stem .. "_choice_" .. idx
                            if not key_exists(choice_key) then
                                missing_choices = missing_choices + 1
                                if missing_choices >= 3 then
                                    break
                                end
                            else
                                missing_choices = 0
                                local reply_key = turn_stem .. "_reply_" .. idx
                                local outcome_key = turn_stem .. "_outcome_" .. idx
                                local choice_precond_key = turn_stem .. "_choice_" .. idx .. "_precond"
                                local hard_route_key = turn_stem .. "_choice_" .. idx .. BRANCH_HARD_ROUTE_SUFFIX

                                local show = true
                                if key_exists(choice_precond_key) then
                                    show = evaluate_shared_precondition(choice_precond_key, npc_se, {
                                        channel = "f2f",
                                        conv_id = cid,
                                        branch = idx,
                                        faction = faction,
                                        turn = f2f_turn,
                                    })
                                end

                                if show then
                                    local hard_route = false
                                    if key_exists(hard_route_key) then
                                        hard_route = parse_bool_flag(tr(hard_route_key))
                                    end

                                    table.insert(found.branches, {
                                        index = idx,
                                        choice_key = choice_key,
                                        reply_key = key_exists(reply_key) and reply_key or nil,
                                        outcome = key_exists(outcome_key) and tr(outcome_key) or "none",
                                        precond_key = key_exists(choice_precond_key) and choice_precond_key or nil,
                                        hard_route = hard_route,
                                    })
                                end
                            end
                        end

                        break
                    end
                end
            end
        end
    end

    return found
end

local function dm_add_dialog(state, parent_id, id, phrase_id, cond, act, use_script_text)
    local dm = get_dialog_manager_iface()

    if type(dm.add_script_dialog) == "function" and use_script_text then
        return dm.add_script_dialog(parent_id, id, phrase_id, cond, act)
    end

    if type(dm.add_dialog) == "function" then
        return dm.add_dialog(parent_id, id, phrase_id, cond, act)
    end

    local phrase = state.dialog:AddPhrase(phrase_id, tostring(id), tostring(parent_id), -10000)
    if not phrase then
        return nil
    end

    local script = phrase:GetPhraseScript()
    if cond then script:AddPrecondition(cond) end
    if act then script:AddAction(act) end
    if use_script_text and script and script.SetScriptText then
        script:SetScriptText(phrase_id)
    end

    return script
end

local function build_dialog_tree(dialog, state)
    local alloc = make_allocator(make_seed(state.npc_se and state.npc_se.id or 0, state.conv_id, state.faction))
    local token = tostring(time_global and time_global() or math.random(10000, 99999))
    local exit_phrase = "dm_universal_actor_exit"

    state.dialog = dialog
    state.alloc = alloc
    state.handlers = {}

    local root_id = alloc()
    dm_add_dialog(state, "", root_id, state.open_key, nil, nil, true)

    local function register_dispatcher(branch)
        local idx = branch.index
        local cond_name = string.format("panda_f2f_bridge_choice_precond_%s_%d", token, idx)
        local act_name = string.format("panda_f2f_bridge_choice_action_%s_%d", token, idx)

        _G[cond_name] = function()
            if not runtime.latest_state then return false end
            if branch.precond_key and branch.precond_key ~= "" then
                return evaluate_shared_precondition(branch.precond_key, runtime.latest_state.npc_se, {
                    channel = "f2f",
                    conv_id = runtime.latest_state.conv_id,
                    branch = branch.index,
                    faction = runtime.latest_state.faction,
                    turn = runtime.latest_state.turn or 1,
                })
            end
            return true
        end

        _G[act_name] = function()
            local active_state = runtime.latest_state
            if not active_state then return end

            -- Re-evaluate preconditions at dispatch time for deterministic safety.
            if branch.precond_key and branch.precond_key ~= "" then
                local ok = evaluate_shared_precondition(branch.precond_key, active_state.npc_se, {
                    channel = "f2f",
                    conv_id = active_state.conv_id,
                    branch = branch.index,
                    faction = active_state.faction,
                    turn = active_state.turn or 1,
                })
                if not ok then return end
            end

            local owner_tag = nil
            local routed = false
            if branch.hard_route then
                owner_tag = make_override_owner_tag(active_state, branch)
                routed = panda_f2f_bridge.hard_route_branch(active_state.npc_se and active_state.npc_se.id or nil, owner_tag)
            end

            local ok = execute_shared_outcome(branch, active_state)
            if ok then
                consume_pending_handoff_for_npc(active_state.npc_se)
            end
            if branch.hard_route and routed and not ok then
                panda_f2f_bridge.restore_branch_route(active_state.npc_se and active_state.npc_se.id or nil, owner_tag)
            end
        end

        state.handlers[#state.handlers + 1] = { cond_name = cond_name, act_name = act_name }
        return cond_name, act_name
    end

    if #state.branches == 0 then
        local fallback_actor_id = alloc()
        local fallback_npc_id = alloc()
        local fallback_exit_id = alloc()

        dm_add_dialog(state, root_id, fallback_actor_id, "dm_universal_actor_exit", nil, nil, false)
        dm_add_dialog(state, fallback_actor_id, fallback_npc_id, state.open_key, nil, nil, true)
        dm_add_dialog(state, fallback_npc_id, fallback_exit_id, exit_phrase, nil, nil, false)
        return
    end

    for _, branch in ipairs(state.branches) do
        local actor_id = alloc()
        local npc_id = alloc()
        local exit_id = alloc()
        local cond_name, act_name = register_dispatcher(branch)

        dm_add_dialog(state, root_id, actor_id, branch.choice_key, cond_name, act_name, false)

        if branch.reply_key then
            dm_add_dialog(state, actor_id, npc_id, branch.reply_key, nil, nil, true)
            dm_add_dialog(state, npc_id, exit_id, exit_phrase, nil, nil, false)
        else
            dm_add_dialog(state, actor_id, exit_id, exit_phrase, nil, nil, false)
        end
    end

    local root_exit_id = alloc()
    dm_add_dialog(state, root_id, root_exit_id, exit_phrase, nil, nil, false)
end

function panda_f2f_bridge.precondition()
    ensure_callbacks_registered()

    local npc_se = get_partner_npc_se()
    if not npc_se then
        bridge_debug("precondition fail: no partner npc")
        return false
    end

    local handoff = get_pending_handoff_for_npc(npc_se)
    local state = collect_branches(npc_se, handoff)
    if not state and handoff then
        state = collect_branches(npc_se, nil)
    end
    if not state then
        local runtime_ids = resolve_partner_runtime_ids(npc_se)
        bridge_debug(
            "precondition fail: no matching state for npc_id=%s runtime_story_id=%s runtime_fallback_name=%s runtime_canonical_id=%s",
            tostring(npc_se and npc_se.id),
            tostring(runtime_ids.story_id),
            tostring(runtime_ids.fallback_name),
            tostring(runtime_ids.canonical_id)
        )
        return false
    end

    state.npc_se = npc_se
    runtime.latest_state = state
    local runtime_ids = resolve_partner_runtime_ids(npc_se)
    bridge_debug(
        "precondition pass: npc_id=%s runtime_story_id=%s runtime_fallback_name=%s runtime_canonical_id=%s conv_id=%s turn=%s branches=%s",
        tostring(npc_se and npc_se.id),
        tostring(runtime_ids.story_id),
        tostring(runtime_ids.fallback_name),
        tostring(runtime_ids.canonical_id),
        tostring(state.conv_id),
        tostring(state.turn),
        tostring(#state.branches)
    )
    return true
end

function panda_f2f_bridge.init_dialog(dialog)
    ensure_callbacks_registered()

    local state = runtime.latest_state
    if not state then
        local npc_se = get_partner_npc_se()
        if not npc_se then
            return
        end
        local handoff = get_pending_handoff_for_npc(npc_se)
        state = collect_branches(npc_se, handoff)
        if not state and handoff then
            state = collect_branches(npc_se, nil)
        end
        if not state then
            return
        end
        state.npc_se = npc_se
    end

    local id = tostring(state.npc_se and state.npc_se.id or "unknown") .. ":" .. tostring(state.conv_id or 0)
    runtime.state_by_id[id] = state
    runtime.latest_state = state

    build_dialog_tree(dialog, state)

    if state.handoff then
        consume_pending_handoff_for_npc(state.npc_se)
    end
end

return panda_f2f_bridge
