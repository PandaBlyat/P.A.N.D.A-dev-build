-- ============================================================
-- pda_typing_personality.script
-- Dynamic NPC Typing Personality System for P.A.N.D.A.
-- Transforms NPC message text based on faction + rank to
-- simulate realistic typing habits (typos, slang, swearing,
-- punctuation quirks, etc.) — all at runtime, no XML changes.
-- ============================================================

-- NPC metadata cache (faction + rank), keyed by contact_id string.
-- Populated by pda_interactive_conv.start_interactive_conv().
local npc_meta = {}

function register_npc(contact_id, faction, rank_name)
    if contact_id then
        npc_meta[tostring(contact_id)] = {
            faction = faction,
            rank = rank_name or "experienced",
        }
    end
end

function get_npc_meta(contact_id)
    return npc_meta[tostring(contact_id)]
end

-- ============================================================
-- DETERMINISTIC PRNG (djb2 hash-seeded)
-- Ensures same message + NPC always produces same typos.
-- ============================================================

local _seed = 0

local function hash_seed(text, contact_id)
    local h = 5381
    local s = tostring(contact_id or "") .. "|" .. tostring(text or "")
    for i = 1, #s do
        h = ((h * 33) + string.byte(s, i)) % 2147483647
    end
    return h
end

local function seeded_random(max)
    if max <= 0 then return 1 end
    _seed = (_seed * 1103515245 + 12345) % 2147483648
    return (_seed % max) + 1
end

local function seeded_chance(pct)
    if pct <= 0 then return false end
    if pct >= 100 then return true end
    return seeded_random(100) <= pct
end

