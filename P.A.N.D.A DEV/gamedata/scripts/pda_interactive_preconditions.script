pda_interactive_preconditions = pda_interactive_preconditions or {}
local M = pda_interactive_preconditions

local PRECONDITION_MACROS = {
    danger_context = "any(req_time_night|req_weather_fx_active|req_surge_soon:900|req_psi_storm_soon:900)",
}

local handlers = {}

local function str_explode(str, sep)
    local t = {}
    for s in string.gmatch(str or "", "([^" .. sep .. "]+)") do table.insert(t, s) end
    return t
end

local function item_condition_percent(item)
    if not item or type(item.condition) ~= "function" then return nil end
    local ok, cond = pcall(function() return item:condition() end)
    if not ok or cond == nil then return nil end
    return (tonumber(cond) or 0) * 100
end

local function get_equipped_weapon_for_condition(act)
    if not act then return nil end

    local active = act.active_item and act:active_item() or nil
    if active and IsWeapon(active) then return active end

    local slot1 = act:item_in_slot(1)
    if slot1 and IsWeapon(slot1) then return slot1 end

    local slot2 = act:item_in_slot(2)
    if slot2 and IsWeapon(slot2) then return slot2 end

    return nil
end

local function check_item_condition_min(item, required, missing_reason)
    local cond = item_condition_percent(item)
    if cond == nil then return false, missing_reason or "item condition unavailable" end
    if cond < required then return false, "condition below minimum" end
end

local function check_item_condition_max(item, required, missing_reason)
    local cond = item_condition_percent(item)
    if cond == nil then return false, missing_reason or "item condition unavailable" end
    if cond > required then return false, "condition above maximum" end
end

local function precond_trace(ctx, fmt, ...)
    local PANDA = ctx and ctx.PANDA or _G.PANDA
    if PANDA and (PANDA.get_config("debug_logging") or PANDA.get_config("precond_verbose_debug")) then
        _G.printf("PANDA_IC[precond]: " .. fmt, ...)
    end
end

local function split_top_level(str, delimiter)
    local result = {}
    local start_idx = 1
    local depth = 0
    for i = 1, #str do
        local ch = string.sub(str, i, i)
        if ch == "(" then depth = depth + 1
        elseif ch == ")" then depth = math.max(depth - 1, 0)
        elseif ch == delimiter and depth == 0 then
            local chunk = string.sub(str, start_idx, i - 1):match("^%s*(.-)%s*$")
            if chunk ~= "" then table.insert(result, chunk) end
            start_idx = i + 1
        end
    end
    local tail = string.sub(str, start_idx):match("^%s*(.-)%s*$")
    if tail ~= "" then table.insert(result, tail) end
    return result
end

local function unwrap_wrapper(token, prefix)
    local full_prefix = prefix .. "("
    if string.sub(token, 1, #full_prefix) ~= full_prefix then return nil end
    if string.sub(token, -1) ~= ")" then return nil end
    return string.sub(token, #full_prefix + 1, -2)
end

local function make_env(ctx, parts, entry, npc_se, act, get_goodwill_actor_id)
    local env = { parts = parts, entry = entry, npc_se = npc_se, act = act, get_goodwill_actor_id = get_goodwill_actor_id, str_explode = ctx.str_explode or str_explode }
    return setmetatable(env, {
        __index = function(_, key)
            local value = ctx and ctx[key]
            if value ~= nil then return value end
            return _G[key]
        end,
        __newindex = function(t, key, value) rawset(t, key, value) end
    })
end

handlers["req_money"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
    if act:money() < (tonumber(parts[2]) or 0) then return false, "insufficient money" end
end

