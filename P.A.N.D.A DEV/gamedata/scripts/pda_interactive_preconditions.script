handlers["req_hunger"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
    local satiety = 1
    if actor_status and actor_status.get_satienty then
        satiety = actor_status.get_satienty()
    end
    if satiety < 2 then return false, "player not hungry" end
end

handlers["req_not_hungry"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
    local satiety = 1
    if actor_status and actor_status.get_satienty then
        satiety = actor_status.get_satienty()
    end
    if satiety >= 2 then return false, "player hungry" end
end

handlers["req_bleeding"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
    if act.bleeding <= 0 then return false, "player not bleeding" end
end

handlers["req_overweight"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
    local max_weight = (db.actor.get_actor_max_weight and db.actor:get_actor_max_weight()) or 60
    local cur_weight = (db.actor.get_total_weight and db.actor:get_total_weight()) or 0
    if cur_weight <= max_weight then return false, "player not overweight" end

        -- ========== HAS ITEM TYPE ==========
end

handlers["req_has_item_type"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
    local item_type = parts[2]
    if not item_type then return false, "missing item type" end
    local TYPE_CHECKERS = {
        weapon = IsWeapon, outfit = IsOutfit, artefact = IsArtefact,
        headgear = IsHeadgear, pistol = IsPistol, rifle = IsRifle,
        shotgun = IsShotgun, sniper = IsSniper, melee = IsMelee,
        explosive = IsExplosive,
    }
    local checker = TYPE_CHECKERS[item_type:lower()]
    if not checker then return false, "unknown item type: " .. tostring(item_type) end
    local found = false
    act:iterate_inventory(function(owner, item)
        if not found and checker(item) then found = true end
    end, act)
    if not found then return false, "no item of type " .. item_type end

        -- ========== ARTEFACTS / FACTION KILLS ==========
end

handlers["req_artefacts_found"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
    local found = 0
    if act_statistic and act_statistic.get_stat then
        found = act_statistic.get_stat("artefacts_found") or 0
    elseif game_stats and game_stats.get_actor_stat then
        found = game_stats.get_actor_stat("artefacts_found") or 0
    end
    if found < (tonumber(parts[2]) or 0) then return false, "artefacts found below minimum" end
end

handlers["req_faction_kills"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
    local required_count = tonumber(parts[2]) or 0
    local target_faction = normalize_faction(parts[3] or "bandit")
    local kills = 0
    if act_statistic and act_statistic.get_stat then
        kills = act_statistic.get_stat("killed_" .. target_faction) or 0
    elseif game_stats and game_stats.get_actor_stat then
        kills = game_stats.get_actor_stat("killed_" .. target_faction) or 0
    end
    if kills < required_count then return false, "faction kills below minimum" end
end

handlers["req_enemy_kills"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
    local required_count = tonumber(parts[2]) or 0
    local kills = 0
    if act_statistic and act_statistic.get_stat then
        kills = act_statistic.get_stat("killed_stalkers_e") or act_statistic.get_stat("killed_stalkers") or 0
    elseif game_stats and game_stats.get_actor_stat then
        kills = game_stats.get_actor_stat("killed_stalkers_e") or game_stats.get_actor_stat("killed_stalkers") or 0
    end
    if kills < required_count then return false, "enemy kills below minimum" end

        -- ========== NOT HAS ITEM / ITEM COUNT ==========
end

handlers["req_not_has_item"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
    local item_sec = parts[2]
    if not item_sec then return false, "missing item section" end
    local found = false
    act:iterate_inventory(function(owner, item)
        if item:section() == item_sec then found = true end
    end, act)
    if found then return false, "item present (should not be)" end
end

handlers["req_has_item_count"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
    local item_sec = parts[2]
    local required = tonumber(parts[3]) or 1
    if not item_sec then return false, "missing item section" end
    local count = 0
    act:iterate_inventory(function(owner, item)
        if item:section() == item_sec then count = count + 1 end
    end, act)
    if count < required then return false, "item count below minimum" end

