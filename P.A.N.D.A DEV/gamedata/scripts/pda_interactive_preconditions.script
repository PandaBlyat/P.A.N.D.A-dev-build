local function evaluate_precondition_entry(ctx, entry, npc_se, act, get_goodwill_actor_id)
    local parts = (ctx.str_explode or str_explode)(entry, ":")
    local cmd = parts[1]
    local handler = handlers[cmd]
    if not handler then return nil, "unknown command" end
    local env = make_env(ctx, parts, entry, npc_se, act, get_goodwill_actor_id)
    setfenv(handler, env)
    local passed, reason = handler(parts, entry, npc_se, act, get_goodwill_actor_id)
    if passed ~= nil then return passed, reason end
    return true, "ok"
end

function M.check(precond_key, npc_se, ctx)
    ctx = ctx or {}
    local val = game.translate_string(precond_key)
    if val == precond_key then return true end
    local act = db.actor
    if not act then return false end
    local PANDA = ctx.PANDA or _G.PANDA
    local unknown_policy = tostring(PANDA.get_config("precond_unknown_policy") or "strict")
    local goodwill_actor_id = nil
    local function get_goodwill_actor_id(context)
        if goodwill_actor_id ~= nil then return goodwill_actor_id end
        goodwill_actor_id = ctx.resolve_actor_id_for_goodwill(context)
        return goodwill_actor_id
    end
    local function eval_expr(expr, depth, macro_stack)
        depth = depth or 0
        macro_stack = macro_stack or {}
        local token = (expr or ""):match("^%s*(.-)%s*$")
        if token == "" then precond_trace(ctx, "%sEmpty expression -> pass", string.rep("  ", depth)); return true end
        local indent = string.rep("  ", depth)
        local macro_name = token:match("^macro:(.+)$")
        if macro_name then
            macro_name = macro_name:match("^%s*(.-)%s*$")
            local macro_expr = PRECONDITION_MACROS[macro_name]
            if not macro_expr then
                precond_trace(ctx, "%sMacro '%s' not found", indent, tostring(macro_name))
                if unknown_policy == "warn-and-skip" then return true end
                return false
            end
            if macro_stack[macro_name] then precond_trace(ctx, "%sMacro recursion detected for '%s'", indent, tostring(macro_name)); return false end
            precond_trace(ctx, "%sMacro '%s' -> %s", indent, tostring(macro_name), tostring(macro_expr))
            macro_stack[macro_name] = true
            local passed = eval_expr(macro_expr, depth + 1, macro_stack)
            macro_stack[macro_name] = nil
            precond_trace(ctx, "%sMacro '%s' result=%s", indent, tostring(macro_name), tostring(passed))
            return passed
        end
        local any_inner = unwrap_wrapper(token, "any")
        if any_inner then
            local options = split_top_level(any_inner, "|")
            precond_trace(ctx, "%sOR block start (%d options): %s", indent, #options, token)
            for idx, option in ipairs(options) do
                local passed = eval_expr(option, depth + 1, macro_stack)
                precond_trace(ctx, "%sOR option %d -> %s", indent, idx, tostring(passed))
                if passed then precond_trace(ctx, "%sOR block PASS via option %d", indent, idx); return true end
            end
            precond_trace(ctx, "%sOR block FAIL", indent); return false
        end
        local not_inner = unwrap_wrapper(token, "not")
        if not_inner then
            local inner_passed = eval_expr(not_inner, depth + 1, macro_stack)
            precond_trace(ctx, "%sNOT block inner=%s final=%s", indent, tostring(inner_passed), tostring(not inner_passed))
            return not inner_passed
        end
        local and_terms = split_top_level(token, ",")
        if #and_terms > 1 then
            precond_trace(ctx, "%sAND block start (%d terms): %s", indent, #and_terms, token)
            for idx, term in ipairs(and_terms) do
                local passed = eval_expr(term, depth + 1, macro_stack)
                precond_trace(ctx, "%sAND term %d -> %s", indent, idx, tostring(passed))
                if not passed then precond_trace(ctx, "%sAND block FAIL at term %d", indent, idx); return false end
            end
            precond_trace(ctx, "%sAND block PASS", indent); return true
        end
        local passed, reason = evaluate_precondition_entry(ctx, token, npc_se, act, get_goodwill_actor_id)
        if passed == nil then
            precond_trace(ctx, "%sUnknown precondition token '%s' (policy=%s)", indent, token, unknown_policy)
            if unknown_policy == "warn-and-skip" then return true end
            return false
        end
        precond_trace(ctx, "%sLeaf '%s' -> %s (%s)", indent, token, tostring(passed), tostring(reason))
        return passed
    end
    return eval_expr(val, 0, {})
end

return M
