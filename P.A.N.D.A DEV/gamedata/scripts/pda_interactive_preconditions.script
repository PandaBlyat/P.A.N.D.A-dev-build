handlers["req_story_npc"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
    local required_sid = parts[2]
    if not required_sid then return false, "missing story id" end
    if not npc_se then return false, "npc missing" end

    local canonical_required = tostring(required_sid):lower()
    local runtime_candidates = {}
    local seen_candidates = {}
    local function push_candidate(value)
        if value == nil then
            return
        end
        local normalized = tostring(value):lower()
        if normalized == "" or seen_candidates[normalized] then
            return
        end
        seen_candidates[normalized] = true
        runtime_candidates[#runtime_candidates + 1] = normalized
    end

    if PANDA_CONV_API and type(PANDA_CONV_API.get_npc_canonical_id) == "function" then
        push_candidate(PANDA_CONV_API.get_npc_canonical_id(npc_se))
    end

    local sid = tonumber(npc_se.id)
    if not sid and type(npc_se.id) == "function" then
        local ok_sid, sid_from_fn = pcall(function() return npc_se:id() end)
        if ok_sid then
            sid = tonumber(sid_from_fn)
        end
    end
    if sid and sid > 0 and type(get_object_story_id) == "function" then
        local ok_story, raw_story_id = pcall(function() return get_object_story_id(math.floor(sid)) end)
        if ok_story then
            push_candidate(raw_story_id)
        end
    end

    if npc_se.name then
        local ok_name, runtime_name = pcall(function() return npc_se:name() end)
        if ok_name then
            push_candidate(runtime_name)
        end
    end
    if npc_se.character_name then
        local ok_char_name, character_name = pcall(function() return npc_se:character_name() end)
        if ok_char_name then
            push_candidate(character_name)
        end
    end

    local matched = false
    for _, candidate in ipairs(runtime_candidates) do
        if candidate == canonical_required then
            matched = true
            break
        end
    end

    if not matched then
        local checked = (#runtime_candidates > 0 and table.concat(runtime_candidates, "|") or "<none>")
        if #checked > 128 then
            checked = checked:sub(1, 128) .. "..."
        end
        return false, "story npc mismatch (need " .. required_sid .. "; checked " .. checked .. ")"
    end
end

handlers["req_custom_story_npc"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
    local tpl_id = parts[2]
    local smart_ref = parts[3]
    if not tpl_id or tpl_id == "" then return false, "missing template_id" end
    if not npc_se then return false, "npc missing" end
    if not panda_npc_creator or type(panda_npc_creator.get_active_npc_se) ~= "function" then
        return false, "custom npc creator unavailable"
    end

    local target_se = panda_npc_creator.get_active_npc_se(tpl_id)
    if not target_se
        and smart_ref and smart_ref ~= ""
        and type(panda_npc_creator.ensure_story_target_spawned) == "function"
    then
        local ok_spawn, spawned_se = pcall(panda_npc_creator.ensure_story_target_spawned, tpl_id, smart_ref)
        if ok_spawn then
            target_se = spawned_se
        end
    end
    if not target_se then
        return false, "custom story npc '" .. tpl_id .. "' not available"
    end

    local function resolve_server_id(se_obj)
        if not se_obj then
            return nil
        end

        local sid = tonumber(se_obj.id)
        if not sid and type(se_obj.id) == "function" then
            local ok_sid, sid_from_fn = pcall(function() return se_obj:id() end)
            if ok_sid then
                sid = tonumber(sid_from_fn)
            end
        end
        return sid
    end

    local required_id = resolve_server_id(target_se)
    local current_id = resolve_server_id(npc_se)
    if not required_id or not current_id or required_id ~= current_id then
        return false, "custom story npc mismatch (" .. tostring(tpl_id) .. ")"
    end

        -- ========== CUSTOM NPC TEMPLATE PRECONDITIONS ==========
end

handlers["req_custom_npc_alive"] = function(parts, entry, npc_se, act, get_goodwill_actor_id)
