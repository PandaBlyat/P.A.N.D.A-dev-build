        "lim_2c_01_ls_anomal_zone",
        "lim_2c_02_ib_anomal_zone",
    },
    jup = {
        "jup_b10_anomal_zone",
        "jup_b25_anomal_zone",
        "jup_b32_anomal_zone",
    },
    zat = {
        "zat_b14_anomal_zone",
        "zat_b39_anomal_zone",
        "zat_b55_anomal_zone",
    },
    pri = {
        "pri_2c_01_pp_anomal_zone",
        "pri_b301_anomal_zone",
        "pri_b307_anomal_zone",
    },
}

function M.resolve_artifact_zone_target(zone_name)
    local zone_raw = tostring(zone_name or "")
    if zone_raw == "" then
        return nil, "empty"
    end

    local token_level = zone_raw:match("^level:([%w_%-]+)$")
    if not token_level then
        return zone_raw, nil
    end

    local pool = ARTIFACT_ZONE_LEVEL_POOLS[token_level]
    local anomaly_by_name = db and db.anomaly_by_name or nil
    local eligible = {}

    if anomaly_by_name then
        local level_prefix = token_level .. "_"
        for anomaly_name, anomaly_obj in pairs(anomaly_by_name) do
            if anomaly_obj and string.find(anomaly_name, "^" .. level_prefix) and string.find(anomaly_name, "anomal_zone") then
                table.insert(eligible, anomaly_name)
            end
        end
    end

    if #eligible == 0 and pool and #pool > 0 then
        for _, zone_id in ipairs(pool) do
            if anomaly_by_name and anomaly_by_name[zone_id] then
                table.insert(eligible, zone_id)
            end
        end
    end

    if #eligible == 0 then
        return nil, string.format("no online anomaly zones for level token '%s'", token_level)
    end

    return eligible[math.random(1, #eligible)], nil
end
