                    "freedom"
                  ]
                },
                {
                  "command": "reward_money",
                  "params": [
                    "6000"
                  ]
                },
                {
                  "command": "give_info",
                  "params": [
                    "panda_desert_to_mercs_act1_complete"
                  ],
                  "_note": "Custom info portion for later Merc branch gating."
                }
              ],
              "terminal": true,
              "allow_generic_stalker": false,
              "cont_npc_id": "cit_killers_merc_barman_mlr"
            },
            {
              "index": 2,
              "text": "I only wanted safe passage.",
              "channel": "f2f",
              "preconditions": [],
              "reply": "Safe passage is a contract with fewer words.",
              "outcomes": [
                {
                  "command": "reward_gw",
