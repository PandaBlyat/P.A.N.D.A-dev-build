          },
          "customLabel": "Desert To Mercs Act 1 Complete",
          "openingMessage": "Aslan accepts the route intel without smiling. Mercs do not forgive your betrayal; they invoice it, then put you on contract.",
          "speaker_allow_generic_stalker": false,
          "requiresNpcFirst": true
        },
        {
          "turnNumber": 44,
