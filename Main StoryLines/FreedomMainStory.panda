    {
      "id": 1,
      "label": "Freedom Act 1 - Supply Lines",
      "turns": [
        {
          "channel": "pda",
          "choices": [
            {
              "text": "I'm omw. give me a few minutes\n\n\n",
              "index": 1,
              "reply": ":thumbsup:\n",
              "channel": "pda",
              "outcomes": [
                {
                  "params": [
                    "%cordon_panda_st_key%",
                    "85"
                  ],
                  "command": "watch_location"
                },
                {
                  "params": [
                    "25",
                    "freedom"
                  ],
                  "command": "reward_gw"
                }
              ],
              "terminal": false,
              "continueTo": 2,
              "preconditions": [],
              "continueChannel": "f2f",
              "continue_channel": "f2f",
              "allow_generic_stalker": false
            },
            {
              "text": "Can I have the details sent over? I'll get on it. \n\n",
              "index": 2,
              "reply": "NO HQ ASAP.\n\n",
              "channel": "pda",
              "outcomes": [],
              "terminal": false,
              "continueTo": 3,
              "preconditions": [],
              "continueChannel": "pda",
              "continue_channel": "pda",
              "allow_generic_stalker": false
            },
            {
              "text": "I'm in the middle of something, sorry.\n",
              "index": 3,
              "reply": "You're in the middle of something?! Get your fucking ass here",
              "channel": "pda",
              "outcomes": [],
              "terminal": false,
              "continueTo": 5,
              "preconditions": [],
              "continueChannel": "pda",
              "continue_channel": "pda",
              "allow_generic_stalker": false
            },
            {
              "text": "Jeez, slow down your horses. Details and I'll think about it\n\n",
              "index": 4,
              "reply": "Listen, kid. I don't have fucking time for jokes rn. You have 5 minutes to get your ass here before I send encouragement.\n",
              "channel": "pda",
              "outcomes": [],
              "terminal": false,
              "continueTo": 6,
              "preconditions": [],
              "continueChannel": "pda",
              "continue_channel": "pda",
              "allow_generic_stalker": false
            }
          ],
          "position": {
            "x": 173,
            "y": 1674
          },
          "f2f_entry": false,
          "pda_entry": true,
          "turnNumber": 1,
          "customLabel": "Go to location",
          "firstSpeaker": "npc",
          "preconditions": [
            {
              "type": "simple",
              "command": "req_story_npc",
              "params": [
                "mil_smart_terrain_7_7_freedom_leader_stalker"
              ]
            },
            {
              "type": "simple",
              "command": "req_rank",
              "params": [
                "experienced"
              ]
            },
            {
              "type": "simple",
              "command": "req_goodwill",
              "params": [
                "1000",
                "freedom"
              ]
            },
            {
              "type": "simple",
              "command": "req_faction_kills",
              "params": [
                "20",
                "dolg"
              ]
            },
            {
              "type": "simple",
              "command": "req_game_days_min",
              "params": [
                "4"
              ]
            },
            {
              "type": "simple",
              "command": "req_not_surge_soon",
              "params": [
                "12000"
              ]
            }
          ],
          "openingMessage": "We have an urgent problem, meet me asap at HQ.\n",
          "speaker_allow_generic_stalker": false,
          "openingImage": "hip_pic"
        },
        {
          "channel": "f2f",
          "choices": [
            {
              "index": 1,
              "text": "Sure, what do you got?",
              "channel": "f2f",
              "preconditions": [],
              "reply": "Drug mule to merc checkpoint. Sensitive package, short route, ugly politics.",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 14,
              "continueChannel": "f2f",
              "continue_channel": "f2f"
            },
            {
              "index": 2,
              "text": "As long as it is not a suicide mission, I am in.",
              "channel": "f2f",
              "preconditions": [],
              "reply": "Not suicide. Escort. Keep Rabbit alive and you get paid.",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 16,
              "continueChannel": "f2f",
              "continue_channel": "f2f"
            },
            {
              "index": 3,
              "text": "I would rather not.",
              "channel": "f2f",
              "preconditions": [],
              "reply": "I am sorry, what?",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 17,
              "continueChannel": "f2f",
              "continue_channel": "f2f"
            }
          ],
          "position": {
            "x": 1718,
            "y": 1366
          },
          "f2f_entry": true,
          "pda_entry": false,
          "turnNumber": 2,
          "customLabel": "Meet In Person",
          "firstSpeaker": "npc",
          "preconditions": [],
          "openingMessage": "Glad you came, there's this new situation that I think might interest you, earn your keep in here.\n",
          "requiresNpcFirst": true,
          "speaker_allow_generic_stalker": false
        },
        {
          "channel": "pda",
          "choices": [
            {
              "index": 1,
              "text": "Roger. Heading to HQ.",
              "channel": "pda",
              "preconditions": [],
              "reply": ":thumbsup:",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 2,
              "continueChannel": "f2f",
              "continue_channel": "f2f"
            },
            {
              "index": 2,
              "text": "If it is that sensitive, I want hazard pay.",
              "channel": "pda",
              "preconditions": [],
              "reply": "You want hazard pay, earn it first. HQ. Now.",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 4,
              "continueChannel": "pda",
              "continue_channel": "pda"
            }
          ],
          "position": {
            "x": 1034,
            "y": 1770
          },
          "f2f_entry": false,
          "pda_entry": false,
          "turnNumber": 3,
          "customLabel": "PDA Details Denied",
          "firstSpeaker": "npc",
          "preconditions": [],
          "openingMessage": "No details over open channel. Too many ears on the net. Move to HQ and hear it face to face.",
          "speaker_allow_generic_stalker": false
        },
        {
          "turnNumber": 4,
          "preconditions": [],
          "channel": "pda",
          "firstSpeaker": "npc",
          "pda_entry": false,
          "f2f_entry": false,
          "choices": [
            {
              "index": 1,
              "text": "Fine. I will hear it in person.",
              "channel": "pda",
              "preconditions": [],
              "reply": "Good. Come alone and keep your PDA quiet.",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 2,
              "continueChannel": "f2f",
              "continue_channel": "f2f"
            },
            {
              "index": 2,
              "text": "Then find another gun.",
              "channel": "pda",
              "preconditions": [],
              "reply": "Bad answer. Do not test me twice today.",
              "outcomes": [
                {
                  "command": "punish_gw",
                  "params": [
                    "150",
                    "freedom"
                  ]
                }
              ],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 7,
              "continueChannel": "pda",
              "continue_channel": "pda"
            }
          ],
          "position": {
            "x": 1370,
            "y": 1905
          },
          "customLabel": "Hazard Pay Pushback",
          "openingMessage": "This is not trader work. Someone is leaning on our supply line and I need a reliable gun, not an accountant.",
          "speaker_allow_generic_stalker": false
        },
        {
          "channel": "pda",
          "choices": [
            {
              "text": "On it, apologies.",
              "index": 1,
              "reply": ":thumbsup:",
              "channel": "pda",
              "outcomes": [],
              "terminal": false,
              "preconditions": [],
              "allow_generic_stalker": false,
              "continueTo": 2,
              "continueChannel": "f2f",
              "continue_channel": "f2f"
            },
            {
              "text": "I don't appreciate that tone Lukash ",
              "index": 2,
              "reply": "Do I need to remind you of your position?",
              "channel": "pda",
              "outcomes": [],
              "terminal": false,
              "preconditions": [],
              "allow_generic_stalker": false,
              "continueTo": 7,
              "continueChannel": "pda",
              "continue_channel": "pda"
            }
          ],
          "position": {
            "x": 1042,
            "y": 2205
          },
          "f2f_entry": false,
          "pda_entry": false,
          "turnNumber": 5,
          "customLabel": "Polite Refuse",
          "firstSpeaker": "npc",
          "preconditions": [],
          "openingMessage": "This is not invitation. You are Freedom, and Freedom answers when base calls.",
          "speaker_allow_generic_stalker": false
        },
        {
          "channel": "pda",
          "choices": [
            {
              "text": "You can't be serious - you know that doesn't work on me, Lukash.",
              "index": 1,
              "reply": "You've been on fucking thin ice and now this shit? Last chance, $player_name, before you become another forgotten name. Don't make me lose patience, kiddo.\n",
              "channel": "pda",
              "outcomes": [],
              "terminal": false,
              "preconditions": [],
              "allow_generic_stalker": false,
              "continueChannel": "pda",
              "continue_channel": "pda",
              "continueTo": 7
            },
            {
              "text": "Okay-okay. I'm coming\n",
              "index": 2,
              "reply": ":thumbsup:",
              "channel": "pda",
              "outcomes": [],
              "terminal": false,
              "preconditions": [],
              "allow_generic_stalker": false,
              "continueChannel": "f2f",
              "continue_channel": "f2f",
              "continueTo": 8
            },
            {
              "index": 3,
              "text": "Sorry, Lukash. I don't know what I was thinking when typing that. I'm omw.",
              "channel": "pda",
              "preconditions": [],
              "reply": "Good.",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueChannel": "f2f",
              "continue_channel": "f2f",
              "continueTo": 8
            }
          ],
          "position": {
            "x": 709,
            "y": 2747
          },
          "f2f_entry": false,
          "pda_entry": false,
          "turnNumber": 6,
          "customLabel": "Rude Reply",
          "firstSpeaker": "npc",
          "preconditions": [],
          "openingMessage": "You want details? Fine. Detail one: you are late. Detail two: I am losing patience.",
          "speaker_allow_generic_stalker": false
        },
        {
          "turnNumber": 7,
          "preconditions": [],
          "channel": "pda",
          "firstSpeaker": "npc",
          "pda_entry": false,
          "f2f_entry": false,
          "choices": [
            {
              "index": 1,
              "text": "Getting a bit sick of your empty threats.",
              "channel": "pda",
              "preconditions": [],
              "reply": "I'm tired of you. Don't ever show your face anywhere near Warehouses. You were warned.",
              "outcomes": [
                {
                  "command": "pause_job",
                  "params": [
                    "6000",
                    "9",
                    "10"
                  ]
                },
                {
                  "command": "spawn_npc_squad",
                  "params": [
                    "freedom_sim_squad_advanced",
                    "75",
                    "120",
                    "3",
                    "hostile"
                  ]
                }
              ],
              "terminal": true,
              "allow_generic_stalker": true,
              "npc_faction_filters": [
                "dolg"
              ]
            },
            {
              "index": 2,
              "text": "Fine, I was just fucking around with you, sorry. I'm coming.",
              "channel": "pda",
              "preconditions": [],
              "reply": "Who do you think you are? We'll talk about it later, don't think that I'll forget it. Now get your ass here already.",
              "outcomes": [
                {
                  "command": "punish_rep",
                  "params": [
                    "50"
                  ]
                },
                {
                  "command": "punish_gw",
                  "params": [
                    "100",
                    "freedom"
                  ]
                }
              ],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 8,
              "continueChannel": "f2f",
              "continue_channel": "f2f"
            }
          ],
          "position": {
            "x": 1419,
            "y": 2757
          },
          "customLabel": "Final Warning",
          "openingMessage": "Last chance. Either walk into HQ, or walk out of Freedom. Pick.",
          "speaker_allow_generic_stalker": false
        },
        {
          "turnNumber": 8,
          "preconditions": [],
          "channel": "f2f",
          "requiresNpcFirst": true,
          "firstSpeaker": "npc",
          "pda_entry": false,
          "f2f_entry": true,
          "choices": [
            {
              "index": 1,
              "text": "Apologies, I am ready. ",
              "channel": "f2f",
              "preconditions": [],
              "reply": "I think you can handle this.",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueChannel": "f2f",
              "continue_channel": "f2f",
              "continueTo": 16
            }
          ],
          "position": {
            "x": 2123,
            "y": 2274
          },
          "openingMessage": "Took you a while.",
          "speaker_allow_generic_stalker": false,
          "customLabel": "Nod between rude and main story"
        },
        {
          "turnNumber": 9,
          "preconditions": [],
          "channel": "pda",
          "firstSpeaker": "npc",
          "pda_entry": false,
          "f2f_entry": false,
          "choices": [
            {
              "index": 1,
              "text": "Minor disagreement.",
              "channel": "pda",
              "preconditions": [],
              "reply": "You want more of these in future?",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 11,
              "continueChannel": "pda",
              "continue_channel": "pda"
            },
            {
              "index": 2,
              "text": "Had enough of Lukash and his shit.",
              "channel": "pda",
              "preconditions": [],
              "reply": "We can tell. You will not make it alone; Duty can use a man who already crossed that line.",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 11,
              "continueChannel": "pda",
              "continue_channel": "pda"
            },
            {
              "index": 3,
              "text": "Mercs were tied to that route. I want their channel.",
              "channel": "pda",
              "preconditions": [],
              "reply": "Dangerous choice. They buy information, but they also sell loose ends.",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 13,
              "continueChannel": "pda",
              "continue_channel": "pda"
            },
            {
              "index": 4,
              "text": "...",
              "channel": "pda",
              "preconditions": [],
              "reply": "Ignoring me, huh? Okay.",
              "outcomes": [
                {
                  "command": "punish_gw",
                  "params": [
                    "1500",
                    "freedom"
                  ]
                },
                {
                  "command": "punish_rep",
                  "params": [
                    "100"
                  ]
                }
              ],
              "terminal": true,
              "allow_generic_stalker": false
            }
          ],
          "position": {
            "x": 2543,
            "y": 2775
          },
          "customLabel": "Success path (duty message)",
          "openingMessage": "Why did we just watch you kill some of your own!?",
          "speaker_allow_generic_stalker": false
        },
        {
          "turnNumber": 10,
          "preconditions": [],
          "channel": "pda",
          "firstSpeaker": "npc",
          "pda_entry": false,
          "f2f_entry": false,
          "choices": [
            {
              "index": 1,
              "text": "I need another exit.",
              "channel": "pda",
              "preconditions": [],
              "reply": "Mercs listen when leverage talks. If you still have anything from that run, call them before Freedom finds you.",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 13,
              "continueChannel": "pda",
              "continue_channel": "pda"
            },
            {
              "index": 2,
              "text": "I will disappear on my own.",
              "channel": "pda",
              "preconditions": [],
              "reply": "Then disappear. No one is burning more men on you.",
              "outcomes": [
                {
                  "command": "punish_gw",
                  "params": [
                    "1500",
                    "freedom"
                  ]
                },
                {
                  "command": "punish_rep",
                  "params": [
                    "200"
                  ]
                }
              ],
              "terminal": true,
              "allow_generic_stalker": false
            }
          ],
          "position": {
            "x": 2528,
            "y": 3204
          },
          "customLabel": "Freedom Retaliation Fail",
          "openingMessage": "Freedom hunters break contact before you can finish them. Lukash still wants your head, and now Duty knows you are loose.",
          "speaker_allow_generic_stalker": false
        },
        {
          "turnNumber": 11,
          "preconditions": [],
          "channel": "pda",
          "firstSpeaker": "npc",
          "pda_entry": false,
          "f2f_entry": false,
          "choices": [
            {
              "index": 1,
              "text": "What do you mean?",
              "channel": "pda",
              "preconditions": [],
              "reply": "Clearly, you have some issues with Lukash, and seeing how you handled those pricks - we could use guys like you in Duty, you know?",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueChannel": "pda",
              "continue_channel": "pda",
              "continueTo": 12
            },
            {
              "index": 2,
              "text": "I don't speak with Duty pigs, fuck off.",
              "channel": "pda",
              "preconditions": [],
              "reply": "I just saw a bunch of freedomers hunting you, a freedomer, all across the Warehouses and you are telling me you okay with that and still hate Duty for your miserable life? Fuck, they must've brainwashed you hard.",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 12,
              "continueChannel": "pda",
              "continue_channel": "pda"
            },
            {
              "index": 3,
              "text": "...",
              "channel": "pda",
              "preconditions": [],
              "reply": "Ignoring me, huh? Okay.",
              "outcomes": [
                {
                  "command": "punish_gw",
                  "params": [
                    "1500",
                    "freedom"
                  ]
                },
                {
                  "command": "punish_gw",
                  "params": [
                    "300",
                    "dolg"
                  ]
                },
                {
                  "command": "punish_rep",
                  "params": [
                    "200"
                  ]
                }
              ],
              "terminal": true,
              "allow_generic_stalker": false
            }
          ],
          "position": {
            "x": 3214,
            "y": 2889
          },
          "customLabel": "Duty Offer",
          "openingMessage": "Duty does not call this sympathy. We call it useful damage. You burned your bridge with Lukash, and we can point that fire somewhere better.",
          "speaker_allow_generic_stalker": false
        },
        {
          "turnNumber": 12,
          "preconditions": [],
          "channel": "pda",
          "firstSpeaker": "npc",
          "pda_entry": false,
          "f2f_entry": false,
          "choices": [
            {
              "index": 1,
              "text": "I need shelter. Put in that word with Duty.",
              "channel": "pda",
              "preconditions": [],
              "reply": "A patrol is moving toward the checkpoint. Follow their route, keep weapons down in Rostok, and ask for Voronin.",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 15,
              "continueChannel": "pda",
              "continue_channel": "pda"
            },
            {
              "index": 2,
              "text": "Mercs were part of this deal. I can sell them what I know.",
              "channel": "pda",
              "preconditions": [],
              "reply": "Risky, but clean. If they answer, you are not Freedom problem anymore.",
              "outcomes": [],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 13,
              "continueChannel": "pda",
              "continue_channel": "pda"
            },
            {
              "index": 3,
              "text": "No Duty, no Mercs. I run alone.",
              "channel": "pda",
              "preconditions": [],
              "reply": "Then run fast.",
              "outcomes": [
                {
                  "command": "punish_gw",
                  "params": [
                    "2000",
                    "freedom"
                  ]
                },
                {
                  "command": "punish_gw",
                  "params": [
                    "200",
                    "dolg"
                  ]
                },
                {
                  "command": "punish_rep",
                  "params": [
                    "150"
                  ]
                }
              ],
              "terminal": true,
              "allow_generic_stalker": false
            }
          ],
          "position": {
            "x": 3810,
            "y": 2898
          },
          "customLabel": "Desertion Decision",
          "openingMessage": "Freedom will not forget this by morning. Duty can shelter you in Rostok. Mercs might buy you, if you bring something worth buying.",
          "speaker_allow_generic_stalker": false
        },
        {
          "turnNumber": 13,
          "preconditions": [],
          "channel": "pda",
          "firstSpeaker": "npc",
          "pda_entry": false,
          "f2f_entry": false,
          "choices": [
            {
              "index": 1,
              "text": "Freedom mule route, Lukash pressure, Duty interference. I can bring names.",
              "channel": "pda",
              "preconditions": [],
              "reply": "Dead City. Sports Center. Come with empty hands visible and useful information ready.",
              "outcomes": [
                {
                  "command": "panda_task_delivery",
                  "params": [
                    "st_cit_killers_name",
                    "7200",
                    "43",
                    "44"
                  ]
                },
                {
                  "command": "punish_gw",
                  "params": [
                    "2500",
                    "freedom"
                  ]
                },
                {
                  "command": "reward_gw",
                  "params": [
                    "700",
                    "killer"
                  ]
                },
                {
                  "command": "watch_location",
                  "params": [
                    "st_cit_killers_name",
                    "100"
                  ]
                }
              ],
              "terminal": true,
              "allow_generic_stalker": false
            },
            {
              "index": 2,
              "text": "I want protection before I move.",
              "channel": "pda",
              "preconditions": [],
              "reply": "Protection costs proof. No proof, no contract.",
              "outcomes": [
                {
                  "command": "punish_gw",
                  "params": [
                    "50",
                    "killer"
                  ]
                }
              ],
              "terminal": false,
              "allow_generic_stalker": false,
              "continueTo": 13,
              "continueChannel": "pda",
              "continue_channel": "pda"
            },
            {
              "index": 3,
              "text": "Forget it.",
              "channel": "pda",
              "preconditions": [],
              "reply": "Already forgotten.",
              "outcomes": [
                {
                  "command": "punish_gw",
                  "params": [
                    "300",
                    "killer"
                  ]
                }
              ],
              "terminal": true,
              "allow_generic_stalker": false
            }
          ],
          "position": {
            "x": 4490,
            "y": 3305
          },
          "customLabel": "Desert To Mercs - Contact",
          "openingMessage": "Merc channel opens after a long dead tone. The voice does not ask your name. It asks what you can prove.",
          "speaker_allow_generic_stalker": false
        },
        {
          "turnNumber": 14,
          "preconditions": [],
          "channel": "f2f",
          "requiresNpcFirst": true,
          "firstSpeaker": "npc",
          "pda_entry": false,
          "f2f_entry": false,
          "choices": [
