          "openingMessage": "No goods, no Rabbit, no patience. Lukash marks you unreliable and every Freedomer in Warehouses gets the same message.",
          "speaker_allow_generic_stalker": false,
          "requiresNpcFirst": true
        },
        {
          "turnNumber": 42,
          "preconditions": [],
          "channel": "f2f",
          "firstSpeaker": "npc",
          "pda_entry": false,
          "f2f_entry": false,
          "choices": [
            {
              "index": 1,
              "text": "What happens now?",
              "channel": "f2f",
              "preconditions": [],
              "reply": "Now you learn discipline, then we aim you back at Lukash.",
              "outcomes": [
                {
                  "command": "give_info",
                  "params": [
                    "panda_desert_to_duty_act1_complete"
                  ],
                  "_note": "Custom info portion for later Duty branch gating."
                },
                {
                  "command": "reward_money",
                  "params": [
                    "4000"
                  ]
                },
                {
                  "command": "reward_rep",
                  "params": [
                    "200"
                  ]
                }
              ],
              "terminal": true,
              "allow_generic_stalker": false,
              "cont_npc_id": "bar_dolg_leader"
            }
          ],
          "position": {
            "x": 5100,
            "y": 2460
          },
          "customLabel": "Desert To Duty Act 1 Complete",
          "openingMessage": "Voronin files your statement under operational intelligence, not confession. Freedom will call you traitor; Duty calls you asset.",
          "speaker_allow_generic_stalker": false,
          "requiresNpcFirst": true
        },
        {
          "turnNumber": 43,
          "preconditions": [],
          "channel": "f2f",
          "firstSpeaker": "npc",
          "pda_entry": false,
          "f2f_entry": true,
          "choices": [
            {
              "index": 1,
              "text": "Contract beats execution.",
              "channel": "f2f",
              "preconditions": [],
              "reply": "For now. Welcome to paid work.",
              "outcomes": [
                {
                  "command": "change_player_faction",
                  "params": [
