    "../text/eng/st_dialog_manager_arch.xml",
    "..\\configs\\text\\eng\\st_dialog_manager_arch.xml",
    "../configs/text/eng/st_dialog_manager_arch.xml",
    "..\\gamedata\\configs\\text\\eng\\st_dialog_manager_arch.xml",
