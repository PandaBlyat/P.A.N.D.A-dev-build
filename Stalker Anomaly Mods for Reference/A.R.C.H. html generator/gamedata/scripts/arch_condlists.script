-- A.R.C.H. Dialog Manager Module

-- ══════════════════════════════════════════════════
-- File I/O Helpers
-- ══════════════════════════════════════════════════

local sorted_keys = arch_filters.sorted_keys
-- File I/O
local function read_text_file(path)
    if not io or not io.open then return nil end
    local file = io.open(path, "r")
    if not file then return nil end
    local content = file:read("*a")
    file:close()
    return content
end
local function write_text_file(path, content)
    local file, err = io.open(path, "w")
    if not file then
        return false, tostring(err or "open failed")
    end
    file:write(content or "")
    file:close()
    return true, nil
end
-- Path + scan helpers
local function normalize_scan_path(path)
    local p = string.lower(tostring(path or ""))
    p = string.gsub(p, "\\", "/")
    p = string.gsub(p, "/+", "/")
    p = string.gsub(p, "/%./", "/")
    local parts = {}
    for part in string.gmatch(p, "[^/]+") do
        if part == ".." then
            if #parts > 0 and parts[#parts] ~= ".." then
                table.remove(parts)
            else
                parts[#parts + 1] = part
            end
        elseif part ~= "." and part ~= "" then
            parts[#parts + 1] = part
        end
    end
    return table.concat(parts, "/")
end
local function path_locale_key(path)
    local p = normalize_scan_path(path)
    if string.find(p, "/text/eng/") then return "eng" end
    if string.find(p, "/text/rus/") then return "rus" end
    return "unknown"
end
local function content_signature(content)
    if type(content) ~= "string" then
        return ""
    end
    local len = #content
    local head = string.sub(content, 1, 128)
    local tail = string.sub(content, math.max(1, len - 127), len)
    return tostring(len) .. "|" .. head .. "|" .. tail
end
local function path_candidates_for_config_rel(path)
    local p = tostring(path or "")
    if p == "" then
        return {}
    end
    return {
        p,
        "configs\\" .. p,
        "configs/" .. p,
        "gamedata\\configs\\" .. p,
        "gamedata/configs/" .. p,
        "..\\" .. p,
        "../" .. p,
        "..\\configs\\" .. p,
        "../configs/" .. p,
        "..\\gamedata\\configs\\" .. p,
        "../gamedata/configs/" .. p
    }
end

