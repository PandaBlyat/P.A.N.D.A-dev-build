-- ──────────────────────────────────────────────────
-- Block definitions — maps role to NPC list + config
-- ──────────────────────────────────────────────────

local BLOCKS = {
    {
        name = "trader",
        npcs = TRADER_NPCS,
        specialization = { "trader" },
    },
    {
        name = "medic",
        npcs = MEDIC_NPCS,
        specialization = { "field_medic" },
    },
    {
        name = "technician",
        npcs = TECH_NPCS,
        specialization = { "technician" },
    },
    {
        name = "barman",
        npcs = BARMAN_NPCS,
        specialization = { "trader" },
    },
}

-- ──────────────────────────────────────────────────
-- Registration
-- ──────────────────────────────────────────────────

local registered = false
local story_archetypes = {}  -- arch_id → { profile, block_name, data }

local function make_arch_id(profile_name)
    return "story_" .. profile_name
end

local function build_archetype_data(profile_name, block)
    return {
        enabled = true,
        assign_to = profile_name,
        specialization = block.specialization,
        strip_dialog_categories = {},
        amount = 1,
        tier = 1,
        chance = 100,
        locked = true,
    }
end

function register_story_npcs()
    if registered then return end
    registered = true

    local C = archetype_core
    if not C then
        printf("[ARCH][STORY] ERROR: archetype_core not available")
        return
    end

    local total = 0
    for _, block in ipairs(BLOCKS) do
        local block_count = 0
        for _, profile in ipairs(block.npcs) do
            local arch_id = make_arch_id(profile)

            -- Check if already registered (by another pack or previous call)
            if C.get_archetype_data and C.get_archetype_data(arch_id) then
                printf("[ARCH][STORY] WARNING: archetype '%s' already exists, skipping", arch_id)
            else
                local data = build_archetype_data(profile, block)
                story_archetypes[arch_id] = {
                    profile = profile,
                    block_name = block.name,
                    data = data,
                }
                block_count = block_count + 1
                total = total + 1
            end
        end
        printf("[ARCH][STORY] Block '%s': %s NPCs registered", block.name, block_count)
    end
    printf("[ARCH][STORY] Total story NPCs: %s", total)
end


-- Returns the full table of story archetypes to register.
-- Called by archetype_core during initialization, BEFORE pack discovery.
function get_story_archetypes()
    if not registered then
        register_story_npcs()
    end
    return story_archetypes
end

-- Check if an archetype ID is a locked story NPC.
function is_locked(arch_id)
    return story_archetypes[arch_id] ~= nil
end

-- Get arch_id for a profile name.
function get_arch_id_for_profile(profile_name)
    return story_archetypes[make_arch_id(profile_name)] and make_arch_id(profile_name) or nil
end

-- Get block name for an arch_id (trader, medic, technician, etc.)
function get_block_name(arch_id)
    local entry = story_archetypes[arch_id]
    return entry and entry.block_name or nil
end

-- Get all profile names for a block.
function get_block_profiles(block_name)
    for _, block in ipairs(BLOCKS) do
        if block.name == block_name then
            return block.npcs
        end
    end
    return {}
end

-- Get all registered story archetype IDs.
function get_all_story_arch_ids()
    local ids = {}
    for arch_id, _ in pairs(story_archetypes) do
        ids[#ids + 1] = arch_id
    end
    table.sort(ids)
    return ids
end
