}
-- Vanilla service dialogs gated by specialization.
-- Injected into character_dialogs.xml via DXML. Gate preconditions in archetype_core
-- check NPC has matching spec before showing. See DIALOG_CATEGORY_GATE medic/repair.
local SPEC_SERVICE_DIALOGS = {
    dm_medic_general = {field_medic = true, medic = true, doctor = true, healer = true},
    dm_init_mechanic = {technician = true, tech = true, mechanic = true},
    dm_tech_repair   = {technician = true, tech = true, mechanic = true},
}
-- Tracks which templates got spec dialogs injected (vs natively present).
-- Gates in archetype_core use this to block non-ARCH NPCs from showing injected services.
local SPEC_SERVICE_INJECTED = {}
function was_spec_dialog_injected(character_id, dialog_id)
    return SPEC_SERVICE_INJECTED[character_id] and SPEC_SERVICE_INJECTED[character_id][dialog_id] or false
end
