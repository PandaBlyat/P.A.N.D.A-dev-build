    arch_task_pool_pool_1_dialog   = true,
    arch_task_pool_pool_2_dialog   = true,
    arch_task_pool_pool_3_dialog   = true,
    arch_task_pool_pool_4_dialog   = true,
    arch_task_pool_pool_5_dialog   = true,
    arch_task_pool_pool_6_dialog   = true,
    arch_task_pool_pool_7_dialog   = true,
    arch_task_pool_pool_8_dialog   = true,
    arch_task_pool_pool_9_dialog   = true,
    arch_task_pool_pool_10_dialog  = true,
}
