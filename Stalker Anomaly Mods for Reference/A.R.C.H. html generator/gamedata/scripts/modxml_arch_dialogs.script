local DEFAULT_TEXT_ENG_KEYS = {}
local DEFAULT_TEXT_RUS_KEYS = {}
local REGISTERED_PACK_DIALOG_XML = {}
local REGISTERED_PACK_TEXT_ENG_XML = {}
local REGISTERED_PACK_TEXT_RUS_XML = {}
local REGISTERED_PACK_DIALOG_XML_SEEN = {}
local REGISTERED_PACK_TEXT_ENG_XML_SEEN = {}
local REGISTERED_PACK_TEXT_RUS_XML_SEEN = {}
local DISCOVERED_PACK_DIALOG_XML = {}
local DISCOVERED_PACK_DIALOG_XML_SEEN = {}
local DISCOVERED_PACK_DIALOG_XML_SCAN_DONE = false
-- CORE_ARCH_DIALOG_IDS: dialog IDs that must be present in the DXML tree and CPhraseDialog registry.
-- IMPORTANT: on_dialog_list_handler adds all IDs here (except arch_task_offer_dialog) to EVERY NPC.
-- Pool tag dialog IDs must NOT go here — they are added only to NPCs with matching archetypes
-- via the config.dialog_id path in on_dialog_list_handler. Adding them here would cause AddAvailableDialog
-- to be called for every NPC, crashing because misc/dialogs_arch.xml is not in the CPhraseDialog registry.
local CORE_ARCH_DIALOG_IDS = {
    arch_task_offer_dialog = true,
    arch_custom_pool_dialog = true,
}
-- Pool tag dialog IDs: used for AVAILABLE_DIALOG_IDS membership check only.
-- NOT added to CORE_ARCH_DIALOG_IDS — see comment above.
