local ARCHETYPE_ALLOWED_KEYS = {
    enabled = true,
    global_block = true,
    ltx = true,
    trade_preset = true,
    buy = true,
    sell = true,
    amount = true,
    respawn = true,
    tier = true,
    chance = true,
    name_format = true,
    dialog_id = true,
    dialog_ids = true,
    dialog_priority = true,
    spawn_loadout = true,
    male = true,
    female = true,
    rank_include = true,
    rank_exclude = true,
