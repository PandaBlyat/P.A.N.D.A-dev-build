local spawn_assign_stats = {
    spawn_callbacks = 0,
    assigned_archetype = 0,
    upgraded_to_archetype = 0,
    loadout_applied = 0,
    loadout_failed = 0,
    deferred_unknown_context = 0,
    skipped_existing = 0,
    skipped_zombied = 0,
    skipped_unique_npc = 0,
    skipped_mode_online_only = 0,
    invalid_arch = 0,
    miss = 0
}
local function logv(fmt, ...)
    if DEBUG_VERBOSE then
        printf(fmt, ...)
    end
end
local function spawn_stat_add(name, value)
    if not name then return end
    local v = tonumber(value) or 0
    spawn_assign_stats[name] = (spawn_assign_stats[name] or 0) + v
end
function get_spawn_assignment_stats()
    local out = {}
    for k, v in pairs(spawn_assign_stats) do
        out[k] = v
    end
    return out
end
function reset_spawn_assignment_stats()
    for k in pairs(spawn_assign_stats) do
        spawn_assign_stats[k] = 0
    end
    printf("[ARCH] Spawn assignment stats reset")
end
local function print_spawn_assignment_stats_internal()
    printf("=== ARCH SPAWN ASSIGNMENT STATS ===")
    local keys = {
        "spawn_callbacks",
        "assigned_archetype",
        "upgraded_to_archetype",
        "loadout_applied",
        "loadout_failed",
        "deferred_unknown_context",
        "skipped_existing",
        "skipped_zombied",
        "skipped_mode_online_only",
        "skipped_unique_npc",
        "invalid_arch",
        "miss"
    }
    for i = 1, #keys do
        local k = keys[i]
        printf("  %s: %s", k, tostring(spawn_assign_stats[k] or 0))
    end
    printf("===================================")
end
local function print_spawn_assignment_compact_line()
    printf(
        "[ARCH][SPAWN] callbacks=%d arch=%d upgrades=%d loadout_ok=%d loadout_fail=%d deferred=%d miss=%d skipped_existing=%d skipped_zombied=%d skipped_online_only=%d skipped_unique=%d invalid_arch=%d",
        tonum(spawn_assign_stats.spawn_callbacks) or 0,
        tonum(spawn_assign_stats.assigned_archetype) or 0,
        tonum(spawn_assign_stats.upgraded_to_archetype) or 0,
        tonum(spawn_assign_stats.loadout_applied) or 0,
        tonum(spawn_assign_stats.loadout_failed) or 0,
        tonum(spawn_assign_stats.deferred_unknown_context) or 0,
        tonum(spawn_assign_stats.miss) or 0,
        tonum(spawn_assign_stats.skipped_existing) or 0,
        tonum(spawn_assign_stats.skipped_zombied) or 0,
        tonum(spawn_assign_stats.skipped_mode_online_only) or 0,
        tonum(spawn_assign_stats.skipped_unique_npc) or 0,
        tonum(spawn_assign_stats.invalid_arch) or 0
    )
end
function print_spawn_assignment_stats()
    return print_spawn_assignment_stats_internal()
end
local perf_stats = {}
function set_assignment_mode(mode)
    local normalized = string.lower(tostring(mode or ""))
    if normalized ~= "hybrid" and normalized ~= "strict_spawn_only" and normalized ~= "online_only" then
        printf("[ARCH] WARNING: Invalid assignment mode '%s' (expected 'hybrid', 'strict_spawn_only', or 'online_only')", tostring(mode))
        return false
    end
    ASSIGNMENT_MODE = normalized
    printf("[ARCH] Assignment mode: %s", ASSIGNMENT_MODE)
    return true
end
function get_assignment_mode()
    return ASSIGNMENT_MODE
end
function set_perf_enabled(enabled)
    PERF_ENABLED = enabled == true
    printf("[ARCH] Perf counters: %s", tostring(PERF_ENABLED))
end
function perf_add(name, value)
    if not PERF_ENABLED or not name then return end
    value = tonumber(value) or 0
    perf_stats[name] = (perf_stats[name] or 0) + value
end
function perf_max(name, value)
    if not PERF_ENABLED or not name then return end
    value = tonumber(value) or 0
    local current = perf_stats[name]
    if not current or value > current then
        perf_stats[name] = value
    end
end
function reset_perf_stats()
    perf_stats = {}
    printf("[ARCH] Perf counters reset")
end
function print_perf_stats()
    printf("=== ARCH PERF STATS ===")
    if next(perf_stats) == nil then
        printf("  (empty)")
    else
        local keys = {}
        for k in pairs(perf_stats) do keys[#keys + 1] = k end
        table.sort(keys)
        for i = 1, #keys do
            local key = keys[i]
            printf("  %s: %s", key, tostring(perf_stats[key]))
        end
    end
    printf("=======================")
end
function set_startup_validation(enabled)
    RUN_STARTUP_VALIDATION = enabled == true
    printf("[ARCH] Startup validation on first update: %s", tostring(RUN_STARTUP_VALIDATION))
end
function is_startup_validation_enabled()
    return RUN_STARTUP_VALIDATION
end

