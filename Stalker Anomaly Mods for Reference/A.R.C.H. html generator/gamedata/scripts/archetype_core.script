    intro_dialog = true,
    intro_done_info = true,
    map_spot = true,
    on_death_info = true,
    locked = true
}
local apply_trade_profile_defaults = arch_trade.apply_trade_profile_defaults
local function validate_spawn_loadout(owner, data)
    if data == nil then
        return 0
    end
    if type(data) ~= "table" then
        printf("[ARCH] WARNING: %s 'spawn_loadout' must be table", owner)
        return 1
    end
    local warnings = 0
    local known_slots = {
        primary = true,
        secondary = true,
        extra = true,
        inherit = true
    }
    for key in pairs(data) do
        if not known_slots[key] then
            printf("[ARCH] WARNING: %s spawn_loadout has unknown slot '%s'", owner, tostring(key))
            warnings = warnings + 1
        end
    end
    local function validate_slot(slot_name, slot_data)
        if slot_data == nil then
            return
        end
        if type(slot_data) ~= "table" then
            printf("[ARCH] WARNING: %s spawn_loadout.%s must be table", owner, slot_name)
            warnings = warnings + 1
            return
        end
        for i = 1, #slot_data do
            local entry = slot_data[i]
            if type(entry) == "string" then
                if entry == "" then
                    printf("[ARCH] WARNING: %s spawn_loadout.%s[%s] must not be empty string", owner, slot_name, i)
                    warnings = warnings + 1
                end
            elseif type(entry) == "table" then
                local section = entry.section or entry[1]
                if type(section) ~= "string" or section == "" then
                    printf("[ARCH] WARNING: %s spawn_loadout.%s[%s] table entry requires non-empty 'section'", owner, slot_name, i)
                    warnings = warnings + 1
                end
                if entry.chance ~= nil and tonumber(entry.chance) == nil then
                    printf("[ARCH] WARNING: %s spawn_loadout.%s[%s] chance must be numeric", owner, slot_name, i)
                    warnings = warnings + 1
                end
            else
                printf("[ARCH] WARNING: %s spawn_loadout.%s[%s] must be string or table", owner, slot_name, i)
                warnings = warnings + 1
            end
        end
    end
    validate_slot("primary", data.primary)
    validate_slot("secondary", data.secondary)
    validate_slot("extra", data.extra)
    return warnings
end
local function validate_archetype_entry(arch_id, data)
    local owner = string.format("Archetype '%s'", tostring(arch_id))
    local warnings = 0
    warnings = warnings + validate_unknown_keys(owner, data, ARCHETYPE_ALLOWED_KEYS)
    warnings = warnings + validate_shared_filters(owner, data)
    warnings = warnings + validate_spawn_loadout(owner, data.spawn_loadout)
    local bool_fields   = {"enabled", "respawn"}
    local string_fields = {"global_block", "ltx", "trade_preset", "dialog_id"}
    local number_fields = {"buy", "sell", "chance", "amount", "dialog_priority", "available_after_days"}
    for _, f in ipairs(bool_fields) do
        if data[f] ~= nil and type_(data[f]) ~= "boolean" then
            printf("[ARCH] WARNING: %s '%s' must be boolean", owner, f)
            warnings = warnings + 1
        end
    end
    for _, f in ipairs(string_fields) do
        if data[f] ~= nil and type_(data[f]) ~= "string" then
            printf("[ARCH] WARNING: %s '%s' must be string", owner, f)
            warnings = warnings + 1
        end
    end
    for _, f in ipairs(number_fields) do
        if data[f] ~= nil and tonum(data[f]) == nil then
            printf("[ARCH] WARNING: %s '%s' must be numeric", owner, f)
            warnings = warnings + 1
        end
    end
    if data.tier ~= nil and tonum(data.tier) == nil then
        printf("[ARCH] WARNING: %s 'tier' must be numeric (1-5)", owner)
        warnings = warnings + 1
    end
    if data.dialog_ids ~= nil then
        if type_(data.dialog_ids) ~= "table" then
            printf("[ARCH] WARNING: %s 'dialog_ids' must be table", owner)
            warnings = warnings + 1
        else
            for i, dialog_id in pairs(data.dialog_ids) do
                if type_(dialog_id) ~= "string" or dialog_id == "" then
                    printf("[ARCH] WARNING: %s dialog_ids[%s] must be non-empty string", owner, tostring(i))
                    warnings = warnings + 1
                end
            end
        end
    end
    if data.name_format ~= nil then
        if type_(data.name_format) ~= "table" then
            printf("[ARCH] WARNING: %s 'name_format' must be a table", owner)
            warnings = warnings + 1
        else
            if type_(data.name_format.type) ~= "string" or type_(data.name_format.text) ~= "string" then
                printf("[ARCH] WARNING: %s name_format must contain string 'type' and 'text'", owner)
                warnings = warnings + 1
            end
        end
    end
    return warnings
end
local function add_index_entry(index_map, key, arch_id)
    if not key then return end
    local list = index_map[key]
    if not list then
        list = {}
        index_map[key] = list
    end
    list[#list + 1] = arch_id
end
local function append_candidates(candidates, seen, list)
    if not list then return end
    for i = 1, #list do
        local arch_id = list[i]
        if not seen[arch_id] then
            seen[arch_id] = true
            candidates[#candidates + 1] = arch_id
        end
    end
end
local function get_filter_signature(filter_data)
    if not filter_data then
        return "__all__"
    end
    return table.concat({
        tostr(filter_data.community or ""),
        tostr(filter_data.location or ""),
        tostr(filter_data.rank or ""),
        tostr(filter_data.gender or ""),
        tostr(filter_data.smart_terrain or "")
    }, "|")
end
local function get_archetype_candidates(filter_data)
    local signature = get_filter_signature(filter_data)
    local cached = archetype_candidate_cache[signature]
    if cached then
        perf_add("arch_candidate_cache_hit", 1)
        return cached
    end
    perf_add("arch_candidate_cache_miss", 1)
    local candidates = {}
    if not filter_data then
        for arch_id in pairs(custom_archetypes) do
            candidates[#candidates + 1] = arch_id
        end
        archetype_candidate_cache[signature] = candidates
        return candidates
    end
    local seen = {}
    append_candidates(candidates, seen, archetype_index.community[filter_data.community])
    append_candidates(candidates, seen, archetype_index.location[filter_data.location])
    append_candidates(candidates, seen, archetype_index.rank[filter_data.rank])
    append_candidates(candidates, seen, archetype_index.gender[filter_data.gender])
    append_candidates(candidates, seen, archetype_index.smart_terrain[filter_data.smart_terrain])
    append_candidates(candidates, seen, archetype_index.unindexed)
    archetype_candidate_cache[signature] = candidates
    return candidates
end

