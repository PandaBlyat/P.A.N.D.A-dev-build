function try_complete_active(a, b, pool_tag)
    local npc = resolve_dialog_npc(a, b)
    local arch_id = npc and resolve_arch_id(npc) or nil
    local task = arch_id and get_active_task_for_arch_tagged(arch_id, pool_tag) or nil
    if not task or not npc then
        set_result("dm_arch_task_no_active")
        return false
    end
    local giver_id = get_task_giver_id(task.id)
    -- For fetch tasks, turnin must be at the giver NPC
    if task.kind == "fetch" then
        if giver_id and giver_id ~= 0 and giver_id ~= npc:id() then
            set_result("dm_arch_task_no_active")
            return false
        end
        if not has_required_fetch_items(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        if not complete_pda_task(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        SUPPRESS_CONSUME_NEWS = true
        PENDING_CONSUME = {}
        if not consume_fetch_items(task, npc) then
            SUPPRESS_CONSUME_NEWS = false
            PENDING_CONSUME = {}
            printe("[TASK] Failed to consume required items for task '%s'", tostring(task.id))
            set_result("dm_arch_task_not_ready")
            return false
        end
        SUPPRESS_CONSUME_NEWS = false
        complete_task(task, arch_id, npc)
        return true
    end
    -- For delivery tasks, turnin is at the TARGET NPC (not the giver)
    if task.kind == "delivery" then
        if not is_delivery_target_npc(task, npc) then
            set_result("dm_arch_task_no_active")
            return false
        end
        if not has_delivery_items(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        if not complete_pda_task(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        -- Consume delivery items
        local state = load_delivery_state(task.id)
        SUPPRESS_CONSUME_NEWS = true
        PENDING_CONSUME = {}
        local ok = consume_single_item(get_actor(), npc, state.item_section, state.item_amount)
        SUPPRESS_CONSUME_NEWS = false
        if not ok then
            PENDING_CONSUME = {}
            set_result("dm_arch_task_not_ready")
            return false
        end
        clear_delivery_state(task.id)
        complete_task(task, arch_id, npc)
        return true
    end
    -- For talk tasks, turnin is at the TARGET NPC (not the giver), no items
    if task.kind == "talk" then
        if not is_delivery_target_npc(task, npc) then
            set_result("dm_arch_task_no_active")
            return false
        end
        if not complete_pda_task(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        clear_delivery_state(task.id)
        complete_task(task, arch_id, npc)
        return true
    end
    -- For collect tasks, turnin is at the GIVER (like fetch), consume collected items
    if task.kind == "collect" then
        if giver_id and giver_id ~= 0 and giver_id ~= npc:id() then
            set_result("dm_arch_task_no_active")
            return false
        end
        if not has_delivery_items(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        if not complete_pda_task(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        -- Consume collected items
        local state = load_delivery_state(task.id)
        SUPPRESS_CONSUME_NEWS = true
        PENDING_CONSUME = {}
        local ok = consume_single_item(get_actor(), npc, state.item_section, state.item_amount)
        SUPPRESS_CONSUME_NEWS = false
        if not ok then
            PENDING_CONSUME = {}
            set_result("dm_arch_task_not_ready")
            return false
        end
        clear_delivery_state(task.id)
        complete_task(task, arch_id, npc)
        return true
    end
    set_result("dm_arch_task_not_ready")
    return false
end
function try_complete_by_id(task_id, a, b)
    ensure_registered()
    task_id = task_id and tostr(task_id) or nil
    local task = task_id and TASK_BY_ID[task_id] or nil
    if not task then
        printf("[TASK] try_complete_by_id FAILED: task '%s' not found", tostr(task_id))
        set_result("dm_arch_task_no_active")
        return false
    end
    if not is_task_active(task_id) then
        printf("[TASK] try_complete_by_id FAILED: task '%s' not active", task_id)
        set_result("dm_arch_task_no_active")
        return false
    end
    local npc = resolve_dialog_npc(a, b)
    local arch_id = task.arch_id
    if task.kind == "fetch" then
        local giver_id = get_task_giver_id(task_id)
        if giver_id and giver_id ~= 0 and npc and npc:id() ~= giver_id then
            set_result("dm_arch_task_no_active")
            return false
        end
        if not has_required_fetch_items(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        if not complete_pda_task(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        SUPPRESS_CONSUME_NEWS = true
        PENDING_CONSUME = {}
        if not consume_fetch_items(task, npc) then
            SUPPRESS_CONSUME_NEWS = false
            PENDING_CONSUME = {}
            set_result("dm_arch_task_not_ready")
            return false
        end
        SUPPRESS_CONSUME_NEWS = false
        complete_task(task, arch_id, npc)
        return true
    end
    if task.kind == "delivery" then
        if not has_delivery_items(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        if not complete_pda_task(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        local state = load_delivery_state(task_id)
        SUPPRESS_CONSUME_NEWS = true
        PENDING_CONSUME = {}
        local ok = consume_single_item(get_actor(), npc, state.item_section, state.item_amount)
        SUPPRESS_CONSUME_NEWS = false
        if not ok then
            PENDING_CONSUME = {}
            set_result("dm_arch_task_not_ready")
            return false
        end
        clear_delivery_state(task_id)
        complete_task(task, arch_id, npc)
        return true
    end
    if task.kind == "talk" then
        if not complete_pda_task(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        clear_delivery_state(task_id)
        complete_task(task, arch_id, npc)
        return true
    end
    if task.kind == "collect" then
        if not has_delivery_items(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        if not complete_pda_task(task) then
            set_result("dm_arch_task_not_ready")
            return false
        end
        local state = load_delivery_state(task_id)
        SUPPRESS_CONSUME_NEWS = true
        PENDING_CONSUME = {}
        local ok = consume_single_item(get_actor(), npc, state.item_section, state.item_amount)
        SUPPRESS_CONSUME_NEWS = false
        if not ok then
            PENDING_CONSUME = {}
            set_result("dm_arch_task_not_ready")
            return false
        end
        clear_delivery_state(task_id)
        complete_task(task, arch_id, npc)
        return true
    end
    set_result("dm_arch_task_not_ready")
    return false
end
function get_result_text()
    local result = get_result()
    if not result or result == "" then
        return tr(nil, "dm_arch_task_declined")
    end
    if type(result) == "string" and string.sub(result, 1, 3) == "dm_" then
        return tr(result, "dm_arch_task_declined")
    end
    return tostring(result)
end

-- ──────────────────────────────────────────────────
-- Tagged Dialog Functors (multi-pool)
-- ──────────────────────────────────────────────────

function can_show_offer_dialog_tagged(a, b, pool_tag)
    local npc = resolve_dialog_npc(a, b)
    local arch_id = npc and resolve_arch_id(npc) or nil
    if not arch_id then return false end
    if not has_pool_internal(arch_id, pool_tag) then return false end
    local npc_id = npc and npc.id and npc:id() or nil
    return pool_has_offerable_tasks(arch_id, pool_tag, npc_id)
end
function has_offer_for_dialog_tagged(a, b, pool_tag)
    local task = current_offer_task(a, b, pool_tag)
    return task ~= nil
end
function get_offer_summary_text_tagged(a, b, pool_tag)
    -- Clear offer cache to force fresh pick (info portions may have changed since last cache)
    local _npc = resolve_dialog_npc(a, b)
    if _npc and _npc.id then
        OFFER_CACHE[offer_cache_key(_npc:id(), pool_tag or "default")] = nil
    end
    local task, arch_id, npc = current_offer_task(a, b, pool_tag)
    if not task then
        return tr(nil, "dm_arch_task_no_available")
    end
    if npc and npc.id and task then
        DIALOG_PINNED_OFFER[npc:id()] = { task_id = task.id, arch_id = arch_id, pool_tag = pool_tag }
    end
    return resolve_task_text(task, "summary", "dm_arch_task_no_available")
end
function get_offer_details_text_tagged(a, b, pool_tag)
    local task = current_offer_task(a, b, pool_tag)
    if not task then
        return tr(nil, "dm_arch_task_no_available")
    end
    return resolve_task_text(task, "details", "dm_arch_task_no_available")
end
function accept_offer_tagged(a, b, pool_tag)
    local npc = resolve_dialog_npc(a, b)
    if not npc or not npc.id then
        set_result("dm_arch_task_no_available")
        return false
    end
    local npc_id = npc:id()
    local task, arch_id
    local pinned = DIALOG_PINNED_OFFER[npc_id]
    if pinned and pinned.task_id and pinned.pool_tag == pool_tag and TASK_BY_ID[pinned.task_id] then
        task = TASK_BY_ID[pinned.task_id]
        arch_id = pinned.arch_id
        logv("[TASK] Using pinned offer '%s' for tagged accept (pool=%s)", tostr(pinned.task_id), tostr(pool_tag))
    else
        task, arch_id, npc = current_offer_task(a, b, pool_tag)
    end
    DIALOG_PINNED_OFFER[npc_id] = nil
    if not task or not arch_id then
        set_result("dm_arch_task_no_available")
        return false
    end
    local giver_id = npc and npc.id and npc:id() or 0
    if npc_has_active_task_for_pool(giver_id, pool_tag) then
        set_result("dm_arch_task_not_ready")
        return false
    end
    if (task.kind == "fetch" or task.kind == "delivery" or task.kind == "talk" or task.kind == "collect") and not ensure_pda_task_started(task, npc) then
        set_result("dm_arch_task_not_ready")
        local cache_key = offer_cache_key(giver_id, pool_tag)
        if giver_id > 0 then
            OFFER_CACHE[cache_key] = nil
        end
        return false
    end
    if task.kind == "delivery" then
        if not accept_delivery_task(task, npc) then
            set_result("dm_arch_task_not_ready")
            return false
        end
    end
    if task.kind == "talk" then
        if not accept_talk_task(task, npc) then
            set_result("dm_arch_task_not_ready")
            return false
        end
    end
    if task.kind == "collect" then
        if not accept_collect_task(task, npc) then
            set_result("dm_arch_task_not_ready")
            return false
        end
    end
    set_task_active(task.id, true)
    set_task_active_index(task.id, true)
    set_active_task_id(arch_id, task.id)
    set_active_task_id_for_npc(giver_id, task.id)
    set_task_giver_id(task.id, giver_id)
    local giver_comm = nil
    if task.reward_goodwill_community then
        giver_comm = task.reward_goodwill_community
    elseif npc and npc.character_community then
        local ok, comm = pcall(npc.character_community, npc)
        if ok and comm and comm ~= "" then
            giver_comm = tostr(comm)
        end
    end
    if giver_comm then
        set_task_giver_community(task.id, giver_comm)
    end
    if task.item_category and task.item_category ~= "" and npc and npc.id then
        local cache_key = offer_cache_key(npc:id(), pool_tag)
        local cached = OFFER_CACHE[cache_key]
        if cached and cached.resolved_item and cached.resolved_item ~= "" then
            set_resolved_item_section(task.id, cached.resolved_item)
            logv("[TASK] Persisted resolved item '%s' for task '%s'",
                tostr(cached.resolved_item), tostr(task.id))
        end
    end
    set_turnin_ready(task.id, false)
    set_turnin_marker_owned(task.id, false)
    set_last_offer_task_id(arch_id, task.id)
    if npc and npc.id then
        local cache_key = offer_cache_key(npc:id(), pool_tag)
        OFFER_CACHE[cache_key] = nil
    end
    set_result(task_accept_message(task))
    update_turnin_tracker_for_task(task, arch_id, true)
    logv("[TASK] ACCEPTED: %s (giver=%s pool=%s)", task.id, tostring(arch_id), tostring(pool_tag))
    return true
end
function decline_offer_tagged(a, b, pool_tag)
    local _, _, npc = current_offer_task(a, b, pool_tag)
    if npc and npc.id then
        local cache_key = offer_cache_key(npc:id(), pool_tag)
        OFFER_CACHE[cache_key] = nil
        DIALOG_PINNED_OFFER[npc:id()] = nil
    end
    set_result("dm_arch_task_declined")
    return true
end
function has_active_for_dialog_tagged(a, b, pool_tag)
    local npc = resolve_dialog_npc(a, b)
    local arch_id = npc and resolve_arch_id(npc) or nil
    if not arch_id then return false end
    local task = get_active_task_for_arch_tagged(arch_id, pool_tag)
    if not task then return false end
    local giver_id = get_task_giver_id(task.id)
    if giver_id and giver_id ~= 0 and npc and npc.id and giver_id ~= npc:id() then return false end
    return true
end
function is_active_task_ready_tagged(a, b, pool_tag)
    local npc = resolve_dialog_npc(a, b)
    local arch_id = npc and resolve_arch_id(npc) or nil
    if not arch_id then return false end
    local task = get_active_task_for_arch_tagged(arch_id, pool_tag)
    if not task then return false end
    local giver_id = get_task_giver_id(task.id)
    if task.kind == "delivery" then
        -- Delivery turnin is at the target, not the giver — check target match instead
        return is_delivery_target_npc(task, npc) and has_delivery_items(task)
    end
    if task.kind == "talk" then
        -- Talk turnin is at the target — just check NPC match, no items
        return is_delivery_target_npc(task, npc)
    end
    if task.kind == "collect" then
        -- Collect turnin is at the giver — check giver match + player has picked up items
        if giver_id and giver_id ~= 0 and npc and npc.id and giver_id ~= npc:id() then return false end
        return has_delivery_items(task)
    end
    if giver_id and giver_id ~= 0 and npc and npc.id and giver_id ~= npc:id() then return false end
    return has_required_fetch_items(task)
end
function is_active_task_ready(a, b)
    return is_active_task_ready_tagged(a, b, nil)
end
function get_active_summary_text_tagged(a, b, pool_tag)
    local npc = resolve_dialog_npc(a, b)
    local arch_id = npc and resolve_arch_id(npc) or nil
    local task = arch_id and get_active_task_for_arch_tagged(arch_id, pool_tag) or nil
    if not task then
        return tr(nil, "dm_arch_task_no_active")
    end
    return resolve_task_text(task, "summary", "dm_arch_task_no_active")
end
function get_pool_open_text(arch_id, pool_tag)
    ensure_registered()
    local pool = get_pool(tostring(arch_id), pool_tag or "default")
    if pool and pool.dialog_open_text then
        return pool.dialog_open_text
    end
    if pool_tag == "default" or not pool_tag then
        return "Got any work?"
    end
    return "Got any " .. tostring(pool_tag) .. " work?"
end
function get_pool_personality(arch_id, pool_tag, field)
    ensure_registered()
    local pool = get_pool(tostring(arch_id), pool_tag or "default")
    if pool and pool[field] then
        return pool[field]
    end
    return nil
end

-- Delivery public API
function is_npc_delivery_target(a, b)
    -- Check if the NPC is the specific delivery target for ANY active delivery task.
    local ok, result = pcall(function()
        local npc = resolve_dialog_npc(a, b)
        if not npc then return false end
        for task_id, task in pairs(TASK_BY_ID) do
            if task.kind == "delivery" and is_task_active(task_id) then
                if is_delivery_target_npc(task, npc) and has_delivery_items(task) then
                    return true
                end
            end
            if task.kind == "talk" and is_task_active(task_id) then
                if is_delivery_target_npc(task, npc) then
                    return true
                end
            end
            if task.kind == "collect" and is_task_active(task_id) then
                -- Only show pickup dialog if player hasn't picked up yet
                local cstate = load_delivery_state(task_id)
                if is_delivery_target_npc(task, npc) and not (cstate and cstate.picked_up) then
                    return true
                end
            end
        end
        return false
    end)
    if not ok then
        printf("[TASK] is_npc_delivery_target error: %s", tostr(result))
        return false
    end
    return result == true
end
function try_complete_delivery(a, b)
    -- Find the matching delivery task for this target NPC and complete it.
    -- Checks specific target NPC (from accept), falls back to filter match.
    local npc = resolve_dialog_npc(a, b)
    if not npc then
        set_result("dm_arch_task_no_active")
        return false
    end
    for task_id, task in pairs(TASK_BY_ID) do
        -- Handle talk tasks — no items, just NPC match
        if task.kind == "talk" and is_task_active(task_id) then
            if is_delivery_target_npc(task, npc) then
                if not complete_pda_task(task) then
                    set_result("dm_arch_task_not_ready")
                    return false
                end
                clear_delivery_state(task_id)
                complete_task(task, task.arch_id, npc)
                return true
            end
        end
        if task.kind == "delivery" and is_task_active(task_id) then
            if is_delivery_target_npc(task, npc) and has_delivery_items(task) then
                if not complete_pda_task(task) then
                    set_result("dm_arch_task_not_ready")
                    return false
                end
                local section = task.deliver_item
                local amount = tonum(task.deliver_amount) or 1
                SUPPRESS_CONSUME_NEWS = true
                PENDING_CONSUME = {}
                local ok = consume_single_item(get_actor(), npc, section, amount)
                SUPPRESS_CONSUME_NEWS = false
                if not ok then
                    PENDING_CONSUME = {}
                    set_result("dm_arch_task_not_ready")
                    return false
                end
                clear_delivery_state(task_id)
                complete_task(task, task.arch_id, npc)
                return true
            end
        end
    end
    set_result("dm_arch_task_no_active")
    return false
end
function complete_delivery_by_id(task_id, a, b)
    ensure_registered()
    local task = task_id and TASK_BY_ID[tostr(task_id)] or nil
    if not task then
        printf("[TASK] complete_delivery_by_id FAILED: task '%s' not found", tostr(task_id))
        set_result("dm_arch_task_no_active")
        return false
    end
    if task.kind ~= "delivery" then
        printf("[TASK] complete_delivery_by_id FAILED: task '%s' is kind '%s', not delivery", tostr(task_id), tostr(task.kind))
        set_result("dm_arch_task_no_active")
        return false
    end
    if not is_task_active(task_id) then
        printf("[TASK] complete_delivery_by_id FAILED: task '%s' not active", tostr(task_id))
        set_result("dm_arch_task_no_active")
        return false
    end
    local npc = resolve_dialog_npc(a, b)
    if not npc then
        printf("[TASK] complete_delivery_by_id FAILED: NPC not resolved for task '%s'", tostr(task_id))
        set_result("dm_arch_task_no_active")
        return false
    end
    if not is_delivery_target_npc(task, npc) then
        printf("[TASK] complete_delivery_by_id FAILED: NPC %s is not target for task '%s'", tostr(npc:id()), tostr(task_id))
        set_result("dm_arch_task_no_active")
        return false
    end
    if not has_delivery_items(task) then
        printf("[TASK] complete_delivery_by_id FAILED: player lacks items for task '%s'", tostr(task_id))
        set_result("dm_arch_task_not_ready")
        return false
    end
    if not complete_pda_task(task) then
        set_result("dm_arch_task_not_ready")
        return false
    end
    local section = task.deliver_item
    local amount = tonum(task.deliver_amount) or 1
    SUPPRESS_CONSUME_NEWS = true
    PENDING_CONSUME = {}
    local ok = consume_single_item(get_actor(), npc, section, amount)
    SUPPRESS_CONSUME_NEWS = false
    if not ok then
        PENDING_CONSUME = {}
        set_result("dm_arch_task_not_ready")
        return false
    end
    clear_delivery_state(task_id)
    complete_task(task, task.arch_id, npc)
    logv("[TASK] COMPLETED (delivery_by_id): %s", tostr(task_id))
    return true
end
function get_delivery_target_for_task(task_id)
    return get_delivery_target_id(task_id)
end
function complete_talk_by_id(task_id, a, b)
    ensure_registered()
    local task = task_id and TASK_BY_ID[tostr(task_id)] or nil
    if not task then
        printf("[TASK] complete_talk_by_id FAILED: task '%s' not found", tostr(task_id))
        set_result("dm_arch_task_no_active")
        return false
    end
    if task.kind ~= "talk" and task.kind ~= "collect" then
        printf("[TASK] complete_talk_by_id FAILED: task '%s' is kind '%s', not talk/collect", tostr(task_id), tostr(task.kind))
        set_result("dm_arch_task_no_active")
        return false
    end
    if not is_task_active(task_id) then
        printf("[TASK] complete_talk_by_id FAILED: task '%s' not active", tostr(task_id))
        set_result("dm_arch_task_no_active")
        return false
    end
    local npc = resolve_dialog_npc(a, b)
    if not npc then
        printf("[TASK] complete_talk_by_id FAILED: NPC not resolved for task '%s'", tostr(task_id))
        set_result("dm_arch_task_no_active")
        return false
    end
    if not is_delivery_target_npc(task, npc) then
        printf("[TASK] complete_talk_by_id FAILED: NPC %s is not target for task '%s'", tostr(npc:id()), tostr(task_id))
        set_result("dm_arch_task_no_active")
        return false
    end
    -- Collect tasks completed via dialog: spawn collect items on player
    -- (report-back delivery task needs these items in inventory)
    if task.kind == "collect" then
        local section = task.collect_item or ""
        local amount = tonum(task.collect_amount) or 1
        if section ~= "" and amount > 0 then
            local granted = give_item_reward(section, amount, true)
            if granted > 0 and news_manager and news_manager.relocate_item then
                news_manager.relocate_item(db.actor, "in", section, granted)
            end
            logv("[TASK] Collect via dialog '%s': spawned %s x '%s' on player", tostr(task_id), granted, section)
        end
    end
    if not complete_pda_task(task) then
        set_result("dm_arch_task_not_ready")
        return false
    end
    clear_delivery_state(task_id)
    complete_task(task, task.arch_id, npc)
    logv("[TASK] COMPLETED (talk_by_id): %s", tostr(task_id))
    return true
end

-- Direct by-id approach: accept/details without pin state.
-- Used by story task dialogs that know their task_id statically.
function get_offer_details_text_by_id(task_id, a, b)
    ensure_registered()
    local task = task_id and TASK_BY_ID[tostr(task_id)] or nil
    if not task then
        return tr(nil, "dm_arch_task_no_available")
    end
    return resolve_task_text(task, "details", "dm_arch_task_no_available")
end
-- Check if a specific task has been completed (for dialog preconditions)
function check_task_done(task_id)
    ensure_registered()
    if not task_id then return false end
    return is_task_done(tostr(task_id))
end
-- Check if a specific task is currently active (for dialog preconditions)
function check_task_active(task_id)
    ensure_registered()
    if not task_id then return false end
    return is_task_active(tostr(task_id))
end
-- Check if a specific task has NOT been completed (inverse of check_task_done)
function check_task_not_done(task_id)
    ensure_registered()
    if not task_id then return true end
    return not is_task_done(tostr(task_id))
end
-- Check if a specific task is active AND the player meets completion conditions
-- Works for all task kinds: fetch (has items + at giver), delivery (has items + at target),
-- talk (at target), collect (has items + at giver)
function check_task_ready_for(task_id, a, b)
    ensure_registered()
    if not task_id then
        logv("[ARCH][DIAG] check_task_ready_for: nil task_id")
        return false
    end
    task_id = tostr(task_id)
    local task = TASK_BY_ID[task_id]
    if not task then
        logv("[ARCH][DIAG] check_task_ready_for(%s): task not in TASK_BY_ID", task_id)
        return false
    end
    if not is_task_active(task_id) then
        logv("[ARCH][DIAG] check_task_ready_for(%s): task not active", task_id)
        return false
    end
    local npc = resolve_dialog_npc(a, b)
    if not npc then
        logv("[ARCH][DIAG] check_task_ready_for(%s): NPC not resolved", task_id)
        return false
    end
    local giver_id = get_task_giver_id(task_id)
    if task.kind == "fetch" then
        if giver_id and giver_id ~= 0 and giver_id ~= npc:id() then
            logv("[ARCH][DIAG] check_task_ready_for(%s): fetch giver mismatch giver=%s npc=%s", task_id, tostr(giver_id), tostr(npc:id()))
            return false
        end
        local ready = has_required_fetch_items(task)
        logv("[ARCH][DIAG] check_task_ready_for(%s): fetch has_items=%s", task_id, tostr(ready))
        return ready
    end
    if task.kind == "delivery" then
        local is_target = is_delivery_target_npc(task, npc)
        local has_items = has_delivery_items(task)
        logv("[ARCH][DIAG] check_task_ready_for(%s): delivery is_target=%s has_items=%s", task_id, tostr(is_target), tostr(has_items))
        return is_target and has_items
    end
    if task.kind == "talk" then
        local is_target = is_delivery_target_npc(task, npc)
        logv("[ARCH][DIAG] check_task_ready_for(%s): talk is_target=%s", task_id, tostr(is_target))
        return is_target
    end
    if task.kind == "collect" then
        if giver_id and giver_id ~= 0 and giver_id ~= npc:id() then
            logv("[ARCH][DIAG] check_task_ready_for(%s): collect giver mismatch giver=%s npc=%s", task_id, tostr(giver_id), tostr(npc:id()))
            return false
        end
        local state = load_delivery_state(task_id)
        local picked = state and state.picked_up or false
        if not picked then
            logv("[ARCH][DIAG] check_task_ready_for(%s): collect not picked up yet", task_id)
            return false
        end
        local has_items = has_delivery_items(task)
        logv("[ARCH][DIAG] check_task_ready_for(%s): collect has_items=%s picked=%s giver=%s npc=%s",
            task_id, tostr(has_items), tostr(picked), tostr(giver_id), tostr(npc:id()))
        return has_items
    end
    -- Unknown kind — fall back to fetch logic
    if giver_id and giver_id ~= 0 and giver_id ~= npc:id() then return false end
    return has_required_fetch_items(task)
end
-- Complete a specific fetch task by ID — per-task equivalent of pool-based try_complete_active for fetch
function complete_fetch_by_id(task_id, a, b)
    ensure_registered()
    local task = task_id and TASK_BY_ID[tostr(task_id)] or nil
    if not task then
        printf("[TASK] complete_fetch_by_id FAILED: task '%s' not found", tostr(task_id))
        set_result("dm_arch_task_no_active")
        return false
    end
    if task.kind ~= "fetch" then
        printf("[TASK] complete_fetch_by_id FAILED: task '%s' is kind '%s', not fetch", tostr(task_id), tostr(task.kind))
        set_result("dm_arch_task_no_active")
        return false
    end
    if not is_task_active(task_id) then
        printf("[TASK] complete_fetch_by_id FAILED: task '%s' not active", tostr(task_id))
        set_result("dm_arch_task_no_active")
        return false
    end
    local npc = resolve_dialog_npc(a, b)
    if not npc then
        printf("[TASK] complete_fetch_by_id FAILED: NPC not resolved for task '%s'", tostr(task_id))
        set_result("dm_arch_task_no_active")
        return false
    end
    local giver_id = get_task_giver_id(task_id)
    if giver_id and giver_id ~= 0 and giver_id ~= npc:id() then
        printf("[TASK] complete_fetch_by_id FAILED: NPC %s is not giver %s for task '%s'", tostr(npc:id()), tostr(giver_id), tostr(task_id))
        set_result("dm_arch_task_no_active")
        return false
    end
    if not has_required_fetch_items(task) then
        printf("[TASK] complete_fetch_by_id FAILED: player lacks items for task '%s'", tostr(task_id))
        set_result("dm_arch_task_not_ready")
        return false
    end
    if not complete_pda_task(task) then
        set_result("dm_arch_task_not_ready")
        return false
    end
    SUPPRESS_CONSUME_NEWS = true
    PENDING_CONSUME = {}
    if not consume_fetch_items(task, npc) then
        SUPPRESS_CONSUME_NEWS = false
        PENDING_CONSUME = {}
        printe("[TASK] Failed to consume required items for task '%s'", tostr(task_id))
        set_result("dm_arch_task_not_ready")
        return false
    end
    SUPPRESS_CONSUME_NEWS = false
    complete_task(task, task.arch_id, npc)
    logv("[TASK] COMPLETED (fetch_by_id): %s", tostr(task_id))
    return true
end
-- Cancel a specific task by ID — clears active state, delivery state, PDA, markers
function cancel_task_by_id(task_id, a, b)
    ensure_registered()
    local task = task_id and TASK_BY_ID[tostr(task_id)] or nil
    if not task then
        printf("[TASK] cancel_task_by_id FAILED: task '%s' not found", tostr(task_id))
        return false
    end
    if not is_task_active(task.id) then
        printf("[TASK] cancel_task_by_id: task '%s' is not active", task.id)
        return false
    end
    -- Notify PDA task manager (shows "Mission failed" + removes marker)
    local pda_task_id = get_pda_task_id(task)
    if pda_task_id then
        local tm = get_task_manager_instance()
        if tm and tm.set_task_cancelled then
            pcall(tm.set_task_cancelled, tm, pda_task_id)
            printf("[TASK] PDA task cancelled: %s", tostr(pda_task_id))
        elseif tm and tm.set_task_failed then
            pcall(tm.set_task_failed, tm, pda_task_id)
            printf("[TASK] PDA task failed (cancel fallback): %s", tostr(pda_task_id))
        end
    end
    remove_task_marker(task.id)
    set_turnin_ready(task.id, false)
    set_task_active_index(task.id, false)
    set_task_active(task.id, false)
    set_active_task_id(task.arch_id, nil)
    local giver_id = get_task_giver_id(task.id)
    if giver_id and giver_id > 0 then
        set_active_task_id_for_npc(giver_id, nil)
    end
    set_task_giver_id(task.id, 0)
    set_task_giver_community(task.id, "")
    set_resolved_item_section(task.id, "")
    -- Clear delivery/talk/collect state if applicable
    if task.kind == "delivery" or task.kind == "talk" or task.kind == "collect" then
        clear_delivery_state(task.id)
    end
    -- Clear offer cache
    local pool_tag = task.pool_tag or "default"
    if giver_id and giver_id > 0 then
        OFFER_CACHE[offer_cache_key(giver_id, pool_tag)] = nil
    end
    printf("[TASK] CANCELLED: %s", task.id)
    return true
end
-- Collect task pickup — called at the source NPC. Spawns items on player.
function transfer_task_giver(task_id, a, b)
    ensure_registered()
    task_id = task_id and tostr(task_id) or nil
    local task = task_id and TASK_BY_ID[task_id] or nil
    if not task then
        printf("[TASK] transfer_task_giver FAILED: task '%s' not found", tostr(task_id))
        return false
    end
    if not is_task_active(task_id) then
        printf("[TASK] transfer_task_giver FAILED: task '%s' not active", task_id)
        return false
    end
    local npc = resolve_dialog_npc(a, b)
    if not npc then
        printf("[TASK] transfer_task_giver FAILED: NPC not resolved")
        return false
    end
    local new_giver_id = npc:id()
    local old_giver_id = get_task_giver_id(task_id)
    -- Update giver
    set_task_giver_id(task_id, new_giver_id)
    -- Update giver community
    if npc.character_community then
        local ok, comm = pcall(npc.character_community, npc)
        if ok and comm and comm ~= "" then
            set_task_giver_community(task_id, tostr(comm))
        end
    end
    -- Clear old NPC's active task
    if old_giver_id and old_giver_id > 0 then
        set_active_task_id_for_npc(old_giver_id, nil)
    end
    -- Set new NPC's active task
    set_active_task_id_for_npc(new_giver_id, task_id)
    -- Refresh marker
    remove_task_marker(task_id)
    printf("[TASK] TRANSFERRED: '%s' giver %s -> %s", task_id, tostr(old_giver_id), tostr(new_giver_id))
    return true
end
function collect_pickup_by_id(task_id, a, b)
    ensure_registered()
    local task = task_id and TASK_BY_ID[tostr(task_id)] or nil
    if not task then
        printf("[TASK] collect_pickup_by_id FAILED: task '%s' not found", tostr(task_id))
        return false
    end
    if task.kind ~= "collect" then
        printf("[TASK] collect_pickup_by_id FAILED: task '%s' is kind '%s', not collect", tostr(task_id), tostr(task.kind))
        return false
    end
    if not is_task_active(task.id) then
        printf("[TASK] collect_pickup_by_id FAILED: task '%s' is not active", task.id)
        return false
    end
    local state = load_delivery_state(task.id)
    if not state then
        printf("[TASK] collect_pickup_by_id FAILED: no delivery state for '%s'", task.id)
        return false
    end
    -- Verify NPC is the source
    local npc = resolve_dialog_npc(a, b)
    if npc then
        local npc_id = npc:id()
        if state.target_id and state.target_id > 0 and npc_id ~= state.target_id then
            logv("[TASK] collect_pickup_by_id: NPC %s is not source %s for task '%s'", npc_id, state.target_id, task.id)
            return false
        end
    end
    -- Spawn items on player
    local section = state.item_section or task.collect_item or ""
    local amount = state.item_amount or tonum(task.collect_amount) or 1
    if section ~= "" and amount > 0 then
        local granted = give_item_reward(section, amount, true)
        if granted > 0 and news_manager and news_manager.relocate_item then
            news_manager.relocate_item(db.actor, "in", section, granted)
        end
        logv("[TASK] Collect pickup '%s': spawned %s/%s x '%s' on player", task.id, granted, amount, section)
    end
    -- Mark as picked up so the source NPC pickup dialog won't show again
    mark_collect_picked_up(task.id)
    -- PDA stage will update automatically via status functor (has_delivery_items → stage 1 → marker switches to giver)
    logv("[TASK] Collect pickup complete for '%s'", task.id)
    return true
end
function accept_task_by_id(task_id, a, b)
    ensure_registered()
    local task = task_id and TASK_BY_ID[tostr(task_id)] or nil
    if not task then
        printf("[TASK] accept_task_by_id FAILED: task '%s' not found in TASK_BY_ID", tostr(task_id))
        set_result("dm_arch_task_no_available")
        return false
    end
    local npc = resolve_dialog_npc(a, b)
    if not npc or not npc.id then
        printf("[TASK] accept_task_by_id FAILED: NPC not resolved for task '%s'", tostr(task_id))
        set_result("dm_arch_task_no_available")
        return false
    end
    local npc_id = npc:id()
    local arch_id = task.arch_id
    local pool_tag = task.pool_tag or "default"
    -- Per-task accept skips pool active-task check — narrative flow controls task sequencing
    -- via requires_task_done / requires_info, not pool constraints.
    if (task.kind == "fetch" or task.kind == "delivery" or task.kind == "talk" or task.kind == "collect") and not ensure_pda_task_started(task, npc) then
        set_result("dm_arch_task_not_ready")
        local cache_key = offer_cache_key(npc_id, pool_tag)
        OFFER_CACHE[cache_key] = nil
        return false
    end
    if task.kind == "delivery" then
        if not accept_delivery_task(task, npc) then
            set_result("dm_arch_task_not_ready")
            return false
        end
    elseif task.kind == "talk" then
        if not accept_talk_task(task, npc) then
            set_result("dm_arch_task_not_ready")
            return false
        end
    elseif task.kind == "collect" then
        if not accept_collect_task(task, npc) then
            set_result("dm_arch_task_not_ready")
            return false
        end
    end
    set_task_active(task.id, true)
    set_task_active_index(task.id, true)
    set_active_task_id(arch_id, task.id)
    set_active_task_id_for_npc(npc_id, task.id)
    set_task_giver_id(task.id, npc_id)
    local giver_comm = nil
    if task.reward_goodwill_community then
        giver_comm = task.reward_goodwill_community
    elseif npc.character_community then
        local ok, comm = pcall(npc.character_community, npc)
        if ok and comm and comm ~= "" then
            giver_comm = tostr(comm)
        end
    end
    if giver_comm then
        set_task_giver_community(task.id, giver_comm)
    end
    if task.item_category and task.item_category ~= "" then
        local cache_key = offer_cache_key(npc_id, pool_tag)
        local cached = OFFER_CACHE[cache_key]
        if cached and cached.resolved_item and cached.resolved_item ~= "" then
            set_resolved_item_section(task.id, cached.resolved_item)
        end
    end
    set_turnin_ready(task.id, false)
    set_turnin_marker_owned(task.id, false)
    set_last_offer_task_id(arch_id, task.id)
    OFFER_CACHE[offer_cache_key(npc_id, pool_tag)] = nil
    set_result(task_accept_message(task))
    update_turnin_tracker_for_task(task, arch_id, true)
    logv("[TASK] ACCEPTED (by_id): %s (arch=%s pool=%s)", task.id, tostring(arch_id), tostring(pool_tag))
    return true
end
function can_offer_task_by_id(task_id, a, b)
    ensure_registered()
    local task = task_id and TASK_BY_ID[tostr(task_id)] or nil
    if not task then
        logv("[ARCH][PIN] can_offer_task_by_id: task '%s' not found in TASK_BY_ID", tostr(task_id))
        return false
    end
    local npc = resolve_dialog_npc(a, b)
    if not npc or not npc.id then
        logv("[ARCH][PIN] can_offer_task_by_id: could not resolve NPC for task '%s'", tostr(task_id))
        return false
    end
    local npc_id = npc:id()
    if not can_offer_task(task, npc_id) then
        logv("[ARCH][PIN] can_offer_task_by_id: can_offer_task returned false for task '%s' npc=%s", tostr(task_id), tostr(npc_id))
        return false
    end
    if npc_has_active_task_for_pool(npc_id, task.pool_tag or "default") then
        logv("[ARCH][PIN] can_offer_task_by_id: npc %s already has active task in pool '%s'", tostr(npc_id), tostr(task.pool_tag or "default"))
        return false
    end
    logv("[ARCH][PIN] can_offer_task_by_id: OK task='%s' npc=%s", tostr(task_id), tostr(npc_id))
    return true
end

-- ──────────────────────────────────────────────────
-- Update Handlers
-- ──────────────────────────────────────────────────

local function actor_on_update_tasks_core()
    if archetype_core and archetype_core.process_pending_news then
        archetype_core.process_pending_news()
    end
    local now = now_ms()
    if now >= tracker_next_resync_ms then
        rebuild_active_task_index()
        cleanup_inactive_trackers()
        tracker_next_resync_ms = now + TRACKER_RESYNC_INTERVAL_MS
    end
    if now < tracker_next_update_ms then
        return
    end
    tracker_next_update_ms = now + TRACKER_UPDATE_INTERVAL_MS
    update_all_turnin_trackers(false)
end
local function on_game_load_tasks_core()
    OFFER_CACHE = {}
    DIALOG_PINNED_OFFER = {}
    RESULT_CACHE = {}
    CATEGORIES_LOADED = false
    CATEGORY_POOLS = {}
    tracker_next_update_ms = 0
    tracker_next_resync_ms = 0
    rebuild_active_task_index()
    cleanup_inactive_trackers()
    update_all_turnin_trackers(true)
end
-- PDA TASK FUNCTORS

-- ──────────────────────────────────────────────────
-- PDA Task Functors
-- ──────────────────────────────────────────────────

local function register_pda_functors()
    if task_functor then
        task_functor.arch_fetch_task = function(task_id, field, p, tsk)
            local task = TASK_BY_ID[task_id]
            if not task then return p end
            if field == "title" then
                local text = resolve_task_text(task, "summary", nil)
                return text or game.translate_string(p) or p
            elseif field == "descr" then
                if tsk and tsk.stage and tsk.stage >= 1 then
                    if task.kind == "delivery" then
                        return game.translate_string("st_arch_delivery_ready") or "Deliver the items to the target."
                    elseif task.kind == "talk" then
                        return game.translate_string("st_arch_talk_ready") or "Go talk to the marked contact."
                    elseif task.kind == "collect" then
                        return game.translate_string("st_arch_collect_return") or "Bring the items back."
                    end
                    return game.translate_string("st_return_for_reward") or "Return for reward."
                end
                local text = resolve_task_text(task, "details", nil)
                return text or game.translate_string(p) or p
            elseif field == "target" then
                -- Delivery/talk tasks: always point to target NPC (not giver)
                if task.kind == "delivery" or task.kind == "talk" then
                    local target_id = get_delivery_target_id(task_id)
                    if target_id and target_id > 0 then
                        return target_id
                    end
                    return nil
                end
                -- Collect tasks: stage 0 → source NPC, stage 1 → giver
                if task.kind == "collect" then
                    if tsk and tsk.stage and tsk.stage >= 1 then
                        -- Has items, point to giver
                        local giver_id = get_task_giver_id(task_id)
                        if giver_id > 0 then return giver_id end
                        if tsk.task_giver_id and tsk.task_giver_id > 0 then return tsk.task_giver_id end
                    else
                        -- Go to source NPC
                        local source_id = get_delivery_target_id(task_id)
                        if source_id and source_id > 0 then return source_id end
                    end
                    return nil
                end
                -- Fetch tasks: point to giver when items ready
                if tsk and tsk.stage and tsk.stage >= 1 then
                    local giver_id = get_task_giver_id(task_id)
                    if giver_id > 0 then
                        return giver_id
                    end
                    if tsk.task_giver_id and tsk.task_giver_id > 0 then
                        return tsk.task_giver_id
                    end
                end
                return nil
            end
            return p
        end
        printf("[TASK] Registered task_functor.arch_fetch_task")
    end
    if task_status_functor then
        task_status_functor.arch_fetch_task_status = function(tsk, task_id)
            local task = TASK_BY_ID[task_id]
            if not task then return end
            local ready = false
            if task.kind == "fetch" then
                ready = has_required_fetch_items(task)
            elseif task.kind == "delivery" then
                ready = has_delivery_items(task)
            elseif task.kind == "talk" then
                ready = true  -- talk tasks are always "ready" — just find the NPC
            elseif task.kind == "collect" then
                -- Only check inventory AFTER pickup from source NPC (picked_up flag)
                -- Otherwise common loot items in inventory would trigger stage=1 prematurely
                local cstate = load_delivery_state(task_id)
                if cstate and cstate.picked_up then
                    ready = has_delivery_items(task)
                end
            end
            tsk.stage = ready and 1 or 0
            -- Check giver alive — but respect on_giver_death = keep/reassign
            local giver_death_behavior = task.on_giver_death or "fail"
            if giver_death_behavior == "fail" then
                local giver_id = get_task_giver_id(task_id)
                if giver_id > 0 then
                    local sim = alife and alife()
                    local se_obj = sim and sim:object(giver_id) or nil
                    if not se_obj then
                        return "fail"
                    end
                    if se_obj.alive then
                        local ok, val = pcall(se_obj.alive, se_obj)
                        if ok and not val then
                            return "fail"
                        end
                    end
                end
            end
        end
        printf("[TASK] Registered task_status_functor.arch_fetch_task_status")
    end
end

-- ──────────────────────────────────────────────────
-- Game Start
-- ──────────────────────────────────────────────────

function on_game_start()
    if (callbacks_registered) then
        return
    end
    register_pda_functors()
    RegisterScriptCallback("actor_on_update", actor_on_update_tasks_core)
    RegisterScriptCallback("on_game_load", on_game_load_tasks_core)
    callbacks_registered = true
    on_game_load_tasks_core()
end
