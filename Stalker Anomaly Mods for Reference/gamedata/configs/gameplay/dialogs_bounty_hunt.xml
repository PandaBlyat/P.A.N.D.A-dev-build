<?xml version="1.0" encoding="windows-1251" ?>
<game_dialogs>

    <!-- ============================================================ -->
    <!-- СТАНДАРТНЫЙ ДИАЛОГ (Душман и др.)                            -->
    <!-- ============================================================ -->
    <dialog id="bounty_check_dialog">
        <dont_has_info>actor_is_enemy_to_trader</dont_has_info>
        
        <phrase_list>
            <!-- ГГ спрашивает -->
            <phrase id="0">
                <text>st_bounty_ask_check</text>
                <next>1</next>
            </phrase>
            
            <!-- Торговец называет цену -->
            <phrase id="1">
                <text>st_bounty_trader_cost</text>
                <next>2</next>
                <next>3</next>
            </phrase>
            
            <!-- ГГ платит -->
            <phrase id="2">
                <text>st_bounty_pay</text>
                <precondition>bounty_hunt.check_cost_cond</precondition>
                <action>bounty_hunt.pay_money_action</action>
                <next>4</next>
                <next>5</next>
            </phrase>
            
            <!-- ГГ отказывается -->
            <phrase id="3">
                <text>st_bounty_cancel</text>
                <action>dialogs.break_dialog</action>
            </phrase>
            
            <!-- Ответ: ЗАКАЗАН -->
            <phrase id="4">
                <text>st_bounty_result_yes</text>
                <precondition>bounty_hunt.is_player_hunted</precondition>
            </phrase>
            
            <!-- Ответ: ЧИСТО -->
            <phrase id="5">
                <text>st_bounty_result_no</text>
                <precondition>bounty_hunt.is_player_safe</precondition>
            </phrase>
        </phrase_list>
    </dialog>


    <!-- ============================================================ -->
    <!-- ДИАЛОГ СИДОРОВИЧА (Уникальный стиль)                         -->
    <!-- ============================================================ -->
    <dialog id="bounty_check_sidor">
        <dont_has_info>actor_is_enemy_to_trader</dont_has_info>

        <phrase_list>
            <!-- ГГ: "Сид, тут слушок прошел..." -->
            <phrase id="0">
                <text>st_bounty_ask_sidor</text>
                <next>1</next>
            </phrase>
            
            <!-- Сидор: "Хех, слушок... Гони 10000" -->
            <phrase id="1">
                <text>st_bounty_cost_sidor</text>
                <next>2</next>
                <next>3</next>
            </phrase>
            
            <!-- ГГ: "Подавись. Говори." -->
            <phrase id="2">
                <text>st_bounty_pay_sidor</text>
                <precondition>bounty_hunt.check_cost_cond</precondition>
                <action>bounty_hunt.pay_money_action</action>
                <next>4</next>
                <next>5</next>
            </phrase>
            
            <!-- ГГ: "Десять кусков? Обойдусь." -->
            <phrase id="3">
                <text>st_bounty_cancel_sidor</text>
                <action>dialogs.break_dialog</action>
            </phrase>
            
            <!-- Сидор: "Дела дрянь..." -->
            <phrase id="4">
                <text>st_bounty_result_yes_sidor</text>
                <precondition>bounty_hunt.is_player_hunted</precondition>
            </phrase>
            
            <!-- Сидор: "Выдыхай, Меченый..." -->
            <phrase id="5">
                <text>st_bounty_result_no_sidor</text>
                <precondition>bounty_hunt.is_player_safe</precondition>
            </phrase>
        </phrase_list>
    </dialog>
	
