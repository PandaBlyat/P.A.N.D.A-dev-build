    </string>

    <string id="ui_mcm_siski_title">
        <text>SISKI 0.9.1</text>
    </string>

    <string id="ui_mcm_siski_enabled">
        <text>SISKI: enable mod</text>
    </string>
    <string id="ui_mcm_siski_enabled_desc">
        <text>Turns all SISKI systems on or off.</text>
    </string>

    <string id="ui_mcm_siski_debug_hud_enabled">
        <text>Map: SISKI debug</text>
    </string>
    <string id="ui_mcm_siski_debug_hud_enabled_desc">
        <text>Shows SISKI debug markers on the map.</text>
    </string>
    <string id="ui_mcm_siski_debug_resync_now">
        <text>Service: resync now</text>
    </string>
    <string id="ui_mcm_siski_debug_resync_now_desc">
        <text>One-shot resync of SISKI runtime caches/indexes (auto-resets).</text>
    </string>

    <string id="ui_mcm_siski_notify_enabled">
        <text>PDA: squad messages</text>
    </string>
    <string id="ui_mcm_siski_notify_enabled_desc">
        <text>Adds vanilla PDA-style messages during squad tasks.</text>
    </string>

    <string id="ui_mcm_siski_explore_enabled">
        <text>Squads: travel to nearby maps</text>
    </string>
    <string id="ui_mcm_siski_explore_enabled_desc">
        <text>Allows squads to move between neighboring levels.</text>
    </string>
    <string id="ui_mcm_siski_mutant_sim_enabled">
