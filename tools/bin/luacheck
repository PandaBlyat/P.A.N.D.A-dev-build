#!/usr/bin/env python3
"""Offline luacheck fallback.
If real luacheck exists elsewhere on PATH, exec it.
Otherwise run lightweight advisory checks and exit 0.
"""
import os, shutil, sys
from pathlib import Path

self_path = Path(__file__).resolve()
filtered = os.pathsep.join(
    p for p in os.environ.get("PATH", "").split(os.pathsep)
    if p and Path(p).resolve() != self_path.parent
)
real = shutil.which("luacheck", path=filtered)
if real:
    os.execv(real, [real, *sys.argv[1:]])

targets = [a for a in sys.argv[1:] if not a.startswith("-")]
files = []
for t in targets:
    p = Path(t)
    if p.is_dir():
        files.extend(sorted(p.rglob("*.script")))
        files.extend(sorted(p.rglob("*.lua")))
    elif p.is_file():
        files.append(p)

if not files:
    print("luacheck fallback: no Lua files found")
    sys.exit(0)

issues = 0
for file in files:
    text = file.read_text(encoding="utf-8", errors="replace")
    if "\t" in text:
        issues += 1
        print(f"{file}:1:1: (W000) tab character found")

print(f"luacheck fallback: advisory mode, {issues} warning(s)")
sys.exit(0)
