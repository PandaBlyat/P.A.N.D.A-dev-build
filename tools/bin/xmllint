#!/usr/bin/env python3
"""Minimal xmllint-compatible wrapper for offline environments.
Supports: xmllint --noout <file> [<file>...]
"""
import sys
import xml.etree.ElementTree as ET

args = [a for a in sys.argv[1:] if a != "--noout"]
if not args:
    print("xmllint wrapper: expected at least one XML file", file=sys.stderr)
    sys.exit(2)

exit_code = 0
for path in args:
    try:
        ET.parse(path)
    except Exception as exc:
        print(f"{path}: {exc}", file=sys.stderr)
        exit_code = 1

sys.exit(exit_code)
