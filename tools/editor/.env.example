# P.A.N.D.A. Conversation Editor — Environment Variables
# Copy this file to .env and fill in your values.
# All VITE_ variables are safe to expose in the browser (they use the publishable anon key).

# Your Supabase project URL (Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Project Settings → API → anon public)
# This key is safe to expose in browser builds — it respects Row Level Security.
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: local or deployed editor API base for server-proxied community/support calls
# Example (dev): VITE_API_BASE_URL=http://localhost:3001/api
# Example (prod): VITE_API_BASE_URL=https://your-domain.example/api
VITE_API_BASE_URL=

