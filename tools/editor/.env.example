# P.A.N.D.A. Editor — Environment Variables
# Copy this file to .env and fill in your values.
# These power the Community Library panel (online conversation sharing).

# Your Supabase project URL (found in Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (found in Project Settings → API)
# This key is safe to expose in the frontend — it only allows what your RLS policies permit.
VITE_SUPABASE_ANON_KEY=your-anon-key-here
