# P.A.N.D.A. Editor — Frontend Environment Variables
# Copy this file to .env and fill in your values.

# API server base URL (only needed in production / GitHub Pages builds).
# In development, leave this unset — Vite proxies /api to localhost:3001 automatically.
# Example: VITE_API_URL=https://my-panda-api.railway.app
VITE_API_URL=
